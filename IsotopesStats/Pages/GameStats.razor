@page "/"
@page "/gamestats"
@using IsotopesStats.Models
@using IsotopesStats.Services
@inject StatsService StatsService
@inject SharedSessionState SharedState
@inject GameStatsState SessionState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Game Stats</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Game Stats</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <div class="desktop-only" style="display: flex; gap: 1rem; align-items: center;">
            <label style="margin:0; font-weight: bold;">Season:</label>
            <select class="form-control" style="width: auto;" value="@SharedState.SelectedSeasonId" @onchange="OnSeasonChange">
                @foreach (Season season in seasons)
                {
                    <option value="@season.Id">@season.Name</option>
                }
            </select>
        </div>
        <div class="mobile-only">
             <button class="view-btn" style="background: var(--isotopes-accent); color: white; border: none; padding: 0.5rem 1rem;" @onclick="ToggleSeasonModal"> 
                🗓️ @seasons.FirstOrDefault(s => s.Id == SharedState.SelectedSeasonId)?.Name
            </button>
        </div>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(SharedState.SelectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="stat-card" style="margin-bottom: 1.5rem;">
    <div class="filter-container" style="max-width: 100%;">
        <div class="search-container">
            <input type="text" class="form-control" @bind="filterText" @bind:event="oninput" @onkeyup="UpdateFilterState" placeholder="Search Player or Opponent..." />
            @if (!string.IsNullOrEmpty(filterText))
            {
                <button class="clear-button" @onclick="ClearFilter">✕</button>
            }
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="game-cards-list">
        @for (int i = 0; i < 3; i++)
        {
            <div class="game-card" style="padding: 1rem;">
                <div class="spinner-border text-danger" role="status" style="margin: 2rem auto; display: block;"></div>
            </div>
        }
    </div>
}
else
{
    @if (!GroupedStats.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Games Found</h4>
            <p>Try a different search or season.</p>
        </div>
    }
    else
    {
        <div class="game-cards-list">
            @{ int index = 0; }
            @foreach (IGrouping<int, GameStatsExtendedView> group in GroupedStats)
            {
                GameStatsExtendedView firstStat = group.First();
                int gameId = firstStat.GameId;
                GameUIState uiState = SessionState.GetState(gameId);

                int teamRuns = group.Sum(s => s.R);
                int teamHits = group.Sum(s => s.H);
                int teamHRs = group.Sum(s => s.HR);
                int teamBBs = group.Sum(s => s.BB);
                int teamAB = group.Sum(s => s.AB);
                int teamPA = group.Sum(s => s.PA);
                int teamRBI = group.Sum(s => s.RBI);
                double teamAVG = teamAB > 0 ? (double)teamHits / teamAB : 0;
                double currentDelay = index * 0.1;
                index++;

                IEnumerable<GameStatsExtendedView> sortedStats = ApplyInnerSorting(uiState, group);

                <div class="game-card view-fade-in" style="animation-delay: @(currentDelay)s">
                    <div class="game-card-header" @onclick="() => ToggleGame(gameId)">
                        <div class="game-info-left">
                            <div class="game-number-badge">GAME #@firstStat.GameNumber</div>
                            <div class="game-date">@firstStat.Date.ToString("MMM dd, yyyy @ HH:mm")</div>
                        </div>

                        <div class="game-matchup">
                            <div class="opponent-name">vs @firstStat.OpponentName</div>
                            <div class="diamond-name">📍 @firstStat.Diamond</div>
                        </div>

                        <div class="game-result-summary">
                            <div class="result-score">@teamRuns <span class="score-label">Runs</span></div>
                            <div class="expand-icon @(uiState.IsExpanded ? "rotated" : "")">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                            </div>
                        </div>
                    </div>

                    <div class="game-card-footer">
                        <div class="footer-stat">
                            <span class="footer-stat-label">Players:</span> @group.Count()
                        </div>
                        <div class="footer-stat">
                            <span class="footer-stat-label">HR:</span> @teamHRs
                        </div>
                        <div class="footer-stat">
                            <span class="footer-stat-label">AVG:</span> @teamAVG.ToString(".000")
                        </div>
                    </div>

                    @if (uiState.IsExpanded)
                    {
                        <div class="game-card-detail expanded view-fade-in">
                            <div class="box-score-table-wrapper">
                                <table class="box-score-table table-sm">
                                <thead>
                                    <tr>
                                        <th @onclick='() => Sort(gameId, "BO")' class="sortable-header" style="width: 40px;">BO<span class="sort-icon">@(GetSortIcon(gameId, "BO"))</span></th>
                                        <th @onclick='() => Sort(gameId, "Player")' class="sortable-header sticky-col">Player<span class="sort-icon">@(GetSortIcon(gameId, "Player"))</span></th>
                                        <th @onclick='() => Sort(gameId, "PA")' class="sortable-header group-divider">PA<span class="sort-icon">@(GetSortIcon(gameId, "PA"))</span></th>
                                        <th @onclick='() => Sort(gameId, "AB")' class="sortable-header">AB<span class="sort-icon">@(GetSortIcon(gameId, "AB"))</span></th>
                                        <th @onclick='() => Sort(gameId, "R")' class="sortable-header group-divider">R<span class="sort-icon">@(GetSortIcon(gameId, "R"))</span></th>
                                        <th @onclick='() => Sort(gameId, "H")' class="sortable-header">H<span class="sort-icon">@(GetSortIcon(gameId, "H"))</span></th>
                                        <th @onclick='() => Sort(gameId, "2B")' class="sortable-header">2B<span class="sort-icon">@(GetSortIcon(gameId, "2B"))</span></th>
                                        <th @onclick='() => Sort(gameId, "3B")' class="sortable-header">3B<span class="sort-icon">@(GetSortIcon(gameId, "3B"))</span></th>
                                        <th @onclick='() => Sort(gameId, "4B")' class="sortable-header">4B<span class="sort-icon">@(GetSortIcon(gameId, "4B"))</span></th>
                                        <th @onclick='() => Sort(gameId, "HR")' class="sortable-header">HR<span class="sort-icon">@(GetSortIcon(gameId, "HR"))</span></th>
                                        <th @onclick='() => Sort(gameId, "RBI")' class="sortable-header">RBI<span class="sort-icon">@(GetSortIcon(gameId, "RBI"))</span></th>
                                        <th @onclick='() => Sort(gameId, "BB")' class="sortable-header group-divider">BB<span class="sort-icon">@(GetSortIcon(gameId, "BB"))</span></th>
                                        <th @onclick='() => Sort(gameId, "K")' class="sortable-header">K<span class="sort-icon">@(GetSortIcon(gameId, "K"))</span></th>
                                        <th @onclick='() => Sort(gameId, "KF")' class="sortable-header">KF<span class="sort-icon">@(GetSortIcon(gameId, "KF"))</span></th>
                                        <th @onclick='() => Sort(gameId, "SF")' class="sortable-header group-divider">SF<span class="sort-icon">@(GetSortIcon(gameId, "SF"))</span></th>
                                        <th @onclick='() => Sort(gameId, "FC")' class="sortable-header">FC<span class="sort-icon">@(GetSortIcon(gameId, "FC"))</span></th>
                                        <th @onclick='() => Sort(gameId, "GO")' class="sortable-header">GO<span class="sort-icon">@(GetSortIcon(gameId, "GO"))</span></th>
                                        <th @onclick='() => Sort(gameId, "FO")' class="sortable-header">FO<span class="sort-icon">@(GetSortIcon(gameId, "FO"))</span></th>
                                        <th @onclick='() => Sort(gameId, "AVG")' class="sortable-header group-divider">AVG<span class="sort-icon">@(GetSortIcon(gameId, "AVG"))</span></th>
                                        <th @onclick='() => Sort(gameId, "OBP")' class="sortable-header">OBP<span class="sort-icon">@(GetSortIcon(gameId, "OBP"))</span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (GameStatsExtendedView stat in sortedStats)
                                    {
                                        <tr>
                                            <td>@stat.BO</td>
                                            <td class="player-name sticky-col">
                                                <a href="/playerlogs/@Uri.EscapeDataString(stat.ExtendedPlayerName)" style="text-decoration: none; color: inherit;">
                                                    @stat.ExtendedPlayerName
                                                </a>
                                            </td>
                                            <td class="group-divider">@stat.PA</td>
                                            <td>@stat.AB</td>
                                            <td class="group-divider">@stat.R</td>
                                            <td>@stat.H</td>
                                            <td>@stat.H2B</td>
                                            <td>@stat.H3B</td>
                                            <td>@stat.H4B</td>
                                            <td>@stat.HR</td>
                                            <td>@stat.RBI</td>
                                            <td class="group-divider">@stat.BB</td>
                                            <td>@stat.K</td>
                                            <td>@stat.KF</td>
                                            <td class="group-divider">@stat.SF</td>
                                            <td>@stat.FC</td>
                                            <td>@stat.GO</td>
                                            <td>@stat.FO</td>
                                            <td class="group-divider">@stat.AVG.ToString(".000")</td>
                                            <td>@stat.OBP.ToString(".000")</td>
                                        </tr>
                                    }
                                    <tr class="game-summary-row" style="background: #f8f9fa; font-weight: bold;">
                                        <td colspan="2" class="sticky-col">TOTALS</td>
                                        <td class="group-divider">@teamPA</td>
                                        <td>@teamAB</td>
                                        <td class="group-divider">@teamRuns</td>
                                        <td>@teamHits</td>
                                        <td>@group.Sum(s => s.H2B)</td>
                                        <td>@group.Sum(s => s.H3B)</td>
                                        <td>@group.Sum(s => s.H4B)</td>
                                        <td>@teamHRs</td>
                                        <td>@teamRBI</td>
                                        <td class="group-divider">@teamBBs</td>
                                        <td>@group.Sum(s => s.K)</td>
                                        <td>@group.Sum(s => s.KF)</td>
                                        <td class="group-divider">@group.Sum(s => s.SF)</td>
                                        <td>@group.Sum(s => s.FC)</td>
                                        <td>@group.Sum(s => s.GO)</td>
                                        <td>@group.Sum(s => s.FO)</td>
                                        <td class="group-divider">@teamAVG.ToString(".000")</td>
                                        @{
                                            int teamSF = group.Sum(s => s.SF);
                                            double teamOBP = (teamAB + teamBBs + teamSF) > 0
                                                ? (double)(teamHits + teamBBs) / (teamAB + teamBBs + teamSF)
                                                : 0;
                                        }
                                        <td>@teamOBP.ToString(".000")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="mobile-player-grid">
                            @foreach (GameStatsExtendedView stat in sortedStats)
                            {
                                <div class="mobile-player-card">
                                    <div class="mobile-card-header">
                                        <span class="mobile-card-name">@stat.BO. @stat.ExtendedPlayerName</span>
                                        <span class="badge bg-light text-dark">AVG: @stat.AVG.ToString(".000") | OBP: @stat.OBP.ToString(".000")</span>
                                    </div>
                                    <div class="mobile-card-stats">
                                        @if (stat.AB > 0) { <div class="m-stat"><span class="m-stat-val">@stat.AB</span><span class="m-stat-label">AB</span></div> }
                                        @if (stat.R > 0) { <div class="m-stat"><span class="m-stat-val">@stat.R</span><span class="m-stat-label">R</span></div> } 
                                        @if (stat.H > 0) { <div class="m-stat"><span class="m-stat-val">@stat.H</span><span class="m-stat-label">H</span></div> } 
                                        @if (stat.H2B > 0) { <div class="m-stat"><span class="m-stat-val">@stat.H2B</span><span class="m-stat-label">2B</span></div> }
                                        @if (stat.H3B > 0) { <div class="m-stat"><span class="m-stat-val">@stat.H3B</span><span class="m-stat-label">3B</span></div> }
                                        @if (stat.H4B > 0) { <div class="m-stat"><span class="m-stat-val">@stat.H4B</span><span class="m-stat-label">4B</span></div> }
                                        @if (stat.HR > 0) { <div class="m-stat"><span class="m-stat-val">@stat.HR</span><span class="m-stat-label">HR</span></div> }
                                        @if (stat.RBI > 0) { <div class="m-stat"><span class="m-stat-val">@stat.RBI</span><span class="m-stat-label">RBI</span></div> }
                                        @if (stat.BB > 0) { <div class="m-stat"><span class="m-stat-val">@stat.BB</span><span class="m-stat-label">BB</span></div> }
                                        @if (stat.K > 0) { <div class="m-stat"><span class="m-stat-val">@stat.K</span><span class="m-stat-label">K</span></div> } 
                                        @if (stat.KF > 0) { <div class="m-stat"><span class="m-stat-val">@stat.KF</span><span class="m-stat-label">KF</span></div> }
                                        @if (stat.SF > 0) { <div class="m-stat"><span class="m-stat-val">@stat.SF</span><span class="m-stat-label">SF</span></div> }
                                        @if (stat.FC > 0) { <div class="m-stat"><span class="m-stat-val">@stat.FC</span><span class="m-stat-label">FC</span></div> }
                                        @if (stat.GO > 0) { <div class="m-stat"><span class="m-stat-val">@stat.GO</span><span class="m-stat-label">GO</span></div> }
                                        @if (stat.FO > 0) { <div class="m-stat"><span class="m-stat-val">@stat.FO</span><span class="m-stat-label">FO</span></div> }
                                    </div>
                                </div>
                            }
                            <div class="mobile-player-card" style="border: 2px solid var(--isotopes-accent); background: #f0f7ff;">
                                <div class="mobile-card-header">
                                    <span class="mobile-card-name">TEAM TOTALS</span>
                                    <span class="badge bg-primary">AVG: @teamAVG.ToString(".000") | OBP: @teamOBP.ToString(".000")</span>
                                </div>
                                <div class="mobile-card-stats">
                                    <div class="m-stat"><span class="m-stat-val">@teamAB</span><span class="m-stat-label">AB</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@teamRuns</span><span class="m-stat-label">R</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@teamHits</span><span class="m-stat-label">H</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@teamHRs</span><span class="m-stat-label">HR</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@teamRBI</span><span class="m-stat-label">RBI</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@teamBBs</span><span class="m-stat-label">BB</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<GameStatsExtendedView> allStats = new();
    private List<Season> seasons = new();
    private string filterText = "";
    private bool showSeasonModal = false;
    private bool isLoading = true;

    private IEnumerable<IGrouping<int, GameStatsExtendedView>> GroupedStats =>
        allStats.GroupBy(s => s.GameId)
        .Where(g =>
            string.IsNullOrEmpty(filterText) ||
            g.Any(s => s.ExtendedPlayerName.Contains(filterText, StringComparison.OrdinalIgnoreCase)) ||
            (g.First().OpponentName.Contains(filterText, StringComparison.OrdinalIgnoreCase))
        )
        .OrderByDescending(g => g.First().Date);

    protected override async Task OnInitializedAsync()
    {
        SharedState.ReturnUrl = "";
        seasons = await StatsService.GetSeasonsAsync();

        if (SharedState.SelectedSeasonId == 0 && seasons.Any())
        {
            SharedState.SelectedSeasonId = seasons.First().Id;
        }

        filterText = SessionState.FilterText;
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            allStats = await StatsService.GetAllGameStatsAsync(SharedState.SelectedSeasonId);
            
            if (!SessionState.GameUIStates.Any(s => s.Value.IsExpanded) && allStats.Any())
            {
                int latestGameId = allStats.First().GameId;
                SessionState.GetState(latestGameId).IsExpanded = true;
            }
        }
        catch (Exception)
        {
            allStats = new List<GameStatsExtendedView>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            SharedState.SelectedSeasonId = id;
            await LoadData();
        }
    }

    private void ToggleSeasonModal() => showSeasonModal = !showSeasonModal;

    private async Task SelectMobileSeason(int id)
    {
        SharedState.SelectedSeasonId = id;
        showSeasonModal = false;
        await LoadData();
    }

    private void ClearFilter()
    {
        filterText = "";
        UpdateFilterState();
    }

    private void UpdateFilterState()
    {
        SessionState.FilterText = filterText;
    }

    private void ToggleGame(int gameId)
    {
        GameUIState state = SessionState.GetState(gameId);
        state.IsExpanded = !state.IsExpanded;
        StateHasChanged();
    }

    private void Sort(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);

        if (state.SortColumn == column)
        {
            state.IsAscending = !state.IsAscending;
        }
        else
        {
            state.SortColumn = column;
            state.IsAscending = false;
            if (column == "Player" || column == "BO") state.IsAscending = true;
        }
        StateHasChanged();
    }

    private string GetSortIcon(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);
        if (state.SortColumn != column) return "";
        return state.IsAscending ? "▴" : "▾";
    }

    private IEnumerable<GameStatsExtendedView> ApplyInnerSorting(GameUIState uiState, IEnumerable<GameStatsExtendedView> stats)
    {
        return uiState.SortColumn switch
        {
            "Player" => uiState.IsAscending ? stats.OrderBy(s => s.ExtendedPlayerName) : stats.OrderByDescending(s => s.ExtendedPlayerName),
            "BO" => uiState.IsAscending ? stats.OrderBy(s => s.BO) : stats.OrderByDescending(s => s.BO),
            "PA" => uiState.IsAscending ? stats.OrderBy(s => s.PA) : stats.OrderByDescending(s => s.PA),
            "AB" => uiState.IsAscending ? stats.OrderBy(s => s.AB) : stats.OrderByDescending(s => s.AB),
            "R" => uiState.IsAscending ? stats.OrderBy(s => s.R) : stats.OrderByDescending(s => s.R),
            "H" => uiState.IsAscending ? stats.OrderBy(s => s.H) : stats.OrderByDescending(s => s.H),
            "2B" => uiState.IsAscending ? stats.OrderBy(s => s.H2B) : stats.OrderByDescending(s => s.H2B),
            "3B" => uiState.IsAscending ? stats.OrderBy(s => s.H3B) : stats.OrderByDescending(s => s.H3B),
            "4B" => uiState.IsAscending ? stats.OrderBy(s => s.H4B) : stats.OrderByDescending(s => s.H4B),
            "HR" => uiState.IsAscending ? stats.OrderBy(s => s.HR) : stats.OrderByDescending(s => s.HR),
            "RBI" => uiState.IsAscending ? stats.OrderBy(s => s.RBI) : stats.OrderByDescending(s => s.RBI),
            "BB" => uiState.IsAscending ? stats.OrderBy(s => s.BB) : stats.OrderByDescending(s => s.BB),
            "K" => uiState.IsAscending ? stats.OrderBy(s => s.K) : stats.OrderByDescending(s => s.K),
            "KF" => uiState.IsAscending ? stats.OrderBy(s => s.KF) : stats.OrderByDescending(s => s.KF),
            "SF" => uiState.IsAscending ? stats.OrderBy(s => s.SF) : stats.OrderByDescending(s => s.SF),
            "FC" => uiState.IsAscending ? stats.OrderBy(s => s.FC) : stats.OrderByDescending(s => s.FC),
            "GO" => uiState.IsAscending ? stats.OrderBy(s => s.GO) : stats.OrderByDescending(s => s.GO),
            "FO" => uiState.IsAscending ? stats.OrderBy(s => s.FO) : stats.OrderByDescending(s => s.FO),
            "AVG" => uiState.IsAscending ? stats.OrderBy(s => s.AVG) : stats.OrderByDescending(s => s.AVG),
            "OBP" => uiState.IsAscending ? stats.OrderBy(s => s.OBP) : stats.OrderByDescending(s => s.OBP),
            _ => stats.OrderBy(s => s.BO)
        };
    }
}

<style>
    .header-with-filter {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .filter-container {
        flex: 1;
        max-width: 400px;
    }

    .search-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .clear-button {
        position: absolute;
        right: 10px;
        background: #eee;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #666;
        font-size: 12px;
        transition: background 0.2s;
    }

    .clear-button:hover {
        background: #ddd;
        color: #333;
    }
</style>
