@page "/lineup/view"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Services
@inject IStatsRepository StatsRepository
@inject SharedSessionState SharedState
@inject SessionStorageService SessionStorage
@inject NavigationManager NavigationManager

<PageTitle>Isotopes - Lineup View</PageTitle>

<div class="full-screen-view">
    <div class="lineup-container">
        <img src="images/defense.png" class="defense-bg" />
        @foreach (PositionAssignment assignment in assignments)
        {
            @if (!string.IsNullOrEmpty(assignment.PlayerName))
            {
                <div class="player-overlay" style="left: @(assignment.X)%; top: @(assignment.Y)%;">
                    <div class="player-name-box">@assignment.PlayerName</div>
                </div>
            }
        }
        @if (benchPlayers.Any())
        {
            <div class="bench-container">
                <div class="bench-label">BENCH</div>
                <div class="bench-names">
                    @string.Join(" • ", benchPlayers)
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] [SupplyParameterFromQuery(Name = "l")] public string? LineupData { get; set; }

    private class PositionAssignment
    {
        public string PlayerName { get; set; } = string.Empty;
        public double X { get; set; }
        public double Y { get; set; }
    }

    private List<PositionAssignment> assignments = new List<PositionAssignment>()
    {
        new PositionAssignment { X = 50, Y = 62 }, // Pitcher (Above mound)
        new PositionAssignment { X = 50, Y = 97 }, // Catcher (Behind home)
        new PositionAssignment { X = 70, Y = 62 }, // 1st Base (Above bag)
        new PositionAssignment { X = 65, Y = 48 }, // 2nd Base
        new PositionAssignment { X = 30, Y = 62 }, // Third Base (Above bag)
        new PositionAssignment { X = 35, Y = 48 }, // Short Stop
        new PositionAssignment { X = 15, Y = 35 }, // Left Field
        new PositionAssignment { X = 38, Y = 15 }, // Left Center Field
        new PositionAssignment { X = 62, Y = 15 }, // Right Center Field
        new PositionAssignment { X = 85, Y = 35 }  // Right Field
    };

    private List<string> benchPlayers = new List<string>();

    protected override async Task OnInitializedAsync()
    {
        int seasonId = SharedState.SelectedSeasonId;
        if (seasonId == 0)
        {
            List<Season> seasons = await StatsRepository.GetSeasonsAsync();
            if (seasons.Any())
            {
                seasonId = seasons.First().Id;
            }
        }

        if (!string.IsNullOrEmpty(LineupData))
        {
            List<Player> players = await StatsRepository.GetPlayersAsync(seasonId);
            string[] parts = LineupData.Split('-', StringSplitOptions.RemoveEmptyEntries);
            
            for (int i = 0; i < parts.Length; i++)
            {
                if (int.TryParse(parts[i], out int id) && id > 0)
                {
                    Player? player = players.FirstOrDefault(p => p.Id == id);
                    if (player != null)
                    {
                        if (i < 10)
                        {
                            assignments[i].PlayerName = player.Name;
                        }
                        else
                        {
                            benchPlayers.Add(player.Name);
                        }
                    }
                }
            }
            return;
        }

        List<string>? savedNames = await SessionStorage.GetItemAsync<List<string>>($"lineup_pos_{seasonId}");
        if (savedNames != null && savedNames.Count == assignments.Count)
        {
            for (int i = 0; i < assignments.Count; i++)
            {
                assignments[i].PlayerName = savedNames[i];
            }

            List<string>? savedBench = await SessionStorage.GetItemAsync<List<string>>($"lineup_bn_{seasonId}");
            if (savedBench != null)
            {
                benchPlayers = savedBench;
            }
        }
        else
        {
            NavigationManager.NavigateTo("/lineup");
        }
    }
}

<style>
    .full-screen-view {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: white;
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .lineup-container {
        position: relative;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .defense-bg {
        height: 100vh;
        width: auto;
        display: block;
    }

    .player-overlay {
        position: absolute;
        transform: translate(-50%, -50%);
        color: black;
        font-weight: bold;
        font-size: 1.4rem;
        white-space: nowrap;
        text-align: center;
    }

    .player-name-box {
        border: 2px solid black;
        padding: 4px 12px;
        background-color: white;
        min-width: 100px;
    }

    .bench-container {
        position: absolute;
        bottom: 30px;
        right: 30px;
        background-color: rgba(255, 255, 255, 0.9);
        border: 2px solid black;
        padding: 8px 20px;
        text-align: center;
        max-width: 40%;
        z-index: 10;
    }

    .bench-label {
        font-weight: bold;
        font-size: 0.8rem;
        color: #666;
        margin-bottom: 2px;
        letter-spacing: 1px;
    }

    .bench-names {
        font-weight: bold;
        font-size: 1.2rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @@media (max-width: 768px) {
        .player-overlay {
            font-size: 0.9rem;
        }
        .player-name-box {
            padding: 2px 6px;
            min-width: 60px;
            border-width: 1.5px;
        }
        .bench-container {
            bottom: 15px;
            right: 15px;
            padding: 4px 12px;
        }
        .bench-label {
            font-size: 0.6rem;
        }
        .bench-names {
            font-size: 0.9rem;
        }
    }
</style>