@page "/management/seasons"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "ManageSeasons")]
@inject StatsService StatsService
@inject IJSRuntime JSRuntime
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Seasons</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Seasons</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick="() => StartAdd()">Add New Season</button>
    }
</div>

@if (isEditing)
{
    <div class="stat-card view-fade-in" style="margin-bottom: 2rem;">
        <h4 style="margin-top:0">@(editingSeason.Id == 0 ? "Add" : "Edit") Season</h4>
        <div class="form-group">
            <label>Season Name</label>
            <input type="text" class="form-control" @bind="editingSeason.Name" @bind:event="oninput" @onkeyup="HandleInput" placeholder="e.g. 2026" />
        </div>

        @if (editingSeason.Id != 0)
        {
            <div class="form-group" style="margin-top: 1.5rem;">
                <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Season Roster</label>
                <div class="selectable-grid" style="padding: 0.5rem; background: #f9f9f9; border-radius: 8px;">
                    @foreach (Player player in allPlayers)
                    {
                        <div class="selectable-item">
                            <input type="checkbox" id="p-@player.Id" 
                                   checked="@assignedPlayerIds.Contains(player.Id)"
                                   @onchange="(e) => TogglePlayer(player.Id, e)" />
                            <label class="selectable-label" for="p-@player.Id">@player.Name</label>
                        </div>
                    }
                </div>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
                <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Opponents This Season</label>
                <div class="selectable-grid" style="padding: 0.5rem; background: #f9f9f9; border-radius: 8px;">
                    @foreach (Opponent opponent in allOpponents)
                    {
                        <div class="selectable-item">
                            <input type="checkbox" id="o-@opponent.Id" 
                                   checked="@assignedOpponentIds.Contains(opponent.Id)"
                                   @onchange="(e) => ToggleOpponent(opponent.Id, e)" />
                            <label class="selectable-label" for="o-@opponent.Id">@opponent.Name</label>
                        </div>
                    }
                </div>
            </div>
        }

        <div style="display: flex; gap: 1rem; margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1.5rem; justify-content: center;">
            <button class="view-btn active" style="padding: 0.8rem 2rem;" @onclick="SaveSeason">Save Season</button>
            <button class="view-btn" style="padding: 0.8rem 2rem;" @onclick="HandleCancel">Cancel</button>
        </div>
    </div>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">ID</th>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Season season in seasons)
                        {
                            <tr>
                                <td style="text-align: left;">@season.Id</td>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@season.Name</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick="() => StartEdit(season)">Edit / Roster</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(season.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Season season in seasons)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name">@season.Name</div>
                        <div class="rank-badge">ID: @season.Id</div>
                    </div>
                    <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick="() => StartEdit(season)">Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(season.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete Season" 
    Message="Are you sure you want to delete this season?"
    Warning="This will delete all associated games and stats."
    OnConfirm="DeleteSeason"
    OnCancel="() => showConfirm = false" />

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    private List<Season> seasons = new();
    private List<Player> allPlayers = new();
    private List<Opponent> allOpponents = new();
    private HashSet<int> assignedPlayerIds = new();
    private HashSet<int> originalPlayerIds = new();
    private HashSet<int> assignedOpponentIds = new();
    private HashSet<int> originalOpponentIds = new();
    private Season editingSeason = new();
    private bool isEditing = false;
    private bool showConfirm = false;
    private bool showDiscardConfirm = false;
    private int seasonIdToDelete;
    private bool hasChanges = false;

    private class SeasonEditState
    {
        public Season Season { get; set; } = new();
        public HashSet<int> AssignedPlayerIds { get; set; } = new();
        public HashSet<int> OriginalPlayerIds { get; set; } = new();
        public HashSet<int> AssignedOpponentIds { get; set; } = new();
        public HashSet<int> OriginalOpponentIds { get; set; } = new();
        public bool IsEditing { get; set; }
        public bool HasChanges { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
        allPlayers = await StatsService.GetAllPlayersAsync();
        allOpponents = await StatsService.GetAllOpponentsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HydrateTempState();
        }
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<SeasonEditState> result = await ProtectedSessionStore.GetAsync<SeasonEditState>("SeasonEditState");
            if (result.Success && result.Value != null && result.Value.IsEditing)
            {
                editingSeason = result.Value.Season;
                assignedPlayerIds = result.Value.AssignedPlayerIds;
                originalPlayerIds = result.Value.OriginalPlayerIds;
                assignedOpponentIds = result.Value.AssignedOpponentIds;
                originalOpponentIds = result.Value.OriginalOpponentIds;
                isEditing = result.Value.IsEditing;
                hasChanges = result.Value.HasChanges;
                StateHasChanged();
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            SeasonEditState state = new SeasonEditState
            {
                Season = editingSeason,
                AssignedPlayerIds = assignedPlayerIds,
                OriginalPlayerIds = originalPlayerIds,
                AssignedOpponentIds = assignedOpponentIds,
                OriginalOpponentIds = originalOpponentIds,
                IsEditing = isEditing,
                HasChanges = hasChanges
            };
            await ProtectedSessionStore.SetAsync("SeasonEditState", state);
        }
        catch (Exception) { }
    }

    private async Task HandleInput()
    {
        hasChanges = true;
        await SaveTempState();
    }

    private async Task ClearTempState()
    {
        hasChanges = false;
        isEditing = false;
        try
        {
            await ProtectedSessionStore.DeleteAsync("SeasonEditState");
        }
        catch (Exception) { }
    }

    private async Task LoadSeasons()
    {
        seasons = await StatsService.GetSeasonsAsync();
    }

    private async Task StartAdd()
    {
        editingSeason = new Season();
        assignedPlayerIds.Clear();
        originalPlayerIds.Clear();
        assignedOpponentIds.Clear();
        originalOpponentIds.Clear();
        isEditing = true;
        hasChanges = false;
        await SaveTempState();
    }

    private async Task StartEdit(Season season)
    {
        editingSeason = new Season { Id = season.Id, Name = season.Name, IsDeleted = season.IsDeleted };
        assignedPlayerIds.Clear();
        originalPlayerIds.Clear();
        assignedOpponentIds.Clear();
        originalOpponentIds.Clear();

        if (season.Id != 0)
        {
            List<Player> seasonPlayers = await StatsService.GetPlayersAsync(season.Id);
            foreach (Player p in seasonPlayers)
            {
                assignedPlayerIds.Add(p.Id);
                originalPlayerIds.Add(p.Id);
            }

            List<Opponent> seasonOpponents = await StatsService.GetOpponentsAsync(season.Id);
            foreach (Opponent o in seasonOpponents)
            {
                assignedOpponentIds.Add(o.Id);
                originalOpponentIds.Add(o.Id);
            }
        }

        isEditing = true;
        hasChanges = false;
        await SaveTempState();
    }

    private async Task HandleCancel()
    {
        if (hasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        editingSeason = new Season();
        assignedPlayerIds.Clear();
        assignedOpponentIds.Clear();
    }

    private async Task CancelEdit() => await HandleCancel();

    private async Task TogglePlayer(int playerId, ChangeEventArgs e)
    {
        hasChanges = true;
        bool isChecked = (bool)(e.Value ?? false);
        if (isChecked) assignedPlayerIds.Add(playerId);
        else assignedPlayerIds.Remove(playerId);
        await SaveTempState();
    }

    private async Task ToggleOpponent(int opponentId, ChangeEventArgs e)
    {
        hasChanges = true;
        bool isChecked = (bool)(e.Value ?? false);
        if (isChecked) assignedOpponentIds.Add(opponentId);
        else assignedOpponentIds.Remove(opponentId);
        await SaveTempState();
    }

    private async Task SaveSeason()
    {
        if (string.IsNullOrEmpty(editingSeason.Name)) return;

        if (editingSeason.Id == 0)
        {
            await StatsService.AddSeasonAsync(editingSeason);
        }
        else
        {
            await StatsService.UpdateSeasonAsync(editingSeason);
            
            // Sync Players
            foreach (int playerId in assignedPlayerIds.Except(originalPlayerIds))
                await StatsService.AddPlayerToSeasonAsync(playerId, editingSeason.Id);
            foreach (int playerId in originalPlayerIds.Except(assignedPlayerIds))
                await StatsService.DeletePlayerFromSeasonAsync(playerId, editingSeason.Id);

            // Sync Opponents
            foreach (int opponentId in assignedOpponentIds.Except(originalOpponentIds))
                await StatsService.AddOpponentToSeasonAsync(opponentId, editingSeason.Id);
            foreach (int opponentId in originalOpponentIds.Except(assignedOpponentIds))
                await StatsService.DeleteOpponentFromSeasonAsync(opponentId, editingSeason.Id);
        }

        await ClearTempState();
        await LoadSeasons();
    }

    private void ShowDeleteConfirm(int id)
    {
        seasonIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeleteSeason()
    {
        showConfirm = false;
        await StatsService.DeleteSeasonAsync(seasonIdToDelete);
        await LoadSeasons();
    }
}
