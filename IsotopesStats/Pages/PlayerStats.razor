@page "/"
@page "/playerstats"
@using IsotopesStats.Models
@using IsotopesStats.Services
@inject IStatsService StatsService
@inject SharedSessionState SharedState
@inject PlayerStatsState SessionState
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Player Stats</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h3 style="margin:0">Player Statistics</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <div class="desktop-only" style="display: flex; gap: 1rem; align-items: center;">
            <label style="margin:0; font-weight: bold;">Season:</label>
            <select class="form-control" style="width: auto;" value="@SharedState.SelectedSeasonId" @onchange="OnSeasonChange">
                <option value="-1">All Seasons</option>
                @foreach (Season season in seasons)
                {
                    <option value="@season.Id">@season.Name</option>
                }
            </select>
        </div>
        <div class="mobile-only">
             <button class="view-btn" style="background: var(--isotopes-accent); color: white; border: none; padding: 0.5rem 1rem;" @onclick="ToggleSeasonModal"> 
                🗓️ @(SharedState.SelectedSeasonId == -1 ? "All Seasons" : seasons.FirstOrDefault(s => s.Id == SharedState.SelectedSeasonId)?.Name)
            </button>
        </div>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                <div class="sort-option @(SharedState.SelectedSeasonId == -1 ? "active" : "")" @onclick="() => SelectMobileSeason(-1)">
                    All Seasons
                </div>
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(SharedState.SelectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div style="text-align: center; padding: 5rem;">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (!allStats.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Stats Found</h4>
            <p>Try a different season.</p>
        </div>
    }
    else
    {
        <div class="stat-card" style="animation-delay: 0.1s; margin-bottom: 1.5rem;">
            <div class="leader-highlights" style="margin-bottom: 1.5rem;">
                <div class="leader-card" @onclick='() => Sort("AVG", false)' style="cursor:pointer; animation-delay: 0.1s;">
                    <div class="leader-category">Batting Average</div>
                    @if (avgLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(avgLeader.PlayerName)' @onclick:stopPropagation="true">@avgLeader.PlayerName</div>
                        <div class="leader-value">@avgLeader.AVG.ToString(".000")</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
                <div class="leader-card" @onclick='() => Sort("OPS", false)' style="cursor:pointer; background: linear-gradient(135deg, #333, #000); animation-delay: 0.2s;">
                    <div class="leader-category">On-Base Plus Slugging</div>
                    @if (opsLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(opsLeader.PlayerName)' @onclick:stopPropagation="true">@opsLeader.PlayerName</div>
                        <div class="leader-value">@opsLeader.OPS.ToString(".000")</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
                <div class="leader-card" @onclick='() => Sort("HR", false)' style="cursor:pointer; background: linear-gradient(135deg, var(--isotopes-red), #990000); animation-delay: 0.3s;">
                    <div class="leader-category">Home Runs</div>
                    @if (hrLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(hrLeader.PlayerName)' @onclick:stopPropagation="true">@hrLeader.PlayerName</div>
                        <div class="leader-value">@hrLeader.HR.ToString()</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
                <div class="leader-card" @onclick='() => Sort("RBI", false)' style="cursor:pointer; background: linear-gradient(135deg, #666, #444); animation-delay: 0.4s;">
                    <div class="leader-category">Runs Batted In</div>
                    @if (rbiLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(rbiLeader.PlayerName)' @onclick:stopPropagation="true">@rbiLeader.PlayerName</div>
                        <div class="leader-value">@rbiLeader.RBI.ToString()</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
            </div>

            <hr style="margin: 0; opacity: 0.1;" />

            <div class="mobile-only" style="margin-top: 1.5rem;">
                <button class="view-btn" style="width: 100%; background: var(--isotopes-accent); color: white; border: none; padding: 0.75rem;" @onclick="ToggleSortModal">
                    ⇅ Sort By: @currentSortColumn
                </button>
            </div>

            @if (showSortModal)
            {
                <div class="sort-modal-overlay" @onclick="ToggleSortModal">
                    <div class="sort-modal" @onclick:stopPropagation="true">
                        <div class="sort-modal-header">
                            <h4 style="margin:0">Sort Statistics</h4>
                            <button class="view-btn" @onclick="ToggleSortModal">Close</button>
                        </div>
                        <div class="sort-grid">
                            @foreach (string stat in AllSortableStats)
                            {
                                <div class="sort-option @(currentSortColumn == stat ? "active" : "")" @onclick="() => SelectMobileSort(stat)">
                                    @stat
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="desktop-only" style="margin-top: 1.5rem;">
                <div class="box-score-table-wrapper" style="padding: 0;">
                    <table class="box-score-table table-sm">
                    <thead>
                        <tr>
                            <th style="width: 30px; text-align: center;">#</th>
                            <th class="player-name sticky-col @(currentSortColumn == "PlayerName" ? "active-sort-header" : "")" @onclick='() => Sort("PlayerName")'>Player<span class="sort-icon">@(GetSortIcon("PlayerName"))</span></th>
                            <th @onclick='() => Sort("GP")' class="sortable-header group-divider narrow-col @(currentSortColumn == "GP" ? "active-sort-header" : "")">GP<span class="sort-icon">@(GetSortIcon("GP"))</span></th>
                            <th @onclick='() => Sort("PA")' class="sortable-header narrow-col @(currentSortColumn == "PA" ? "active-sort-header" : "")">PA<span class="sort-icon">@(GetSortIcon("PA"))</span></th>
                            <th @onclick='() => Sort("AB")' class="sortable-header narrow-col @(currentSortColumn == "AB" ? "active-sort-header" : "")">AB<span class="sort-icon">@(GetSortIcon("AB"))</span></th>
                            <th @onclick='() => Sort("R")' class="sortable-header group-divider narrow-col @(currentSortColumn == "R" ? "active-sort-header" : "")">R<span class="sort-icon">@(GetSortIcon("R"))</span></th>
                            <th @onclick='() => Sort("H")' class="sortable-header narrow-col @(currentSortColumn == "H" ? "active-sort-header" : "")">H<span class="sort-icon">@(GetSortIcon("H"))</span></th>
                            <th @onclick='() => Sort("2B")' class="sortable-header narrow-col @(currentSortColumn == "2B" ? "active-sort-header" : "")">2B<span class="sort-icon">@(GetSortIcon("2B"))</span></th>
                            <th @onclick='() => Sort("3B")' class="sortable-header narrow-col @(currentSortColumn == "3B" ? "active-sort-header" : "")">3B<span class="sort-icon">@(GetSortIcon("3B"))</span></th>
                            <th @onclick='() => Sort("4B")' class="sortable-header narrow-col @(currentSortColumn == "4B" ? "active-sort-header" : "")">4B<span class="sort-icon">@(GetSortIcon("4B"))</span></th>
                            <th @onclick='() => Sort("HR")' class="sortable-header narrow-col @(currentSortColumn == "HR" ? "active-sort-header" : "")">HR<span class="sort-icon">@(GetSortIcon("HR"))</span></th>
                            <th @onclick='() => Sort("RBI")' class="sortable-header narrow-col @(currentSortColumn == "RBI" ? "active-sort-header" : "")">RBI<span class="sort-icon">@(GetSortIcon("RBI"))</span></th>
                            <th @onclick='() => Sort("BB")' class="sortable-header group-divider narrow-col @(currentSortColumn == "BB" ? "active-sort-header" : "")">BB<span class="sort-icon">@(GetSortIcon("BB"))</span></th>
                            <th @onclick='() => Sort("K")' class="sortable-header narrow-col @(currentSortColumn == "K" ? "active-sort-header" : "")">K<span class="sort-icon">@(GetSortIcon("K"))</span></th>
                            <th @onclick='() => Sort("KF")' class="sortable-header narrow-col @(currentSortColumn == "KF" ? "active-sort-header" : "")">KF<span class="sort-icon">@(GetSortIcon("KF"))</span></th>
                            <th @onclick='() => Sort("SF")' class="sortable-header group-divider narrow-col @(currentSortColumn == "SF" ? "active-sort-header" : "")">SF<span class="sort-icon">@(GetSortIcon("SF"))</span></th>
                            <th @onclick='() => Sort("FC")' class="sortable-header narrow-col @(currentSortColumn == "FC" ? "active-sort-header" : "")">FC<span class="sort-icon">@(GetSortIcon("FC"))</span></th>
                            <th @onclick='() => Sort("GO")' class="sortable-header narrow-col @(currentSortColumn == "GO" ? "active-sort-header" : "")">GO<span class="sort-icon">@(GetSortIcon("GO"))</span></th>
                            <th @onclick='() => Sort("FO")' class="sortable-header narrow-col @(currentSortColumn == "FO" ? "active-sort-header" : "")">FO<span class="sort-icon">@(GetSortIcon("FO"))</span></th>
                            <th @onclick='() => Sort("AVG")' class="sortable-header group-divider @(currentSortColumn == "AVG" ? "active-sort-header" : "")">AVG<span class="sort-icon">@(GetSortIcon("AVG"))</span></th>
                            <th @onclick='() => Sort("OBP")' class="sortable-header @(currentSortColumn == "OBP" ? "active-sort-header" : "")">OBP<span class="sort-icon">@(GetSortIcon("OBP"))</span></th>
                            <th @onclick='() => Sort("SLG")' class="sortable-header @(currentSortColumn == "SLG" ? "active-sort-header" : "")">SLG<span class="sort-icon">@(GetSortIcon("SLG"))</span></th>
                            <th @onclick='() => Sort("OPS")' class="sortable-header @(currentSortColumn == "OPS" ? "active-sort-header" : "")">OPS<span class="sort-icon">@(GetSortIcon("OPS"))</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < allStats.Count; i++)
                        {
                            PlayerStatsSummary player = allStats[i];
                            <tr>
                                <td style="color: #999; font-weight: bold; text-align: center;">@(i + 1)</td>
                                <td class="player-name sticky-col">
                                    <a href="/playerlogs/@Uri.EscapeDataString(player.PlayerName)" style="text-decoration: none; color: inherit;">        
                                        @player.PlayerName
                                    </a>
                                </td>
                                <td class="group-divider narrow-col @(currentSortColumn == "GP" ? "active-sort-col" : "")">@player.GamesPlayed</td>
                                <td class="narrow-col @(currentSortColumn == "PA" ? "active-sort-col" : "")">@player.PA</td>
                                <td class="narrow-col @(currentSortColumn == "AB" ? "active-sort-col" : "")">@player.AB</td>
                                <td class="group-divider narrow-col @(currentSortColumn == "R" ? "active-sort-col" : "")">@player.R</td>
                                <td class="narrow-col @(currentSortColumn == "H" ? "active-sort-col" : "")">@player.H</td>
                                <td class="narrow-col @(currentSortColumn == "2B" ? "active-sort-col" : "")">@player.H2B</td>
                                <td class="narrow-col @(currentSortColumn == "3B" ? "active-sort-col" : "")">@player.H3B</td>
                                <td class="narrow-col @(currentSortColumn == "4B" ? "active-sort-col" : "")">@player.H4B</td>
                                <td class="narrow-col @(currentSortColumn == "HR" ? "active-sort-col" : "")">@player.HR</td>
                                <td class="narrow-col @(currentSortColumn == "RBI" ? "active-sort-col" : "")">@player.RBI</td>
                                <td class="group-divider narrow-col @(currentSortColumn == "BB" ? "active-sort-col" : "")">@player.BB</td>
                                <td class="narrow-col @(currentSortColumn == "K" ? "active-sort-col" : "")">@player.K</td>
                                <td class="narrow-col @(currentSortColumn == "KF" ? "active-sort-col" : "")">@player.KF</td>
                                <td class="group-divider narrow-col @(currentSortColumn == "SF" ? "active-sort-col" : "")">@player.SF</td>
                                <td class="narrow-col @(currentSortColumn == "FC" ? "active-sort-col" : "")">@player.FC</td>
                                <td class="narrow-col @(currentSortColumn == "GO" ? "active-sort-col" : "")">@player.GO</td>
                                <td class="narrow-col @(currentSortColumn == "FO" ? "active-sort-col" : "")">@player.FO</td>
                                <td class="group-divider @(currentSortColumn == "AVG" ? "active-sort-col" : "")">@player.AVG.ToString(".000")</td>
                                <td class="@(currentSortColumn == "OBP" ? "active-sort-col" : "")">@player.OBP.ToString(".000")</td>
                                <td class="@(currentSortColumn == "SLG" ? "active-sort-col" : "")">@player.SLG.ToString(".000")</td>
                                <td class="@(currentSortColumn == "OPS" ? "active-sort-col" : "")">@player.OPS.ToString(".000")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="game-summary-row">
                            <td colspan="2" class="sticky-col">TEAM TOTALS</td>
                            <td class="group-divider narrow-col">-</td>
                            <td class="narrow-col">@teamTotals.PA</td>
                            <td class="narrow-col">@teamTotals.AB</td>
                            <td class="group-divider narrow-col">@teamTotals.R</td>
                            <td class="narrow-col">@teamTotals.H</td>
                            <td class="narrow-col">@teamTotals.H2B</td>
                            <td class="narrow-col">@teamTotals.H3B</td>
                            <td class="narrow-col">@teamTotals.H4B</td>
                            <td class="narrow-col">@teamTotals.HR</td>
                            <td class="narrow-col">@teamTotals.RBI</td>
                            <td class="group-divider narrow-col">@teamTotals.BB</td>
                            <td class="narrow-col">@teamTotals.K</td>
                            <td class="narrow-col">@teamTotals.KF</td>
                            <td class="group-divider narrow-col">@teamTotals.SF</td>
                            <td class="narrow-col">@teamTotals.FC</td>
                            <td class="narrow-col">@teamTotals.GO</td>
                            <td class="narrow-col">@teamTotals.FO</td>
                            <td class="group-divider">@teamTotals.AVG.ToString(".000")</td>
                            <td>@teamTotals.OBP.ToString(".000")</td>
                            <td>@teamTotals.SLG.ToString(".000")</td>
                            <td>@teamTotals.OPS.ToString(".000")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            </div>

            <div class="mobile-only">
            <div class="mobile-player-grid view-fade-in">
                @for (int i = 0; i < allStats.Count; i++)
                {
                    PlayerStatsSummary player = allStats[i];
                    <div class="mobile-player-card">
                        <div class="mobile-card-header">
                            <span class="mobile-card-name" @onclick='() => NavigationManager.NavigateTo($"/playerlogs/{Uri.EscapeDataString(player.PlayerName)}")' style="cursor: pointer;">
                                <span class="rank-badge">#@(i + 1)</span>
                                @player.PlayerName
                            </span>
                            <div style="display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end;">
                                <span class="badge bg-light text-dark @(currentSortColumn == "AVG" ? "border border-danger" : "")" @onclick='@(() => Sort("AVG"))' @onclick:stopPropagation="true" style="cursor: pointer;">AVG: @player.AVG.ToString(".000")</span>
                                <span class="badge bg-light text-dark @(currentSortColumn == "OBP" ? "border border-danger" : "")" @onclick='@(() => Sort("OBP"))' @onclick:stopPropagation="true" style="cursor: pointer;">OBP: @player.OBP.ToString(".000")</span>
                                <span class="badge bg-light text-dark @(currentSortColumn == "SLG" ? "border border-danger" : "")" @onclick='@(() => Sort("SLG"))' @onclick:stopPropagation="true" style="cursor: pointer;">SLG: @player.SLG.ToString(".000")</span>
                                <span class="badge bg-light text-dark @(currentSortColumn == "OPS" ? "border border-danger" : "")" @onclick='@(() => Sort("OPS"))' @onclick:stopPropagation="true" style="cursor: pointer;">OPS: @player.OPS.ToString(".000")</span>
                            </div>
                        </div>
                        <div class="mobile-card-stats">
                            <div class="m-stat @(currentSortColumn == "GP" ? "active" : "")" @onclick='@(() => Sort("GP"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.GamesPlayed</span><span class="m-stat-label">GP</span></div>
                            <div class="m-stat @(currentSortColumn == "PA" ? "active" : "")" @onclick='@(() => Sort("PA"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.PA</span><span class="m-stat-label">PA</span></div>
                            <div class="m-stat @(currentSortColumn == "AB" ? "active" : "")" @onclick='@(() => Sort("AB"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.AB</span><span class="m-stat-label">AB</span></div>
                            <div class="m-stat @(currentSortColumn == "H" ? "active" : "")" @onclick='@(() => Sort("H"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.H</span><span class="m-stat-label">H</span></div>
                            <div class="m-stat @(currentSortColumn == "1B" ? "active" : "")" @onclick='@(() => Sort("1B"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.H1B</span><span class="m-stat-label">1B</span></div>
                            <div class="m-stat @(currentSortColumn == "2B" ? "active" : "")" @onclick='@(() => Sort("2B"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.H2B</span><span class="m-stat-label">2B</span></div>
                            <div class="m-stat @(currentSortColumn == "3B" ? "active" : "")" @onclick='@(() => Sort("3B"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.H3B</span><span class="m-stat-label">3B</span></div>
                            <div class="m-stat @(currentSortColumn == "4B" ? "active" : "")" @onclick='@(() => Sort("4B"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.H4B</span><span class="m-stat-label">4B</span></div>
                            <div class="m-stat @(currentSortColumn == "HR" ? "active" : "")" @onclick='@(() => Sort("HR"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.HR</span><span class="m-stat-label">HR</span></div>
                            <div class="m-stat @(currentSortColumn == "RBI" ? "active" : "")" @onclick='@(() => Sort("RBI"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.RBI</span><span class="m-stat-label">RBI</span></div>
                            <div class="m-stat @(currentSortColumn == "R" ? "active" : "")" @onclick='@(() => Sort("R"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.R</span><span class="m-stat-label">R</span></div>
                            <div class="m-stat @(currentSortColumn == "BB" ? "active" : "")" @onclick='@(() => Sort("BB"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.BB</span><span class="m-stat-label">BB</span></div>
                            <div class="m-stat @(currentSortColumn == "SF" ? "active" : "")" @onclick='@(() => Sort("SF"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.SF</span><span class="m-stat-label">SF</span></div>
                            <div class="m-stat @(currentSortColumn == "FC" ? "active" : "")" @onclick='@(() => Sort("FC"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.FC</span><span class="m-stat-label">FC</span></div>
                            <div class="m-stat @(currentSortColumn == "K" ? "active" : "")" @onclick='@(() => Sort("K"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.K</span><span class="m-stat-label">K</span></div>
                            <div class="m-stat @(currentSortColumn == "KF" ? "active" : "")" @onclick='@(() => Sort("KF"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.KF</span><span class="m-stat-label">KF</span></div>
                            <div class="m-stat @(currentSortColumn == "GO" ? "active" : "")" @onclick='@(() => Sort("GO"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.GO</span><span class="m-stat-label">GO</span></div>
                            <div class="m-stat @(currentSortColumn == "FO" ? "active" : "")" @onclick='@(() => Sort("FO"))' @onclick:stopPropagation="true" style="cursor: pointer;"><span class="m-stat-val">@player.FO</span><span class="m-stat-label">FO</span></div>
                        </div>
                    </div>
                }
                <div class="mobile-player-card" style="border: 2px solid var(--isotopes-accent); background: #f0f7ff; margin-top: 1rem;">
                    <div class="mobile-card-header">
                        <span class="mobile-card-name">TEAM TOTALS</span>
                        <div style="display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end;">
                            <span class="badge bg-primary">AVG: @teamTotals.AVG.ToString(".000")</span>
                            <span class="badge bg-primary">OBP: @teamTotals.OBP.ToString(".000")</span>
                            <span class="badge bg-primary">SLG: @teamTotals.SLG.ToString(".000")</span>
                            <span class="badge bg-primary">OPS: @teamTotals.OPS.ToString(".000")</span>
                        </div>
                    </div>
                    <div class="mobile-card-stats">
                        <div class="m-stat"><span class="m-stat-val">@teamTotals.PA</span><span class="m-stat-label">PA</span></div>
                        <div class="m-stat"><span class="m-stat-val">@teamTotals.AB</span><span class="m-stat-label">AB</span></div>
                        <div class="m-stat"><span class="m-stat-val">@teamTotals.H</span><span class="m-stat-label">H</span></div>
                        <div class="m-stat"><span class="m-stat-val">@teamTotals.HR</span><span class="m-stat-label">HR</span></div>
                        <div class="m-stat"><span class="m-stat-val">@teamTotals.RBI</span><span class="m-stat-label">RBI</span></div>
