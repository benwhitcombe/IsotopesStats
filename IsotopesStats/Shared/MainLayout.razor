@inherits LayoutComponentBase

<PageTitle>Isotopes Stats 2026</PageTitle>

<div class="page">
    <header class="isotopes-header">
        <div class="header-content">
            <div style="display: flex; align-items: center; gap: 10px;">
                <span class="logo-atom">⚛️</span>
                <h1>ISOTOPES STATS</h1>
            </div>
            
            <nav class="desktop-nav">
                <NavLink href="gamestats">Games</NavLink>
                <NavLink href="" Match="NavLinkMatch.All">Players</NavLink>
            </nav>
        </div>
    </header>

    <main>
        <article class="content">
            @Body
        </article>
    </main>

    <nav class="mobile-nav">
        <NavLink href="gamestats">
            <span class="nav-icon">⚾</span>
            <span>Games</span>
        </NavLink>
        <NavLink href="" Match="NavLinkMatch.All">
            <span class="nav-icon">📋</span>
            <span>Players</span>
        </NavLink>
    </nav>
</div>
