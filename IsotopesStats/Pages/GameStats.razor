        </div>
    }
}

@code {
    private List<GameSummaryView>? summaries;
    private Dictionary<int, List<GameStatsExtendedView>> expandedStats = new();
    private List<Season> seasons = new();
    private string filterText = "";
    private bool showSeasonModal = false;
    private bool isLoading = true;

    private IEnumerable<GameSummaryView> FilteredSummaries =>
        (summaries ?? new List<GameSummaryView>())
        .Where(s =>
            string.IsNullOrEmpty(filterText) ||
            s.OpponentName.Contains(filterText, StringComparison.OrdinalIgnoreCase)
        )
        .OrderByDescending(s => s.Date);

    protected override async Task OnInitializedAsync()
    {
        SharedState.ReturnUrl = "gamestats";
        seasons = await StatsService.GetSeasonsAsync();

        if (SharedState.SelectedSeasonId == 0 && seasons.Any())
        {
            SharedState.SelectedSeasonId = seasons.First().Id;
        }

        filterText = SessionState.FilterText;
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("drawerDragging.initOpponentNames");
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            summaries = await StatsService.GetGameSummariesAsync(SharedState.SelectedSeasonId);
            
            // Re-fetch expanded games if needed
            foreach (KeyValuePair<int, GameUIState> state in SessionState.GameUIStates.Where(s => s.Value.IsExpanded))
            {
                if (summaries.Any(s => s.GameId == state.Key))
                {
                    expandedStats[state.Key] = await StatsService.GetExtendedGameStatsAsync(state.Key);
                }
            }
        }
        catch (Exception)
        {
            summaries = new List<GameSummaryView>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSeasonSelected(int id)
    {
        SharedState.SelectedSeasonId = id;
        await LoadData();
    }

    private void ClearFilter()
    {
        filterText = "";
        UpdateFilterState();
    }

    private void UpdateFilterState()
    {
        SessionState.FilterText = filterText;
    }

    private async Task ToggleGame(GameSummaryView summary)
    {
        int gameId = summary.GameId;
        GameUIState state = SessionState.GetState(gameId);
        state.IsExpanded = !state.IsExpanded;
        SessionState.TriggerChange();

        if (state.IsExpanded && (!expandedStats.ContainsKey(gameId) || expandedStats[gameId] == null))
        {
            StateHasChanged();
            expandedStats[gameId] = await StatsService.GetExtendedGameStatsAsync(gameId);
        }

        StateHasChanged();
    }

    private void Sort(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);

        if (state.SortColumn == column)
        {
            state.IsAscending = !state.IsAscending;
        }
        else
        {
            state.SortColumn = column;
            state.IsAscending = false;
            if (column == "Player" || column == "BO") state.IsAscending = true;
        }
        SessionState.TriggerChange();
        StateHasChanged();
    }

    private string GetSortIcon(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);
        if (state.SortColumn != column) return "";
        return state.IsAscending ? "▲" : "▼";
    }

    private IEnumerable<GameStatsExtendedView> ApplyInnerSorting(GameUIState uiState, IEnumerable<GameStatsExtendedView> stats)
    {
        return uiState.SortColumn switch
        {
            "Player" => uiState.IsAscending ? stats.OrderBy(s => s.PlayerName) : stats.OrderByDescending(s => s.PlayerName),
            "BO" => uiState.IsAscending ? stats.OrderBy(s => s.BO) : stats.OrderByDescending(s => s.BO),
            "PA" => uiState.IsAscending ? stats.OrderBy(s => s.PA) : stats.OrderByDescending(s => s.PA),
            "AB" => uiState.IsAscending ? stats.OrderBy(s => s.AB) : stats.OrderByDescending(s => s.AB),
            "R" => uiState.IsAscending ? stats.OrderBy(s => s.R) : stats.OrderByDescending(s => s.R),
            "H" => uiState.IsAscending ? stats.OrderBy(s => s.H) : stats.OrderByDescending(s => s.H),
            "2B" => uiState.IsAscending ? stats.OrderBy(s => s.H2B) : stats.OrderByDescending(s => s.H2B),
            "3B" => uiState.IsAscending ? stats.OrderBy(s => s.H3B) : stats.OrderByDescending(s => s.H3B),
            "4B" => uiState.IsAscending ? stats.OrderBy(s => s.H4B) : stats.OrderByDescending(s => s.H4B),
            "HR" => uiState.IsAscending ? stats.OrderBy(s => s.HR) : stats.OrderByDescending(s => s.HR),
            "RBI" => uiState.IsAscending ? stats.OrderBy(s => s.RBI) : stats.OrderByDescending(s => s.RBI),
            "BB" => uiState.IsAscending ? stats.OrderBy(s => s.BB) : stats.OrderByDescending(s => s.BB),
            "K" => uiState.IsAscending ? stats.OrderBy(s => s.K) : stats.OrderByDescending(s => s.K),
            "KF" => uiState.IsAscending ? stats.OrderBy(s => s.KF) : stats.OrderByDescending(s => s.KF),
            "SF" => uiState.IsAscending ? stats.OrderBy(s => s.SF) : stats.OrderByDescending(s => s.SF),
            "FC" => uiState.IsAscending ? stats.OrderBy(s => s.FC) : stats.OrderByDescending(s => s.FC),
            "GO" => uiState.IsAscending ? stats.OrderBy(s => s.GO) : stats.OrderByDescending(s => s.GO),
            "FO" => uiState.IsAscending ? stats.OrderBy(s => s.FO) : stats.OrderByDescending(s => s.FO),
            "AVG" => uiState.IsAscending ? stats.OrderBy(s => s.AVG) : stats.OrderByDescending(s => s.AVG),
            "OBP" => uiState.IsAscending ? stats.OrderBy(s => s.OBP) : stats.OrderByDescending(s => s.OBP),
            "SLG" => uiState.IsAscending ? stats.OrderBy(s => s.SLG) : stats.OrderByDescending(s => s.SLG),
            "OPS" => uiState.IsAscending ? stats.OrderBy(s => s.OPS) : stats.OrderByDescending(s => s.OPS),
            _ => stats.OrderBy(s => s.BO)
        };
    }
}

