@page "/gamestats"
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject StatsService StatsService

<div class="header-with-filter">
    <h3>Detailed Game Stats</h3>
    <div class="filter-container">
        <input type="text" class="form-control" @bind="filterText" @bind:event="oninput" placeholder="Search Player or Opponent..." />
    </div>
    <div class="action-buttons">
        <NavLink href="admin" class="view-btn" style="background-color: var(--isotopes-accent); color: white; border: none; text-decoration: none;">➕ Add New Game</NavLink>
        <button class="view-btn" @onclick="ExpandAll">Expand All</button>
        <button class="view-btn" @onclick="CollapseAll">Collapse All</button>
    </div>
</div>

<div class="game-cards-list">
    @foreach (var group in GroupedStats)
    {
        var gameInfo = group.First().Game;
        var isExpanded = expandedGames.Contains(gameInfo?.Id ?? 0);
        var teamRuns = group.Sum(s => s.R);
        var teamHits = group.Sum(s => s.H);
        var teamHRs = group.Sum(s => s.HR);
        var teamBBs = group.Sum(s => s.BB);
        var teamAB = group.Sum(s => s.AB);
        var teamPA = group.Sum(s => s.PA);
        var teamRBI = group.Sum(s => s.RBI);
        var teamAVG = teamAB > 0 ? (double)teamHits / teamAB : 0;

        <div class="game-card">
            <div class="game-card-header" @onclick="() => ToggleGame(gameInfo?.Id ?? 0)">
                <div class="game-info-left">
                    <div class="game-number-badge">GAME #@gameInfo?.GameNumber</div>
                    <div class="game-date">@gameInfo?.Date.ToString("MMM dd, yyyy @ HH:mm")</div>
                </div>
                
                <div class="game-matchup">
                    <div class="opponent-name">vs @gameInfo?.Opponent</div>
                    <div class="diamond-name">📍 @gameInfo?.Diamond</div>
                </div>

                <div class="game-score-summary">
                    <div class="score-item">
                        <span class="score-value">@teamRuns</span>
                        <span class="score-label">Runs</span>
                    </div>
                    <div class="score-item">
                        <span class="score-value">@teamHits</span>
                        <span class="score-label">Hits</span>
                    </div>
                    <div class="expand-icon" style="margin-left: 1rem; color: #ccc;">
                        @(isExpanded ? "▲" : "▼")
                    </div>
                </div>
            </div>

            <div class="game-card-footer">
                <div class="footer-stat">
                    <span class="footer-stat-label">HR:</span> @teamHRs
                </div>
                <div class="footer-stat">
                    <span class="footer-stat-label">BB:</span> @teamBBs
                </div>
                <div class="footer-stat">
                    <span class="footer-stat-label">AVG:</span> @teamAVG.ToString(".000")
                </div>
            </div>

            @if (isExpanded)
            {
                <div class="game-card-detail">
                    <div class="box-score-table-wrapper">
                        <table class="box-score-table table-sm">
                            <thead>
                                <tr>
                                    <th class="sticky-col">Player</th>
                                    <th>PA</th>
                                    <th>AB</th>
                                    <th>H</th>
                                    <th>1B</th>
                                    <th>2B</th>
                                    <th>3B</th>
                                    <th>4B</th>
                                    <th>HR</th>
                                    <th>FC</th>
                                    <th>BB</th>
                                    <th>SF</th>
                                    <th>K</th>
                                    <th>KF</th>
                                    <th>GO</th>
                                    <th>FO</th>
                                    <th>R</th>
                                    <th>RBI</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (StatEntry stat in group)
                                {
                                    <tr>
                                        <td class="player-name sticky-col">@stat.BO. @stat.Player?.Name</td>
                                        <td>@stat.PA</td>
                                        <td>@stat.AB</td>
                                        <td>@stat.H</td>
                                        <td>@stat.H1B</td>
                                        <td>@stat.H2B</td>
                                        <td>@stat.H3B</td>
                                        <td>@stat.H4B</td>
                                        <td>@stat.HR</td>
                                        <td>@stat.FC</td>
                                        <td>@stat.BB</td>
                                        <td>@stat.SF</td>
                                        <td>@stat.K</td>
                                        <td>@stat.KF</td>
                                        <td>@stat.GO</td>
                                        <td>@stat.FO</td>
                                        <td>@stat.R</td>
                                        <td>@stat.RBI</td>
                                    </tr>
                                }
                                <tr class="game-summary-row" style="background: #f8f9fa; font-weight: bold;">
                                    <td class="sticky-col">TOTALS</td>
                                    <td>@teamPA</td>
                                    <td>@teamAB</td>
                                    <td>@teamHits</td>
                                    <td>@group.Sum(s => s.H1B)</td>
                                    <td>@group.Sum(s => s.H2B)</td>
                                    <td>@group.Sum(s => s.H3B)</td>
                                    <td>@group.Sum(s => s.H4B)</td>
                                    <td>@teamHRs</td>
                                    <td>@group.Sum(s => s.FC)</td>
                                    <td>@teamBBs</td>
                                    <td>@group.Sum(s => s.SF)</td>
                                    <td>@group.Sum(s => s.K)</td>
                                    <td>@group.Sum(s => s.KF)</td>
                                    <td>@group.Sum(s => s.GO)</td>
                                    <td>@group.Sum(s => s.FO)</td>
                                    <td>@teamRuns</td>
                                    <td>@teamRBI</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mobile-player-grid">
                        @foreach (StatEntry stat in group)
                        {
                            <div class="mobile-player-card">
                                <div class="mobile-card-header">
                                    <span class="mobile-card-name">@stat.BO. @stat.Player?.Name</span>
                                    <span class="badge bg-light text-dark">R: @stat.R | RBI: @stat.RBI</span>
                                </div>
                                <div class="mobile-card-stats">
                                    <div class="m-stat"><span class="m-stat-val">@stat.PA</span><span class="m-stat-label">PA</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.AB</span><span class="m-stat-label">AB</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.H</span><span class="m-stat-label">H</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.H1B</span><span class="m-stat-label">1B</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.H2B</span><span class="m-stat-label">2B</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.HR</span><span class="m-stat-label">HR</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.BB</span><span class="m-stat-label">BB</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.K</span><span class="m-stat-label">K</span></div>
                                    <div class="m-stat"><span class="m-stat-val">@stat.GO</span><span class="m-stat-label">GO</span></div>
                                </div>
                            </div>
                        }
                        <div class="mobile-player-card" style="border: 2px solid var(--isotopes-accent); background: #f0f7ff;">
                            <div class="mobile-card-header">
                                <span class="mobile-card-name">TEAM TOTALS</span>
                                <span class="badge bg-primary">R: @teamRuns | RBI: @teamRBI</span>
                            </div>
                            <div class="mobile-card-stats">
                                <div class="m-stat"><span class="m-stat-val">@teamPA</span><span class="m-stat-label">PA</span></div>
                                <div class="m-stat"><span class="m-stat-val">@teamAB</span><span class="m-stat-label">AB</span></div>
                                <div class="m-stat"><span class="m-stat-val">@teamHits</span><span class="m-stat-label">H</span></div>
                                <div class="m-stat"><span class="m-stat-val">@teamHRs</span><span class="m-stat-label">HR</span></div>
                                <div class="m-stat"><span class="m-stat-val">@teamBBs</span><span class="m-stat-label">BB</span></div>
                                <div class="m-stat"><span class="m-stat-val">@group.Sum(s => s.K)</span><span class="m-stat-label">K</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<StatEntry> allStats = new();
    private HashSet<int> expandedGames = new();
    private string filterText = "";

    protected override void OnInitialized()
    {
        try 
        {
            allStats = StatsService.GetAllGameStats();
            // Expand the most recent game by default
            var latestGame = allStats.FirstOrDefault()?.Game;
            if (latestGame != null)
            {
                expandedGames.Add(latestGame.Id);
            }
        }
        catch (Exception)
        {
            allStats = new List<StatEntry>();
        }
    }

    private IEnumerable<IGrouping<int, StatEntry>> GroupedStats => allStats
        .Where(s => string.IsNullOrWhiteSpace(filterText) 
            || (s.Player?.Name?.Contains(filterText, StringComparison.OrdinalIgnoreCase) ?? false) 
            || (s.Game?.Opponent?.Contains(filterText, StringComparison.OrdinalIgnoreCase) ?? false))
        .GroupBy(s => s.GameId);

    private void ToggleGame(int gameId)
    {
        if (expandedGames.Contains(gameId))
        {
            expandedGames.Remove(gameId);
        }
        else
        {
            expandedGames.Add(gameId);
        }
    }

    private void ExpandAll()
    {
        foreach (var group in GroupedStats)
        {
            expandedGames.Add(group.Key);
        }
    }

    private void CollapseAll()
    {
        expandedGames.Clear();
    }
}

<style>
    .header-with-filter {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .filter-container {
        flex: 1;
        max-width: 400px;
    }

    /* Small hack to fix the PA/Score alignment in the summary row */
    .game-summary-row td:nth-child(3) {
        /* Total PA calculation instead of teamRuns */
    }
</style>
