@page "/"
@page "/gamestats"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject StatsService StatsService
@inject GameStatsState SessionState
@inject SharedSessionState SharedState
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Game Stats</PageTitle>

<div class="header-with-filter">
    <div class="filter-container">
        <div class="search-container">
            <span class="search-icon">🔍</span>
            <input type="text" class="form-control search-input" placeholder="Filter by player name..." 
                   @bind-value="filterText" @bind-value:event="oninput" @onkeyup="UpdateFilterState" />
            @if (!string.IsNullOrEmpty(filterText))
            {
                <button class="clear-button" @onclick="ClearFilter">✕</button>
            }
        </div>
    </div>

    <div class="desktop-only" style="display: flex; gap: 10px;">
        <button class="view-btn @(SessionState.GameUIStates.All(s => s.Value.IsExpanded) ? "active" : "")" @onclick="ExpandAll">Expand All</button>
        <button class="view-btn @(SessionState.GameUIStates.All(s => !s.Value.IsExpanded) ? "active" : "")" @onclick="CollapseAll">Collapse All</button>
        <select class="form-control" style="width: auto; min-width: 120px;" @onchange="OnSeasonChange">
            @foreach (Season season in seasons)
            {
                <option value="@season.Id" selected="@(SharedState.SelectedSeasonId == season.Id)">@season.Name</option>
            }
        </select>
    </div>

    <div class="mobile-only" style="width: 100%; display: flex; gap: 10px; margin-top: 10px;">
        <button class="view-btn" style="flex: 1;" @onclick="ToggleSeasonModal">
            📅 Season: @(seasons.FirstOrDefault(s => s.Id == SharedState.SelectedSeasonId)?.Name ?? "Select")
        </button>
        <button class="view-btn" style="flex: 1;" @onclick="ExpandAll">Expand All</button>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(SharedState.SelectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="game-list">
    @if (isLoading && !showSkeleton)
    {
        @* Initial quiet load *@
    }
    else if (showSkeleton)
    {
        @for (int i = 0; i < 3; i++)
        {
            <div class="stat-card skeleton-card">
                <div class="skeleton-header"></div>
                <div class="skeleton-line"></div>
                <div class="skeleton-line short"></div>
            </div>
        }
    }
    else if (!allStats.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 3rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <p style="color: #666;">No games found for this season.</p>
        </div>
    }
    else
    {
        @foreach (IGrouping<int, StatEntry> group in GroupedStats)
        {
            int gameId = group.Key;
            GameUIState uiState = SessionState.GetState(gameId);
            StatEntry first = group.First();
            Game game = first.Game!;
            
            <div class="stat-card view-fade-in" @key="gameId">
                <div class="game-card-header" @onclick="() => ToggleGame(gameId)">
                    <div class="game-main-info">
                        <div class="game-primary">
                            <span class="game-number">#@game.GameNumber</span>
                            <span class="game-opponent">vs @game.Opponent</span>
                        </div>
                        <div class="game-meta">
                            <span>@game.Date.ToString("MMM dd, yyyy")</span>
                            <span class="meta-dot">•</span>
                            <span>@game.Diamond</span>
                            <span class="meta-dot">•</span>
                            <span class="game-type-tag">@game.Type</span>
                        </div>
                    </div>
                    <div class="game-expand-icon @(uiState.IsExpanded ? "expanded" : "")">
                        ▼
                    </div>
                </div>

                <div class="game-card-detail @(uiState.IsExpanded ? "expanded" : "")">
                    @if (uiState.IsExpanded)
                    {
                        <div class="box-score-container">
                            @* Desktop Table *@
                            <div class="desktop-only">
                                <table class="box-score-table">
                                    <thead>
                                        <tr>
                                            <th @onclick='() => Sort(gameId, "BO")'>BO @GetSortIcon(gameId, "BO")</th>
                                            <th @onclick='() => Sort(gameId, "Player")' style="text-align:left">Player @GetSortIcon(gameId, "Player")</th>
                                            <th @onclick='() => Sort(gameId, "PA")' title="Plate Appearances">PA @GetSortIcon(gameId, "PA")</th>
                                            <th @onclick='() => Sort(gameId, "AB")' title="At Bats">AB @GetSortIcon(gameId, "AB")</th>
                                            <th @onclick='() => Sort(gameId, "R")' title="Runs">R @GetSortIcon(gameId, "R")</th>
                                            <th @onclick='() => Sort(gameId, "H")' title="Hits">H @GetSortIcon(gameId, "H")</th>
                                            <th @onclick='() => Sort(gameId, "2B")' title="Doubles">2B @GetSortIcon(gameId, "2B")</th>
                                            <th @onclick='() => Sort(gameId, "3B")' title="Triples">3B @GetSortIcon(gameId, "3B")</th>
                                            <th @onclick='() => Sort(gameId, "HR")' title="Home Runs">HR @GetSortIcon(gameId, "HR")</th>
                                            <th @onclick='() => Sort(gameId, "RBI")' title="Runs Batted In">RBI @GetSortIcon(gameId, "RBI")</th>
                                            <th @onclick='() => Sort(gameId, "BB")' title="Walks">BB @GetSortIcon(gameId, "BB")</th>
                                            <th @onclick='() => Sort(gameId, "K")' title="Strikeouts">K @GetSortIcon(gameId, "K")</th>
                                            <th @onclick='() => Sort(gameId, "AVG")' title="Batting Average">AVG @GetSortIcon(gameId, "AVG")</th>
                                            <th @onclick='() => Sort(gameId, "OBP")' title="On Base Percentage">OBP @GetSortIcon(gameId, "OBP")</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (StatEntry stat in ApplyInnerSorting(uiState, group))
                                        {
                                            <tr>
                                                <td>@stat.BO</td>
                                                <td style="text-align:left; font-weight: 600;">@stat.Player?.Name</td>
                                                <td>@stat.PA</td>
                                                <td>@stat.AB</td>
                                                <td style="color: var(--isotopes-red); font-weight: bold;">@stat.R</td>
                                                <td style="font-weight: 600;">@stat.H</td>
                                                <td>@stat.H2B</td>
                                                <td>@stat.H3B</td>
                                                <td>@stat.HR</td>
                                                <td style="color: var(--isotopes-red); font-weight: bold;">@stat.RBI</td>
                                                <td>@stat.BB</td>
                                                <td>@stat.K</td>
                                                <td style="font-weight: bold;">@stat.AVG.ToString(".000")</td>
                                                <td>@stat.OBP.ToString(".000")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @* Mobile Grid *@
                            <div class="mobile-only">
                                <div class="mobile-player-grid">
                                    @foreach (StatEntry stat in ApplyInnerSorting(uiState, group))
                                    {
                                        <div class="mobile-player-card">
                                            <div class="mobile-card-header">
                                                <div class="mobile-card-name">@stat.Player?.Name</div>
                                                <div class="rank-badge">BO: @stat.BO</div>
                                            </div>
                                            <div class="mobile-card-stats">
                                                <div class="m-stat"><span class="m-stat-label">AVG</span><span class="m-stat-val">@stat.AVG.ToString(".000")</span></div>
                                                <div class="m-stat"><span class="m-stat-label">H</span><span class="m-stat-val">@stat.H</span></div>
                                                <div class="m-stat"><span class="m-stat-label">R</span><span class="m-stat-val">@stat.R</span></div>
                                                <div class="m-stat"><span class="m-stat-label">RBI</span><span class="m-stat-val">@stat.RBI</span></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="game-card-footer">
                    @{
                        int teamRuns = group.Sum(s => s.R);
                        int teamHits = group.Sum(s => s.H);
                        int teamHRs = group.Sum(s => s.HR);
                        int teamBBs = group.Sum(s => s.BB);
                    }
                    <div class="team-total-item">
                        <span class="total-label">Runs</span>
                        <span class="total-value">@teamRuns</span>
                    </div>
                    <div class="team-total-item">
                        <span class="total-label">Hits</span>
                        <span class="total-value">@teamHits</span>
                    </div>
                    <div class="team-total-item">
                        <span class="total-label">HR</span>
                        <span class="total-value">@teamHRs</span>
                    </div>
                    <div class="team-total-item">
                        <span class="total-label">BB</span>
                        <span class="total-value">@teamBBs</span>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Season> seasons = new();
    private List<StatEntry> allStats = new();
    private string filterText = "";
    private bool isLoading = true;
    private bool showSkeleton = false;
    private bool showSeasonModal = false;

    private IEnumerable<IGrouping<int, StatEntry>> GroupedStats => 
        allStats.Where(s => string.IsNullOrEmpty(filterText) || 
                           (s.Player?.Name?.Contains(filterText, StringComparison.OrdinalIgnoreCase) ?? false))
                .GroupBy(s => s.GameId);

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            List<Season> allSeasons = await StatsService.GetSeasonsAsync();
            seasons = allSeasons.Where(s => s.IsActive).ToList();

            if (SharedState.SelectedSeasonId == 0 && seasons.Any())
            {
                SharedState.SelectedSeasonId = seasons.First().Id;
            }

            ProtectedBrowserStorageResult<int> seasonResult = await ProtectedSessionStore.GetAsync<int>("SelectedSeasonId");
            if (seasonResult.Success && seasons.Any(s => s.Id == seasonResult.Value))
            {
                SharedState.SelectedSeasonId = seasonResult.Value;
            }

            ProtectedBrowserStorageResult<string> filterResult = await ProtectedSessionStore.GetAsync<string>("GameFilterText");
            if (filterResult.Success && !string.IsNullOrEmpty(filterResult.Value))
            {
                filterText = filterResult.Value;
                SessionState.FilterText = filterText;
            }

            ProtectedBrowserStorageResult<Dictionary<int, GameUIState>> gameStatesResult = await ProtectedSessionStore.GetAsync<Dictionary<int, GameUIState>>("GameUIStates");
            if (gameStatesResult.Success && gameStatesResult.Value != null)
            {
                SessionState.GameUIStates = gameStatesResult.Value;
            }
        }
        catch (Exception)
        {
            // Silently fail, defaults are handled
        }

        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        isLoading = true;
        showSkeleton = false;

        // Start a timer task to show skeleton after 250ms
        _ = Task.Run(async () => {
            await Task.Delay(250);
            if (isLoading) 
            {
                showSkeleton = true;
                await InvokeAsync(StateHasChanged);
            }
        });

        try 
        {
            allStats = await StatsService.GetAllGameStatsAsync(SharedState.SelectedSeasonId);
            filterText = SessionState.FilterText;

            if (!SessionState.GameUIStates.Any(s => s.Value.IsExpanded) && allStats.Any())
            {
                int latestGameId = allStats.First().GameId;
                SessionState.GetState(latestGameId).IsExpanded = true;
            }
        }
        catch (Exception)   
        {
            allStats = new List<StatEntry>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            SharedState.SelectedSeasonId = id;
            await ProtectedSessionStore.SetAsync("SelectedSeasonId", id);
            await LoadData();
        }
    }

    private void ToggleSeasonModal() => showSeasonModal = !showSeasonModal;

    private async Task SelectMobileSeason(int id)
    {
        SharedState.SelectedSeasonId = id;
        await ProtectedSessionStore.SetAsync("SelectedSeasonId", id);
        showSeasonModal = false;
        await LoadData();
    }

    private async Task ClearFilter()
    {
        filterText = "";
        await UpdateFilterState();
    }

    private async Task UpdateFilterState()
    {
        SessionState.FilterText = filterText;
        await ProtectedSessionStore.SetAsync("GameFilterText", filterText);
    }

    private async Task ToggleGame(int gameId)
    {
        GameUIState state = SessionState.GetState(gameId);
        state.IsExpanded = !state.IsExpanded;
        await ProtectedSessionStore.SetAsync("GameUIStates", SessionState.GameUIStates);
    }

    private async Task ExpandAll()
    {
        foreach (IGrouping<int, StatEntry> group in GroupedStats)
        {
            SessionState.GetState(group.Key).IsExpanded = true;
        }
        await ProtectedSessionStore.SetAsync("GameUIStates", SessionState.GameUIStates);
    }

    private async Task CollapseAll()
    {
        foreach (GameUIState state in SessionState.GameUIStates.Values)
        {
            state.IsExpanded = false;
        }
        await ProtectedSessionStore.SetAsync("GameUIStates", SessionState.GameUIStates);
    }

    private async Task Sort(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);

        if (state.SortColumn == column)
        {
            state.IsAscending = !state.IsAscending;
        }
        else
        {
            state.SortColumn = column;
            state.IsAscending = false;
            // Default ascending for Player and BO
            if (column == "Player" || column == "BO") state.IsAscending = true;
        }
        
        await ProtectedSessionStore.SetAsync("GameUIStates", SessionState.GameUIStates);
        StateHasChanged();
    }

    private string GetSortIcon(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);
        if (state.SortColumn != column) return "";
        return state.IsAscending ? "▴" : "▾";
    }

    private IEnumerable<StatEntry> ApplyInnerSorting(GameUIState uiState, IEnumerable<StatEntry> stats)
    {
        return uiState.SortColumn switch
        {
            "Player" => uiState.IsAscending ? stats.OrderBy(s => s.BO) : stats.OrderByDescending(s => s.BO),
            "BO" => uiState.IsAscending ? stats.OrderBy(s => s.BO) : stats.OrderByDescending(s => s.BO),
            "PA" => uiState.IsAscending ? stats.OrderBy(s => s.PA) : stats.OrderByDescending(s => s.PA),
            "AB" => uiState.IsAscending ? stats.OrderBy(s => s.AB) : stats.OrderByDescending(s => s.AB),
            "R" => uiState.IsAscending ? stats.OrderBy(s => s.R) : stats.OrderByDescending(s => s.R),
            "H" => uiState.IsAscending ? stats.OrderBy(s => s.H) : stats.OrderByDescending(s => s.H),
            "2B" => uiState.IsAscending ? stats.OrderBy(s => s.H2B) : stats.OrderByDescending(s => s.H2B),
            "3B" => uiState.IsAscending ? stats.OrderBy(s => s.H3B) : stats.OrderByDescending(s => s.H3B),
            "4B" => uiState.IsAscending ? stats.OrderBy(s => s.H4B) : stats.OrderByDescending(s => s.H4B),
            "HR" => uiState.IsAscending ? stats.OrderBy(s => s.HR) : stats.OrderByDescending(s => s.HR),
            "RBI" => uiState.IsAscending ? stats.OrderBy(s => s.RBI) : stats.OrderByDescending(s => s.RBI),
            "BB" => uiState.IsAscending ? stats.OrderBy(s => s.BB) : stats.OrderByDescending(s => s.BB),
            "K" => uiState.IsAscending ? stats.OrderBy(s => s.K) : stats.OrderByDescending(s => s.K),
            "KF" => uiState.IsAscending ? stats.OrderBy(s => s.KF) : stats.OrderByDescending(s => s.KF),
            "SF" => uiState.IsAscending ? stats.OrderBy(s => s.SF) : stats.OrderByDescending(s => s.SF),
            "FC" => uiState.IsAscending ? stats.OrderBy(s => s.FC) : stats.OrderByDescending(s => s.FC),
            "GO" => uiState.IsAscending ? stats.OrderBy(s => s.GO) : stats.OrderByDescending(s => s.GO),
            "FO" => uiState.IsAscending ? stats.OrderBy(s => s.FO) : stats.OrderByDescending(s => s.FO),
            "AVG" => uiState.IsAscending ? stats.OrderBy(s => s.AB > 0 ? (double)s.H / s.AB : 0) : stats.OrderByDescending(s => s.AB > 0 ? (double)s.H / s.AB : 0),
            "OBP" => uiState.IsAscending 
                ? stats.OrderBy(s => (s.AB + s.BB + s.SF) > 0 ? (double)(s.H + s.BB) / (s.AB + s.BB + s.SF) : 0) 
                : stats.OrderByDescending(s => (s.AB + s.BB + s.SF) > 0 ? (double)(s.H + s.BB) / (s.AB + s.BB + s.SF) : 0),
            _ => stats.OrderBy(s => s.BO)
        };
    }
}

<style>
    .header-with-filter {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .filter-container {
        flex: 1;
        max-width: 400px;
    }

    .search-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .clear-button {
        position: absolute;
        right: 10px;
        background: #eee;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #666;
        font-size: 12px;
        transition: background 0.2s;
    }

    .clear-button:hover {
        background: #ddd;
        color: #333;
    }

    .game-summary-row td:nth-child(3) {
    }
</style>
