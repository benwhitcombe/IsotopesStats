@page "/gamestats"
@using IsotopesStats.Models
@using IsotopesStats.Services
@inject IStatsService StatsService
@inject SharedSessionState SharedState
@inject GameStatsState SessionState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Game Stats</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Game Stats</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <div class="desktop-only" style="display: flex; gap: 1rem; align-items: center;">
            <label style="margin:0; font-weight: bold;">Season:</label>
            <select class="form-control" style="width: auto;" value="@SharedState.SelectedSeasonId" @onchange="OnSeasonChange">
                @foreach (Season season in seasons)
                {
                    <option value="@season.Id">@season.Name</option>
                }
            </select>
        </div>
        <div class="mobile-only">
             <button class="view-btn" style="background: var(--isotopes-accent); color: white; border: none; padding: 0.5rem 1rem;" @onclick="ToggleSeasonModal"> 
                🗓️ @seasons.FirstOrDefault(s => s.Id == SharedState.SelectedSeasonId)?.Name
            </button>
        </div>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(SharedState.SelectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="stat-card" style="margin-bottom: 1.5rem;">
    <div class="filter-container" style="max-width: 100%;">
        <div class="search-container">
            <input type="text" class="form-control" @bind="filterText" @bind:event="oninput" @onkeyup="UpdateFilterState" placeholder="Search Opponent..." />
            @if (!string.IsNullOrEmpty(filterText))
            {
                <button class="clear-button" @onclick="ClearFilter">✕</button>
            }
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="game-cards-list">
        @for (int i = 0; i < 3; i++)
        {
            <div class="game-card" style="padding: 1rem;">
                <div class="spinner-border text-danger" role="status" style="margin: 2rem auto; display: block;"></div>
            </div>
        }
    </div>
}
else
{
    @if (!FilteredSummaries.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Games Found</h4>
            <p>Try a different search or season.</p>
        </div>
    }
    else
    {
        <div class="game-cards-list">
            @{ int index = 0; }
            @foreach (GameSummaryView summary in FilteredSummaries)
            {
                int gameId = summary.GameId;
                GameUIState uiState = SessionState.GetState(gameId);

                double teamAVG = summary.TeamAB > 0 ? (double)summary.TeamHits / summary.TeamAB : 0;
                double currentDelay = index * 0.1;
                index++;

                <div class="game-card view-fade-in" style="animation-delay: @(currentDelay)s">
                    <div class="game-card-header" @onclick="() => ToggleGame(summary)" style="padding: 1.25rem; cursor: pointer; display: block;">
                        <!-- Desktop Header (Side-by-Side) -->
                        <div class="desktop-only" style="display: flex; justify-content: space-between; align-items: center;">
                            <div class="game-info-main" style="flex: 1; display: flex; flex-direction: column; gap: 0.5rem;">
                                <div class="game-row-1" style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div class="game-number-badge" style="margin: 0; white-space: nowrap;">GAME #@summary.GameNumber</div>
                                    <div class="opponent-name" style="font-size: 1.1rem; font-weight: bold; color: var(--isotopes-dark);">@(summary.IsHome ? "vs" : "@") @summary.OpponentName</div>
                                </div>
                                <div class="game-row-2" style="display: flex; align-items: center; gap: 1rem; color: #666; font-size: 0.85rem;">
                                    <div class="game-date">📅 @summary.Date.ToString("MMM dd, yyyy @ h:mm tt")</div>
                                    <div class="diamond-name">📍 @summary.Diamond</div>
                                </div>
                            </div>
                            <div class="game-score-summary" style="display: flex; align-items: center; gap: 1rem; margin-left: 1rem;">
                                <div style="display: flex; gap: 0.75rem;">
                                    <div class="score-item" style="text-align: center; min-width: 45px;">
                                        <span class="score-value" style="display: block; font-size: 1.5rem; font-weight: 900; color: var(--isotopes-red);">@summary.TeamRuns</span>
                                        <span class="score-label" style="display: block; font-size: 0.7rem; text-transform: uppercase; color: #999; font-weight: bold;">Runs</span>
                                    </div>
                                    <div class="score-item" style="text-align: center; min-width: 45px;">
                                        <span class="score-value" style="display: block; font-size: 1.5rem; font-weight: 900; color: var(--isotopes-red);">@summary.TeamHits</span>
                                        <span class="score-label" style="display: block; font-size: 0.7rem; text-transform: uppercase; color: #999; font-weight: bold;">Hits</span>
                                    </div>
                                </div>
                                <div class="expand-icon" style="color: #ccc; font-size: 0.8rem;">@(uiState.IsExpanded ? "▲" : "▼")</div>
                            </div>
                        </div>

                        <!-- Mobile Header (Stacked) -->
                        <div class="mobile-only" style="width: 100%;">
                            <div class="game-row-1" style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; width: 100%;">
                                <div class="game-number-badge" style="margin: 0; white-space: nowrap; font-size: 0.75rem; padding: 0.2rem 0.5rem;">#@summary.GameNumber</div>
                                <div class="opponent-name" style="font-size: 1.1rem; font-weight: bold; color: var(--isotopes-dark); flex: 1;">vs @summary.OpponentName</div>
                                <div class="expand-icon" style="color: #ccc; font-size: 0.7rem; width: 20px; text-align: center;">@(uiState.IsExpanded ? "▲" : "▼")</div>
                            </div>
                            <div class="game-row-2" style="display: flex; justify-content: space-between; align-items: center; width: 100%; flex-wrap: wrap; gap: 0.5rem;">
                                <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; color: #666; font-size: 0.8rem; align-items: center;">
                                    <div class="game-date">📅 @summary.Date.ToString("MMM dd @ h:mm tt")</div>
                                    <div class="diamond-name">📍 @summary.Diamond</div>
                                </div>
                                <div class="game-score-summary" style="display: flex; gap: 0.75rem; margin-left: auto;">
                                    <div class="score-item" style="text-align: center; min-width: 45px;">
                                        <span class="score-value" style="display: block; font-size: 1.5rem; font-weight: 900; color: var(--isotopes-red); line-height: 1;">@summary.TeamRuns</span>
                                        <span class="score-label" style="display: block; font-size: 0.7rem; text-transform: uppercase; color: #999; font-weight: bold;">Runs</span>
                                    </div>
                                    <div class="score-item" style="text-align: center; min-width: 45px;">
                                        <span class="score-value" style="display: block; font-size: 1.5rem; font-weight: 900; color: var(--isotopes-red); line-height: 1;">@summary.TeamHits</span>
                                        <span class="score-label" style="display: block; font-size: 0.7rem; text-transform: uppercase; color: #999; font-weight: bold;">Hits</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (uiState.IsExpanded)
                    {
                        if (!expandedStats.ContainsKey(gameId) || expandedStats[gameId] == null)
                        {
                            <div class="game-card-detail expanded view-fade-in" style="padding: 2rem; text-align: center;">
                                <div class="spinner-border text-danger" role="status"></div>
                            </div>
                        }
                        else
                        {
                            IEnumerable<GameStatsExtendedView> sortedStats = ApplyInnerSorting(uiState, expandedStats[gameId]);

                            <div class="game-card-detail expanded view-fade-in" style="padding: 0; border-top: 1px solid #eee; background: white;">
                                <div class="box-score-table-wrapper" style="padding: 0; width: 100%; overflow-x: auto;">
                                    <table class="box-score-table table-sm" style="margin-bottom: 0; border: none; border-radius: 0 !important; width: 100%;">
                                    <thead>
                                        <tr>
                                            <th @onclick='() => Sort(gameId, "BO")' class="sortable-header @(uiState.SortColumn == "BO" ? "active-sort-header" : "")" style="width: 30px;">BO<span class="sort-icon">@(GetSortIcon(gameId, "BO"))</span></th>
                                            <th @onclick='() => Sort(gameId, "Player")' class="sortable-header sticky-col @(uiState.SortColumn == "Player" ? "active-sort-header" : "")">Player<span class="sort-icon">@(GetSortIcon(gameId, "Player"))</span></th>
                                            <th @onclick='() => Sort(gameId, "PA")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "PA" ? "active-sort-header" : "")">PA<span class="sort-icon">@(GetSortIcon(gameId, "PA"))</span></th>
                                            <th @onclick='() => Sort(gameId, "AB")' class="sortable-header narrow-col @(uiState.SortColumn == "AB" ? "active-sort-header" : "")">AB<span class="sort-icon">@(GetSortIcon(gameId, "AB"))</span></th>
                                            <th @onclick='() => Sort(gameId, "R")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "R" ? "active-sort-header" : "")">R<span class="sort-icon">@(GetSortIcon(gameId, "R"))</span></th>
                                            <th @onclick='() => Sort(gameId, "H")' class="sortable-header narrow-col @(uiState.SortColumn == "H" ? "active-sort-header" : "")">H<span class="sort-icon">@(GetSortIcon(gameId, "H"))</span></th>
                                            <th @onclick='() => Sort(gameId, "2B")' class="sortable-header narrow-col @(uiState.SortColumn == "2B" ? "active-sort-header" : "")">2B<span class="sort-icon">@(GetSortIcon(gameId, "2B"))</span></th>
                                            <th @onclick='() => Sort(gameId, "3B")' class="sortable-header narrow-col @(uiState.SortColumn == "3B" ? "active-sort-header" : "")">3B<span class="sort-icon">@(GetSortIcon(gameId, "3B"))</span></th>
                                            <th @onclick='() => Sort(gameId, "4B")' class="sortable-header narrow-col @(uiState.SortColumn == "4B" ? "active-sort-header" : "")">4B<span class="sort-icon">@(GetSortIcon(gameId, "4B"))</span></th>
                                            <th @onclick='() => Sort(gameId, "HR")' class="sortable-header narrow-col @(uiState.SortColumn == "HR" ? "active-sort-header" : "")">HR<span class="sort-icon">@(GetSortIcon(gameId, "HR"))</span></th>
                                            <th @onclick='() => Sort(gameId, "RBI")' class="sortable-header narrow-col @(uiState.SortColumn == "RBI" ? "active-sort-header" : "")">RBI<span class="sort-icon">@(GetSortIcon(gameId, "RBI"))</span></th>
                                            <th @onclick='() => Sort(gameId, "BB")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "BB" ? "active-sort-header" : "")">BB<span class="sort-icon">@(GetSortIcon(gameId, "BB"))</span></th>
                                            <th @onclick='() => Sort(gameId, "K")' class="sortable-header narrow-col @(uiState.SortColumn == "K" ? "active-sort-header" : "")">K<span class="sort-icon">@(GetSortIcon(gameId, "K"))</span></th>
                                            <th @onclick='() => Sort(gameId, "KF")' class="sortable-header narrow-col @(uiState.SortColumn == "KF" ? "active-sort-header" : "")">KF<span class="sort-icon">@(GetSortIcon(gameId, "KF"))</span></th>
                                            <th @onclick='() => Sort(gameId, "SF")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "SF" ? "active-sort-header" : "")">SF<span class="sort-icon">@(GetSortIcon(gameId, "SF"))</span></th>
                                            <th @onclick='() => Sort(gameId, "FC")' class="sortable-header narrow-col @(uiState.SortColumn == "FC" ? "active-sort-header" : "")">FC<span class="sort-icon">@(GetSortIcon(gameId, "FC"))</span></th>
                                            <th @onclick='() => Sort(gameId, "GO")' class="sortable-header narrow-col @(uiState.SortColumn == "GO" ? "active-sort-header" : "")">GO<span class="sort-icon">@(GetSortIcon(gameId, "GO"))</span></th>
                                            <th @onclick='() => Sort(gameId, "FO")' class="sortable-header narrow-col @(uiState.SortColumn == "FO" ? "active-sort-header" : "")">FO<span class="sort-icon">@(GetSortIcon(gameId, "FO"))</span></th>
                                            <th @onclick='() => Sort(gameId, "AVG")' class="sortable-header group-divider @(uiState.SortColumn == "AVG" ? "active-sort-header" : "")">AVG<span class="sort-icon">@(GetSortIcon(gameId, "AVG"))</span></th>
                                            <th @onclick='() => Sort(gameId, "OBP")' class="sortable-header @(uiState.SortColumn == "OBP" ? "active-sort-header" : "")">OBP<span class="sort-icon">@(GetSortIcon(gameId, "OBP"))</span></th>
                                            <th @onclick='() => Sort(gameId, "SLG")' class="sortable-header @(uiState.SortColumn == "SLG" ? "active-sort-header" : "")">SLG<span class="sort-icon">@(GetSortIcon(gameId, "SLG"))</span></th>
                                            <th @onclick='() => Sort(gameId, "OPS")' class="sortable-header @(uiState.SortColumn == "OPS" ? "active-sort-header" : "")">OPS<span class="sort-icon">@(GetSortIcon(gameId, "OPS"))</span></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (GameStatsExtendedView stat in sortedStats)
                                        {
                                            <tr>
                                                <td class="@(uiState.SortColumn == "BO" ? "active-sort-col" : "")">@stat.BO</td>
                                                <td class="player-name sticky-col @(uiState.SortColumn == "Player" ? "active-sort-col" : "")">
                                                    <a href="/playerlogs/@Uri.EscapeDataString(stat.PlayerName)" style="text-decoration: none; color: inherit;">
                                                        @stat.PlayerName
                                                    </a>
                                                </td>
                                                <td class="group-divider narrow-col @(uiState.SortColumn == "PA" ? "active-sort-col" : "")">@stat.PA</td>
                                                <td class="narrow-col @(uiState.SortColumn == "AB" ? "active-sort-col" : "")">@stat.AB</td>
                                                <td class="group-divider narrow-col @(uiState.SortColumn == "R" ? "active-sort-col" : "")">@stat.R</td>
                                                <td class="narrow-col @(uiState.SortColumn == "H" ? "active-sort-col" : "")">@stat.H</td>
                                                <td class="narrow-col @(uiState.SortColumn == "2B" ? "active-sort-col" : "")">@stat.H2B</td>
                                                <td class="narrow-col @(uiState.SortColumn == "3B" ? "active-sort-col" : "")">@stat.H3B</td>
                                                <td class="narrow-col @(uiState.SortColumn == "4B" ? "active-sort-col" : "")">@stat.H4B</td>
                                                <td class="narrow-col @(uiState.SortColumn == "HR" ? "active-sort-col" : "")">@stat.HR</td>
                                                <td class="narrow-col @(uiState.SortColumn == "RBI" ? "active-sort-col" : "")">@stat.RBI</td>
                                                <td class="group-divider narrow-col @(uiState.SortColumn == "BB" ? "active-sort-col" : "")">@stat.BB</td>
                                                <td class="narrow-col @(uiState.SortColumn == "K" ? "active-sort-col" : "")">@stat.K</td>
                                                <td class="narrow-col @(uiState.SortColumn == "KF" ? "active-sort-col" : "")">@stat.KF</td>
                                                <td class="group-divider narrow-col @(uiState.SortColumn == "SF" ? "active-sort-col" : "")">@stat.SF</td>
                                                <td class="narrow-col @(uiState.SortColumn == "FC" ? "active-sort-col" : "")">@stat.FC</td>
                                                <td class="narrow-col @(uiState.SortColumn == "GO" ? "active-sort-col" : "")">@stat.GO</td>
                                                <td class="narrow-col @(uiState.SortColumn == "FO" ? "active-sort-col" : "")">@stat.FO</td>
                                                <td class="group-divider @(uiState.SortColumn == "AVG" ? "active-sort-col" : "")">@stat.AVG.ToString(".000")</td>
                                                <td class="@(uiState.SortColumn == "OBP" ? "active-sort-col" : "")">@stat.OBP.ToString(".000")</td>
                                                <td class="@(uiState.SortColumn == "SLG" ? "active-sort-col" : "")">@stat.SLG.ToString(".000")</td>
                                                <td class="@(uiState.SortColumn == "OPS" ? "active-sort-col" : "")">@stat.OPS.ToString(".000")</td>
                                            </tr>
                                        }
                                        <tr class="game-summary-row">
                                            <td colspan="2" class="sticky-col">TOTALS</td>
                                            <td class="group-divider narrow-col">@summary.TeamPA</td>
                                            <td class="narrow-col">@summary.TeamAB</td>
                                            <td class="group-divider narrow-col">@summary.TeamRuns</td>
                                            <td class="narrow-col">@summary.TeamHits</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.H2B)</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.H3B)</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.H4B)</td>
                                            <td class="narrow-col">@summary.TeamHRs</td>
                                            <td class="narrow-col">@summary.TeamRBI</td>
                                            <td class="group-divider narrow-col">@summary.TeamBBs</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.K)</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.KF)</td>
                                            <td class="group-divider narrow-col">@expandedStats[gameId].Sum(s => s.SF)</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.FC)</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.GO)</td>
                                            <td class="narrow-col">@expandedStats[gameId].Sum(s => s.FO)</td>
                                            <td class="group-divider">@teamAVG.ToString(".000")</td>
                                            @{
                                                int teamSF = expandedStats[gameId].Sum(s => s.SF);
                                                int team1B = expandedStats[gameId].Sum(s => s.H1B);
                                                int team2B = expandedStats[gameId].Sum(s => s.H2B);
                                                int team3B = expandedStats[gameId].Sum(s => s.H3B);
                                                int team4B = expandedStats[gameId].Sum(s => s.H4B);
                                                int teamHR = expandedStats[gameId].Sum(s => s.HR);
                                                int teamTB = team1B + (2 * team2B) + (3 * team3B) + (4 * (team4B + teamHR));

                                                double teamOBP = (summary.TeamAB + summary.TeamBBs + teamSF) > 0
                                                    ? (double)(summary.TeamHits + summary.TeamBBs) / (summary.TeamAB + summary.TeamBBs + teamSF)
                                                    : 0;
                                                
                                                double teamSLG = summary.TeamAB > 0 ? (double)teamTB / summary.TeamAB : 0;
                                                double teamOPS = teamOBP + teamSLG;
                                            }
                                            <td>@teamOBP.ToString(".000")</td>
                                            <td>@teamSLG.ToString(".000")</td>
                                            <td>@teamOPS.ToString(".000")</td>
                                        </tr>
                                    </tbody>
                                </table>
                                </div>
                            </div>

                            <div class="mobile-player-grid">
                                @foreach (GameStatsExtendedView stat in sortedStats)
                                {
                                    <div class="mobile-player-card">
                                        <div class="mobile-card-header">
                                            <span class="mobile-card-name" @onclick='() => Navigation.NavigateTo($"/playerlogs/{Uri.EscapeDataString(stat.PlayerName)}")' style="cursor: pointer;">@stat.BO. @stat.PlayerName</span>
                                            <div style="display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end;">
                                                <span class="badge bg-light text-dark">AVG: @stat.AVG.ToString(".000")</span>
                                                <span class="badge bg-light text-dark">OBP: @stat.OBP.ToString(".000")</span>
                                                <span class="badge bg-light text-dark">SLG: @stat.SLG.ToString(".000")</span>
                                                <span class="badge bg-light text-dark">OPS: @stat.OPS.ToString(".000")</span>
                                            </div>
                                        </div>
                                        <div class="mobile-card-stats">
                                            <div class="m-stat @(uiState.SortColumn == "PA" ? "active" : "")"><span class="m-stat-val">@stat.PA</span><span class="m-stat-label">PA</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "AB" ? "active" : "")"><span class="m-stat-val">@stat.AB</span><span class="m-stat-label">AB</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "R" ? "active" : "")"><span class="m-stat-val">@stat.R</span><span class="m-stat-label">R</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "H" ? "active" : "")"><span class="m-stat-val">@stat.H</span><span class="m-stat-label">H</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "2B" ? "active" : "")"><span class="m-stat-val">@stat.H2B</span><span class="m-stat-label">2B</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "3B" ? "active" : "")"><span class="m-stat-val">@stat.H3B</span><span class="m-stat-label">3B</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "4B" ? "active" : "")"><span class="m-stat-val">@stat.H4B</span><span class="m-stat-label">4B</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "HR" ? "active" : "")"><span class="m-stat-val">@stat.HR</span><span class="m-stat-label">HR</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "RBI" ? "active" : "")"><span class="m-stat-val">@stat.RBI</span><span class="m-stat-label">RBI</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "BB" ? "active" : "")"><span class="m-stat-val">@stat.BB</span><span class="m-stat-label">BB</span></div>
                                            <div class="m-stat @(uiState.SortColumn == "SF" ? "active" : "")"><span class="m-stat-val">@stat.SF</span><span class="m-stat-label">SF</span></div>
                                        </div>
                                    </div>
                                }
                                <div class="mobile-player-card" style="border: 2px solid var(--isotopes-accent); background: #f0f7ff; margin-top: 1rem;">
                                    <div class="mobile-card-header">
                                        <span class="mobile-card-name">TEAM TOTALS</span>
                                        <div style="display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end;">
                                            <span class="badge bg-light text-dark">AVG: @teamAVG.ToString(".000")</span>
                                            <span class="badge bg-light text-dark">OBP: @teamOBP.ToString(".000")</span>
                                            <span class="badge bg-light text-dark">SLG: @teamSLG.ToString(".000")</span>
                                            <span class="badge bg-light text-dark">OPS: @teamOPS.ToString(".000")</span>
                                        </div>
                                    </div>
                                    <div class="mobile-card-stats">
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamPA</span><span class="m-stat-label">PA</span></div>
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamAB</span><span class="m-stat-label">AB</span></div>
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamRuns</span><span class="m-stat-label">R</span></div>
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamHits</span><span class="m-stat-label">H</span></div>
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamHRs</span><span class="m-stat-label">HR</span></div>
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamRBI</span><span class="m-stat-label">RBI</span></div>
                                        <div class="m-stat"><span class="m-stat-val">@summary.TeamBBs</span><span class="m-stat-label">BB</span></div>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    @if (!uiState.IsExpanded)
                    {
                        <div class="game-card-footer">
                            <div class="footer-stat">
                                <span class="footer-stat-label">Players:</span> @summary.PlayerCount
                            </div>
                            <div class="footer-stat">
                                <span class="footer-stat-label">HR:</span> @summary.TeamHRs
                            </div>
                            <div class="footer-stat">
                                <span class="footer-stat-label">AVG:</span> @teamAVG.ToString(".000")
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<GameSummaryView>? summaries;
    private Dictionary<int, List<GameStatsExtendedView>> expandedStats = new();
    private List<Season> seasons = new();
    private string filterText = "";
    private bool showSeasonModal = false;
    private bool isLoading = true;

    private IEnumerable<GameSummaryView> FilteredSummaries =>
        (summaries ?? new List<GameSummaryView>())
        .Where(s =>
            string.IsNullOrEmpty(filterText) ||
            s.OpponentName.Contains(filterText, StringComparison.OrdinalIgnoreCase)
        )
        .OrderByDescending(s => s.Date);

    protected override async Task OnInitializedAsync()
    {
        SharedState.ReturnUrl = "gamestats";
        seasons = await StatsService.GetSeasonsAsync();

        if (SharedState.SelectedSeasonId == 0 && seasons.Any())
        {
            SharedState.SelectedSeasonId = seasons.First().Id;
        }

        filterText = SessionState.FilterText;
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            summaries = await StatsService.GetGameSummariesAsync(SharedState.SelectedSeasonId);
            
            // Re-fetch expanded games if needed
            foreach (KeyValuePair<int, GameUIState> state in SessionState.GameUIStates.Where(s => s.Value.IsExpanded))
            {
                if (summaries.Any(s => s.GameId == state.Key))
                {
                    expandedStats[state.Key] = await StatsService.GetExtendedGameStatsAsync(state.Key);
                }
            }
        }
        catch (Exception)
        {
            summaries = new List<GameSummaryView>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            SharedState.SelectedSeasonId = id;
            await LoadData();
        }
    }

    private void ToggleSeasonModal() => showSeasonModal = !showSeasonModal;

    private async Task SelectMobileSeason(int id)
    {
        SharedState.SelectedSeasonId = id;
        showSeasonModal = false;
        await LoadData();
    }

    private void ClearFilter()
    {
        filterText = "";
        UpdateFilterState();
    }

    private void UpdateFilterState()
    {
        SessionState.FilterText = filterText;
    }

    private async Task ToggleGame(GameSummaryView summary)
    {
        int gameId = summary.GameId;
        GameUIState state = SessionState.GetState(gameId);
        state.IsExpanded = !state.IsExpanded;
        SessionState.TriggerChange();

        if (state.IsExpanded && (!expandedStats.ContainsKey(gameId) || expandedStats[gameId] == null))
        {
            StateHasChanged();
            expandedStats[gameId] = await StatsService.GetExtendedGameStatsAsync(gameId);
        }

        StateHasChanged();
    }

    private void Sort(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);

        if (state.SortColumn == column)
        {
            state.IsAscending = !state.IsAscending;
        }
        else
        {
            state.SortColumn = column;
            state.IsAscending = false;
            if (column == "Player" || column == "BO") state.IsAscending = true;
        }
        SessionState.TriggerChange();
        StateHasChanged();
    }

    private string GetSortIcon(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);
        if (state.SortColumn != column) return "";
        return state.IsAscending ? "▴" : "▾";
    }

    private IEnumerable<GameStatsExtendedView> ApplyInnerSorting(GameUIState uiState, IEnumerable<GameStatsExtendedView> stats)
    {
        return uiState.SortColumn switch
        {
            "Player" => uiState.IsAscending ? stats.OrderBy(s => s.PlayerName) : stats.OrderByDescending(s => s.PlayerName),
            "BO" => uiState.IsAscending ? stats.OrderBy(s => s.BO) : stats.OrderByDescending(s => s.BO),
            "PA" => uiState.IsAscending ? stats.OrderBy(s => s.PA) : stats.OrderByDescending(s => s.PA),
            "AB" => uiState.IsAscending ? stats.OrderBy(s => s.AB) : stats.OrderByDescending(s => s.AB),
            "R" => uiState.IsAscending ? stats.OrderBy(s => s.R) : stats.OrderByDescending(s => s.R),
            "H" => uiState.IsAscending ? stats.OrderBy(s => s.H) : stats.OrderByDescending(s => s.H),
            "2B" => uiState.IsAscending ? stats.OrderBy(s => s.H2B) : stats.OrderByDescending(s => s.H2B),
            "3B" => uiState.IsAscending ? stats.OrderBy(s => s.H3B) : stats.OrderByDescending(s => s.H3B),
            "4B" => uiState.IsAscending ? stats.OrderBy(s => s.H4B) : stats.OrderByDescending(s => s.H4B),
            "HR" => uiState.IsAscending ? stats.OrderBy(s => s.HR) : stats.OrderByDescending(s => s.HR),
            "RBI" => uiState.IsAscending ? stats.OrderBy(s => s.RBI) : stats.OrderByDescending(s => s.RBI),
            "BB" => uiState.IsAscending ? stats.OrderBy(s => s.BB) : stats.OrderByDescending(s => s.BB),
            "K" => uiState.IsAscending ? stats.OrderBy(s => s.K) : stats.OrderByDescending(s => s.K),
            "KF" => uiState.IsAscending ? stats.OrderBy(s => s.KF) : stats.OrderByDescending(s => s.KF),
            "SF" => uiState.IsAscending ? stats.OrderBy(s => s.SF) : stats.OrderByDescending(s => s.SF),
            "FC" => uiState.IsAscending ? stats.OrderBy(s => s.FC) : stats.OrderByDescending(s => s.FC),
            "GO" => uiState.IsAscending ? stats.OrderBy(s => s.GO) : stats.OrderByDescending(s => s.GO),
            "FO" => uiState.IsAscending ? stats.OrderBy(s => s.FO) : stats.OrderByDescending(s => s.FO),
            "AVG" => uiState.IsAscending ? stats.OrderBy(s => s.AVG) : stats.OrderByDescending(s => s.AVG),
            "OBP" => uiState.IsAscending ? stats.OrderBy(s => s.OBP) : stats.OrderByDescending(s => s.OBP),
            "SLG" => uiState.IsAscending ? stats.OrderBy(s => s.SLG) : stats.OrderByDescending(s => s.SLG),
            "OPS" => uiState.IsAscending ? stats.OrderBy(s => s.OPS) : stats.OrderByDescending(s => s.OPS),
            _ => stats.OrderBy(s => s.BO)
        };
    }
}

