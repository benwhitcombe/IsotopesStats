@page "/player/{PlayerName}/{SeasonId:int}"
@page "/playerlogs/{PlayerName}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject StatsService StatsService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject SharedSessionState SharedState

<PageTitle>Isotopes - @PlayerName Game Log</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h3 style="margin:0">@PlayerName - Game Log</h3>
    <button class="view-btn" @onclick="GoBack">Back to Stats</button>
</div>

@if (isLoading)
{
    <div style="text-align: center; padding: 5rem;">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (logs == null || !logs.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Games Found</h4>
            <p>This player doesn't have any stats for the selected season.</p>
        </div>
    }
    else
    {
        <div class="stat-card view-fade-in" style="margin-bottom: 1.5rem;">
            <div class="stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 1rem;">
                <div class="stat-item" style="text-align: center; padding: 1rem; background: #f8f9fa; border-radius: 12px;">
                    <div style="font-size: 0.75rem; text-transform: uppercase; color: #999; font-weight: 800; margin-bottom: 0.25rem;">Games</div>
                    <div style="font-size: 1.5rem; font-weight: 900; color: var(--isotopes-accent);">@logs.Count</div>
                </div>
                <div class="stat-item" style="text-align: center; padding: 1rem; background: #f8f9fa; border-radius: 12px;">
                    <div style="font-size: 0.75rem; text-transform: uppercase; color: #999; font-weight: 800; margin-bottom: 0.25rem;">Hits</div>
                    <div style="font-size: 1.5rem; font-weight: 900; color: var(--isotopes-accent);">@logs.Sum(l => l.H)</div>
                </div>
                <div class="stat-item" style="text-align: center; padding: 1rem; background: #f8f9fa; border-radius: 12px;">
                    <div style="font-size: 0.75rem; text-transform: uppercase; color: #999; font-weight: 800; margin-bottom: 0.25rem;">HR</div>
                    <div style="font-size: 1.5rem; font-weight: 900; color: var(--isotopes-red);">@logs.Sum(l => l.HR)</div>
                </div>
                <div class="stat-item" style="text-align: center; padding: 1rem; background: #f8f9fa; border-radius: 12px;">
                    <div style="font-size: 0.75rem; text-transform: uppercase; color: #999; font-weight: 800; margin-bottom: 0.25rem;">RBI</div>
                    <div style="font-size: 1.5rem; font-weight: 900; color: var(--isotopes-accent);">@logs.Sum(l => l.RBI)</div>
                </div>
            </div>
        </div>

        <div class="table-container view-fade-in" style="animation-delay: 0.2s;">
            <div class="box-score-table-wrapper">
                <table class="box-score-table table-sm">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Opponent</th>
                            <th>PA</th>
                            <th>AB</th>
                            <th>H</th>
                            <th>2B</th>
                            <th>3B</th>
                            <th>4B</th>
                            <th>HR</th>
                            <th>RBI</th>
                            <th>BB</th>
                            <th>K</th>
                            <th>KF</th>
                            <th>R</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (GameStatsExtendedView log in logs)
                        {
                            <tr>
                                <td style="color: #666;">@log.Date.ToString("MMM dd")</td>
                                <td style="font-weight: bold; text-align: left;">@log.OpponentName</td>
                                <td>@log.PA</td>
                                <td>@log.AB</td>
                                <td style="font-weight: bold; color: var(--isotopes-accent);">@log.H</td>
                                <td>@log.H2B</td>
                                <td>@log.H3B</td>
                                <td>@log.H4B</td>
                                <td style="color: var(--isotopes-red); font-weight: bold;">@log.HR</td>
                                <td>@log.RBI</td>
                                <td>@log.BB</td>
                                <td>@log.K</td>
                                <td>@log.KF</td>
                                <td>@log.R</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string PlayerName { get; set; } = string.Empty;
    [Parameter] public int? SeasonId { get; set; }

    private List<GameStatsExtendedView>? logs;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        int targetSeasonId = SeasonId ?? SharedState.SelectedSeasonId;
        if (targetSeasonId == 0)
        {
            List<Season> seasons = await StatsService.GetSeasonsAsync();
            if (seasons.Any()) targetSeasonId = seasons.First().Id;
        }

        if (targetSeasonId != 0)
        {
            logs = await StatsService.GetPlayerGameLogAsync(PlayerName, targetSeasonId);
        }
        else
        {
            logs = new List<GameStatsExtendedView>();
        }
        
        isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/" + SharedState.ReturnUrl);
    }
}
