@page "/account/login"
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject SharedSessionState SharedState

<PageTitle>Isotopes - Login</PageTitle>

<div style="max-width: 450px; margin: 4rem auto; padding: 0 1rem;">
    <div class="stat-card view-fade-in" style="padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🔐</div>
            <h3 style="margin:0; color: var(--isotopes-dark); font-weight: 800; letter-spacing: 1px;">MANAGEMENT LOGIN</h3>
            <p style="color: #666; font-size: 0.9rem; margin-top: 0.5rem;">Enter your credentials to access the dashboard</p>
        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                @errorMessage
            </div>
        }

        <div class="form-group">
            <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">Email Address</label>
            <input type="email" class="form-control" @bind="email" placeholder="email@isotopes.com" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; transition: border-color 0.3s;" />
        </div>

        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">Password</label>
            <input type="password" class="form-control" @bind="password" placeholder="••••••••" @onkeyup="HandleKeyUp" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; transition: border-color 0.3s;" />
        </div>

        <button class="view-btn active" @onclick="HandleLogin" style="margin-top: 2rem; width: 100%; padding: 1rem; font-size: 1.1rem; background-color: var(--isotopes-accent); border-color: var(--isotopes-accent);">Login to Management</button>
        
        <div style="text-align: center; margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1.5rem;">
            <a href="/account/forgot-password" style="font-size: 0.9rem; color: #888; text-decoration: none; font-weight: 600;">Forgot your password?</a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        errorMessage = "";
        User? user = await AuthService.LoginAsync(email, password);
        
        if (user != null)
        {
            await ((CustomAuthenticationStateProvider)AuthStateProvider).UpdateAuthenticationState(user);
            
            SharedState.OpenMenuOnLoad = true;

            if (!string.IsNullOrEmpty(ReturnUrl))
            {
                Navigation.NavigateTo(ReturnUrl);
            }
            else
            {
                Navigation.NavigateTo("/");
            }
        }
        else
        {
            errorMessage = "Invalid email or password.";
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLogin();
        }
    }
}
