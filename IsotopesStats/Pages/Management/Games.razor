@page "/management/games"
@using IsotopesStats.Services
@using IsotopesStats.Models
@attribute [Authorize(Roles = "Administrator,TeamRep,Scorekeeper")]
@inject StatsService StatsService
@inject NavigationManager Navigation

<PageTitle>Isotopes - Manage Games</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Games</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick="StartNewGame">Add New Game</button>
    }
</div>

@if (isEditing)
{
    <div class="stat-card view-fade-in" style="margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h4 style="margin:0">@(editingGame.Id == 0 ? "Add New" : "Edit") Game</h4>
            <button class="view-btn" @onclick="CancelEdit">Cancel</button>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div class="form-group">
                <label>Season</label>
                <select class="form-control" @bind="editingGame.SeasonId">
                    @foreach (Season season in seasons)
                    {
                        <option value="@season.Id">@season.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Date & Time</label>
                <input type="datetime-local" class="form-control" @bind="editingGame.Date" />
            </div>
            <div class="form-group">
                <label>Opponent</label>
                <input type="text" class="form-control" placeholder="Opponent Name" @bind="editingGame.Opponent" />
            </div>
            <div class="form-group">
                <label>Game Type</label>
                <select class="form-control" @bind="editingGame.Type">
                    @foreach (GameType type in Enum.GetValues<GameType>())
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
        </div>

        <h5 style="margin-bottom: 1rem; color: var(--isotopes-accent);">Player Stats</h5>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
            @foreach (StatEntry stat in playerStats)
            {
                <div class="stat-card" style="margin-bottom: 0; padding: 1rem; border: 1px solid #eee;">
                    <div class="admin-player-name" style="color: var(--isotopes-accent); border-bottom: 2px solid #f0f0f0; margin-bottom: 0.5rem; padding-bottom: 0.3rem; font-weight: bold;">@stat.Player?.Name</div>
                    <div class="admin-stats-grid">
                        <div class="admin-stat-input"><label>1B</label><input type="number" @bind="stat.H1B" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>2B</label><input type="number" @bind="stat.H2B" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>3B</label><input type="number" @bind="stat.H3B" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>4B</label><input type="number" @bind="stat.H4B" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>HR</label><input type="number" @bind="stat.HR" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>BB</label><input type="number" @bind="stat.BB" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>SF</label><input type="number" @bind="stat.SF" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>FC</label><input type="number" @bind="stat.FC" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>K</label><input type="number" @bind="stat.K" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>KF</label><input type="number" @bind="stat.KF" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>GO</label><input type="number" @bind="stat.GO" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>FO</label><input type="number" @bind="stat.FO" class="form-control" style="padding: 0.3rem; text-align: center;" /></div>
                        <div class="admin-stat-input"><label>R</label><input type="number" @bind="stat.R" class="form-control" style="padding: 0.3rem; text-align: center; font-weight: bold; color: var(--isotopes-red);" /></div>
                        <div class="admin-stat-input"><label>RBI</label><input type="number" @bind="stat.RBI" class="form-control" style="padding: 0.3rem; text-align: center; font-weight: bold; color: var(--isotopes-red);" /></div>
                    </div>
                </div>
            }
        </div>

        <div style="margin-top: 2rem; text-align: center;">
            <button class="view-btn active" style="padding: 1rem 3rem; font-size: 1.2rem; background-color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="SaveGame">Save Game & Stats</button>
        </div>
    </div>
}

<div class="stat-card view-fade-in">
    <div class="desktop-only">
        <div class="form-group" style="max-width: 300px; margin-bottom: 0;">
            <label>Season</label>
            <select class="form-control" @onchange="OnSeasonChange">
                @foreach (Season season in seasons)
                {
                    <option value="@season.Id" selected="@(selectedSeasonId == season.Id)">@season.Name</option>
                }
            </select>
        </div>
    </div>
    <div class="mobile-only">
        <button class="view-btn" style="width: 100%; background: var(--isotopes-accent); color: white; border: none; padding: 0.75rem;" @onclick="ToggleSeasonModal">
            📅 Season: @(seasons.FirstOrDefault(s => s.Id == selectedSeasonId)?.Name ?? "Select Season")
        </button>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(selectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="desktop-only" style="margin-top: 1rem;">
    <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th style="text-align: left;">#</th>
                        <th style="text-align: left;">Date</th>
                        <th style="text-align: left;">Opponent</th>
                        <th style="text-align: left;">Diamond</th>
                        <th>Type</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Game game in games)
                    {
                        <tr>
                            <td style="text-align: left;">@game.GameNumber</td>
                            <td style="text-align: left;">@game.Date.ToString("MMM dd, yyyy")</td>
                            <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@game.Opponent</td>
                            <td style="text-align: left;">@game.Diamond</td>
                            <td>
                                <span class="badge @(game.Type == GameType.RegularSeason ? "bg-primary" : "bg-warning")" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                    @game.Type
                                </span>
                            </td>
                            <td style="text-align: right;">
                                <button class="view-btn" @onclick="() => StartEdit(game)">Edit</button>
                                <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => DeleteGame(game.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mobile-only" style="margin-top: 1rem;">
    <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
        @foreach (Game game in games)
        {
            <div class="mobile-player-card">
                <div class="mobile-card-header">
                    <div class="mobile-card-name">vs @game.Opponent</div>
                    <div class="rank-badge">#@game.GameNumber</div>
                </div>
                <div class="mobile-card-stats" style="grid-template-columns: 1fr 1fr; margin-bottom: 1rem;">
                    <div class="m-stat" style="align-items: flex-start;">
                        <span class="m-stat-label">Date</span>
                        <span class="m-stat-val" style="font-size: 0.9rem;">@game.Date.ToString("MMM dd")</span>
                    </div>
                    <div class="m-stat" style="align-items: flex-start;">
                        <span class="m-stat-label">Diamond</span>
                        <span class="m-stat-val" style="font-size: 0.9rem;">@game.Diamond</span>
                    </div>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
                    <span class="badge @(game.Type == GameType.RegularSeason ? "bg-primary" : "bg-warning")" style="padding: 0.3rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">
                        @game.Type
                    </span>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" @onclick="() => StartEdit(game)">Edit</button>
                        <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red); padding: 0.3rem 0.8rem;" @onclick="() => DeleteGame(game.Id)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (showSuccess)
{
    <div class="view-fade-in" style="position: fixed; bottom: 2rem; right: 2rem; background: #155724; color: white; padding: 1rem 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 3000;">
        ✨ Game saved successfully!
    </div>
}

@code {
    private List<Season> seasons = new();
    private List<Game> games = new();
    private List<StatEntry> playerStats = new();
    private Game editingGame = new() { Date = DateTime.Today };
    private int selectedSeasonId;
    private bool isEditing = false;
    private bool showSeasonModal = false;
    private bool showSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        seasons = await StatsService.GetSeasonsAsync();
        if (seasons.Any())
        {
            selectedSeasonId = seasons.First().Id;
            editingGame.SeasonId = selectedSeasonId;
            await LoadGames();
        }
    }

    private async Task LoadGames()
    {
        List<StatEntry> stats = await StatsService.GetAllGameStatsAsync(selectedSeasonId);
        games = stats.GroupBy(s => s.GameId)
                    .Select(g => g.First().Game!)
                    .OrderByDescending(g => g.Date)
                    .ToList();
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedSeasonId = id;
            await LoadGames();
        }
    }

    private void ToggleSeasonModal()
    {
        showSeasonModal = !showSeasonModal;
    }

    private async Task SelectMobileSeason(int id)
    {
        selectedSeasonId = id;
        showSeasonModal = false;
        await LoadGames();
    }

    private async Task StartNewGame()
    {
        editingGame = new Game { Date = DateTime.Today, SeasonId = selectedSeasonId };
        List<Player> players = await StatsService.GetPlayersAsync(selectedSeasonId);
        playerStats = players.Select(p => new StatEntry { PlayerId = p.Id, Player = p }).ToList();
        isEditing = true;
    }

    private async Task StartEdit(Game game)
    {
        editingGame = new Game 
        { 
            Id = game.Id, 
            SeasonId = game.SeasonId, 
            GameNumber = game.GameNumber, 
            Date = game.Date, 
            Diamond = game.Diamond, 
            Opponent = game.Opponent, 
            Type = game.Type 
        };
        
        playerStats = await StatsService.GetGameStatsAsync(game.Id);
        isEditing = true;
        Navigation.NavigateTo("/management/games#top"); // Scroll to top if possible or just visual
    }

    private void CancelEdit()
    {
        isEditing = false;
        editingGame = new Game { Date = DateTime.Today, SeasonId = selectedSeasonId };
        playerStats.Clear();
    }

    private async Task SaveGame()
    {
        try
        {
            if (editingGame.Id == 0)
            {
                await StatsService.AddGameWithStatsAsync(editingGame, playerStats);
            }
            else
            {
                await StatsService.UpdateGameWithStatsAsync(editingGame, playerStats);
            }
            
            showSuccess = true;
            isEditing = false;
            await LoadGames();
            
            _ = Task.Run(async () => {
                await Task.Delay(3000);
                showSuccess = false;
                await InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception)
        {
            // Error handling
        }
    }

    private async Task DeleteGame(int id)
    {
        await StatsService.DeleteGameAsync(id);
        await LoadGames();
    }
}
