@page "/gamestats"
@page "/gamestats/{SeasonName}"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Services
@inject IStatsRepository StatsRepository
@inject SharedSessionState SharedState
@inject GameStatsState SessionState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Game Stats</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Game Stats</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <SeasonSelector 
            Seasons="@seasons" 
            SelectedSeasonId="@effectiveSeasonId" 
            OnSeasonSelected="OnSeasonSelected"
            AllowAllSeasons="false" />
    </div>
</div>

@if (!isLoading)
{
    <div class="stat-card" style="margin-bottom: 1.5rem;">
        <div class="filter-container" style="max-width: 100%;">
            <div class="search-container">
                <input type="text" class="form-control" @bind="filterText" @bind:event="oninput" @onkeyup="UpdateFilterState" placeholder="Search Opponent..." />
                @if (!string.IsNullOrEmpty(filterText))
                {
                    <button class="clear-button" @onclick="ClearFilter">✕</button>
                }
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <LoadingIndicator />
}
else
{
    @if (!FilteredSummaries.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Games Found</h4>
            <p>Try a different search or season.</p>
        </div>
    }
    else
    {
        List<GameSummaryView> playedGames = FilteredSummaries.Where(s => s.PlayerCount > 0).OrderByDescending(s => s.GameNumber).ToList();
        List<GameSummaryView> upcomingGames = FilteredSummaries.Where(s => s.PlayerCount == 0).OrderBy(s => s.Date).ToList();

        <div class="game-cards-list">
            @if (playedGames.Any())
            {
                int index = 0;
                @foreach (GameSummaryView summary in playedGames)
                {
                    int gameId = summary.GameId;
                    GameUIState uiState = SessionState.GetState(gameId);

                    double teamAVG = summary.TeamAB > 0 ? (double)summary.TeamHits / summary.TeamAB : 0;
                    double currentDelay = Math.Min(index * 0.1, 0.5);
                    index++;

                    <div class="game-card view-fade-in" style="animation-delay: @(currentDelay)s">
                        @{
                            int? isotopesScore = summary.IsHome ? summary.HomeTeamScore : summary.VisitingTeamScore;
                            int? opponentScore = summary.IsHome ? summary.VisitingTeamScore : summary.HomeTeamScore;
                        }
                        <div class="game-card-header" @onclick="() => ToggleGame(summary)" style="padding: 1.25rem; cursor: pointer; display: block;">
                            <!-- Desktop Header (Scoreboard Style) -->
                            <div class="desktop-only" style="width: 100%;">
                                <div class="mobile-scoreboard">
                                    <div class="scoreboard-meta">
                                        <span>GAME #@summary.GameNumber</span>
                                        <span>@summary.Date.ToString("MMM dd, yyyy @ h:mm tt")</span>
                                        <GameResultBadge OurScore="isotopesScore" OpponentScore="opponentScore" Style="margin: 0; font-size: 1rem; padding: 2px 12px;" />
                                    </div>
                                    <div class="scoreboard-matchup">
                                        <div class="scoreboard-team visitor smart-name-container">
                                            <span class="full-name">@(summary.IsHome ? summary.OpponentName : "Isotopes")</span>
                                            @if (summary.IsHome && !string.IsNullOrEmpty(summary.OpponentShortName))
                                            {
                                                <span class="short-name">@summary.OpponentShortName</span>
                                            }
                                            else if (!summary.IsHome)
                                            {
                                                <span class="short-name">Isotopes</span>
                                            }
                                        </div>
                                        <div class="scoreboard-scores">
                                            <span class="scoreboard-score">@(summary.VisitingTeamScore?.ToString() ?? "0")</span>
                                            <span class="scoreboard-divider">-</span>
                                            <span class="scoreboard-score">@(summary.HomeTeamScore?.ToString() ?? "0")</span>
                                        </div>
                                        <div class="scoreboard-team home smart-name-container">
                                            <span class="full-name">@(summary.IsHome ? "Isotopes" : summary.OpponentName)</span>
                                            @if (!summary.IsHome && !string.IsNullOrEmpty(summary.OpponentShortName))
                                            {
                                                <span class="short-name">@summary.OpponentShortName</span>
                                            }
                                            else if (summary.IsHome)
                                            {
                                                <span class="short-name">Isotopes</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="scoreboard-location">
                                        <span>📍 @summary.Diamond</span>
                                        <div class="expand-icon" style="margin-left: auto; color: #ccc; font-size: 0.8rem; width: 20px; text-align: center;">@(uiState.IsExpanded ? "▲" : "▼")</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Mobile Header (Scoreboard Style) -->
                            <div class="mobile-only" style="width: 100%;">
                                <div class="mobile-scoreboard">
                                    <div class="scoreboard-meta">
                                        <span>GAME #@summary.GameNumber</span>
                                        <span>@summary.Date.ToString("MMM dd @ h:mm tt")</span>
                                        <GameResultBadge OurScore="isotopesScore" OpponentScore="opponentScore" Style="margin: 0; font-size: 0.65rem; padding: 2px 6px;" />
                                    </div>
                                    <div class="scoreboard-matchup">
                                        <div class="scoreboard-team visitor smart-name-container">
                                            <span class="full-name">@(summary.IsHome ? summary.OpponentName : "Isotopes")</span>
                                            @if (summary.IsHome && !string.IsNullOrEmpty(summary.OpponentShortName))
                                            {
                                                <span class="short-name">@summary.OpponentShortName</span>
                                            }
                                            else if (!summary.IsHome)
                                            {
                                                <span class="short-name">Isotopes</span>
                                            }
                                        </div>
                                        <div class="scoreboard-scores">
                                            <span class="scoreboard-score">@(summary.VisitingTeamScore?.ToString() ?? "0")</span>
                                            <span class="scoreboard-divider">-</span>
                                            <span class="scoreboard-score">@(summary.HomeTeamScore?.ToString() ?? "0")</span>
                                        </div>
                                        <div class="scoreboard-team home smart-name-container">
                                            <span class="full-name">@(summary.IsHome ? "Isotopes" : summary.OpponentName)</span>
                                            @if (!summary.IsHome && !string.IsNullOrEmpty(summary.OpponentShortName))
                                            {
                                                <span class="short-name">@summary.OpponentShortName</span>
                                            }
                                            else if (summary.IsHome)
                                            {
                                                <span class="short-name">Isotopes</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="scoreboard-location">
                                        <span>📍 @summary.Diamond</span>
                                        <div class="expand-icon" style="margin-left: auto; color: #ccc; font-size: 0.7rem; width: 20px; text-align: center;">@(uiState.IsExpanded ? "▲" : "▼")</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (uiState.IsExpanded)
                        {
                            if (!expandedStats.ContainsKey(gameId) || expandedStats[gameId] == null)
                            {
                                <div class="game-card-detail expanded view-fade-in" style="padding: 2rem; text-align: center;">
                                    <div class="spinner-border text-danger" role="status"></div>
                                </div>
                            }
                            else
                            {
                                IEnumerable<GameStatsExtendedView> sortedStats = ApplyInnerSorting(uiState, expandedStats[gameId]);
                                IEnumerable<GameStatsExtendedView> mobileStats = expandedStats[gameId].OrderBy(s => s.BO);

                                <div class="game-card-detail expanded view-fade-in" style="padding: 0; border-top: 1px solid #eee; background: white;">
                                    <!-- Desktop View: Table -->
                                    <div class="desktop-only box-score-table-wrapper" style="padding: 0; width: 100%; overflow-x: auto;">
                                        <table class="box-score-table table-sm" style="margin-bottom: 0; border: none; border-radius: 0 !important; width: 100%;">
                                        <thead>
                                            <tr>
                                                <th @onclick='() => Sort(gameId, "BO")' class="sortable-header @(uiState.SortColumn == "BO" ? "active-sort-header" : "")" style="width: 40px;" title="@StatDefinitions.GetDefinition("BO")">
                                                    <span style="position: relative; display: inline-block;">
                                                        BO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "BO"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "Player")' class="player-name sortable-header sticky-col @(uiState.SortColumn == "Player" ? "active-sort-header" : "")">
                                                    <span style="position: relative; display: inline-block;">
                                                        Player<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "Player"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "PA")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "PA" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("PA")">
                                                    <span style="position: relative; display: inline-block;">
                                                        PA<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "PA"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "AB")' class="sortable-header narrow-col @(uiState.SortColumn == "AB" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("AB")">
                                                    <span style="position: relative; display: inline-block;">
                                                        AB<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "AB"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "R")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "R" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("R")">
                                                    <span style="position: relative; display: inline-block;">
                                                        R<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "R"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "H")' class="sortable-header narrow-col @(uiState.SortColumn == "H" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("H")">
                                                    <span style="position: relative; display: inline-block;">
                                                        H<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "H"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "1B")' class="sortable-header narrow-col @(uiState.SortColumn == "1B" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("1B")">
                                                    <span style="position: relative; display: inline-block;">
                                                        1B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "1B"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "2B")' class="sortable-header narrow-col @(uiState.SortColumn == "2B" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("2B")">
                                                    <span style="position: relative; display: inline-block;">
                                                        2B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "2B"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "3B")' class="sortable-header narrow-col @(uiState.SortColumn == "3B" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("3B")">
                                                    <span style="position: relative; display: inline-block;">
                                                        3B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "3B"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "HR")' class="sortable-header narrow-col @(uiState.SortColumn == "HR" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("HR")">
                                                    <span style="position: relative; display: inline-block;">
                                                        HR<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "HR"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "IPHR")' class="sortable-header narrow-col @(uiState.SortColumn == "IPHR" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("IPHR")">
                                                    <span style="position: relative; display: inline-block;">
                                                        IPHR<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "IPHR"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "RBI")' class="sortable-header narrow-col @(uiState.SortColumn == "RBI" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("RBI")">
                                                    <span style="position: relative; display: inline-block;">
                                                        RBI<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "RBI"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "BB")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "BB" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("BB")">
                                                    <span style="position: relative; display: inline-block;">
                                                        BB<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "BB"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "K")' class="sortable-header narrow-col @(uiState.SortColumn == "K" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("K")">
                                                    <span style="position: relative; display: inline-block;">
                                                        K<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "K"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "KF")' class="sortable-header narrow-col @(uiState.SortColumn == "KF" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("KF")">
                                                    <span style="position: relative; display: inline-block;">
                                                        KF<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "KF"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "SF")' class="sortable-header group-divider narrow-col @(uiState.SortColumn == "SF" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("SF")">
                                                    <span style="position: relative; display: inline-block;">
                                                        SF<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "SF"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "FC")' class="sortable-header narrow-col @(uiState.SortColumn == "FC" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("FC")">
                                                    <span style="position: relative; display: inline-block;">
                                                        FC<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "FC"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "GO")' class="sortable-header narrow-col @(uiState.SortColumn == "GO" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("GO")">
                                                    <span style="position: relative; display: inline-block;">
                                                        GO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "GO"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "FO")' class="sortable-header narrow-col @(uiState.SortColumn == "FO" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("FO")">
                                                    <span style="position: relative; display: inline-block;">
                                                        FO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "FO"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "AVG")' class="sortable-header group-divider @(uiState.SortColumn == "AVG" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("AVG")">
                                                    <span style="position: relative; display: inline-block;">
                                                        AVG<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "AVG"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "OBP")' class="sortable-header @(uiState.SortColumn == "OBP" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("OBP")">
                                                    <span style="position: relative; display: inline-block;">
                                                        OBP<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "OBP"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "SLG")' class="sortable-header @(uiState.SortColumn == "SLG" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("SLG")">
                                                    <span style="position: relative; display: inline-block;">
                                                        SLG<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "SLG"))</span>
                                                    </span>
                                                </th>
                                                <th @onclick='() => Sort(gameId, "OPS")' class="sortable-header @(uiState.SortColumn == "OPS" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("OPS")">
                                                    <span style="position: relative; display: inline-block;">
                                                        OPS<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(gameId, "OPS"))</span>
                                                    </span>
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (GameStatsExtendedView stat in sortedStats)
                                            {
                                                <tr>
                                                    <td class="@(uiState.SortColumn == "BO" ? "active-sort-col" : "")">@stat.BO</td>
                                                    <td class="player-name sticky-col @(uiState.SortColumn == "Player" ? "active-sort-col" : "")">
                                                        <a href="/player/@Uri.EscapeDataString(stat.PlayerName)/@Uri.EscapeDataString(GetSeasonName(effectiveSeasonId))" style="text-decoration: none; color: inherit;">
                                                            @stat.PlayerName
                                                        </a>
                                                    </td>
                                                    <td class="group-divider narrow-col @(uiState.SortColumn == "PA" ? "active-sort-col" : "")">@stat.PA</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "AB" ? "active-sort-col" : "")">@stat.AB</td>
                                                    <td class="group-divider narrow-col @(uiState.SortColumn == "R" ? "active-sort-col" : "")">@stat.R</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "H" ? "active-sort-col" : "")">@stat.H</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "1B" ? "active-sort-col" : "")">@stat.H1B</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "2B" ? "active-sort-col" : "")">@stat.H2B</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "3B" ? "active-sort-col" : "")">@stat.H3B</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "HR" ? "active-sort-col" : "")">@stat.HR</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "IPHR" ? "active-sort-col" : "")">@stat.IPHR</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "RBI" ? "active-sort-col" : "")">@stat.RBI</td>
                                                    <td class="group-divider narrow-col @(uiState.SortColumn == "BB" ? "active-sort-col" : "")">@stat.BB</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "K" ? "active-sort-col" : "")">@stat.K</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "KF" ? "active-sort-col" : "")">@stat.KF</td>
                                                    <td class="group-divider narrow-col @(uiState.SortColumn == "SF" ? "active-sort-col" : "")">@stat.SF</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "FC" ? "active-sort-col" : "")">@stat.FC</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "GO" ? "active-sort-col" : "")">@stat.GO</td>
                                                    <td class="narrow-col @(uiState.SortColumn == "FO" ? "active-sort-col" : "")">@stat.FO</td>
                                                    <td class="group-divider @(uiState.SortColumn == "AVG" ? "active-sort-col" : "")">@stat.AVG.ToString(".000")</td>
                                                    <td class="@(uiState.SortColumn == "OBP" ? "active-sort-col" : "")">@stat.OBP.ToString(".000")</td>
                                                    <td class="@(uiState.SortColumn == "SLG" ? "active-sort-col" : "")">@stat.SLG.ToString(".000")</td>
                                                    <td class="@(uiState.SortColumn == "OPS" ? "active-sort-col" : "")">@stat.OPS.ToString(".000")</td>
                                                </tr>
                                            }
                                            <tr class="game-summary-row">
                                                <td></td>
                                                <td class="player-name sticky-col">Team</td>
                                                <td class="group-divider narrow-col">@summary.TeamPA</td>
                                                <td class="narrow-col">@summary.TeamAB</td>
                                                <td class="group-divider narrow-col">@summary.TeamRuns</td>
                                                <td class="narrow-col">@summary.TeamHits</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.H1B)</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.H2B)</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.H3B)</td>
                                                <td class="narrow-col">@summary.TeamHRs</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.IPHR)</td>
                                                <td class="narrow-col">@summary.TeamRBI</td>
                                                <td class="group-divider narrow-col">@summary.TeamBBs</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.K)</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.KF)</td>
                                                <td class="group-divider narrow-col">@expandedStats[gameId].Sum(s => s.SF)</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.FC)</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.GO)</td>
                                                <td class="narrow-col">@expandedStats[gameId].Sum(s => s.FO)</td>
                                                <td class="group-divider">@teamAVG.ToString(".000")</td>
                                                @{
                                                    int teamSF = expandedStats[gameId].Sum(s => s.SF);
                                                    int team1B = expandedStats[gameId].Sum(s => s.H1B);
                                                    int team2B = expandedStats[gameId].Sum(s => s.H2B);
                                                    int team3B = expandedStats[gameId].Sum(s => s.H3B);
                                                    int teamIPHR = expandedStats[gameId].Sum(s => s.IPHR);
                                                    int teamHR = expandedStats[gameId].Sum(s => s.HR);
                                                    int teamTB = team1B + (2 * team2B) + (3 * team3B) + (4 * (teamIPHR + teamHR));

                                                    double teamOBP = (summary.TeamAB + summary.TeamBBs + teamSF) > 0
                                                        ? (double)(summary.TeamHits + summary.TeamBBs) / (summary.TeamAB + summary.TeamBBs + teamSF)
                                                        : 0;
                                                    
                                                    double teamSLG = summary.TeamAB > 0 ? (double)teamTB / summary.TeamAB : 0;
                                                    double teamOPS = teamOBP + teamSLG;
                                                }
                                                <td>@teamOBP.ToString(".000")</td>
                                                <td>@teamSLG.ToString(".000")</td>
                                                <td>@teamOPS.ToString(".000")</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    </div>

                                    <!-- Mobile View: Activity Feed -->
                                    <div class="mobile-only mobile-player-list">
                                        @foreach (GameStatsExtendedView stat in mobileStats)
                                        {
                                            <div class="mobile-player-row">
                                                <div class="player-row-header">
                                                    <span class="player-row-name" @onclick='() => Navigation.NavigateTo($"/player/{Uri.EscapeDataString(stat.PlayerName)}/{Uri.EscapeDataString(GetSeasonName(effectiveSeasonId))}")' style="cursor: pointer;">
