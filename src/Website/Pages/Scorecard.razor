@page "/games/{GameId:int}/scorecard"
@implements IDisposable
@using System.Threading
@using IsotopesStats.Domain.Models
@using IsotopesStats.Domain.Interfaces
@inject IStatsRepository StatsRepository
@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@inject IJSRuntime JS
@inject IAuthRepository AuthSvc

<PageTitle>Scorecard - Isotopes</PageTitle>

@if (isLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-dark" role="status"></div>
        <p class="mt-2 text-dark">Loading scorecard...</p>
    </div>
}
else if (game == null)
{
    <div class="alert alert-danger">Game not found.</div>
}
else
{
    <div class="scorecard-wrapper">
        <div class="d-flex flex-row justify-content-between align-items-center no-print mb-3 gap-2 pt-1">
            <h2 class="mb-0">Scorecard</h2>
            <div class="d-flex flex-wrap justify-content-center gap-2 p-1">
                @if (canManageGames)
                {
                    <button class="view-btn" style="background-color: var(--isotopes-red); color: white; border-color: var(--isotopes-red);" @onclick="OpenResetModal">Reset</button>
                    <a href="/games/@GameId/scorekeeping" class="view-btn active">Scorekeeper</a>
                }
            </div>
        </div>

        @if (canManageGames && isOutOfSync)
        {
            <div class="alert alert-warning d-flex justify-content-between align-items-center mb-3 no-print border-warning">
                <div>
                    <strong class="text-dark">Warning:</strong> The official game stats do not match the play-by-play plate appearances.
                </div>
                <button class="view-btn active" style="background-color: var(--isotopes-accent); color: white; border: none;" @onclick="OpenSyncModal">Reconcile Stats</button>
            </div>
        }
        <div class="zoom-viewport">
            <div class="scorecard-container" id="scorecard-zoom-container">
            <ScorecardGrid 
                Game="game" 
                OpponentName="@opponentName"
                Roster="roster" 
                GameStats="gameStats" 
                PlateAppearances="plateAppearances" 
                TotalBatters="TotalBatters" 
                RecentlyChangedPaIds="recentlyChangedPaIds" 
                CanManageGames="canManageGames" 
                OnCellClick="HandleCellClick" 
                OnOpponentScoreChanged="HandleOpponentScoreChanged" />
        </div>
        </div>
    </div>
}

@if (isSyncModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Reconcile Game Stats</h5>
                    <button type="button" class="btn-close" @onclick="CloseSyncModal"></button>
                </div>
                <div class="modal-body">
                    <p>The following players have discrepancies between the official game stats and the stats calculated from the plate appearances recorded in the scorekeeper.</p>
                    <table class="table table-bordered table-sm text-center">
                        <thead class="table-light">
                            <tr>
                                <th>Player</th>
                                <th>Source</th>
                                <th>1B</th><th>2B</th><th>3B</th><th>IPHR</th><th>HR</th><th>BB</th><th>K</th><th>KF</th><th>R</th><th>RBI</th><th>FC</th><th>SF</th><th>GO</th><th>FO</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mismatch in mismatchedPlayers)
                            {
                                var existing = gameStats.FirstOrDefault(s => s.PlayerId == mismatch.PlayerId) ?? new StatEntry();
                                var calc = calculatedStats.FirstOrDefault(s => s.PlayerId == mismatch.PlayerId) ?? new StatEntry();
                                
                                <tr>
                                    <td rowspan="2" class="align-middle fw-bold text-start">@GetPlayerName(mismatch.PlayerId)</td>
                                    <td class="text-start">Calculated</td>
                                    <td class="@(existing.H1B != calc.H1B ? "text-danger fw-bold" : "")">@calc.H1B</td>
                                    <td class="@(existing.H2B != calc.H2B ? "text-danger fw-bold" : "")">@calc.H2B</td>
                                    <td class="@(existing.H3B != calc.H3B ? "text-danger fw-bold" : "")">@calc.H3B</td>
                                    <td class="@(existing.IPHR != calc.IPHR ? "text-danger fw-bold" : "")">@calc.IPHR</td>
                                    <td class="@(existing.HR != calc.HR ? "text-danger fw-bold" : "")">@calc.HR</td>
                                    <td class="@(existing.BB != calc.BB ? "text-danger fw-bold" : "")">@calc.BB</td>
                                    <td class="@(existing.K != calc.K ? "text-danger fw-bold" : "")">@calc.K</td>
                                    <td class="@(existing.KF != calc.KF ? "text-danger fw-bold" : "")">@calc.KF</td>
                                    <td class="@(existing.R != calc.R ? "text-danger fw-bold" : "")">@calc.R</td>
                                    <td class="@(existing.RBI != calc.RBI ? "text-danger fw-bold" : "")">@calc.RBI</td>
                                    <td class="@(existing.FC != calc.FC ? "text-danger fw-bold" : "")">@calc.FC</td>
                                    <td class="@(existing.SF != calc.SF ? "text-danger fw-bold" : "")">@calc.SF</td>
                                    <td class="@(existing.GO != calc.GO ? "text-danger fw-bold" : "")">@calc.GO</td>
                                    <td class="@(existing.FO != calc.FO ? "text-danger fw-bold" : "")">@calc.FO</td>
                                </tr>
                                <tr>
                                    <td class="text-start">Existing</td>
                                    <td>@existing.H1B</td>
                                    <td>@existing.H2B</td>
                                    <td>@existing.H3B</td>
                                    <td>@existing.IPHR</td>
                                    <td>@existing.HR</td>
                                    <td>@existing.BB</td>
                                    <td>@existing.K</td>
                                    <td>@existing.KF</td>
                                    <td>@existing.R</td>
                                    <td>@existing.RBI</td>
                                    <td>@existing.FC</td>
                                    <td>@existing.SF</td>
                                    <td>@existing.GO</td>
                                    <td>@existing.FO</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="alert alert-info mt-3 mb-0">
                        <strong>Note:</strong> Clicking "Sync Calculated Stats" will permanently overwrite the official box score stats for all players in this game with the calculated values above.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseSyncModal">Cancel</button>
                    <button type="button" class="btn fw-bold text-dark" style="background-color: var(--isotopes-accent);" @onclick="SyncAllStats">Sync Calculated Stats</button>
                </div>
            </div>
        </div>
    </div>
}

@if (isResetModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header text-white" style="background-color: var(--isotopes-red);">
                    <h5 class="modal-title fw-bold">Reset Scorecard</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseResetModal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to reset the scorecard for this game?</p>
                    <p class="text-danger fw-bold mb-0">This will permanently delete:</p>
                    <ul class="text-danger text-start" style="text-align: left;">
                        <li>All plate appearances</li>
                        <li>The batting order</li>
                        <li>All official game stats (if synced)</li>
                        <li>The inning-by-inning opponent score</li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseResetModal" disabled="@isProcessing">Cancel</button>
                    <button type="button" class="btn text-white fw-bold" style="background-color: var(--isotopes-red);" @onclick="ResetScorecardAsync" disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span class="ms-1">Resetting...</span>
                        }
                        else
                        {
                            <span>Yes, Reset Scorecard</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}



@code {
    [Parameter]
    public int GameId { get; set; }

    [CascadingParameter] 
    private Task<AuthenticationState> authenticationStateTask { get; set; } = null!;

    private CancellationTokenSource cts = new();
    private HashSet<int> recentlyChangedPaIds = new();

    private async Task LogActionAsync(string description)
    {
        if (authenticationStateTask == null) return;
        var authState = await authenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userEmail = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "unknown";
            await AuthSvc.AddLogAsync(new UserLog
            {
                UserEmail = userEmail,
                Action = UserLogAction.Updated,
                EntityType = "Game",
                EntityId = GameId.ToString(),
                Description = description,
                Timestamp = DateTime.UtcNow
            });
        }
    }

    private bool isLoading = true;
    private Game? game;
    private List<Player> roster = new();
    private List<Opponent> opponents = new();
    private List<StatEntry> gameStats = new();
    private List<PlateAppearance> plateAppearances = new();
    private List<StatEntry> calculatedStats = new();
    private List<StatEntry> mismatchedPlayers = new();
    private bool isOutOfSync = false;
    private bool isSyncModalVisible = false;
    private bool isResetModalVisible = false;
    private bool isProcessing = false;
    private bool zoomInitialized = false;
    
    private string opponentName = "Unknown";
    
    private int TotalBatters => Math.Max(15, gameStats.Count > 0 ? gameStats.Max(s => s.BO) : 0);
    private bool canManageGames = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "Manage Scorekeeping");
        canManageGames = authResult.Succeeded;

        await LoadDataAsync();
        
        _ = PollForUpdatesAsync();
    }

    private async Task PollForUpdatesAsync()
    {
        using PeriodicTimer timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        try
        {
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                await SilentUpdateAsync();
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task SilentUpdateAsync()
    {
        try
        {
            List<PlateAppearance> newPAs = await StatsRepository.GetPlateAppearancesAsync(GameId);
            bool changed = false;
            HashSet<int> changedIds = new();

            foreach(PlateAppearance newPa in newPAs)
            {
                PlateAppearance? oldPa = plateAppearances.FirstOrDefault(p => p.Id == newPa.Id);
                if (oldPa == null || 
                    oldPa.Result != newPa.Result || 
                    oldPa.RunsScored != newPa.RunsScored || 
                    oldPa.RunnerOn1B != newPa.RunnerOn1B || 
                    oldPa.RunnerOn2B != newPa.RunnerOn2B || 
                    oldPa.RunnerOn3B != newPa.RunnerOn3B ||
                    oldPa.RunnerOn1B_End != newPa.RunnerOn1B_End || 
                    oldPa.RunnerOn2B_End != newPa.RunnerOn2B_End || 
                    oldPa.RunnerOn3B_End != newPa.RunnerOn3B_End ||
                    oldPa.OutsRecorded != newPa.OutsRecorded ||
                    oldPa.EndsInning != newPa.EndsInning)
                {
                    changedIds.Add(newPa.Id);
                    changed = true;
                }
            }

            if (plateAppearances.Count != newPAs.Count) changed = true;

            if (changed)
            {
                List<StatEntry> newGameStats = await StatsRepository.GetGameStatsAsync(GameId);
                List<StatEntry> newCalculatedStats = await StatsRepository.CalculateStatsFromPlateAppearancesAsync(GameId);
                Game? newGame = await StatsRepository.GetGameAsync(GameId);

                await InvokeAsync(() =>
                {
                    plateAppearances = newPAs;
                    gameStats = newGameStats;
                    calculatedStats = newCalculatedStats;
                    if (newGame != null) game = newGame;

                    recentlyChangedPaIds = changedIds;
                    BuildScorecardGrid();
                    CalculateDifferences();
                    StateHasChanged();
                });

                // Clear highlights after animation
                await Task.Delay(2500, cts.Token);
                await InvokeAsync(() =>
                {
                    recentlyChangedPaIds.Clear();
                    StateHasChanged();
                });
            }
        }
        catch (Exception)
        {
            // Ignore background update errors
        }
    }

    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            game = await StatsRepository.GetGameAsync(GameId);
            if (game != null)
            {
                roster = await StatsRepository.GetPlayersAsync(game.SeasonId);
                opponents = await StatsRepository.GetOpponentsAsync(game.SeasonId);
                
                Opponent? opp = opponents.FirstOrDefault(o => o.Id == game.OpponentId);
                if (opp != null) opponentName = opp.Name;
                
                gameStats = await StatsRepository.GetGameStatsAsync(GameId);
                plateAppearances = await StatsRepository.GetPlateAppearancesAsync(GameId);
                calculatedStats = await StatsRepository.CalculateStatsFromPlateAppearancesAsync(GameId);
                BuildScorecardGrid();
                CalculateDifferences();
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }


    private async Task HandleOpponentScoreChanged((int inning, object? value) args)
    {
        if (game == null) return;
        
        var scores = game.GetOpponentInningScores();
        if (args.value != null && int.TryParse(args.value.ToString(), out int score))
        {
            scores[args.inning] = score;
        }
        else
        {
            scores.Remove(args.inning);
        }
        
        game.SetOpponentInningScores(scores);
        game.VisitingTeamScore = game.IsHome ? scores.Values.Sum() : game.VisitingTeamScore;
        game.HomeTeamScore = game.IsHome ? game.HomeTeamScore : scores.Values.Sum();
        
        await StatsRepository.UpdateGameAsync(game);
        await LogActionAsync($"Updated opponent score for inning {args.inning} to {args.value} for Game {GameId}");
    }

    private string GetPlayerName(int id)
    {
        return roster.FirstOrDefault(p => p.Id == id)?.Name ?? "Unknown";
    }

    private void BuildScorecardGrid()
    {
        // Now handled entirely within ScorecardGrid.razor
    }
    
    private void HandleCellClick(PlateAppearance? pa)
    {
        if (pa != null && canManageGames)
        {
            int index = plateAppearances.OrderBy(p => p.Id).ToList().IndexOf(pa);
            if (index >= 0)
            {
                NavigationManager.NavigateTo($"/games/{GameId}/scorekeeping?paIndex={index}");
            }
            else
            {
                NavigationManager.NavigateTo($"/games/{GameId}/scorekeeping");
            }
        }
    }

    private void CalculateDifferences()
    {
        mismatchedPlayers.Clear();
        foreach (var calc in calculatedStats)
        {
            var existing = gameStats.FirstOrDefault(s => s.PlayerId == calc.PlayerId);
            if (existing == null || 
                existing.H1B != calc.H1B || existing.H2B != calc.H2B || 
                existing.H3B != calc.H3B || existing.IPHR != calc.IPHR || existing.HR != calc.HR ||
                existing.BB != calc.BB || existing.K != calc.K || existing.KF != calc.KF ||
                existing.R != calc.R || existing.RBI != calc.RBI ||
                existing.FO != calc.FO || existing.GO != calc.GO ||
                existing.FC != calc.FC || existing.SF != calc.SF)
            {
                mismatchedPlayers.Add(calc);
            }
        }
        foreach (var existing in gameStats)
        {
            if (!calculatedStats.Any(s => s.PlayerId == existing.PlayerId))
            {
                mismatchedPlayers.Add(new StatEntry { PlayerId = existing.PlayerId, BO = existing.BO });
            }
        }
        isOutOfSync = mismatchedPlayers.Count > 0;
    }

    private void OpenSyncModal() => isSyncModalVisible = true;
    private void CloseSyncModal() => isSyncModalVisible = false;

    private void OpenResetModal() => isResetModalVisible = true;
    private void CloseResetModal() => isResetModalVisible = false;

    private async Task ResetScorecardAsync()
    {
        isProcessing = true;
        StateHasChanged();
        try
        {
            var pas = await StatsRepository.GetPlateAppearancesAsync(GameId);
            foreach (var pa in pas)
            {
                await StatsRepository.DeletePlateAppearanceAsync(pa.Id);
            }

            if (game != null)
            {
                game.SetOpponentInningScores(new System.Collections.Generic.Dictionary<int, int>());
                game.HomeTeamScore = null;
                game.VisitingTeamScore = null;
                
                await StatsRepository.UpdateGameAsync(game);
                
                if (game.ScorecardStatsSync)
                {
                    await StatsRepository.UpdateGameWithStatsAsync(game, new List<StatEntry>());
                }
            }

            await LogActionAsync($"Reset scorecard (cleared lineup, plays, and scores) for Game {GameId}");
            
            CloseResetModal();
            await LoadDataAsync();
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task SyncAllStats()
    {
        await StatsRepository.SyncGameStatsFromPlateAppearancesAsync(GameId);
        gameStats = await StatsRepository.GetGameStatsAsync(GameId);
        CalculateDifferences();
        BuildScorecardGrid();
        CloseSyncModal();
        StateHasChanged();
        await LogActionAsync($"Synced calculated stats from play-by-play for Game {GameId}");
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !zoomInitialized)
        {
            zoomInitialized = true;
            try
            {
                var module = await JS.InvokeAsync<IJSObjectReference>("import", $"./js/scorecard-zoom.js?v={Guid.NewGuid()}");
                await module.InvokeVoidAsync("init", "scorecard-zoom-container");
            }
            catch (Exception ex)
            {
                // Ignore JS errors if panning isn't loaded or prerendering
                Console.WriteLine(ex.Message);
            }
        }
    }
}
