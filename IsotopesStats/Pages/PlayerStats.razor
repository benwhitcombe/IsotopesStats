@page "/playerstats"
@using IsotopesStats.Models
@using IsotopesStats.Services
@inject StatsService StatsService
@inject SharedSessionState SessionState
@inject PlayerStatsState PageState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Player Stats</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Player Stats</h3>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
        <input type="text" class="form-control" @bind="PageState.FilterText" @bind:event="oninput" placeholder="Search players..." style="max-width: 200px;" />
    </div>
</div>

<div class="view-selector" style="margin-bottom: 1.5rem; display: flex; gap: 0.5rem;">
    <button class="view-btn @(PageState.ActiveView == "Standard" ? "active" : "")" @onclick='() => SetView("Standard")'>Standard</button>
    <button class="view-btn @(PageState.ActiveView == "Hits" ? "active" : "")" @onclick='() => SetView("Hits")'>Hits</button>
    <button class="view-btn @(PageState.ActiveView == "Outcomes" ? "active" : "")" @onclick='() => SetView("Outcomes")'>Outcomes</button>
</div>

@if (stats == null)
{
    <div style="text-align: center; padding: 5rem;">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;" @onclick='() => Sort("PlayerName")'>Player @GetSortIcon("PlayerName")</th>
                            <th @onclick='() => Sort("GamesPlayed")'>G @GetSortIcon("GamesPlayed")</th>
                            <th @onclick='() => Sort("PA")'>PA @GetSortIcon("PA")</th>
                            <th @onclick='() => Sort("AB")'>AB @GetSortIcon("AB")</th>
                            
                            @if (PageState.ActiveView == "Standard")
                            {
                                <th @onclick='() => Sort("H")'>H @GetSortIcon("H")</th>
                                <th @onclick='() => Sort("R")'>R @GetSortIcon("R")</th>
                                <th @onclick='() => Sort("RBI")'>RBI @GetSortIcon("RBI")</th>
                                <th @onclick='() => Sort("BB")'>BB @GetSortIcon("BB")</th>
                                <th @onclick='() => Sort("K")'>K @GetSortIcon("K")</th>
                                <th class="highlight-col" @onclick='() => Sort("AVG")'>AVG @GetSortIcon("AVG")</th>
                                <th class="highlight-col" @onclick='() => Sort("OBP")'>OBP @GetSortIcon("OBP")</th>
                                <th class="highlight-col" @onclick='() => Sort("SLG")'>SLG @GetSortIcon("SLG")</th>
                                <th class="highlight-col" @onclick='() => Sort("OPS")'>OPS @GetSortIcon("OPS")</th>
                            }
                            else if (PageState.ActiveView == "Hits")
                            {
                                <th @onclick='() => Sort("H1B")'>1B @GetSortIcon("H1B")</th>
                                <th @onclick='() => Sort("H2B")'>2B @GetSortIcon("H2B")</th>
                                <th @onclick='() => Sort("H3B")'>3B @GetSortIcon("H3B")</th>
                                <th @onclick='() => Sort("HR")'>HR @GetSortIcon("HR")</th>
                                <th @onclick='() => Sort("TB")'>TB @GetSortIcon("TB")</th>
                                <th class="highlight-col" @onclick='() => Sort("SLG")'>SLG @GetSortIcon("SLG")</th>
                            }
                            else if (PageState.ActiveView == "Outcomes")
                            {
                                <th @onclick='() => Sort("BB")'>BB @GetSortIcon("BB")</th>
                                <th @onclick='() => Sort("FC")'>FC @GetSortIcon("FC")</th>
                                <th @onclick='() => Sort("K")'>K @GetSortIcon("K")</th>
                                <th @onclick='() => Sort("KF")'>KF @GetSortIcon("KF")</th>
                                <th @onclick='() => Sort("GO")'>GO @GetSortIcon("GO")</th>
                                <th @onclick='() => Sort("FO")'>FO @GetSortIcon("FO")</th>
                                <th class="highlight-col" @onclick='() => Sort("OBP")'>OBP @GetSortIcon("OBP")</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (PlayerStatsSummary player in FilteredStats)
                        {
                            <tr @onclick='() => NavigateToLog(player.PlayerName)' style="cursor: pointer;">
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@player.PlayerName</td>
                                <td>@player.GamesPlayed</td>
                                <td>@player.PA</td>
                                <td>@player.AB</td>

                                @if (PageState.ActiveView == "Standard")
                                {
                                    <td>@player.H</td>
                                    <td>@player.R</td>
                                    <td>@player.RBI</td>
                                    <td>@player.BB</td>
                                    <td>@(player.K + player.KF)</td>
                                    <td class="highlight-col">@player.AVG.ToString(".000")</td>
                                    <td class="highlight-col">@player.OBP.ToString(".000")</td>
                                    <td class="highlight-col">@player.SLG.ToString(".000")</td>
                                    <td class="highlight-col">@player.OPS.ToString(".000")</td>
                                }
                                else if (PageState.ActiveView == "Hits")
                                {
                                    <td>@player.H1B</td>
                                    <td>@player.H2B</td>
                                    <td>@player.H3B</td>
                                    <td>@player.HR</td>
                                    <td>@player.TB</td>
                                    <td class="highlight-col">@player.SLG.ToString(".000")</td>
                                }
                                else if (PageState.ActiveView == "Outcomes")
                                {
                                    <td>@player.BB</td>
                                    <td>@player.FC</td>
                                    <td>@player.K</td>
                                    <td>@player.KF</td>
                                    <td>@player.GO</td>
                                    <td>@player.FO</td>
                                    <td class="highlight-col">@player.OBP.ToString(".000")</td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background: #f8f9fa; font-weight: bold; border-top: 2px solid #dee2e6;">
                            <td style="text-align: left;">@teamTotals.PlayerName</td>
                            <td>-</td>
                            <td>@teamTotals.PA</td>
                            <td>@teamTotals.AB</td>
                            
                            @if (PageState.ActiveView == "Standard")
                            {
                                <td>@teamTotals.H</td>
                                <td>@teamTotals.R</td>
                                <td>@teamTotals.RBI</td>
                                <td>@teamTotals.BB</td>
                                <td>@(teamTotals.K + teamTotals.KF)</td>
                                <td class="highlight-col">@teamTotals.AVG.ToString(".000")</td>
                                <td class="highlight-col">@teamTotals.OBP.ToString(".000")</td>
                                <td class="highlight-col">@teamTotals.SLG.ToString(".000")</td>
                                <td class="highlight-col">@teamTotals.OPS.ToString(".000")</td>
                            }
                            else if (PageState.ActiveView == "Hits")
                            {
                                <td>@teamTotals.H1B</td>
                                <td>@teamTotals.H2B</td>
                                <td>@teamTotals.H3B</td>
                                <td>@teamTotals.HR</td>
                                <td>@teamTotals.TB</td>
                                <td class="highlight-col">@teamTotals.SLG.ToString(".000")</td>
                            }
                            else if (PageState.ActiveView == "Outcomes")
                            {
                                <td>@teamTotals.BB</td>
                                <td>@teamTotals.FC</td>
                                <td>@teamTotals.K</td>
                                <td>@teamTotals.KF</td>
                                <td>@teamTotals.GO</td>
                                <td>@teamTotals.FO</td>
                                <td class="highlight-col">@teamTotals.OBP.ToString(".000")</td>
                            }
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s;">
            @foreach (PlayerStatsSummary player in FilteredStats)
            {
                <div class="mobile-player-card" @onclick='() => NavigateToLog(player.PlayerName)'>
                    <div class="mobile-card-header">
                        <div class="mobile-card-name">@player.PlayerName</div>
                        <div class="mobile-card-avg">. @(player.AVG.ToString("000"))</div>
                    </div>
                    <div class="mobile-card-stats">
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label">G</span>
                            <span class="mobile-stat-value">@player.GamesPlayed</span>
                        </div>
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label">H</span>
                            <span class="mobile-stat-value">@player.H</span>
                        </div>
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label">R</span>
                            <span class="mobile-stat-value">@player.R</span>
                        </div>
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label">RBI</span>
                            <span class="mobile-stat-value">@player.RBI</span>
                        </div>
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label">OPS</span>
                            <span class="mobile-stat-value">@player.OPS.ToString(".000")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<PlayerStatsSummary>? stats;
    private PlayerStatsSummary teamTotals = new();

    private IEnumerable<PlayerStatsSummary> FilteredStats
    {
        get
        {
            IEnumerable<PlayerStatsSummary> result = stats ?? new List<PlayerStatsSummary>();
            if (!string.IsNullOrWhiteSpace(PageState.FilterText))
            {
                result = result.Where(p => p.PlayerName.Contains(PageState.FilterText, StringComparison.OrdinalIgnoreCase)).ToList();
            }

            return PageState.IsAscending 
                ? result.OrderBy(p => GetSortValue(p, PageState.CurrentSortColumn))
                : result.OrderByDescending(p => GetSortValue(p, PageState.CurrentSortColumn));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        if (SessionState.SelectedSeasonId != 0)
        {
            stats = await StatsService.GetStatsSummaryAsync(SessionState.SelectedSeasonId);
            teamTotals = await StatsService.GetTeamTotalsAsync(SessionState.SelectedSeasonId);
        }
    }

    private void SetView(string view)
    {
        PageState.ActiveView = view;
        StateHasChanged();
    }

    private void Sort(string column)
    {
        switch (PageState.ActiveView)
        {
            case "Standard":
                if (PageState.StandardSortColumn == column) PageState.StandardIsAscending = !PageState.StandardIsAscending;
                else PageState.StandardSortColumn = column;
                break;
            case "Hits":
                if (PageState.HitsSortColumn == column) PageState.HitsIsAscending = !PageState.HitsIsAscending;
                else PageState.HitsSortColumn = column;
                break;
            case "Outcomes":
                if (PageState.OutcomesSortColumn == column) PageState.OutcomesIsAscending = !PageState.OutcomesIsAscending;
                else PageState.OutcomesSortColumn = column;
                break;
        }
    }

    private object GetSortValue(PlayerStatsSummary p, string column) => column switch
    {
        "PlayerName" => p.PlayerName,
        "GamesPlayed" => p.GamesPlayed,
        "PA" => p.PA,
        "AB" => p.AB,
        "H" => p.H,
        "R" => p.R,
        "RBI" => p.RBI,
        "BB" => p.BB,
        "K" => p.K + p.KF,
        "AVG" => p.AVG,
        "OBP" => p.OBP,
        "SLG" => p.SLG,
        "OPS" => p.OPS,
        "H1B" => p.H1B,
        "H2B" => p.H2B,
        "H3B" => p.H3B,
        "HR" => p.HR,
        "TB" => p.TB,
        "FC" => p.FC,
        "KF" => p.KF,
        "GO" => p.GO,
        "FO" => p.FO,
        _ => (object)p.AVG
    };

    private string GetSortIcon(string column)
    {
        if (PageState.CurrentSortColumn != column) return "↕";
        return PageState.IsAscending ? "↑" : "↓";
    }

    private void NavigateToLog(string playerName)
    {
        SessionState.ReturnUrl = "playerstats";
        Navigation.NavigateTo($"/playerlogs/{Uri.EscapeDataString(playerName)}");
    }
}
