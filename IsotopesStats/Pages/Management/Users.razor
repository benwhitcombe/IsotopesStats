@page "/management/users"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "ManageUsers")]
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Users</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">User Management</h3>
    @if (!isAdding && !isEditing)
    {
        <button class="view-btn active" @onclick="() => StartAdd()">Add New User</button>
    }
</div>

@if (isAdding || isEditing)
{
    <div class="stat-card view-fade-in" style="margin-bottom: 2rem;">
        <h4 style="margin-top:0">@(isAdding ? "Add" : "Edit") User</h4>
        <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control" @bind="userEmail" @bind:event="oninput" @onkeyup="HandleInput" placeholder="user@isotopes.com" autocomplete="off" />
        </div>

        @if (isAdding)
        {
            <div class="form-group">
                <label>Password</label>
                <div style="position: relative;">
                    <input type="@(showPassword ? "text" : "password")" class="form-control" @bind="password" @bind:event="oninput" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" style="padding-right: 3rem;" />
                    <button type="button" @onclick="TogglePassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                        <PasswordToggleIcon IsVisible="@showPassword" />
                    </button>
                </div>
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password" class="form-control" @bind="confirmPassword" @bind:event="oninput" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" />
            </div>
        }
        else
        {
            <div style="background: #f9f9f9; padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0; border: 1px solid #eee;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: @(showPasswordFields ? "1rem" : "0")">
                    <label style="margin:0; font-weight: bold;">Change Password?</label>
                    <button class="view-btn" @onclick="TogglePasswordFields">@(showPasswordFields ? "Cancel Password Change" : "Update Password")</button>
                </div>

                @if (showPasswordFields)
                {
                    <div class="view-fade-in">
                        <div class="form-group">
                            <label>New Password</label>
                            <div style="position: relative;">
                                <input type="@(showPassword ? "text" : "password")" class="form-control" @bind="password" @bind:event="oninput" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" style="padding-right: 3rem;" />
                                <button type="button" @onclick="TogglePassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                                    <PasswordToggleIcon IsVisible="@showPassword" />
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Confirm New Password</label>
                            <input type="password" class="form-control" @bind="confirmPassword" @bind:event="oninput" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" />
                        </div>
                    </div>
                }
            </div>
        }

        <div class="form-group">
            <label>Role</label>
            <select class="form-control" value="@roleId" @onchange="OnRoleChange">
                <option value="0">-- Select Role --</option>
                @foreach (UserRole role in availableRoles)
                {
                    <option value="@role.Id">@role.Name</option>
                }
            </select>
        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                @errorMessage
            </div>
        }

        <div style="display: flex; gap: 1rem; margin-top: 1rem; justify-content: center;">
            <button class="view-btn active" style="padding: 0.8rem 2rem;" @onclick="HandleSave">@(isAdding ? "Create User" : "Save Changes")</button>
            <button class="view-btn" style="padding: 0.8rem 2rem;" @onclick="HandleCancel">Cancel</button>
        </div>
    </div>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Email</th>
                            <th>Role</th>
                            <th style="text-align: left;">Created</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (User user in users)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@user.Email</td>
                                <td>
                                    <span class="badge @GetRoleBadgeClass(user.Role?.Name)" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                        @(user.Role?.Name ?? "Unknown")
                                    </span>
                                </td>
                                <td style="text-align: left;">@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" style="margin-right: 0.5rem;" @onclick="() => StartEdit(user)">Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(user.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (User user in users)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name">@user.Email</div>
                        <span class="badge @GetRoleBadgeClass(user.Role?.Name)" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">
                            @(user.Role?.Name ?? "Unknown")
                        </span>
                    </div>
                    <div style="margin-bottom: 1rem; color: #666; font-size: 0.9rem;">
                        <strong>Created:</strong> @user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick="() => StartEdit(user)">Edit</button>
                        <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red); flex: 1;" @onclick="() => ShowDeleteConfirm(user.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete User" 
    Message="Are you sure you want to delete this user? They will no longer be able to log in."
    OnConfirm="DeleteUser"
    OnCancel="() => showConfirm = false" />

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    private List<User> users = new();
    private List<UserRole> availableRoles = new();
    private bool isAdding = false;
    private bool isEditing = false;
    private int editingUserId = 0;
    
    private string userEmail = "";
    private string password = "";
    private string confirmPassword = "";
    private int roleId = 0;
    
    private bool showPassword = false;
    private bool showPasswordFields = false;
    private string errorMessage = "";
    
    private bool showConfirm = false;
    private bool showDiscardConfirm = false;
    private int userIdToDelete;
    private bool hasChanges = false;

    private class UserEditState
    {
        public int UserId { get; set; }
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public int RoleId { get; set; }
        public bool IsAdding { get; set; }
        public bool IsEditing { get; set; }
        public bool HasChanges { get; set; }
        public bool ShowPasswordFields { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HydrateTempState();
        }
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<UserEditState> result = await ProtectedSessionStore.GetAsync<UserEditState>("UserEditState");
            if (result.Success && result.Value != null && (result.Value.IsAdding || result.Value.IsEditing))
            {
                editingUserId = result.Value.UserId;
                userEmail = result.Value.Email;
                password = result.Value.Password;
                confirmPassword = result.Value.ConfirmPassword;
                roleId = result.Value.RoleId;
                isAdding = result.Value.IsAdding;
                isEditing = result.Value.IsEditing;
                hasChanges = result.Value.HasChanges;
                showPasswordFields = result.Value.ShowPasswordFields;
                StateHasChanged();
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            UserEditState state = new UserEditState
            {
                UserId = editingUserId,
                Email = userEmail,
                Password = password,
                ConfirmPassword = confirmPassword,
                RoleId = roleId,
                IsAdding = isAdding,
                IsEditing = isEditing,
                HasChanges = hasChanges,
                ShowPasswordFields = showPasswordFields
            };
            await ProtectedSessionStore.SetAsync("UserEditState", state);
        }
        catch (Exception) { }
    }

    private async Task HandleInput()
    {
        hasChanges = true;
        await SaveTempState();
    }

    private async Task ClearTempState()
    {
        hasChanges = false;
        isAdding = false;
        isEditing = false;
        try
        {
            await ProtectedSessionStore.DeleteAsync("UserEditState");
        }
        catch (Exception) { }
    }

    private async Task LoadData()
    {
        users = await AuthService.GetUsersAsync();
        availableRoles = await AuthService.GetUserRolesAsync(true);
    }

    private string GetRoleBadgeClass(string? roleName) => roleName switch
    {
        "Administrator" => "bg-dark",
        "Team Rep" => "bg-primary",
        "Scorekeeper" => "bg-warning",
        "Player" => "bg-info",
        _ => "bg-secondary"
    };

    private async Task StartAdd()
    {
        userEmail = "";
        password = "";
        confirmPassword = "";
        roleId = 0;
        isAdding = true;
        isEditing = false;
        hasChanges = false;
        showPasswordFields = true;
        await SaveTempState();
    }

    private async Task StartEdit(User user)
    {
        editingUserId = user.Id;
        userEmail = user.Email;
        password = "";
        confirmPassword = "";
        roleId = user.RoleId;
        isEditing = true;
        isAdding = false;
        hasChanges = false;
        showPasswordFields = false;
        await SaveTempState();
    }

    private async Task HandleCancel()
    {
        if (hasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        userEmail = "";
        password = "";
        confirmPassword = "";
        roleId = 0;
    }

    private async Task OnRoleChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            hasChanges = true;
            roleId = id;
            await SaveTempState();
        }
    }

    private void TogglePassword() => showPassword = !showPassword;

    private async Task TogglePasswordFields()
    {
        showPasswordFields = !showPasswordFields;
        if (!showPasswordFields)
        {
            password = "";
            confirmPassword = "";
        }
        await SaveTempState();
    }

    private async Task HandleSave()
    {
        errorMessage = "";

        // 1. Basic Validation
        if (string.IsNullOrWhiteSpace(userEmail)) { errorMessage = "Email is required."; return; }
        if (!IsValidEmail(userEmail)) { errorMessage = "Invalid email format."; return; }
        if (roleId == 0) { errorMessage = "Role is required."; return; }

        // 2. Password Validation (if adding or explicit update)
        if (isAdding || (isEditing && showPasswordFields))
        {
            if (string.IsNullOrEmpty(password)) { errorMessage = "Password is required."; return; }
            if (password != confirmPassword) { errorMessage = "Passwords do not match."; return; }
            if (password.Length < 8) { errorMessage = "Password must be at least 8 characters."; return; }
            if (!Regex.IsMatch(password, @"[A-Z]") || !Regex.IsMatch(password, @"[0-9]")) 
            { 
                errorMessage = "Password must contain at least one uppercase letter and one number."; 
                return; 
            }
        }

        // 3. Save
        if (isAdding)
        {
            bool result = await AuthService.RegisterAsync(userEmail, password, roleId);
            if (!result) { errorMessage = "Error creating user. Email might already exist."; return; }
        }
        else
        {
            // Update User Info
            await AuthService.UpdateUserAsync(new User { Id = editingUserId, Email = userEmail, RoleId = roleId });
            
            // Update Password if fields are shown
            if (showPasswordFields && !string.IsNullOrEmpty(password))
            {
                await AuthService.UpdateUserPasswordAsync(editingUserId, password);
            }
        }

        await ClearTempState();
        await LoadData();
    }

    private bool IsValidEmail(string email)
    {
        try { return Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"); }
        catch { return false; }
    }

    private void ShowDeleteConfirm(int id)
    {
        userIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeleteUser()
    {
        showConfirm = false;
        await AuthService.DeleteUserAsync(userIdToDelete);
        await LoadData();
    }
}
