@page "/career/{PlayerName}/{SeasonName}"
@using IsotopesStats.Website.Services
@using IsotopesStats.Domain.Models
@inject IStatsRepository StatsRepository
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject SharedSessionState SharedState

<PageTitle>Isotopes - @PlayerName</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">
        <span class="mobile-only">@PlayerName</span>
        <span class="desktop-only">@PlayerName - Career Stats</span>
    </h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <SeasonSelector 
            Seasons="@seasons" 
            SelectedSeasonId="@GetSeasonId(SeasonName)" 
            OnSeasonSelected="OnSeasonSelected"
            AllowAllSeasons="true" />
    </div>
</div>

@if (isLoading)
{
    <LoadingIndicator />
}
else
{
    @if (allLogs == null || !allLogs.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Games Found</h4>
            <p>This player doesn't have any stats found.</p>
        </div>
    }
    else
    {
        <div class="mobile-only">
            <div style="margin-bottom: 1.5rem;">
                <div class="mobile-switcher">
                    <button class="@(activeView == "Stats" ? "active" : "")" @onclick='() => activeView = "Stats"'>Career Stats</button>
                    <button class="@(activeView == "Log" ? "active" : "")" @onclick='() => activeView = "Log"'>Game Log</button>
                </div>
            </div>

            @if (activeView == "Stats")
            {
                <div class="mobile-list-container">
                    <div class="mobile-list-header" style="padding: 12px 16px;">
                        <div class="mobile-list-rank" style="justify-content: center; padding-right: 24px;">#</div>
                        <div class="mobile-list-name" style="text-align: left; justify-content: flex-start;">Stat</div>
                        <div class="mobile-list-value">Value</div>
                    </div>
                    <div class="subtle-fade-in">
                        @{
                            int targetSeasonId = GetSeasonId(SeasonName);
                            PlayerStatsSummary? statsToUse = targetSeasonId == SharedSessionState.AllSeasonsId ? overallCareerStats : playerSummary;
                            bool hasPlayedInSeason = statsToUse != null && (targetSeasonId == SharedSessionState.AllSeasonsId ? statsToUse.GamesPlayed > 0 : statsToUse.PA > 0);
                        }

                        @foreach (string stat in AllSortableStats)
                        {
                            string value = hasPlayedInSeason ? GetStatValue(statsToUse!, stat) : "-";
                            string rank = hasPlayedInSeason ? GetRankForSeason(stat, targetSeasonId, statsToUse!) : "-";
                            string rankClass = rank.Contains("1st") ? "rank-1" : rank.Contains("2nd") ? "rank-2" : rank.Contains("3rd") ? "rank-3" : "";
                            string statFullName = StatDefinitions.GetDefinition(stat);
                            if (string.IsNullOrEmpty(statFullName)) statFullName = stat;

                            <div class="mobile-list-item" style="cursor: default; padding: 12px 16px;">
                                <div class="mobile-list-rank @rankClass" style="justify-content: center; padding-right: 24px;">@rank</div>
                                <div class="mobile-list-name" style="text-align: left; justify-content: flex-start; min-width: 0; white-space: normal; line-height: 1.2;">@statFullName</div>
                                <div class="mobile-list-value">@value</div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (activeView == "Log" && logs != null)
            {
                <div class="game-cards-list">
                    @for (int i = 0; i < logs.Count; i++)
                    {
                        GameStatsExtendedView log = logs[i];
                        double currentDelay = i * 0.1;

                        <div class="game-card view-fade-in" style="animation-delay: @(currentDelay)s; margin-bottom: 1rem;">
                            <div class="game-card-header" style="cursor: default; padding: 1.25rem !important; display: block;">
                                <div class="mobile-scoreboard">
                                    <div class="scoreboard-meta">
                                        <span>GAME #@log.GameNumber</span>
                                        <span>@log.Date.ToString("MMM dd @ h:mm tt")</span>
                                        <GameResultBadge OurScore="log.OurScore" OpponentScore="log.OpponentScore" Style="margin: 0; font-size: 0.65rem; padding: 2px 6px;" />
                                    </div>
                                    <div class="scoreboard-matchup">
                                        <div class="scoreboard-team visitor smart-name-container">
                                            <span class="full-name">@(log.IsHome ? log.OpponentName : "Isotopes")</span>
                                            @if (log.IsHome && !string.IsNullOrEmpty(log.OpponentShortName))
                                            {
                                                <span class="short-name">@log.OpponentShortName</span>
                                            }
                                            else if (!log.IsHome)
                                            {
                                                <span class="short-name">Isotopes</span>
                                            }
                                        </div>
                                        <div class="scoreboard-scores">
                                            <span class="scoreboard-score">@(log.VisitingTeamScore?.ToString() ?? "0")</span>
                                            <span class="scoreboard-divider">-</span>
                                            <span class="scoreboard-score">@(log.HomeTeamScore?.ToString() ?? "0")</span>
                                        </div>
                                        <div class="scoreboard-team home smart-name-container">
                                            <span class="full-name">@(log.IsHome ? "Isotopes" : log.OpponentName)</span>
                                            @if (!log.IsHome && !string.IsNullOrEmpty(log.OpponentShortName))
                                            {
                                                <span class="short-name">@log.OpponentShortName</span>
                                            }
                                            else if (log.IsHome)
                                            {
                                                <span class="short-name">Isotopes</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="scoreboard-location">
                                        <span>📍 @log.Diamond</span>
                                    </div>
                                </div>
                            </div>

                            <div class="game-card-detail expanded" style="border-top: 1px solid #eee; padding: 1.25rem; background: white;">
                                <div class="stat-badge-list">
                                    @if (log.PA > 0) { <div class="stat-badge primary-stat"><span class="stat-badge-val">@log.PA</span><span class="stat-badge-lbl">PA</span></div> }
                                    @if (log.AB > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.AB</span><span class="stat-badge-lbl">AB</span></div> }
                                    @if (log.R > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.R</span><span class="stat-badge-lbl">R</span></div> }
                                    @if (log.H > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H</span><span class="stat-badge-lbl">H</span></div> }
                                    @if (log.H1B > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H1B</span><span class="stat-badge-lbl">1B</span></div> }
                                    @if (log.H2B > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H2B</span><span class="stat-badge-lbl">2B</span></div> }
                                    @if (log.H3B > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H3B</span><span class="stat-badge-lbl">3B</span></div> }
                                    @if (log.HR > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.HR</span><span class="stat-badge-lbl">HR</span></div> }
                                    @if (log.IPHR > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.IPHR</span><span class="stat-badge-lbl">IPHR</span></div> }
                                    @if (log.RBI > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.RBI</span><span class="stat-badge-lbl">RBI</span></div> }
                                    @if (log.BB > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.BB</span><span class="stat-badge-lbl">BB</span></div> }
                                    @if (log.K > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.K</span><span class="stat-badge-lbl">K</span></div> }
                                    @if (log.KF > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.KF</span><span class="stat-badge-lbl">KF</span></div> }
                                    @if (log.SF > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.SF</span><span class="stat-badge-lbl">SF</span></div> }
                                    @if (log.FC > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.FC</span><span class="stat-badge-lbl">FC</span></div> }
                                    @if (log.GO > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.GO</span><span class="stat-badge-lbl">GO</span></div> }
                                    @if (log.FO > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.FO</span><span class="stat-badge-lbl">FO</span></div> }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="desktop-only">
            <div class="table-container box-score-table-wrapper view-fade-in" style="padding: 0; margin-bottom: 2rem;">
                <table class="box-score-table career-table table-sm" style="margin-bottom: 0;">
                <thead>
                    <tr>
                        <th class="career-season-name sortable-header @(careerSortColumn == "Season" ? "active-sort-header" : "")" style="text-align: left !important; padding-left: 12px !important;" @onclick='() => SortCareer("Season")'>
                            <span style="position: relative; display: inline-block;">
                                Season<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "Season"))</span>
                            </span>
                        </th>
                        <th class="group-divider narrow-col sortable-header @(careerSortColumn == "GP" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("GP")" @onclick='() => SortCareer("GP")'>
                            <span style="position: relative; display: inline-block;">
                                GP<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "GP"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "PA" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("PA")" @onclick='() => SortCareer("PA")'>
                            <span style="position: relative; display: inline-block;">
                                PA<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "PA"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "AB" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("AB")" @onclick='() => SortCareer("AB")'>
                            <span style="position: relative; display: inline-block;">
                                AB<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "AB"))</span>
                            </span>
                        </th>
                        <th class="group-divider narrow-col sortable-header @(careerSortColumn == "R" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("R")" @onclick='() => SortCareer("R")'>
                            <span style="position: relative; display: inline-block;">
                                R<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "R"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "H" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("H")" @onclick='() => SortCareer("H")'>
                            <span style="position: relative; display: inline-block;">
                                H<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "H"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "1B" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("1B")" @onclick='() => SortCareer("1B")'>
                            <span style="position: relative; display: inline-block;">
                                1B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "1B"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "2B" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("2B")" @onclick='() => SortCareer("2B")'>
                            <span style="position: relative; display: inline-block;">
                                2B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "2B"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "3B" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("3B")" @onclick='() => SortCareer("3B")'>
                            <span style="position: relative; display: inline-block;">
                                3B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "3B"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "HR" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("HR")" @onclick='() => SortCareer("HR")'>
                            <span style="position: relative; display: inline-block;">
                                HR<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "HR"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "IPHR" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("IPHR")" @onclick='() => SortCareer("IPHR")'>
                            <span style="position: relative; display: inline-block;">
                                IPHR<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "IPHR"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "RBI" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("RBI")" @onclick='() => SortCareer("RBI")'>
                            <span style="position: relative; display: inline-block;">
                                RBI<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "RBI"))</span>
                            </span>
                        </th>
                        <th class="group-divider narrow-col sortable-header @(careerSortColumn == "BB" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("BB")" @onclick='() => SortCareer("BB")'>
                            <span style="position: relative; display: inline-block;">
                                BB<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "BB"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "K" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("K")" @onclick='() => SortCareer("K")'>
                            <span style="position: relative; display: inline-block;">
                                K<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "K"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "KF" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("KF")" @onclick='() => SortCareer("KF")'>
                            <span style="position: relative; display: inline-block;">
                                KF<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "KF"))</span>
                            </span>
                        </th>
                        <th class="group-divider narrow-col sortable-header @(careerSortColumn == "SF" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("SF")" @onclick='() => SortCareer("SF")'>
                            <span style="position: relative; display: inline-block;">
                                SF<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "SF"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "FC" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("FC")" @onclick='() => SortCareer("FC")'>
                            <span style="position: relative; display: inline-block;">
                                FC<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "FC"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "GO" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("GO")" @onclick='() => SortCareer("GO")'>
                            <span style="position: relative; display: inline-block;">
                                GO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "GO"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "FO" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("FO")" @onclick='() => SortCareer("FO")'>
                            <span style="position: relative; display: inline-block;">
                                FO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "FO"))</span>
                            </span>
                        </th>
                        <th class="group-divider narrow-col sortable-header @(careerSortColumn == "AVG" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("AVG")" @onclick='() => SortCareer("AVG")'>
                            <span style="position: relative; display: inline-block;">
                                AVG<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "AVG"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "OBP" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("OBP")" @onclick='() => SortCareer("OBP")'>
                            <span style="position: relative; display: inline-block;">
                                OBP<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "OBP"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "SLG" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("SLG")" @onclick='() => SortCareer("SLG")'>
                            <span style="position: relative; display: inline-block;">
                                SLG<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "SLG"))</span>
                            </span>
                        </th>
                        <th class="narrow-col sortable-header @(careerSortColumn == "OPS" ? "active-sort-header" : "")" title="@StatDefinitions.GetDefinition("OPS")" @onclick='() => SortCareer("OPS")'>
                            <span style="position: relative; display: inline-block;">
                                OPS<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon(careerSortColumn, careerIsAscending, "OPS"))</span>
                            </span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (SeasonPlayerStats seasonStat in ApplyCareerSorting())
                    {
                        bool hasPlayed = seasonStat.Stats.PA > 0;
                        <tr class="@(GetSeasonId(SeasonName) == seasonStat.SeasonId ? "selected-season-row" : "")" @onclick="() => OnSeasonSelected(seasonStat.SeasonId)" style="cursor: pointer;">
                            <td class="career-season-name">@seasonStat.SeasonName</td>
                            
                            <td class="group-divider narrow-col">@RenderStatWithMedal("GP", hasPlayed ? seasonStat.Stats.GamesPlayed.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("PA", hasPlayed ? seasonStat.Stats.PA.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("AB", hasPlayed ? seasonStat.Stats.AB.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            
                            <td class="group-divider narrow-col">@RenderStatWithMedal("R", hasPlayed ? seasonStat.Stats.R.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("H", hasPlayed ? seasonStat.Stats.H.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("1B", hasPlayed ? seasonStat.Stats.H1B.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("2B", hasPlayed ? seasonStat.Stats.H2B.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("3B", hasPlayed ? seasonStat.Stats.H3B.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("HR", hasPlayed ? seasonStat.Stats.HR.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("IPHR", hasPlayed ? seasonStat.Stats.IPHR.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("RBI", hasPlayed ? seasonStat.Stats.RBI.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            
                            <td class="group-divider narrow-col">@RenderStatWithMedal("BB", hasPlayed ? seasonStat.Stats.BB.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("K", hasPlayed ? seasonStat.Stats.K.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("KF", hasPlayed ? seasonStat.Stats.KF.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            
                            <td class="group-divider narrow-col">@RenderStatWithMedal("SF", hasPlayed ? seasonStat.Stats.SF.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("FC", hasPlayed ? seasonStat.Stats.FC.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("GO", hasPlayed ? seasonStat.Stats.GO.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("FO", hasPlayed ? seasonStat.Stats.FO.ToString() : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            
                            <td class="group-divider narrow-col">@RenderStatWithMedal("AVG", hasPlayed ? seasonStat.Stats.AVG.ToString(".000") : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("OBP", hasPlayed ? seasonStat.Stats.OBP.ToString(".000") : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("SLG", hasPlayed ? seasonStat.Stats.SLG.ToString(".000") : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                            <td class="narrow-col">@RenderStatWithMedal("OPS", hasPlayed ? seasonStat.Stats.OPS.ToString(".000") : "-", seasonStat.SeasonId, seasonStat.Stats)</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="game-summary-row">
                        <td class="career-season-name">Career</td>
                        <td class="group-divider narrow-col">@RenderStatWithMedal("GP", overallCareerStats.GamesPlayed.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("PA", overallCareerStats.PA.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("AB", overallCareerStats.AB.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        
                        <td class="group-divider narrow-col">@RenderStatWithMedal("R", overallCareerStats.R.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("H", overallCareerStats.H.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("1B", overallCareerStats.H1B.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("2B", overallCareerStats.H2B.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("3B", overallCareerStats.H3B.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
                        <td class="narrow-col">@RenderStatWithMedal("HR", overallCareerStats.HR.ToString(), SharedSessionState.AllSeasonsId, overallCareerStats)</td>
