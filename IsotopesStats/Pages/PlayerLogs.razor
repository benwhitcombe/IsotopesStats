@page "/player/{PlayerName}/{SeasonId:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject StatsService StatsService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - @PlayerName Game Log</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h3 style="margin:0">@PlayerName - Game Log</h3>
    <button class="view-btn" @onclick="GoBack">Back to Stats</button>
</div>

@if (logs == null)
{
    <div class="stat-card">
        <div class="skeleton" style="height: 400px; width: 100%;"></div>
    </div>
}
else if (!logs.Any())
{
    <div class="empty-state">
        <span class="empty-icon">⚾</span>
        <h4>No Games Found</h4>
        <p>This player doesn't have any stats for the selected season.</p>
    </div>
}
else
{
    <div class="stat-card view-fade-in" style="margin-bottom: 1.5rem;">
        <div class="stat-grid">
            <div class="stat-item">
                <span class="stat-label">Games</span>
                <span class="stat-value">@logs.Count</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">Hits</span>
                <span class="stat-value">@logs.Sum(l => l.H)</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">HR</span>
                <span class="stat-value">@logs.Sum(l => l.HR)</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">RBI</span>
                <span class="stat-value">@logs.Sum(l => l.RBI)</span>
            </div>
        </div>
    </div>

    <div class="table-container view-fade-in">
        <div class="box-score-table-wrapper">
            <table class="box-score-table table-sm">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Opponent</th>
                        <th>PA</th>
                        <th>AB</th>
                        <th>H</th>
                        <th>2B</th>
                        <th>3B</th>
                        <th>4B</th>
                        <th>HR</th>
                        <th>RBI</th>
                        <th>BB</th>
                        <th>K</th>
                        <th>KF</th>
                        <th>R</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (StatEntry log in logs)
                    {
                        <tr>
                            <td style="color: #666;">@log.Game?.Date.ToString("MMM dd")</td>
                            <td style="font-weight: bold; text-align: left;">@log.Game?.Opponent</td>
                            <td>@log.PA</td>
                            <td>@log.AB</td>
                            <td style="font-weight: bold; color: var(--isotopes-accent);">@log.H</td>
                            <td>@log.H2B</td>
                            <td>@log.H3B</td>
                            <td>@log.H4B</td>
                            <td style="color: var(--isotopes-red); font-weight: bold;">@log.HR</td>
                            <td>@log.RBI</td>
                            <td>@log.BB</td>
                            <td>@log.K</td>
                            <td>@log.KF</td>
                            <td>@log.R</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public string PlayerName { get; set; } = string.Empty;
    [Parameter] public int SeasonId { get; set; }

    private List<StatEntry>? logs;

    protected override async Task OnInitializedAsync()
    {
        // Small delay for smooth entry
        await Task.Delay(100);
        logs = StatsService.GetPlayerGameLog(PlayerName, SeasonId);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo(SharedState.ReturnUrl);
    }
}
