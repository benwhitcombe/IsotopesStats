                            </div>
                        }
                    </div>
                }
            }

            @if (upcomingGames.Any())
            {
                <h4 style="margin: 2rem 0 1rem; color: #666; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Upcoming games</h4>
