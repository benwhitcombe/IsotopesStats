@page "/management/roles"
@page "/management/roles/{Action}"
@page "/management/roles/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "Manage Roles")]
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Roles</PageTitle>

<DeleteManager TItem="UserRole" @ref="deleteManager" OnDeleted="LoadData" DeleteAction="AuthService.DeleteUserRoleAsync" />

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Roles</h3>
    @if (!isAdding && !isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Role</button>
    }
</div>

@if (isAdding || isEditing)
{
    <ModelEditor 
        TItem="UserRole"
        Title="@($"{(isAdding ? "Add" : "Edit")} User Role")"
        Item="editingRole"
        OriginalItem="originalRole"
        BasePath="/management/roles"
        OnSave="SaveRole"
        OnDelete="DeleteRole"
        HasCustomChanges="@(() => !selectedPermissionIds.SetEquals(originalPermissionIds))">

        <div class="form-group">
            <label>Role Name</label>
            <InputText class="form-control" @bind-Value="editingRole.Name" @bind-Value:event="oninput" placeholder="e.g. Moderator" />
            <ValidationMessage For="@(() => editingRole.Name)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
        </div>

        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Permissions</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.5rem; border-radius: 8px;">
                @foreach (Permission permission in allPermissions)
                {
                    <CheckboxButton 
                        Id="@($"p-{permission.Id}")" 
                        Text="@permission.Name" 
                        Checked="@selectedPermissionIds.Contains(permission.Id)" 
                        CheckedChanged="@((bool val) => OnPermissionToggled(permission.Id, val))" />
                }
            </div>
        </div>
    </ModelEditor>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Name</th>
                            <th>Permissions</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (UserRole role in roles)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", role.Id)'>@role.Name</td>
                                <td>
                                    <div style="display: flex; flex-wrap: wrap; gap: 0.3rem; justify-content: center;">
                                        @foreach (Permission p in role.Permissions)
                                        {
                                            <span class="badge bg-light text-dark" style="font-size: 0.75rem; padding: 0.3rem 0.6rem; border: 1px solid #eee;">@p.Name</span>
                                        }
                                    </div>
                                </td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", role.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(role)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (UserRole role in roles)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", role.Id)'>@role.Name</div>
                    </div>
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                            @foreach (Permission p in role.Permissions)
                            {
                                <span class="badge bg-light text-dark" style="font-size: 0.7rem;">@p.Name</span>
                            }
                        </div>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", role.Id)'>Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(role)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private DeleteManager<UserRole> deleteManager = null!;
    private List<UserRole> roles = new();
    private List<Permission> allPermissions = new();
    private HashSet<int> selectedPermissionIds = new();
    private HashSet<int> originalPermissionIds = new();
    private UserRole editingRole = new();
    private UserRole originalRole = new();
    private bool isAdding = false;
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        allPermissions = await AuthService.GetPermissionsAsync();
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasAdding = isAdding;
        bool wasEditing = isEditing;
        
        isAdding = Action == "add";
        isEditing = Action == "edit";

        if (isAdding || isEditing)
        {
            if (isAdding && !wasAdding)
            {
                await LoadNewRole();
            }
            else if (isEditing && (!wasEditing || (Id.HasValue && Id != editingRole.Id)))
            {
                await LoadEditingRole();
            }
        }
        else
        {
            editingRole = new UserRole();
            originalRole = new UserRole();
            selectedPermissionIds.Clear();
            originalPermissionIds.Clear();
        }
    }

    private async Task LoadNewRole()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        editingRole = new UserRole();
        originalRole = new UserRole();
        selectedPermissionIds.Clear();
        originalPermissionIds.Clear();
        await HydrateTempState();
    }

    private async Task LoadEditingRole()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        ResetState();
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            UserRole? role = roles.FirstOrDefault(r => r.Id == Id);
            if (role == null)
            {
                role = (await AuthService.GetUserRolesAsync(true)).FirstOrDefault(r => r.Id == Id);
            }

            if (role != null)
            {
                editingRole = role with { };
                originalRole = role with { };
                selectedPermissionIds.Clear();
                originalPermissionIds.Clear();
                foreach (Permission p in role.Permissions)
                {
                    selectedPermissionIds.Add(p.Id);
                    originalPermissionIds.Add(p.Id);
                }
            }
        }
        else
        {
            editingRole = new UserRole();
            originalRole = new UserRole();
            selectedPermissionIds.Clear();
            originalPermissionIds.Clear();
        }

        await HydrateTempState();
    }

    private void ResetState()
    {
        editingRole = new UserRole();
        originalRole = new UserRole();
        selectedPermissionIds.Clear();
        originalPermissionIds.Clear();
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<UserRole> result = await ProtectedSessionStore.GetAsync<UserRole>($"EditState_UserRole_{Id ?? 0}");
            if (result.Success && result.Value != null)
            {
                editingRole = result.Value;
                StateHasChanged();
            }
        }
        catch (Exception) { }
    }

    private async Task LoadData()
    {
        roles = await AuthService.GetUserRolesAsync(true);
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/roles/add");
        else Navigation.NavigateTo($"/management/roles/edit/{id}");
    }

    private async Task<string?> CheckUniqueRole(UserRole model)
    {
        if (string.IsNullOrWhiteSpace(model.Name)) return null;
        bool isUnique = await AuthService.IsRoleNameUniqueAsync(model.Name, model.Id);
        return isUnique ? null : "A role with this name already exists.";
    }

    private void OnPermissionToggled(int permissionId, bool isChecked)
    {
        if (isChecked) selectedPermissionIds.Add(permissionId);
        else selectedPermissionIds.Remove(permissionId);
    }

    private async Task SaveRole()
    {
        editingRole.Permissions = allPermissions.Where(p => selectedPermissionIds.Contains(p.Id)).ToList();
        
        if (editingRole.Id == 0)
        {
            await AuthService.AddUserRoleAsync(editingRole);
        }
        else
        {
            await AuthService.UpdateUserRoleAsync(editingRole);
        }
        await LoadData();
    }

    private async Task DeleteRole()
    {
        await AuthService.DeleteUserRoleAsync(editingRole.Id);
        await LoadData();
    }
}
