@code {
    [Parameter] public string? SeasonName { get; set; }

    private List<GameSummaryView>? summaries;
    private Dictionary<int, List<GameStatsExtendedView>> expandedStats = new();
    private List<Season> seasons = new();
    private string filterText = "";
    private bool isLoading = true;
    private int effectiveSeasonId;

    private IEnumerable<GameSummaryView> FilteredSummaries =>
        (summaries ?? new List<GameSummaryView>())
        .Where(s =>
            string.IsNullOrEmpty(filterText) ||
            s.OpponentName.Contains(filterText, StringComparison.OrdinalIgnoreCase)
        )
        .OrderByDescending(s => s.Date);

    protected override async Task OnInitializedAsync()
    {
        SharedState.ReturnUrl = "gamestats";
        seasons = await StatsRepository.GetSeasonsAsync();

        filterText = SessionState.FilterText;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(SeasonName))
        {
            int targetId = SharedState.SelectedSeasonId;
            if (targetId <= 0 || targetId == SharedSessionState.AllSeasonsId)
            {
                if (SessionState.LastValidSeasonId > 0)
                {
                    targetId = SessionState.LastValidSeasonId;
                }
                else
                {
                    targetId = await StatsRepository.GetMostRecentStatsSeasonIdAsync();
                    if (targetId == 0 && seasons.Any())
                    {
                        targetId = seasons.First().Id;
                    }
                }
            }
            
            string name = GetSeasonName(targetId);
            Navigation.NavigateTo($"/gamestats/{Uri.EscapeDataString(name)}", replace: true);
            return;
        }

        int seasonId = GetSeasonId(SeasonName);
        
        // Game stats doesn't support 'all'
        if (seasonId <= 0 || seasonId == SharedSessionState.AllSeasonsId)
        {
            if (SessionState.LastValidSeasonId > 0)
            {
                seasonId = SessionState.LastValidSeasonId;
            }
            else
            {
                seasonId = await StatsRepository.GetMostRecentStatsSeasonIdAsync();
                if (seasonId == 0 && seasons.Any())
                {
                    seasonId = seasons.First().Id;
                }
            }
            
            string name = GetSeasonName(seasonId);
            Navigation.NavigateTo($"/gamestats/{Uri.EscapeDataString(name)}", replace: true);
            return;
        }

        effectiveSeasonId = seasonId;
        SessionState.LastValidSeasonId = seasonId;
        
        if (SharedState.SelectedSeasonId != seasonId && SharedState.SelectedSeasonId != SharedSessionState.AllSeasonsId)
        {
            SharedState.SelectedSeasonId = seasonId;
        }

        await LoadData();
    }

    private string GetSeasonName(int id)
    {
        if (id == SharedSessionState.AllSeasonsId) return "all";
        return seasons.FirstOrDefault(s => s.Id == id)?.Name ?? "all";
    }

    private int GetSeasonId(string name)
    {
        if (string.Equals(name, "all", StringComparison.OrdinalIgnoreCase)) return SharedSessionState.AllSeasonsId;
        return seasons.FirstOrDefault(s => string.Equals(s.Name, name, StringComparison.OrdinalIgnoreCase))?.Id ?? 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("drawerDragging.initOpponentNames");
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            summaries = await StatsRepository.GetGameSummariesAsync(effectiveSeasonId);
            
            // Re-fetch expanded games if needed
            foreach (KeyValuePair<int, GameUIState> state in SessionState.GameUIStates.Where(s => s.Value.IsExpanded))
            {
                if (summaries != null && summaries.Any(s => s.GameId == state.Key))
                {
                    expandedStats[state.Key] = await StatsRepository.GetExtendedGameStatsAsync(state.Key);
                }
            }
        }
        catch (Exception)
        {
            summaries = new List<GameSummaryView>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSeasonSelected(int id)
    {
        SharedState.SelectedSeasonId = id;
        string name = GetSeasonName(id);
        Navigation.NavigateTo($"/gamestats/{Uri.EscapeDataString(name)}");
    }

    private void ClearFilter()
    {
        filterText = "";
        UpdateFilterState();
    }

    private void UpdateFilterState()
    {
        SessionState.FilterText = filterText;
    }

    private async Task ToggleGame(GameSummaryView summary)
    {
        int gameId = summary.GameId;
        GameUIState state = SessionState.GetState(gameId);
        state.IsExpanded = !state.IsExpanded;
        SessionState.TriggerChange();

        if (state.IsExpanded && (!expandedStats.ContainsKey(gameId) || expandedStats[gameId] == null))
        {
            StateHasChanged();
            expandedStats[gameId] = await StatsRepository.GetExtendedGameStatsAsync(gameId);
        }

        StateHasChanged();
    }

    private void Sort(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);

        if (state.SortColumn == column)
        {
            state.IsAscending = !state.IsAscending;
        }
        else
        {
            state.SortColumn = column;
            state.IsAscending = false;
            if (column == "Player" || column == "BO") state.IsAscending = true;
        }
        SessionState.TriggerChange();
        StateHasChanged();
    }

    private string GetSortIcon(int gameId, string column)
    {
        GameUIState state = SessionState.GetState(gameId);
        if (state.SortColumn != column) return "";
        return state.IsAscending ? "▲" : "▼";
    }

    private IEnumerable<GameStatsExtendedView> ApplyInnerSorting(GameUIState uiState, IEnumerable<GameStatsExtendedView> stats)
    {
        return stats.SortByColumn(uiState.SortColumn, uiState.IsAscending);
    }
}

