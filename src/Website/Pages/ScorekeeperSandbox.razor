@page "/sandbox/scorekeeper"
@using IsotopesStats.Domain.Interfaces
@using IsotopesStats.Website.Services
@using IsotopesStats.Website.Shared
@using IsotopesStats.Website.Shared.Models
@inject IStatsRepository StatsRepository
@inject SessionStorageService SessionStorage

<PageTitle>Scorekeeping Sandbox - Isotopes</PageTitle>

@if (provider != null)
{
    <ScorekeeperApp DataProvider="provider" EnableLiveSync="false" GameId="1" ScorecardUrl="/sandbox/scorecard" />
}
else
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@code {
    private SandboxScorekeeperProvider? provider;

    protected override void OnInitialized()
    {
        provider = new SandboxScorekeeperProvider(StatsRepository, SessionStorage);
    }
}
