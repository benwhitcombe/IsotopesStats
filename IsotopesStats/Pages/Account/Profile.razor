@page "/account/profile"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using System.Security.Claims
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.ComponentModel.DataAnnotations
@implements IDisposable
@attribute [Authorize]
@inject AuthService AuthService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - My Profile</PageTitle>

<div class="header-with-filter" style="margin-bottom: 1.5rem;">
    <h3 style="margin:0">My Profile</h3>
</div>

<div style="max-width: 600px; margin: 0 auto;">
    @if (editContext != null)
    {
        <ManagementEditCard 
            Title="Update Profile Information"
            IsEdit="false"
            SaveText="Save Profile"
            EditContext="editContext"
            OnSave="HandleSave"
            OnCancel="HandleCancel">

            <div class="form-group">
                <label>Email Address</label>
                <InputText class="form-control" @bind-Value="profileModel.Email" placeholder="user@isotopes.com" />
                <ValidationMessage For="@(() => profileModel.Email)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                <small style="color: #666; display: block; margin-top: 0.5rem;">Changing your email will affect your login credentials.</small>
            </div>

            <div style="background: #f9f9f9; padding: 1.5rem; border-radius: 12px; margin: 2rem 0; border: 1px solid #eee;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: @(profileModel.ShowPasswordFields ? "1.5rem" : "0")">
                    <label style="margin:0; font-weight: bold;">Security</label>
                    <button type="button" class="view-btn" @onclick="TogglePasswordFields">@(profileModel.ShowPasswordFields ? "Cancel" : "Change Password")</button>
                </div>

                @if (profileModel.ShowPasswordFields)
                {
                    <div class="view-fade-in">
                        <div class="form-group">
                            <label>New Password</label>
                            <div style="position: relative;">
                                <InputText type="@(showPassword ? "text" : "password")" class="form-control" @bind-Value="profileModel.Password" placeholder="••••••••" style="padding-right: 3rem;" />
                                <button type="button" @onclick="TogglePassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                                    <PasswordToggleIcon IsVisible="@showPassword" />
                                </button>
                            </div>
                            <ValidationMessage For="@(() => profileModel.Password)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                        </div>
                        <div class="form-group">
                            <label>Confirm New Password</label>
                            <InputText type="password" class="form-control" @bind-Value="profileModel.ConfirmPassword" placeholder="••••••••" />
                            <ValidationMessage For="@(() => profileModel.ConfirmPassword)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                        </div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                    @errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="view-fade-in" style="background: #f0fff4; color: #2f855a; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #c6f6d5; text-align: center; font-weight: 600;">
                    @successMessage
                </div>
            }
        </ManagementEditCard>
    }
</div>

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    private User? currentUser;
    private ProfileViewModel profileModel = new();
    private EditContext? editContext;
    
    private bool showPassword = false;
    private bool showDiscardConfirm = false;
    private string errorMessage = "";
    private string successMessage = "";

    private bool HasChanges => 
        profileModel.Email != profileModel.OriginalEmail || 
        !string.IsNullOrEmpty(profileModel.Password) || 
        !string.IsNullOrEmpty(profileModel.ConfirmPassword) || 
        profileModel.ShowPasswordFields != profileModel.OriginalShowPasswordFields;

    public class ProfileViewModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = "";
        
        public string OriginalEmail { get; set; } = "";

        [StringLength(100, MinimumLength = 8, ErrorMessage = "Password must be at least 8 characters.")]
        [RegularExpression(@"^(?=.*[A-Z])(?=.*[0-9]).+$", ErrorMessage = "Password must contain at least one uppercase letter and one number.")]
        public string Password { get; set; } = "";

        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";

        public bool ShowPasswordFields { get; set; }
        public bool OriginalShowPasswordFields { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(profileModel);
        editContext.OnFieldChanged += HandleFieldChanged;

        AuthenticationState authState = await AuthStateTask;
        ClaimsPrincipal user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            string? email = user.FindFirst(ClaimTypes.Email)?.Value;
            if (!string.IsNullOrEmpty(email))
            {
                List<User> users = await AuthService.GetUsersAsync();
                currentUser = users.FirstOrDefault(u => u.Email == email);
                if (currentUser != null)
                {
                    profileModel.Email = currentUser.Email;
                    profileModel.OriginalEmail = currentUser.Email;
                }
            }
        }

        if (currentUser == null)
        {
            Navigation.NavigateTo("account/login");
        }

        await HydrateTempState();
    }

    private void TogglePassword() => showPassword = !showPassword;

    private async Task TogglePasswordFields()
    {
        profileModel.ShowPasswordFields = !profileModel.ShowPasswordFields;
        if (!profileModel.ShowPasswordFields)
        {
            profileModel.Password = "";
            profileModel.ConfirmPassword = "";
        }
        errorMessage = "";
        successMessage = "";
        await SaveTempState();
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<ProfileViewModel> result = await ProtectedSessionStore.GetAsync<ProfileViewModel>("ProfileEditState");
            if (result.Success && result.Value != null)
            {
                profileModel.Email = result.Value.Email;
                profileModel.OriginalEmail = result.Value.OriginalEmail;
                profileModel.Password = result.Value.Password;
                profileModel.ConfirmPassword = result.Value.ConfirmPassword;
                profileModel.ShowPasswordFields = result.Value.ShowPasswordFields;
                profileModel.OriginalShowPasswordFields = result.Value.OriginalShowPasswordFields;
                editContext?.Validate();
                StateHasChanged();
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            await ProtectedSessionStore.SetAsync("ProfileEditState", profileModel);
        }
        catch (Exception) { }
    }

    private async Task ClearTempState()
    {
        try
        {
            await ProtectedSessionStore.DeleteAsync("ProfileEditState");
        }
        catch (Exception) { }
    }

    private async Task HandleCancel()
    {
        if (HasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        Navigation.NavigateTo("/");
    }

    private async Task HandleFormSubmit()
    {
        if (editContext != null && editContext.Validate())
        {
            await HandleSave();
        }
    }

    private async Task HandleSave()
    {
        if (currentUser == null) return;
        
        errorMessage = "";
        successMessage = "";

        try
        {
            // Save Email if changed
            bool emailChanged = profileModel.Email != currentUser.Email;
            if (emailChanged)
            {
                List<int> roleIds = currentUser.Roles.Select(r => r.Id).ToList();
                await AuthService.UpdateUserAsync(new User { Id = currentUser.Id, Email = profileModel.Email }, roleIds);
                currentUser = currentUser with { Email = profileModel.Email };
                profileModel.OriginalEmail = profileModel.Email;
            }

            // Save Password if changed
            if (profileModel.ShowPasswordFields && !string.IsNullOrEmpty(profileModel.Password))
            {
                await AuthService.UpdateUserPasswordAsync(currentUser.Id, profileModel.Password);
                profileModel.ShowPasswordFields = false;
                profileModel.OriginalShowPasswordFields = false;
                profileModel.Password = "";
                profileModel.ConfirmPassword = "";
            }

            successMessage = "Profile updated successfully!";
            await ClearTempState();
            
            if (emailChanged)
            {
                await AuthStateProvider.UpdateAuthenticationState(currentUser);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while saving: " + ex.Message;
        }
    }

    public void Dispose()
    {
        if (editContext != null)
        {
            editContext.OnFieldChanged -= HandleFieldChanged;
        }
    }

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        _ = SaveTempState();
    }
}
