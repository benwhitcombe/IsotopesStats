@inherits LayoutComponentBase
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using System.Security.Claims
@inject NavigationManager Navigation
@inject SharedSessionState SharedState
@inject IJSRuntime JSRuntime

<div class="page">
    <header class="isotopes-header">
        <div class="header-content">
            <div style="display: flex; align-items: center; gap: 10px;">
                @* Mobile Hamburger Button - Now on the left *@
                <button class="hamburger-btn mobile-only" @onclick="ToggleMenu" title="Menu" style="margin-right: 5px;">
                    <span>☰</span>
                </button>

                <svg class="logo-atom" viewBox="0 0 100 100" width="32" height="32" style="fill:none; stroke:white; stroke-width:5;">
                    <circle cx="50" cy="50" r="5" fill="white" stroke="none"/>
                    <ellipse cx="50" cy="50" rx="45" ry="15" />
                    <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(60 50 50)" />
                    <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(120 50 50)" />
                </svg>
                <h1 style="margin:0; font-size: 1.25rem;">ISOTOPES STATS</h1>
                
                <nav class="desktop-nav">
                    <NavLink href="gamestats" Match="NavLinkMatch.All">Games</NavLink>
                    <NavLink href="" Match="NavLinkMatch.All">Players</NavLink>
                </nav>
            </div>
            
            <div class="header-auth">
                <AuthorizeView Context="authContext">
                    <Authorized>
                        <div style="display: flex; align-items: center; gap: 0.5rem;" class="desktop-only">
                            <a href="account/profile" class="view-btn" style="background: var(--isotopes-red); color: white; border: none; font-weight: bold; text-decoration: none; display: flex; align-items: center; padding: 0.5rem 1.25rem;">
                                <span>@authContext.User.Identity?.Name</span>
                            </a>
                            <a href="account/logout" class="view-btn" style="background: var(--isotopes-red); color: white; border: none; display: flex; align-items: center; justify-content: center; padding: 0.5rem 1.25rem; text-decoration: none; font-weight: bold;">
                                <span>Logout</span>
                            </a>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="@GetLoginUrl()" class="view-btn desktop-only" style="background: var(--isotopes-red); color: white; border: none; font-weight: bold; text-decoration: none; display: flex; align-items: center; justify-content: center; padding: 0.5rem 1.25rem;">
                            <span>Login</span>
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    @if (isMenuOpen)
    {
        <div class="mobile-drawer-overlay" @onclick="ToggleMenu"></div>
        <div class="mobile-drawer">
            <div class="drawer-header">
                <h3 style="margin:0">Isotopes</h3>
                <button class="hamburger-btn" @onclick="ToggleMenu">✕</button>
            </div>
            <div class="drawer-content" style="padding-top: 0;">
                @* Public Links *@
                <div style="padding: 1rem 0;">
                    <NavLink href="gamestats" class="drawer-item" @onclick="ToggleMenu">
                        <span>⚾</span> Games
                    </NavLink>
                    <NavLink href="" Match="NavLinkMatch.All" class="drawer-item" @onclick="ToggleMenu">
                        <JerseyIcon /> Players
                    </NavLink>
                </div>

                @* Management Links - Only show container if user has at least one management permission *@
                <AuthorizeView Context="mgmtContext">
                    <Authorized>
                        @if (HasAnyManagementPermission(mgmtContext.User))
                        {
                            <div style="background: #f9f9f9; border-top: 1px solid #eee; border-bottom: 1px solid #eee; padding-bottom: 1rem;">
                                @* Management Section *@
                                <div style="padding: 1.5rem 1.5rem 0.5rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #999; font-weight: bold;">
                                    Management
                                </div>
                                <AuthorizeView Policy="Manage Games" Context="pContext">
                                    <NavLink href="management/games" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <span>🏟️</span> Games
                                    </NavLink>
                                </AuthorizeView>
                                <AuthorizeView Policy="Manage Opponents" Context="pContext">
                                    <NavLink href="management/opponents" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                                        </svg> Opponents
                                    </NavLink>
                                </AuthorizeView>
                                <AuthorizeView Policy="Manage Players" Context="pContext">
                                    <NavLink href="management/players" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <span>👥</span> Players
                                    </NavLink>
                                </AuthorizeView>
                                <AuthorizeView Policy="Manage Seasons" Context="pContext">
                                    <NavLink href="management/seasons" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <span>🗓️</span> Seasons
                                    </NavLink>
                                </AuthorizeView>

                                @* Administration Section *@
                                <div style="padding: 1.5rem 1.5rem 0.5rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #999; font-weight: bold; border-top: 1px solid #eee; margin-top: 0.5rem;">
                                    Administration
                                </div>
                                <AuthorizeView Policy="Manage Logs" Context="pContext">
                                    <NavLink href="management/logs" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <span>📜</span> Logs
                                    </NavLink>
                                </AuthorizeView>
                                <AuthorizeView Policy="Manage Roles" Context="pContext">
                                    <NavLink href="management/roles" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <span>🛠️</span> Roles
                                    </NavLink>
                                </AuthorizeView>
                                <AuthorizeView Policy="Manage Users" Context="pContext">
                                    <NavLink href="management/users" class="drawer-item" style="border-bottom: none; background: transparent;" @onclick="ToggleMenu">
                                        <span>🔐</span> Users
                                    </NavLink>
                                </AuthorizeView>
                            </div>
                        }
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="drawer-footer" style="padding: 0;">
                <AuthorizeView Context="footerContext">
                    <Authorized>
                        <a href="account/profile" class="drawer-item" style="border-top: 1px solid #eee; border-bottom: none;" @onclick="ToggleMenu">
                            <span>👤</span> @footerContext.User.Identity?.Name
                        </a>
                        <a href="account/logout" class="drawer-item" style="border:none; color: var(--isotopes-red); padding-top: 0;" @onclick="ToggleMenu">
                            <span>🚪</span> Logout
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="@GetLoginUrl()" class="drawer-item" style="border:none;" @onclick="ToggleMenu">
                            <span>🔑</span> Login
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    }

    <AuthorizeView Context="subnavContext">
        <Authorized>
            @if (HasAnyManagementPermission(subnavContext.User))
            {
                <div class="management-sub-nav desktop-only">
                    <div class="sub-nav-content">
                        <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; color: #999; font-weight: 800; display: flex; align-items: center; margin-right: 1rem; border-right: 1px solid #ddd; padding-right: 1.5rem;">
                            Management
                        </div>
                        <AuthorizeView Policy="Manage Games" Context="pContext">
                            <NavLink href="management/games">Games</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="Manage Opponents" Context="pContext">
                            <NavLink href="management/opponents">Opponents</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="Manage Players" Context="pContext">
                            <NavLink href="management/players">Players</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="Manage Seasons" Context="pContext">
                            <NavLink href="management/seasons">Seasons</NavLink>
                        </AuthorizeView>

                        <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; color: #999; font-weight: 800; display: flex; align-items: center; margin: 0 1rem 0 2rem; border-right: 1px solid #ddd; padding-right: 1.5rem; border-left: 1px solid #ddd; padding-left: 2rem;">
                            Administration
                        </div>
                        <AuthorizeView Policy="Manage Logs" Context="pContext">
                            <NavLink href="management/logs">Logs</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="Manage Roles" Context="pContext">
                            <NavLink href="management/roles">Roles</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="Manage Users" Context="pContext">
                            <NavLink href="management/users">Users</NavLink>
                        </AuthorizeView>
                    </div>
                </div>
            }
        </Authorized>
    </AuthorizeView>

    <main>
        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    private bool isMenuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (SharedState.OpenMenuOnLoad)
        {
            int width = await JSRuntime.InvokeAsync<int>("getWindowWidth");
            if (width <= 768)
            {
                isMenuOpen = true;
                StateHasChanged();
            }
            SharedState.OpenMenuOnLoad = false;
        }
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private string GetLoginUrl()
    {
        string relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (string.IsNullOrEmpty(relativePath) || relativePath.StartsWith("account/login"))
        {
            return "account/login";
        }
        return $"account/login?returnUrl={Uri.EscapeDataString(relativePath)}";
    }

    private bool HasAnyManagementPermission(ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == "Permission" && 
            (c.Value == "Manage Games" || 
             c.Value == "Manage Players" || 
             c.Value == "Manage Opponents" || 
             c.Value == "Manage Seasons" || 
             c.Value == "Manage Users" || 
             c.Value == "Manage Roles" ||
             c.Value == "Manage Logs"));
    }
}
