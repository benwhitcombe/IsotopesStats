@inherits LayoutComponentBase
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject NavigationManager Navigation
@inject SharedSessionState SharedState
@inject IJSRuntime JSRuntime

<div class="page">
    <header class="isotopes-header">
        <div class="header-content">
            <div style="display: flex; align-items: center; gap: 10px;">
                @* Mobile Hamburger Button - Now on the left *@
                <button class="hamburger-btn mobile-only" @onclick="ToggleMenu" title="Menu" style="margin-right: 5px;">
                    <span>☰</span>
                </button>

                <svg class="logo-atom" viewBox="0 0 100 100" width="32" height="32" style="fill:none; stroke:white; stroke-width:5;">
                    <circle cx="50" cy="50" r="5" fill="white" stroke="none"/>
                    <ellipse cx="50" cy="50" rx="45" ry="15" />
                    <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(60 50 50)" />
                    <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(120 50 50)" />
                </svg>
                <h1 style="margin:0; font-size: 1.25rem;">ISOTOPES STATS</h1>
                
                <nav class="desktop-only" style="margin-left: 2rem; display: flex; gap: 1rem;">
                    <NavLink href="" Match="NavLinkMatch.All" class="view-btn" style="background: var(--isotopes-red); color: white; border: none; font-weight: bold; text-decoration: none;">Games</NavLink>
                    <NavLink href="players" class="view-btn" style="background: var(--isotopes-red); color: white; border: none; font-weight: bold; text-decoration: none;">Players</NavLink>
                </nav>
            </div>
            
            <div class="header-auth">
                <AuthorizeView Context="authContext">
                    <Authorized>
                        <div style="display: flex; align-items: center; gap: 0.5rem;" class="desktop-only">
                            <span style="font-size: 0.8rem; opacity: 0.9; margin-right: 0.5rem;">@authContext.User.Identity?.Name (@authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                            <a href="account/logout" class="view-btn" style="background: var(--isotopes-red); color: white; border: none; display: flex; align-items: center; justify-content: center; padding: 0.4rem 1rem; text-decoration: none; font-weight: bold; border-radius: 20px;">
                                <span>Logout</span>
                            </a>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="@GetLoginUrl()" class="view-btn desktop-only" style="background: var(--isotopes-red); color: white; border: none; font-weight: bold; text-decoration: none; display: flex; align-items: center; justify-content: center; padding: 0.4rem 1rem; border-radius: 20px;">
                            <span>Login</span>
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    @if (isMenuOpen)
    {
        <div class="mobile-drawer-overlay" @onclick="ToggleMenu"></div>
        <div class="mobile-drawer">
            <div class="drawer-header">
                <h3 style="margin:0">Isotopes</h3>
                <button class="hamburger-btn" @onclick="ToggleMenu">✕</button>
            </div>
            <div class="drawer-content">
                @* Public Links *@
                <NavLink href="" Match="NavLinkMatch.All" class="drawer-item" @onclick="ToggleMenu">
                    <span>⚾</span> Games
                </NavLink>
                <NavLink href="players" class="drawer-item" @onclick="ToggleMenu">
                    <JerseyIcon /> Players
                </NavLink>

                @* Management Links - Conditional by Policy *@
                <AuthorizeView Context="mgmtContext">
                    <Authorized>
                        <div style="padding: 1.5rem 1.5rem 0.5rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #999; font-weight: bold; border-top: 1px solid #eee; margin-top: 0.5rem;">
                            Management
                        </div>
                        <AuthorizeView Policy="ManageGames" Context="pContext">
                            <NavLink href="management/games" class="drawer-item" style="border-bottom: none;" @onclick="ToggleMenu">
                                <span>🏟️</span> Manage Games
                            </NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManagePlayers" Context="pContext">
                            <NavLink href="management/players" class="drawer-item" style="border-bottom: none;" @onclick="ToggleMenu">
                                <span>👥</span> Manage Players
                            </NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManageSeasons" Context="pContext">
                            <NavLink href="management/seasons" class="drawer-item" style="border-bottom: none;" @onclick="ToggleMenu">
                                <span>🗓️</span> Manage Seasons
                            </NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManageUsers" Context="pContext">
                            <NavLink href="management/users" class="drawer-item" style="border-bottom: none;" @onclick="ToggleMenu">
                                <span>🔐</span> Manage Users
                            </NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManageRoles" Context="pContext">
                            <NavLink href="management/roles" class="drawer-item" style="border-bottom: none;" @onclick="ToggleMenu">
                                <span>🛠️</span> Manage Roles
                            </NavLink>
                        </AuthorizeView>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="drawer-footer">
                <AuthorizeView Context="footerContext">
                    <Authorized>
                        <div style="padding: 0 1.5rem 0.5rem 1.5rem; font-size: 0.8rem; color: #888; word-break: break-all; font-weight: 600;">
                            @footerContext.User.Identity?.Name
                        </div>
                        <a href="account/logout" class="drawer-item" style="border:none; color: var(--isotopes-red); padding-top: 0;" @onclick="ToggleMenu">
                            <span>🚪</span> Logout
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="@GetLoginUrl()" class="drawer-item" style="border:none;" @onclick="ToggleMenu">
                            <span>🔑</span> Login
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    }

    <div class="desktop-only">
        <AuthorizeView Context="subnavContext">
            <Authorized>
                <div class="management-sub-nav">
                    <div class="sub-nav-content">
                        <AuthorizeView Policy="ManageGames" Context="pContext">
                            <NavLink href="management/games">Games</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManagePlayers" Context="pContext">
                            <NavLink href="management/players">Players</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManageSeasons" Context="pContext">
                            <NavLink href="management/seasons">Seasons</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManageUsers" Context="pContext">
                            <NavLink href="management/users">Users</NavLink>
                        </AuthorizeView>
                        <AuthorizeView Policy="ManageRoles" Context="pContext">
                            <NavLink href="management/roles">Roles</NavLink>
                        </AuthorizeView>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <main>
        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    private bool isMenuOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (SharedState.OpenMenuOnLoad)
        {
            int width = await JSRuntime.InvokeAsync<int>("getWindowWidth");
            if (width <= 768)
            {
                isMenuOpen = true;
                StateHasChanged();
            }
            SharedState.OpenMenuOnLoad = false;
        }
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private string GetLoginUrl()
    {
        string relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (string.IsNullOrEmpty(relativePath) || relativePath.StartsWith("account/login"))
        {
            return "account/login";
        }
        return $"account/login?returnUrl={Uri.EscapeDataString(relativePath)}";
    }
}
