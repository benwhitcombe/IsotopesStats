@inherits LayoutComponentBase

<PageTitle>Isotopes Stats 2026</PageTitle>

<div class="page">
    <header class="isotopes-header">
        <div class="header-content">
            <div style="display: flex; align-items: center; gap: 10px;">
                <svg class="logo-atom" viewBox="0 0 100 100" width="32" height="32" style="fill:none; stroke:white; stroke-width:5;">
                    <circle cx="50" cy="50" r="5" fill="white" stroke="none"/>
                    <ellipse cx="50" cy="50" rx="45" ry="15" />
                    <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(60 50 50)" />
                    <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(120 50 50)" />
                </svg>
                <h1>ISOTOPES STATS</h1>
            </div>
            
            <nav class="desktop-nav">
                <NavLink href="gamestats">Games</NavLink>
                <NavLink href="" Match="NavLinkMatch.All">Players</NavLink>
            </nav>
        </div>
    </header>

    <main>
        <article class="content">
            @Body
        </article>
    </main>

    <nav class="mobile-nav">
        <NavLink href="gamestats">
            <span class="nav-icon">⚾</span>
            <span>Games</span>
        </NavLink>
        <NavLink href="" Match="NavLinkMatch.All">
            <span class="nav-icon">📋</span>
            <span>Players</span>
        </NavLink>
    </nav>
</div>
