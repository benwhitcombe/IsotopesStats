@page "/defense"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Services
@inject IStatsRepository StatsRepository
@inject SharedSessionState SharedState
@inject SessionStorageService SessionStorage
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Defensive Lineup</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Defensive Lineup</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <SeasonSelector 
            Seasons="@seasons" 
            SelectedSeasonId="@selectedSeasonId" 
            OnSeasonSelected="OnSeasonSelected"
            AllowAllSeasons="false" />
    </div>
</div>

@if (isLoading)
{
    <LoadingIndicator />
}
else
{
    <div class="lineup-card-container">
        <div class="lineup-card-header">
            <div class="team-name">ISOTOPES</div>
            <div class="card-title">DEFENSIVE LINEUP CARD</div>
        </div>
        
        <div class="lineup-content-wrapper">
            <div class="table-pane @(activeViewMode == "field" ? "d-none d-xl-flex" : "")">
                <table class="lineup-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th style="width: 60px;">POS</th>
                            <th>PLAYER NAME</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < assignments.Count; i++)
                        {
                            int index = i;
                            PositionAssignment assignment = assignments[index];
                            <tr @key="assignment.PositionLabel">
                                <td class="pos-num">@assignment.PositionNumber</td>
                                <td class="pos-abbr">@assignment.PositionAbbreviation</td>
                                <td class="player-select-cell">
                                    <PlayerAutocompleteCell 
                                        @ref="autocompleteCells[index]"
                                        Value="@(players.FirstOrDefault(p => p.Id == assignment.PlayerId)?.Name ?? string.Empty)"
                                        Players="@players"
                                        PlayerAssignments="@playerAssignments"
                                        OnSelected="@(p => HandleStarterSelection(assignment, p))"
                                        OnCommit="@(() => FocusNextPosition(index))"
                                        OnFocused="@(() => { selectedIndex = index; selectedFromBench = false; isExplicitlySelected = false; })"
                                        OnBlurred="@(() => { if (selectedIndex == index && selectedFromBench == false && !isExplicitlySelected) { selectedIndex = null; selectedFromBench = null; } })" />
                                </td>
                            </tr>
                        }
                        
                        @{
                            List<int> currentBenchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
                            int totalBenchRows = currentBenchIds.Count + (players.Count > availablePlayerIds.Count ? 1 : 0);
                        }
                        @for (int j = 0; j < totalBenchRows; j++)
                        {
                            int benchIndex = j;
                            int cellIndex = 10 + benchIndex;
                            int? playerId = benchIndex < currentBenchIds.Count ? currentBenchIds[benchIndex] : null;
                            
                            <tr @key="@($"bench-{benchIndex}")">
                                <td class="pos-num">--</td>
                                <td class="pos-abbr">B</td>
                                <td class="player-select-cell">
                                    <PlayerAutocompleteCell 
                                        @ref="autocompleteCells[cellIndex]"
                                        Value="@(players.FirstOrDefault(p => p.Id == playerId)?.Name ?? string.Empty)"
                                        Players="@players"
                                        PlayerAssignments="@playerAssignments"
                                        OnSelected="@(p => HandleBenchSelection(playerId, p))"
                                        OnCommit="@(() => FocusNextPosition(cellIndex))"
                                        OnFocused="@(() => { selectedIndex = benchIndex; selectedFromBench = true; isExplicitlySelected = false; })"
                                        OnBlurred="@(() => { if (selectedIndex == benchIndex && selectedFromBench == true && !isExplicitlySelected) { selectedIndex = null; selectedFromBench = null; } })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="lineup-actions p-3 border-top mt-auto">
                    <div class="d-flex gap-2">
                        <button class="view-btn flex-grow-1" @onclick="ClearAll">Clear All</button>
                        <button class="view-btn active flex-grow-1 d-xl-none" @onclick='() => SetViewMode("field")'>View Defense</button>
                        <button class="view-btn active flex-grow-1 d-none d-xl-block" @onclick="ShareDefense">📤 Share</button>
                    </div>
                </div>
            </div>

            <div class="field-pane @(activeViewMode == "lineup" ? "d-none d-xl-flex" : "d-flex")">

                <div class="field-container-sticky">
                    <DefenseField 
                        Assignments="@fieldAssignments" 
                        BenchPlayers="@benchPlayerNames" 
                        Players="@players"
                        PlayerAssignments="@playerAssignments"
                        SelectedIndex="@selectedIndex" 
                        SelectedFromBench="@selectedFromBench" 
                        IsExplicitlySelected="@isExplicitlySelected"
                        AnimationCounters="@animationCounters" 
                        OnPlayerClick="@(e => HandleFieldClick(e.Index, e.FromBench))"
                        OnDeselect="HandleDeselect"
                        OnPlayerSelected="@(e => HandleInPlaceSelection(e.Index, e.FromBench, e.Player))"
                        IsEditable="true"
                        MaxWidth="800" />
                    
                    <div class="mt-4 d-flex gap-2 justify-content-center mb-4 w-100 px-3 d-xl-none">
                        <button class="view-btn flex-grow-1" @onclick='() => SetViewMode("lineup")'>⬅️ Lineup</button>
                        <button class="view-btn active flex-grow-1" @onclick="ShareDefense">📤 Share</button>
                    </div>
                </div>
            </div>
        </div>

        @if (isInitializing)
        {
            @* Nothing to show while initializing *@
        }
    </div>

    @if (showToast)
    {
        <div class="toast-notification-simple">
            Copied to clipboard!
        </div>
    }
}

@code {
    [Parameter] [SupplyParameterFromQuery(Name = "p")] public string? DefenseData { get; set; }

    private string activeViewMode = "field";

    private void SetViewMode(string mode)
    {
        activeViewMode = mode;
        StateHasChanged();
    }

    private List<Season> seasons = new List<Season>();
    private List<Player> players = new List<Player>();
    private List<int> availablePlayerIds = new List<int>();
    private int selectedSeasonId;
    private bool isLoading = true;
    private bool isInitializing = false;
    private bool showToast = false;

    private Dictionary<int, PlayerAutocompleteCell> autocompleteCells = new();

    private async Task FocusNextPosition(int currentIndex)
    {
        int nextIndex = currentIndex + 1;
        await Task.Yield(); // Give Blazor a chance to render new row if added
        if (autocompleteCells.TryGetValue(nextIndex, out PlayerAutocompleteCell? cell) && cell != null)
        {
            await cell.FocusAsync();
        }
    }

    private void HandleStarterSelection(PositionAssignment assignment, Player? newPlayer)
    {
        int index = assignments.IndexOf(assignment);

        // 1. If we are replacing an existing player in this spot, remove them from the game
        if (assignment.PlayerId.HasValue && (newPlayer == null || assignment.PlayerId != newPlayer.Id))
        {
            availablePlayerIds.Remove(assignment.PlayerId.Value);
        }

        // 2. Determine previous position for animation
        if (newPlayer != null)
        {
            // Where were they before?
            int prevStarterIdx = assignments.FindIndex(a => a != assignment && a.PlayerId == newPlayer.Id);
            if (prevStarterIdx != -1)
            {
                _ = TriggerAnimation(prevStarterIdx, false, DefenseField.AnimationType.Swapped);
            }
            else
            {
                // Were they on the bench?
                List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
                int prevBenchIdx = benchIds.IndexOf(newPlayer.Id);
                if (prevBenchIdx != -1)
                {
                    _ = TriggerAnimation(prevBenchIdx, true, DefenseField.AnimationType.Swapped);
                }
            }
        }

        // 3. Set the new player (triggers HandleAssignmentChange)
        assignment.PlayerId = newPlayer?.Id;
        
        // 4. Animate the current spot
        _ = TriggerAnimation(index, false, newPlayer == null ? DefenseField.AnimationType.Removed : DefenseField.AnimationType.Swapped);

        StateHasChanged();
        UpdateUrl();
    }

    private void HandleBenchSelection(int? oldPlayerId, Player? newPlayer)
    {
        // 1. Identify previous starter spot if moving to bench
        if (newPlayer != null)
        {
            int prevStarterIdx = assignments.FindIndex(a => a.PlayerId == newPlayer.Id);
            if (prevStarterIdx != -1)
            {
                _ = TriggerAnimation(prevStarterIdx, false, DefenseField.AnimationType.Swapped);
            }
        }

        // 2. Perform selection
        if (oldPlayerId.HasValue)
        {
            if (newPlayer == null)
            {
                List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
                int benchIdx = benchIds.IndexOf(oldPlayerId.Value);
                if (benchIdx != -1)
                {
                    _ = TriggerAnimation(benchIdx, true, DefenseField.AnimationType.Removed);
                }
            }
            availablePlayerIds.Remove(oldPlayerId.Value);
        }

        if (newPlayer != null)
        {
            if (!availablePlayerIds.Contains(newPlayer.Id))
            {
                availablePlayerIds.Add(newPlayer.Id);
            }

            // Ensure they aren't assigned to a starter spot
            foreach (PositionAssignment a in assignments)
            {
                if (a.PlayerId == newPlayer.Id) a.PlayerId = null;
            }
        }

        StateHasChanged();
        UpdateUrl();

        // 3. Animate the new bench spot
        if (newPlayer != null)
        {
            List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
            int newBenchIdx = benchIds.IndexOf(newPlayer.Id);
            if (newBenchIdx != -1)
            {
                _ = TriggerAnimation(newBenchIdx, true, DefenseField.AnimationType.Swapped);
            }
        }
    }

    private bool IsPlayerAssigned(int playerId)
    {
        foreach (PositionAssignment a in assignments)
        {
            if (a.PlayerId == playerId) return true;
        }
        return false;
    }

    private int? selectedIndex;
    private bool? selectedFromBench;
    private bool isExplicitlySelected;
    
    private Dictionary<(int Index, bool FromBench), DefenseField.AnimationState> animationCounters = new();

    private List<DefenseField.FieldPositionAssignment> fieldAssignments => assignments.Select(a => new DefenseField.FieldPositionAssignment
    {
        PlayerName = players.FirstOrDefault(p => p.Id == a.PlayerId)?.Name ?? string.Empty,
        X = a.X,
        Y = a.Y
    }).ToList();

    private Dictionary<int, string> playerAssignments 
    {
        get 
        {
            Dictionary<int, string> dict = assignments
                .Where(a => a.PlayerId.HasValue)
                .ToDictionary(a => a.PlayerId!.Value, a => a.PositionAbbreviation);
            
            foreach (int id in availablePlayerIds)
            {
                if (!dict.ContainsKey(id))
                {
                    dict[id] = "B";
                }
            }
            return dict;
        }
    }

    private List<string> benchPlayerNames => availablePlayerIds
        .Where(id => !IsPlayerAssigned(id))
        .Select(id => players.FirstOrDefault(p => p.Id == id)?.Name ?? string.Empty)
        .Where(name => !string.IsNullOrEmpty(name))
        .ToList();

    private void HandleInPlaceSelection(int index, bool fromBench, Player player)
    {
        if (fromBench)
        {
            // If index is BenchPlayers.Count, it's a new bench spot
            int? oldPlayerId = index < benchPlayerNames.Count ? GetBenchPlayerId(index) : null;
            HandleBenchSelection(oldPlayerId, player);
            
            // Animate the new bench spot
            List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
            int newBenchIdx = benchIds.IndexOf(player.Id);
            if (newBenchIdx != -1)
            {
                _ = TriggerAnimation(newBenchIdx, true, DefenseField.AnimationType.Swapped);
            }
        }
        else
        {
            HandleStarterSelection(assignments[index], player);
            _ = TriggerAnimation(index, false, DefenseField.AnimationType.Swapped);
        }
    }

    private void HandleDeselect()
    {
        selectedIndex = null;
        selectedFromBench = null;
        isExplicitlySelected = false;
        StateHasChanged();
    }

    private async Task HandleFieldClick(int index, bool fromBench)
    {
        int? clickedPlayerId = fromBench ? GetBenchPlayerId(index) : assignments[index].PlayerId;

        if (selectedIndex == null || !isExplicitlySelected)
        {
            if (!clickedPlayerId.HasValue)
            {
                // Empty spot clicked: focus the corresponding lineup entry
                int cellIndex = fromBench ? 10 + index : index;
                if (autocompleteCells.TryGetValue(cellIndex, out PlayerAutocompleteCell? cell) && cell != null)
                {
                    await cell.FocusAsync();
                }
                return;
            }

            selectedIndex = index;
            selectedFromBench = fromBench;
            isExplicitlySelected = true;
            StateHasChanged();
            return;
        }

        if (selectedIndex == index && selectedFromBench == fromBench)
        {
            // CLICKED AGAIN: Remove player from position and the game entirely
            if (fromBench)
            {
                int? playerId = GetBenchPlayerId(index);
                if (playerId.HasValue)
                {
                    availablePlayerIds.Remove(playerId.Value);
                    _ = TriggerAnimation(index, true, DefenseField.AnimationType.Removed);
                }
            }
            else
            {
                int? playerId = assignments[index].PlayerId;
                if (playerId.HasValue)
                {
                    availablePlayerIds.Remove(playerId.Value);
                    assignments[index].PlayerId = null;
                    _ = TriggerAnimation(index, false, DefenseField.AnimationType.Removed);
                }
            }

            selectedIndex = null;
            selectedFromBench = null;
            isExplicitlySelected = false;
            StateHasChanged();
            UpdateUrl();
            return;
        }

        // Capture indices for animation
        int idx1 = selectedIndex!.Value;
        bool bench1 = selectedFromBench!.Value;
        int idx2 = index;
        bool bench2 = fromBench;

        int? id1 = bench1 ? GetBenchPlayerId(idx1) : assignments[idx1].PlayerId;
        int? id2 = bench2 ? GetBenchPlayerId(idx2) : assignments[idx2].PlayerId;

        if (bench1 && bench2)
        {
            // Swap bench with bench
            if (id1.HasValue && id2.HasValue)
            {
                int pos1 = availablePlayerIds.IndexOf(id1.Value);
                int pos2 = availablePlayerIds.IndexOf(id2.Value);
                if (pos1 != -1 && pos2 != -1)
                {
                    int temp = availablePlayerIds[pos1];
                    availablePlayerIds[pos1] = availablePlayerIds[pos2];
                    availablePlayerIds[pos2] = temp;
                }
            }
        }
        else if (bench1 && !bench2)
        {
            // Bench to Starter
            assignments[idx2].PlayerId = id1;
            // Also swap in availablePlayerIds to preserve bench position for the former starter
            if (id1.HasValue && id2.HasValue)
            {
                int pos1 = availablePlayerIds.IndexOf(id1.Value);
                int pos2 = availablePlayerIds.IndexOf(id2.Value);
                if (pos1 != -1 && pos2 != -1)
                {
                    int temp = availablePlayerIds[pos1];
                    availablePlayerIds[pos1] = availablePlayerIds[pos2];
                    availablePlayerIds[pos2] = temp;
                }
            }
        }
        else if (!bench1 && bench2)
        {
            // Starter to Bench
            assignments[idx1].PlayerId = id2;
            // Also swap in availablePlayerIds to preserve bench position for the former starter
            if (id1.HasValue && id2.HasValue)
            {
                int pos1 = availablePlayerIds.IndexOf(id1.Value);
                int pos2 = availablePlayerIds.IndexOf(id2.Value);
                if (pos1 != -1 && pos2 != -1)
                {
                    int temp = availablePlayerIds[pos1];
                    availablePlayerIds[pos1] = availablePlayerIds[pos2];
                    availablePlayerIds[pos2] = temp;
                }
            }
        }
        else
        {
            // Starter to Starter
            assignments[idx1].PlayerId = id2;
            assignments[idx2].PlayerId = id1;
            // No need to swap in availablePlayerIds for starter-starter as bench order isn't affected
        }

        selectedIndex = null;
        selectedFromBench = null;
        isExplicitlySelected = false;
        
        // Trigger animations
        _ = TriggerAnimation(idx1, bench1, DefenseField.AnimationType.Swapped);
        _ = TriggerAnimation(idx2, bench2, DefenseField.AnimationType.Swapped);
        
        StateHasChanged();
        UpdateUrl();
        await Task.CompletedTask;
    }

    private int? GetBenchPlayerId(int benchIndex)
    {
        List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
        if (benchIndex >= 0 && benchIndex < benchIds.Count)
        {
            return benchIds[benchIndex];
        }
        return null;
    }

    private async Task TriggerAnimation(int index, bool fromBench, DefenseField.AnimationType type = DefenseField.AnimationType.Swapped)
    {
        (int Index, bool FromBench) key = (index, fromBench);
        if (animationCounters.TryGetValue(key, out DefenseField.AnimationState? state))
        {
            state.Count++;
            state.Type = type;
        }
        else
        {
            animationCounters[key] = new DefenseField.AnimationState { Count = 1, Type = type };
        }
        
        StateHasChanged();
        await Task.Delay(600);
        
        if (animationCounters.TryGetValue(key, out state))
        {
            state.Count--;
            if (state.Count <= 0) animationCounters.Remove(key);
            StateHasChanged();
        }
    }

    private class PositionAssignment
    {
        public int PositionNumber { get; set; }
        public string PositionLabel { get; set; } = string.Empty;
        public string PositionAbbreviation { get; set; } = string.Empty;
        public double X { get; set; }
        public double Y { get; set; }
        
        private int? _playerId;
        public int? PlayerId 
        { 
            get => _playerId;
            set 
            {
                if (_playerId != value)
                {
                    _playerId = value;
                    OnAssignmentChanged?.Invoke(this);
                }
            }
        }

        public Action<PositionAssignment>? OnAssignmentChanged { get; set; }
    }

    private List<PositionAssignment> assignments = new List<PositionAssignment>();

    private void InitializeAssignments()
    {
        assignments = new List<PositionAssignment>()
        {
            new PositionAssignment { PositionNumber = 1, PositionLabel = "Pitcher", PositionAbbreviation = "P", X = 50, Y = 62, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 2, PositionLabel = "Catcher", PositionAbbreviation = "C", X = 50, Y = 92, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 3, PositionLabel = "1st Base", PositionAbbreviation = "1B", X = 70, Y = 62, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 4, PositionLabel = "2nd Base", PositionAbbreviation = "2B", X = 65, Y = 48, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 5, PositionLabel = "Third Base", PositionAbbreviation = "3B", X = 30, Y = 62, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 6, PositionLabel = "Short Stop", PositionAbbreviation = "SS", X = 35, Y = 48, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 7, PositionLabel = "Left Field", PositionAbbreviation = "LF", X = 15, Y = 35, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 8, PositionLabel = "Left Center Field", PositionAbbreviation = "LC", X = 38, Y = 15, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 9, PositionLabel = "Right Center Field", PositionAbbreviation = "RC", X = 62, Y = 15, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 10, PositionLabel = "Right Field", PositionAbbreviation = "RF", X = 85, Y = 35, OnAssignmentChanged = HandleAssignmentChange }
        };
    }

    private void HandleAssignmentChange(PositionAssignment assignment)
    {
        if (assignment.PlayerId.HasValue)
        {
            int playerId = assignment.PlayerId.Value;
            
            // Mark as available if not already
            if (!availablePlayerIds.Contains(playerId))
            {
                availablePlayerIds.Add(playerId);
            }

            // Bulletproof: Clear this player from every OTHER position
            foreach (PositionAssignment a in assignments)
            {
                if (a != assignment && a.PlayerId == playerId)
                {
                    a.PlayerId = null;
                }
            }
        }
        StateHasChanged();
        UpdateUrl();
    }

    private string GetCurrentDefenseData()
    {
        if (!availablePlayerIds.Any() && !assignments.Any(a => a.PlayerId.HasValue))
        {
            return string.Empty;
        }

        List<int> ids = assignments.Select(a => a.PlayerId ?? 0).ToList();
        List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
        ids.AddRange(benchIds);
        return DefenseEncoder.Encode(ids, players);
    }

    private void UpdateUrl()
    {
        if (isInitializing) return;
        
        string data = GetCurrentDefenseData();
        string? queryValue = string.IsNullOrEmpty(data) ? null : data;
        _ = JSRuntime.InvokeVoidAsync("updateUrlQuery", "p", queryValue);
    }

    private string? _appliedDefenseData;

    private void ApplyQueryParameters()
    {
        if (string.IsNullOrEmpty(DefenseData) || players == null || !players.Any()) return;

        List<int> ids = DefenseEncoder.Decode(DefenseData, players);
        if (ids == null || !ids.Any()) return;
        
        // Full reset before applying query parameters
        availablePlayerIds.Clear();
        foreach (PositionAssignment a in assignments)
        {
            a.PlayerId = null;
        }

        for (int i = 0; i < ids.Count; i++)
        {
            int id = ids[i];
            
            // Set starters (0-9)
            if (i < 10 && i < assignments.Count)
            {
                assignments[i].PlayerId = id > 0 ? id : null;
            }
            
            // Track all available players (starters + bench)
            if (id > 0)
            {
                if (!availablePlayerIds.Contains(id))
                {
                    availablePlayerIds.Add(id);
                }
            }
        }
        _appliedDefenseData = DefenseData;
    }

    private bool IsDefenseComplete => assignments.All(a => a.PlayerId.HasValue);

    protected override async Task OnInitializedAsync()
    {
        isInitializing = true;
        InitializeAssignments();

        seasons = await StatsRepository.GetSeasonsAsync();
        selectedSeasonId = SharedState.SelectedSeasonId;
        
        if (selectedSeasonId == 0 && seasons.Any())
        {
            selectedSeasonId = seasons.First().Id;
        }

        await LoadPlayers();
        await LoadStateFromStorage();
        ApplyQueryParameters();
        
        isInitializing = false;
        UpdateUrl();
        StateHasChanged();
    }

    protected override void OnParametersSet()
    {
        if (isInitializing) return;

        if (DefenseData != _appliedDefenseData)
        {
            ApplyQueryParameters();
            StateHasChanged();
        }
    }

    private async Task OnSeasonSelected(int seasonId)
    {
        isInitializing = true;
        selectedSeasonId = seasonId;
        SharedState.SelectedSeasonId = seasonId;
        await LoadPlayers();
        ClearAllInternal();
        await LoadStateFromStorage();
        isInitializing = false;
        UpdateUrl();
    }

    private async Task LoadPlayers()
    {
        isLoading = true;
        players = await StatsRepository.GetPlayersAsync(selectedSeasonId);
        isLoading = false;
    }

    private async Task LoadStateFromStorage()
    {
        List<int>? savedAvail = await SessionStorage.GetItemAsync<List<int>>($"defense_av_{selectedSeasonId}");
        if (savedAvail != null)
        {
            availablePlayerIds = savedAvail;
        }

        List<string>? savedNames = await SessionStorage.GetItemAsync<List<string>>($"defense_pos_{selectedSeasonId}");
        if (savedNames != null && savedNames.Count == assignments.Count)
        {
            for (int i = 0; i < assignments.Count; i++)
            {
                string name = savedNames[i];
                if (!string.IsNullOrEmpty(name))
                {
                    Player? player = players.FirstOrDefault(p => string.Equals(p.Name, name, StringComparison.OrdinalIgnoreCase));
                    if (player != null)
                    {
                        assignments[i].PlayerId = player.Id;
                    }
                }
            }
        }
    }

    private void ClearAllInternal()
    {
        availablePlayerIds.Clear();
        foreach (PositionAssignment a in assignments)
        {
            a.PlayerId = null;
        }
    }

    private void ClearAll()
    {
        ClearAllInternal();
        StateHasChanged();
        UpdateUrl();
    }

    private async Task ShareDefense()
    {
        ShareResult? result = await JSRuntime.InvokeAsync<ShareResult>("shareOrCopy", null, null);
        if (result != null && result.Copied)
        {
            showToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            showToast = false;
            StateHasChanged();
        }
    }

    private class ShareResult
    {
        public bool Shared { get; set; }
        public bool Copied { get; set; }
        public bool Cancelled { get; set; }
        public string? Error { get; set; }
    }
}
