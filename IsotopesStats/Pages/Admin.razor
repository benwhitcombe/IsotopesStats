@page "/admin"
@using IsotopesStats.Services
@using IsotopesStats.Models
@attribute [Authorize]
@inject StatsService StatsService
@inject NavigationManager Navigation

<PageTitle>Isotopes - Enter Game Stats</PageTitle>

<div class="header-with-filter view-fade-in">
    <h3 style="margin:0">Enter Game Stats</h3>
</div>

<div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
        <div class="form-group">
            <label>Season</label>
            <select class="form-control" @onchange="OnSeasonChange">
                @foreach (Season season in seasons)
                {
                    <option value="@season.Id" selected="@(newGame.SeasonId == season.Id)">@season.Name</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Date & Time</label>
            <input type="datetime-local" class="form-control" @bind="newGame.Date" />
        </div>
        <div class="form-group">
            <label>Opponent</label>
            <input type="text" class="form-control" placeholder="Opponent Name" @bind="newGame.Opponent" />
        </div>
        <div class="form-group">
            <label>Game Type</label>
            <select class="form-control" @bind="newGame.Type">
                @foreach (GameType type in Enum.GetValues<GameType>())
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>
    </div>
</div>

<div class="stat-list view-fade-in" style="animation-delay: 0.2s;">
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
        @foreach (StatEntry stat in playerStats)
        {
            Player? player = players.FirstOrDefault(p => p.Id == stat.PlayerId);
            <div class="stat-card" style="margin-bottom: 0; padding: 1rem; border: 1px solid #eee;">
                <div class="admin-player-name" style="color: var(--isotopes-accent); border-bottom: 2px solid #f0f0f0;">@player?.Name</div>
                <div class="admin-stats-grid">
                    <div class="admin-stat-input"><label>1B</label><input type="number" @bind="stat.H1B" class="form-control" /></div>
                    <div class="admin-stat-input"><label>2B</label><input type="number" @bind="stat.H2B" class="form-control" /></div>
                    <div class="admin-stat-input"><label>3B</label><input type="number" @bind="stat.H3B" class="form-control" /></div>
                    <div class="admin-stat-input"><label>4B</label><input type="number" @bind="stat.H4B" class="form-control" /></div>
                    <div class="admin-stat-input"><label>HR</label><input type="number" @bind="stat.HR" class="form-control" /></div>
                    <div class="admin-stat-input"><label>BB</label><input type="number" @bind="stat.BB" class="form-control" /></div>
                    <div class="admin-stat-input"><label>SF</label><input type="number" @bind="stat.SF" class="form-control" /></div>
                    <div class="admin-stat-input"><label>FC</label><input type="number" @bind="stat.FC" class="form-control" /></div>
                    <div class="admin-stat-input"><label>K</label><input type="number" @bind="stat.K" class="form-control" /></div>
                    <div class="admin-stat-input"><label>KF</label><input type="number" @bind="stat.KF" class="form-control" /></div>
                    <div class="admin-stat-input"><label>GO</label><input type="number" @bind="stat.GO" class="form-control" /></div>
                    <div class="admin-stat-input"><label>FO</label><input type="number" @bind="stat.FO" class="form-control" /></div>
                    <div class="admin-stat-input"><label>R</label><input type="number" @bind="stat.R" class="form-control" style="font-weight: bold; color: var(--isotopes-red);" /></div>
                    <div class="admin-stat-input"><label>RBI</label><input type="number" @bind="stat.RBI" class="form-control" style="font-weight: bold; color: var(--isotopes-red);" /></div>
                </div>
            </div>
        }
    </div>

    <div class="stat-card" style="margin-top: 2rem; text-align: center; background: #f8f9fa;">
        <button class="view-btn active" style="padding: 1rem 3rem; font-size: 1.2rem; background-color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="SubmitGame">Save Game Stats</button>
    </div>
</div>

@if (showSuccess)
{
    <div class="view-fade-in" style="position: fixed; bottom: 2rem; right: 2rem; background: #155724; color: white; padding: 1rem 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 3000;">
        ✨ Game saved successfully!
    </div>
}

@code {
    private Game newGame = new() { Date = DateTime.Today };
    private List<Player> players = new();
    private List<Season> seasons = new();
    private List<StatEntry> playerStats = new();
    private bool showSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            seasons = await StatsService.GetSeasonsAsync();
            if (seasons.Any())
            {
                newGame.SeasonId = seasons.First().Id;
            }
            
            await LoadPlayers();
        }
        catch (Exception)
        {
            seasons = new List<Season>();
            players = new List<Player>();
            playerStats = new List<StatEntry>();
        }
    }

    private async Task LoadPlayers()
    {
        players = await StatsService.GetPlayersAsync(newGame.SeasonId);
        ResetForm();
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            newGame.SeasonId = id;
            await LoadPlayers();
        }
    }

    private void ResetForm()
    {
        playerStats.Clear();
        foreach (Player player in players)
        {
            playerStats.Add(new StatEntry { PlayerId = player.Id, Player = player });
        }
    }

    private async Task SubmitGame()
    {
        try
        {
            await StatsService.AddGameWithStatsAsync(newGame, playerStats);
            showSuccess = true;
            int currentSeason = newGame.SeasonId;
            newGame = new() { Date = DateTime.Today, SeasonId = currentSeason };
            ResetForm();
            StateHasChanged();
        }
        catch (Exception)
        {
            // Error handling
        }
    }
}
