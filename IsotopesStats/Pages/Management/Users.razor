@page "/management/users"
@page "/management/users/{Action}"
@page "/management/users/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Policy = "Manage Users")]
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Users</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Users</h3>
    @if (!isAdding && !isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New User</button>
    }
</div>

@if (isAdding || isEditing)
{
    <ManagementEditCard 
        Title="@($"{(isAdding ? "Add" : "Edit")} User")"
        IsEdit="@isEditing"
        SaveText="Save User"
        Model="editViewModel"
        OnSave="HandleSave"
        OnCancel="HandleCancel"
        OnDelete="@(() => ShowDeleteConfirm(editingUserId))">

        <div class="form-group">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="editViewModel.Email" @onkeyup="HandleInput" placeholder="user@isotopes.com" autocomplete="off" />
            <ValidationMessage For="@(() => editViewModel.Email)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
        </div>

        @if (isAdding)
        {
            <div class="form-group">
                <label>Password</label>
                <div style="position: relative;">
                    <InputText type="@(showPassword ? "text" : "password")" class="form-control" @bind-Value="editViewModel.Password" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" style="padding-right: 3rem;" />
                    <button type="button" @onclick="TogglePassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                        <PasswordToggleIcon IsVisible="@showPassword" />
                    </button>
                </div>
                <ValidationMessage For="@(() => editViewModel.Password)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <InputText type="password" class="form-control" @bind-Value="editViewModel.ConfirmPassword" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" />
                <ValidationMessage For="@(() => editViewModel.ConfirmPassword)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
        }
        else
        {
            <div style="background: #f9f9f9; padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0; border: 1px solid #eee;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: @(editViewModel.ShowPasswordFields ? "1rem" : "0")">
                    <label style="margin:0; font-weight: bold;">Change Password?</label>
                    <button type="button" class="view-btn" @onclick="TogglePasswordFields">@(editViewModel.ShowPasswordFields ? "Cancel Password Change" : "Update Password")</button>
                </div>

                @if (editViewModel.ShowPasswordFields)
                {
                    <div class="view-fade-in">
                        <div class="form-group">
                            <label>New Password</label>
                            <div style="position: relative;">
                                <InputText type="@(showPassword ? "text" : "password")" class="form-control" @bind-Value="editViewModel.Password" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" style="padding-right: 3rem;" />
                                <button type="button" @onclick="TogglePassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                                    <PasswordToggleIcon IsVisible="@showPassword" />
                                </button>
                            </div>
                            <ValidationMessage For="@(() => editViewModel.Password)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                        </div>
                        <div class="form-group">
                            <label>Confirm New Password</label>
                            <InputText type="password" class="form-control" @bind-Value="editViewModel.ConfirmPassword" @onkeyup="HandleInput" placeholder="••••••••" autocomplete="new-password" />
                            <ValidationMessage For="@(() => editViewModel.ConfirmPassword)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                        </div>
                    </div>
                }
            </div>
        }

        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Roles</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.5rem; border-radius: 8px;">
                @foreach (UserRole role in availableRoles)
                {
                    <CheckboxButton 
                        Id="@($"r-{role.Id}")" 
                        Text="@role.Name" 
                        Checked="@selectedRoleIds.Contains(role.Id)" 
                        CheckedChanged="@((bool val) => OnRoleToggled(role.Id, val))" />
                }
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                @errorMessage
            </div>
        }
    </ManagementEditCard>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Email</th>
                            <th>Roles</th>
                            <th style="text-align: left;">Created</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (User user in users)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", user.Id)'>@user.Email</td>
                                <td>
                                    <div style="display: flex; flex-wrap: wrap; gap: 0.3rem; justify-content: center;">
                                        @if (user.Roles.Any())
                                        {
                                            @foreach (UserRole role in user.Roles)
                                            {
                                                <span class="badge bg-primary" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                                    @role.Name
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary" style="padding: 0.4rem 0.8rem; border-radius: 20px;">None</span>
                                        }
                                    </div>
                                </td>
                                <td style="text-align: left;">@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" style="margin-right: 0.5rem;" @onclick='() => StartEdit("edit", user.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(user.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (User user in users)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", user.Id)'>@user.Email</div>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                            @if (user.Roles.Any())
                            {
                                @foreach (UserRole role in user.Roles)
                                {
                                    <span class="badge bg-primary" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">
                                        @role.Name
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">None</span>
                            }
                        </div>
                    </div>
                    <div style="margin-bottom: 1rem; color: #666; font-size: 0.9rem;">
                        <strong>Created:</strong> @user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", user.Id)'>Edit</button>
                        <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red); flex: 1;" @onclick="() => ShowDeleteConfirm(user.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete User" 
    Message="Are you sure you want to delete this user? They will no longer be able to log in."
    OnConfirm="DeleteUser"
    OnCancel="() => showConfirm = false" />

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private List<User> users = new();
    private List<UserRole> availableRoles = new();
    private bool isAdding = false;
    private bool isEditing = false;
    private int editingUserId = 0;
    
    private UserEditViewModel editViewModel = new();
    private string originalEmail = "";
    private HashSet<int> selectedRoleIds = new();
    private HashSet<int> originalRoleIds = new();
    
    private bool showPassword = false;
    private string errorMessage = "";
    
    private bool showConfirm = false;
    private bool showDiscardConfirm = false;
    private int userIdToDelete;

    private bool HasChanges => 
        editViewModel.Email != originalEmail || 
        !string.IsNullOrEmpty(editViewModel.Password) || 
        !selectedRoleIds.SetEquals(originalRoleIds) ||
        editViewModel.ShowPasswordFields != (editingUserId != 0 && originalEmail != "");

    private class UserEditViewModel
    {
        [Required(ErrorMessage = "Email address is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = "";

        [StringLength(100, MinimumLength = 8, ErrorMessage = "Password must be at least 8 characters.")]
        [RegularExpression(@"^(?=.*[A-Z])(?=.*[0-9]).*$", ErrorMessage = "Password must contain at least one uppercase letter and one number.")]
        public string? Password { get; set; }

        [Compare("Password", ErrorMessage = "Passwords do not match.")]
        public string? ConfirmPassword { get; set; }
        
        public bool ShowPasswordFields { get; set; }
    }

    private class UserEditState
    {
        public int UserId { get; set; }
        public UserEditViewModel ViewModel { get; set; } = new();
        public string OriginalEmail { get; set; } = "";
        public HashSet<int> SelectedRoleIds { get; set; } = new();
        public HashSet<int> OriginalRoleIds { get; set; } = new();
        public bool IsAdding { get; set; }
        public bool IsEditing { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasAdding = isAdding;
        bool wasEditing = isEditing;
        
        isAdding = Action == "add";
        isEditing = Action == "edit";

        if (isAdding || isEditing)
        {
            if (isAdding && !wasAdding)
            {
                await LoadNewUser();
            }
            else if (isEditing && (!wasEditing || (Id.HasValue && Id != editingUserId)))
            {
                await LoadEditingUser();
            }
        }
        else
        {
            ResetState();
        }
    }

    private void ResetState()
    {
        editingUserId = 0;
        editViewModel = new UserEditViewModel();
        originalEmail = "";
        selectedRoleIds.Clear();
        originalRoleIds.Clear();
        errorMessage = "";
    }

    private async Task LoadNewUser()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        ResetState();
        editViewModel.ShowPasswordFields = true;
        await HydrateTempState();
    }

    private async Task LoadEditingUser()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        ResetState();
        
        if (Id.HasValue && Id != 0)
        {
            User? user = users.FirstOrDefault(u => u.Id == Id);
            if (user == null)
            {
                user = (await AuthService.GetUsersAsync()).FirstOrDefault(u => u.Id == Id);
            }

            if (user != null)
            {
                editingUserId = user.Id;
                editViewModel.Email = user.Email;
                originalEmail = user.Email;
                selectedRoleIds.Clear();
                originalRoleIds.Clear();
                foreach (UserRole r in user.Roles)
                {
                    selectedRoleIds.Add(r.Id);
                    originalRoleIds.Add(r.Id);
                }
            }
        }

        await HydrateTempState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && (isAdding || isEditing))
        {
            await HydrateTempState();
        }
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<UserEditState> result = await ProtectedSessionStore.GetAsync<UserEditState>("UserEditState");
            if (result.Success && result.Value != null && (result.Value.IsAdding || result.Value.IsEditing))
            {
                if (result.Value.UserId == (Id ?? 0))
                {
                    editingUserId = result.Value.UserId;
                    editViewModel = result.Value.ViewModel;
                    originalEmail = result.Value.OriginalEmail;
                    selectedRoleIds = result.Value.SelectedRoleIds;
                    originalRoleIds = result.Value.OriginalRoleIds;
                    StateHasChanged();
                }
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            UserEditState state = new UserEditState
            {
                UserId = editingUserId,
                ViewModel = editViewModel,
                OriginalEmail = originalEmail,
                SelectedRoleIds = selectedRoleIds,
                OriginalRoleIds = originalRoleIds,
                IsAdding = isAdding,
                IsEditing = isEditing
            };
            await ProtectedSessionStore.SetAsync("UserEditState", state);
        }
        catch (Exception) { }
    }

    private async Task HandleInput()
    {
        await SaveTempState();
    }

    private async Task ClearTempState()
    {
        try
        {
            await ProtectedSessionStore.DeleteAsync("UserEditState");
        }
        catch (Exception) { }
    }

    private async Task LoadData()
    {
        users = await AuthService.GetUsersAsync();
        availableRoles = await AuthService.GetUserRolesAsync(true);
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/users/add");
        else Navigation.NavigateTo($"/management/users/edit/{id}");
    }

    private async Task HandleCancel()
    {
        if (HasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        Navigation.NavigateTo("/management/users");
    }

    private async Task OnRoleToggled(int roleId, bool isChecked)
    {
        if (isChecked) selectedRoleIds.Add(roleId);
        else selectedRoleIds.Remove(roleId);
        await SaveTempState();
    }

    private void TogglePassword() => showPassword = !showPassword;

    private async Task TogglePasswordFields()
    {
        editViewModel.ShowPasswordFields = !editViewModel.ShowPasswordFields;
        if (!editViewModel.ShowPasswordFields)
        {
            editViewModel.Password = null;
            editViewModel.ConfirmPassword = null;
        }
        await SaveTempState();
    }

    private async Task HandleSave()
    {
        errorMessage = "";

        if (!selectedRoleIds.Any()) { errorMessage = "At least one role is required."; return; }

        if (isAdding && string.IsNullOrEmpty(editViewModel.Password)) { errorMessage = "Password is required."; return; }

        // 3. Save
        if (isAdding)
        {
            bool result = await AuthService.RegisterAsync(editViewModel.Email, editViewModel.Password!, selectedRoleIds.ToList());
            if (!result) { errorMessage = "Error creating user. Email might already exist."; return; }
        }
        else
        {
            // Update User Info
            await AuthService.UpdateUserAsync(new User { Id = editingUserId, Email = editViewModel.Email }, selectedRoleIds.ToList());
            
            // Update Password if fields are shown
            if (editViewModel.ShowPasswordFields && !string.IsNullOrEmpty(editViewModel.Password))
            {
                await AuthService.UpdateUserPasswordAsync(editingUserId, editViewModel.Password);
            }
        }

        await ClearTempState();
        Navigation.NavigateTo("/management/users");
        await LoadData();
    }

    private void ShowDeleteConfirm(int id)
    {
        userIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeleteUser()
    {
        showConfirm = false;
        await AuthService.DeleteUserAsync(userIdToDelete);
        await LoadData();
    }
}