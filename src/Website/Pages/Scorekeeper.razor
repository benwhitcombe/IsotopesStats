@page "/management/games/{GameId:int}/scorekeeping"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Domain.Interfaces
@using IsotopesStats.Website.Components
@attribute [Authorize(Policy = "Manage Games")]
@inject IStatsRepository StatsRepository
@inject NavigationManager NavigationManager

<PageTitle>Scorekeeping - Isotopes</PageTitle>

<style>
    .play-btn {
        transition: background-color 0.2s, color 0.2s, transform 0.1s;
    }

    .play-btn:active:not([disabled]) {
        transform: scale(0.96);
    }
    
    .play-btn[disabled] {
        opacity: 0.5;
        pointer-events: none;
    }
    
    .play-btn-hit {
        color: var(--isotopes-accent) !important;
        border-color: var(--isotopes-accent) !important;
    }
    .play-btn-hit.active-play {
        background-color: var(--isotopes-accent) !important;
        color: white !important;
        border-width: 3px !important;
    }
    
    .play-btn-out {
        color: var(--isotopes-red) !important;
        border-color: var(--isotopes-red) !important;
    }
    .play-btn-out.active-play {
        background-color: var(--isotopes-red) !important;
        color: white !important;
        border-width: 3px !important;
    }

    .play-btn-util {
        color: #6c757d !important;
        border-color: #6c757d !important;
    }
    @@media (hover: hover) {
        .play-btn-hit:hover:not(.active-play) {
            background-color: var(--isotopes-accent) !important;
            color: white !important;
        }
        .play-btn-out:hover:not(.active-play) {
            background-color: var(--isotopes-red) !important;
            color: white !important;
        }
        .play-btn-util:hover:not([disabled]) {
            background-color: #6c757d !important;
            color: white !important;
        }
    }

    @@keyframes popHighlight {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }
    .pop-highlight {
        display: inline-block;
        animation: popHighlight 0.4s ease-out;
    }
    
    @@keyframes slideFade {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .slide-fade {
        animation: slideFade 0.3s ease-out;
        display: inline-block;
    }
    
    @@keyframes simpleFadeIn {
        0% { opacity: 0; }
        100% { opacity: 1; }
    }
    .badge-fade {
        animation: simpleFadeIn 0.3s ease-in-out;
    }
</style>

@if (isLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Loading game data...</p>
    </div>
}
else if (game == null)
{
    <div class="alert alert-danger">Game not found.</div>
}
else if (!isLineupSet)
{
    <div class="scorekeeper-container mx-auto" style="max-width: 800px;">
        <div class="stat-card mb-3">
            <div class="card-body">
                <h4 class="mb-3 text-center" style="color: var(--isotopes-accent);">Set Batting Order</h4>
                <p class="text-muted text-center">Select players from the roster to add them to the batting order.</p>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <h6 class="text-primary border-bottom pb-2">Selected Lineup (@setupBattingOrderIds.Count)</h6>
                        @if (setupBattingOrderIds.Count == 0)
                        {
                            <div class="text-muted fst-italic">No players selected</div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @for (int i = 0; i < setupBattingOrderIds.Count; i++)
                                {
                                    int pid = setupBattingOrderIds[i];
                                    <li class="list-group-item d-flex justify-content-between align-items-center" style="border-color: #eee;">
                                        <div>
                                            <span class="badge bg-secondary me-2">@(i + 1)</span> @GetPlayerName(pid)
                                        </div>
                                        <div>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MovePlayerUp(pid)" disabled="@(i == 0)">↑</button>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MovePlayerDown(pid)" disabled="@(i == setupBattingOrderIds.Count - 1)">↓</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => TogglePlayerInSetupLineup(pid)">X</button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <h6 class="text-primary border-bottom pb-2">Available Roster</h6>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (Player player in roster.Where(p => !setupBattingOrderIds.Contains(p.Id)).OrderBy(p => p.Name))
                            {
                                <button class="view-btn btn-sm" @onclick="() => TogglePlayerInSetupLineup(player.Id)">
                                    + @player.Name
                                </button>
                            }
                        </div>
                    </div>
                </div>
                
                <button class="view-btn active w-100 mt-3 py-2 fs-5" disabled="@(setupBattingOrderIds.Count == 0)" @onclick="ConfirmLineup">Confirm Lineup & Start Game</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="scorekeeper-container mx-auto" style="max-width: 600px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0 fw-bold text-nowrap me-3">Scorekeeper</h2>
            <div class="d-flex gap-2 justify-content-end w-100">
                <button class="btn btn-sm btn-outline-danger fw-bold flex-grow-1 px-1" style="max-width: 100px;" @onclick="ClearPlay" disabled="@(viewingPaIndex == null)">Reset</button>
                <button class="btn btn-sm btn-danger fw-bold flex-grow-1 px-1" style="max-width: 100px;" @onclick="DeletePlay" disabled="@(viewingPaIndex == null)">Delete</button>
            </div>
        </div>
        <!-- Diamond / Bases View -->
        <div class="stat-card mb-2 py-3 position-relative">
            <div class="d-flex justify-content-between text-center px-4 mb-2">
                <div>
                    <h6 class="mb-0 text-muted">INNING</h6>
                    <div class="fs-4 fw-bold" style="color: var(--isotopes-primary);">@currentInning</div>
                </div>
                <div>
                    <h6 class="mb-0 text-muted">SCORE</h6>
                    <div class="fs-4 fw-bold pop-highlight" style="color: var(--isotopes-green);" @key="runsScored">@runsScored</div>
                </div>
                <div>
                    <h6 class="mb-0 text-muted">OUTS</h6>
                    <div class="fs-4 fw-bold pop-highlight" style="color: var(--isotopes-red);" @key="currentOuts">@currentOuts</div>
                </div>
            </div>

            <div class="position-relative mx-auto mb-5 mt-2" style="width: 200px; height: 200px;">
                @{
                    int? display1B = viewingPaIndex != null ? plateAppearances[viewingPaIndex.Value].RunnerOn1B_End : runnerOn1B;
                    int? display2B = viewingPaIndex != null ? plateAppearances[viewingPaIndex.Value].RunnerOn2B_End : runnerOn2B;
                    int? display3B = viewingPaIndex != null ? plateAppearances[viewingPaIndex.Value].RunnerOn3B_End : runnerOn3B;
                }
                <div class="diamond-container h-100 w-100">
                    <svg viewBox="0 0 100 100" style="width: 100%; height: 100%;">
                        <!-- Base paths -->
                        <polygon points="50,90 90,50 50,10 10,50" fill="none" stroke="#ddd" stroke-width="2" />
                        <!-- 1B -->
                        <polygon points="90,50 85,45 80,50 85,55" fill="@(display1B != null ? "var(--isotopes-accent)" : "#fff")" stroke="#aaa" />
                        <!-- 2B -->
                        <polygon points="50,10 45,15 50,20 55,15" fill="@(display2B != null ? "var(--isotopes-accent)" : "#fff")" stroke="#aaa" />
                        <!-- 3B -->
                        <polygon points="10,50 15,45 20,50 15,55" fill="@(display3B != null ? "var(--isotopes-accent)" : "#fff")" stroke="#aaa" />
                        <!-- Home Plate (pointing down) -->
                        <polygon points="45,85 55,85 55,90 50,95 45,90" fill="#fff" stroke="#aaa" />
                    </svg>
                </div>
                <!-- Runner Names Overlays -->
                @if (display2B != null)
                {
                    <div class="position-absolute badge badge-fade" style="background-color: var(--isotopes-accent); left: 50%; bottom: 90%; transform: translateX(-50%); z-index: 10;">
                        @GetPlayerName(display2B.Value)
                    </div>
                }
                @if (display3B != null)
                {
                    <div class="position-absolute badge badge-fade" style="background-color: var(--isotopes-accent); right: 90%; top: 50%; transform: translateY(-50%); z-index: 10;">
                        @GetPlayerName(display3B.Value)
                    </div>
                }
                @if (display1B != null)
                {
                    <div class="position-absolute badge badge-fade" style="background-color: var(--isotopes-accent); left: 90%; top: 50%; transform: translateY(-50%); z-index: 10;">
                        @GetPlayerName(display1B.Value)
                    </div>
                }
                @if (viewingPaIndex != null)
                {
                    var (scored, outs) = GetRunnersHomeAndOut(plateAppearances[viewingPaIndex.Value]);
                    @if (scored.Any())
                    {
                        <div class="position-absolute d-flex flex-row gap-1 align-items-center badge-fade" style="left: 50%; top: 100%; transform: translateX(-50%); margin-top: 10px; z-index: 10;">
                            @foreach (var p in scored)
                            {
                                <div class="badge bg-success">@p</div>
                            }
                        </div>
                    }
                    @foreach (var o in outs)
                    {
                        if (o.StartBase == 1)
                        {
                            <div class="position-absolute badge bg-danger badge-fade" style="left: 75%; top: 25%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
                        }
                        else if (o.StartBase == 2)
                        {
                            <div class="position-absolute badge bg-danger badge-fade" style="left: 25%; top: 25%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
                        }
                        else if (o.StartBase == 3)
                        {
                            <div class="position-absolute badge bg-danger badge-fade" style="left: 25%; top: 75%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
                        }
                    }
                }
            </div>
            
            <!-- Batter Info -->
            <div class="text-center mt-2" style="min-height: 4rem;">
                <h6 class="text-muted mb-1 fw-bold" style="letter-spacing: 1px;">@(viewingPaIndex == null ? "CURRENT BATTER" : "BATTER")</h6>
                <h3 class="fw-bold mb-0 slide-fade" @key="currentBatterId">
                    @currentBatterName
                    @if (viewingPaIndex != null && plateAppearances.Count > viewingPaIndex.Value)
                    {
                        <text> - @plateAppearances[viewingPaIndex.Value].Result</text>
                    }
                </h3>
            </div>
        </div>

        <!-- Play Controls -->
        <div class="row g-2 mb-3">
            <div class="col-6"><button class="@GetPlayButtonClass("1B")" @onclick='() => RecordPlay("1B")'>1B</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("2B")" @onclick='() => RecordPlay("2B")'>2B</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("3B")" @onclick='() => RecordPlay("3B")'>3B</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("IPHR")" @onclick='() => RecordPlay("IPHR")'>IPHR</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("HR")" @onclick='() => RecordPlay("HR")'>HR</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("BB")" @onclick='() => RecordPlay("BB")'>BB</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("GO")" @onclick='() => RecordPlay("GO")'>GO</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("FO")" @onclick='() => RecordPlay("FO")'>FO</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("K")" @onclick='() => RecordPlay("K")'>K</button></div>
            <div class="col-6"><button class="@GetPlayButtonClass("KF")" @onclick='() => RecordPlay("KF")'>KF</button></div>
        </div>
        
        <div class="row g-2 mt-2">
            <div class="col-3">
                <button class="view-btn play-btn play-btn-util w-100 py-3" @onclick="PrevPlay" disabled="@(plateAppearances.Count == 0 || viewingPaIndex == 0)">&laquo; Prev</button>
            </div>
            <div class="col-3">
                <button class="view-btn play-btn w-100 py-3 @(IsEndsInningToggled() ? "play-btn-out active-play" : "play-btn-out bg-white")" @onclick="ToggleEndInning" disabled="@(viewingPaIndex == null)">End Inning</button>
            </div>
            <div class="col-3">
                <button class="view-btn play-btn play-btn-util w-100 py-3" @onclick='() => RecordPlay("Skip")'>Skip</button>
            </div>
            <div class="col-3">
                <button class="view-btn play-btn play-btn-util w-100 py-3" @onclick="NextPlay" disabled="@(viewingPaIndex == null)">Next &raquo;</button>
            </div>
        </div>

        <hr class="my-4" />

        <div class="row g-2">
            <div class="col-12">
                <a href="/management/games/@GameId/scorecard" class="view-btn w-100 py-3 d-block text-center text-decoration-none text-dark">Scorecard</a>
            </div>
        </div>
    </div>
}

<RunnerAdvancementModal 
    IsVisible="isModalVisible" 
    CurrentBase="runnerToAdvanceBase" 
    RunnerName="@GetRunnerNameForModal()"
    MinBase="CalculateMinBaseForModal()"
    MaxBase="CalculateMaxBaseForModal()"
    TopOption="CalculateTopOptionForModal()"
    OnDestinationSelected="HandleAdvancement" 
    OnClose="CloseModal" />

@code {
    [Parameter]
    public int GameId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int? paIndex { get; set; }

    private bool isLoading = true;
    private Game? game;
    private List<PlateAppearance> plateAppearances = new();
    private List<Player> roster = new();
    
    // Live State
    private int currentInning = 1;
    private int currentOuts = 0;
    private int runsScored = 0;
    
    private int? runnerOn1B = null;
    private int? runnerOn2B = null;
    private int? runnerOn3B = null;
    
    private string currentBatterName = "Unknown";
    private int currentBatterId = 0;
    private int batterOrderIndex = 0;

    // Timeline State
    private int? viewingPaIndex = null;

    // Lineup
    private bool isLineupSet = false;
    private List<int> battingOrderIds = new();
    private List<int> setupBattingOrderIds = new();

    // Modal State
    private bool isModalVisible = false;
    private int runnerToAdvanceBase = 0;
    private Queue<int> runnersToAdvance = new();
    private PlateAppearance? pendingPA;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            game = await StatsRepository.GetGameAsync(GameId);
            if (game != null)
            {
                roster = await StatsRepository.GetPlayersAsync(game.SeasonId);
                plateAppearances = await StatsRepository.GetPlateAppearancesAsync(GameId);
                
                // Load batting order from roster to avoid needing a saved Lineup entity
                // In reality, pull this from the saved Lineup/StatEntries
                List<StatEntry> gameStats = await StatsRepository.GetGameStatsAsync(GameId);
                if (gameStats.Any())
                {
                    battingOrderIds = gameStats.OrderBy(s => s.BO).Select(s => s.PlayerId).Distinct().ToList();
                    isLineupSet = true;
                }
                else
                {
                    isLineupSet = false;
                }
                
                if (isLineupSet)
                {
                    if (paIndex.HasValue && paIndex.Value >= 0 && paIndex.Value < plateAppearances.Count)
                    {
                        viewingPaIndex = paIndex.Value;
                    }
                    RecalculateState();
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override void OnParametersSet()
    {
        if (isLineupSet && plateAppearances.Count > 0)
        {
            if (paIndex.HasValue && paIndex.Value >= 0 && paIndex.Value < plateAppearances.Count)
            {
                viewingPaIndex = paIndex.Value;
            }
            RecalculateState();
        }
    }

    private string GetPlayerName(int id)
    {
        return roster.FirstOrDefault(p => p.Id == id)?.Name ?? "Unknown";
    }

    private void TogglePlayerInSetupLineup(int playerId)
    {
        if (setupBattingOrderIds.Contains(playerId))
            setupBattingOrderIds.Remove(playerId);
        else
            setupBattingOrderIds.Add(playerId);
    }

    private void MovePlayerUp(int playerId)
    {
        int index = setupBattingOrderIds.IndexOf(playerId);
        if (index > 0)
        {
            setupBattingOrderIds.RemoveAt(index);
            setupBattingOrderIds.Insert(index - 1, playerId);
        }
    }

    private void MovePlayerDown(int playerId)
    {
        int index = setupBattingOrderIds.IndexOf(playerId);
        if (index >= 0 && index < setupBattingOrderIds.Count - 1)
        {
            setupBattingOrderIds.RemoveAt(index);
            setupBattingOrderIds.Insert(index + 1, playerId);
        }
    }

    private async Task ConfirmLineup()
    {
        if (setupBattingOrderIds.Count == 0 || game == null) return;
        
        List<StatEntry> stats = new();
        for (int i = 0; i < setupBattingOrderIds.Count; i++)
        {
            stats.Add(new StatEntry
            {
                PlayerId = setupBattingOrderIds[i],
                GameId = GameId,
                BO = i + 1
            });
        }
        
        await StatsRepository.UpdateGameWithStatsAsync(game, stats);
        
        battingOrderIds = setupBattingOrderIds.ToList();
        isLineupSet = true;
        RecalculateState();
    }

    private void RecalculateState()
    {
        // Replay PAs up to viewingPaIndex to determine state
        currentInning = 1;
        currentOuts = 0;
        runsScored = 0;
        runnerOn1B = null;
        runnerOn2B = null;
        runnerOn3B = null;
        batterOrderIndex = 0;

        int limit = viewingPaIndex.HasValue ? viewingPaIndex.Value : plateAppearances.Count;
        for (int i = 0; i < limit; i++)
        {
            PlateAppearance pa = plateAppearances[i];
            currentInning = pa.Inning;
            currentOuts += pa.OutsRecorded;
            runsScored += pa.RunsScored;
            
            runnerOn1B = pa.RunnerOn1B_End;
            runnerOn2B = pa.RunnerOn2B_End;
            runnerOn3B = pa.RunnerOn3B_End;
            
            if (pa.EndsInning)
            {
                currentOuts = 0;
                currentInning++;
                runnerOn1B = null;
                runnerOn2B = null;
                runnerOn3B = null;
            }
            
            int actualIndex = battingOrderIds.IndexOf(pa.PlayerId);
            if (actualIndex >= 0)
            {
                batterOrderIndex = (actualIndex + 1) % Math.Max(1, battingOrderIds.Count);
            }
            else
            {
                batterOrderIndex = (batterOrderIndex + 1) % Math.Max(1, battingOrderIds.Count);
            }
        }

        if (viewingPaIndex != null && viewingPaIndex.Value < plateAppearances.Count)
        {
            currentBatterId = plateAppearances[viewingPaIndex.Value].PlayerId;
            currentBatterName = GetPlayerName(currentBatterId);
        }
        else if (battingOrderIds.Count > 0)
        {
            currentBatterId = battingOrderIds[batterOrderIndex];
            currentBatterName = GetPlayerName(currentBatterId);
        }
    }

    private async Task RecordPlay(string result)
    {
        PlateAppearance pa;
        if (viewingPaIndex != null)
        {
            pa = plateAppearances[viewingPaIndex.Value];
            pa.Result = result;
            pa.RunsScored = 0;
            pa.OutsRecorded = 0;
            pa.RunnerOn1B_End = runnerOn1B;
            pa.RunnerOn2B_End = runnerOn2B;
            pa.RunnerOn3B_End = runnerOn3B;
            // The starting bases remain the same as when it was originally created
        }
        else
        {
            pa = new PlateAppearance
            {
                GameId = GameId,
                PlayerId = currentBatterId,
                Inning = currentInning,
                OrderNumber = plateAppearances.Count + 1,
                Result = result,
                OutsBefore = currentOuts,
                RunnerOn1B = runnerOn1B,
                RunnerOn2B = runnerOn2B,
                RunnerOn3B = runnerOn3B,
                RunnerOn1B_End = runnerOn1B,
                RunnerOn2B_End = runnerOn2B,
                RunnerOn3B_End = runnerOn3B,
                RunsScored = 0,
                OutsRecorded = 0
            };
        }

        bool isOut = result == "K" || result == "KF" || result == "GO" || result == "FO" || result == "SF";
        if (isOut)
        {
            pa.OutsRecorded = 1;
        }
        else if (result == "HR" || result == "IPHR")
        {
            pa.RunsScored++;
        }

        pendingPA = pa;
        runnersToAdvance.Clear();

        if (result == "Skip")
        {
            pa.RunnerOn1B_End = runnerOn1B;
            pa.RunnerOn2B_End = runnerOn2B;
            pa.RunnerOn3B_End = runnerOn3B;
        }
        else if (result == "BB")
        {
            pa.RunnerOn1B_End = currentBatterId;
            if (runnerOn1B != null)
            {
                pa.RunnerOn2B_End = runnerOn1B;
                if (runnerOn2B != null)
                {
                    pa.RunnerOn3B_End = runnerOn2B;
                    if (runnerOn3B != null) pa.RunsScored++;
                }
                else pa.RunnerOn3B_End = runnerOn3B;
            }
            else
            {
                pa.RunnerOn2B_End = runnerOn2B;
                pa.RunnerOn3B_End = runnerOn3B;
            }
        }
        else if (result == "HR" || result == "IPHR")
        {
            if (runnerOn3B != null) { pendingPA.RunsScored++; pendingPA.RunnerOn3B_End = null; }
            if (runnerOn2B != null) { pendingPA.RunsScored++; pendingPA.RunnerOn2B_End = null; }
            if (runnerOn1B != null) { pendingPA.RunsScored++; pendingPA.RunnerOn1B_End = null; }
        }
        else if (result != "Skip")
        {
            // Queue runners for advancement (start from 3B backwards)
            if (runnerOn3B != null) runnersToAdvance.Enqueue(3);
            if (runnerOn2B != null) runnersToAdvance.Enqueue(2);
            if (runnerOn1B != null) runnersToAdvance.Enqueue(1);
            if (result == "1B" || result == "2B" || result == "3B" || result == "FC")
            {
                runnersToAdvance.Enqueue(0); // Queue the batter
            }
        }

        ProcessNextRunner();
        
        if (!isModalVisible)
        {
            // No runners to advance, save immediately
            await SavePendingPA();
        }
    }

    private void ProcessNextRunner()
    {
        if (pendingPA != null && pendingPA.OutsBefore + pendingPA.OutsRecorded >= 3)
        {
            // 3rd out auto-resolve: clear queue
            runnersToAdvance.Clear();
            
            // Assume remaining unprompted runners stayed (or didn't reach if batter)
            // (Batter doesn't make it to base if they are in queue and 3rd out happens)
        }

        if (runnersToAdvance.Count > 0)
        {
            runnerToAdvanceBase = runnersToAdvance.Dequeue();
            isModalVisible = true;
        }
        else
        {
            isModalVisible = false;
        }
    }

    private async Task HandleAdvancement(int destination)
    {
        if (pendingPA == null) return;
        
        int runnerId = runnerToAdvanceBase switch
        {
            1 => pendingPA.RunnerOn1B.GetValueOrDefault(),
            2 => pendingPA.RunnerOn2B.GetValueOrDefault(),
            3 => pendingPA.RunnerOn3B.GetValueOrDefault(),
            0 => pendingPA.PlayerId, // Batter
            _ => 0
        };

        // Clear original base in End state (for base runners)
        if (runnerToAdvanceBase == 1 && pendingPA.RunnerOn1B_End == runnerId) pendingPA.RunnerOn1B_End = null;
        if (runnerToAdvanceBase == 2 && pendingPA.RunnerOn2B_End == runnerId) pendingPA.RunnerOn2B_End = null;
        if (runnerToAdvanceBase == 3 && pendingPA.RunnerOn3B_End == runnerId) pendingPA.RunnerOn3B_End = null;

        if (destination == 4)
        {
            pendingPA.RunsScored++;
        }
        else if (destination == 0)
        {
            pendingPA.OutsRecorded++;
        }
        else if (destination == 1)
        {
            pendingPA.RunnerOn1B_End = runnerId;
        }
        else if (destination == 2)
        {
            pendingPA.RunnerOn2B_End = runnerId;
        }
        else if (destination == 3)
        {
            pendingPA.RunnerOn3B_End = runnerId;
        }

        if (runnersToAdvance.Count > 0 && pendingPA.OutsBefore + pendingPA.OutsRecorded < 3)
        {
            ProcessNextRunner();
        }
        else
        {
            // Auto-resolve if 3 outs reached
            runnersToAdvance.Clear();
            isModalVisible = false;
            await SavePendingPA();
        }
    }

    private string GetRunnerNameForModal()
    {
        if (pendingPA == null) return "Unknown";
        int runnerId = runnerToAdvanceBase switch
        {
            1 => pendingPA.RunnerOn1B.GetValueOrDefault(),
            2 => pendingPA.RunnerOn2B.GetValueOrDefault(),
            3 => pendingPA.RunnerOn3B.GetValueOrDefault(),
            0 => pendingPA.PlayerId,
            _ => 0
        };
        return GetPlayerName(runnerId);
    }

    private int CalculateMinBaseForModal()
    {
        if (pendingPA == null) return 1;
        
        // Only restrict MinBase for the Batter (0)
        if (runnerToAdvanceBase == 0)
        {
            if (pendingPA.Result == "1B" || pendingPA.Result == "FC") return 1;
            if (pendingPA.Result == "2B") return 2;
            if (pendingPA.Result == "3B") return 3;
        }
        
        // For runners already on base, they could stay on their current base or advance.
        // The modal loop uses 'if (i >= CurrentBase)', so 1 is fine as a global minimum.
        return 1;
    }

    private int CalculateMaxBaseForModal()
    {
        if (pendingPA == null) return 4;
        
        int maxBase = 4; // Can always score unless blocked
        
        // Restrict the batter's maximum base to the hit result
        if (runnerToAdvanceBase == 0)
        {
            if (pendingPA.Result == "1B" || pendingPA.Result == "FC") maxBase = 1;
            else if (pendingPA.Result == "2B") maxBase = 2;
            else if (pendingPA.Result == "3B") maxBase = 3;
        }
        
        // Find the closest occupied base *ahead* of this runner
        // Since we resolve from 3B down to Batter, we check End states!
        if (pendingPA.RunnerOn1B_End != null && runnerToAdvanceBase < 1) maxBase = Math.Min(maxBase, 0);
        if (pendingPA.RunnerOn2B_End != null && runnerToAdvanceBase < 2) maxBase = Math.Min(maxBase, 1);
        if (pendingPA.RunnerOn3B_End != null && runnerToAdvanceBase < 3) maxBase = Math.Min(maxBase, 2);
        
        return maxBase;
    }

    private int CalculateTopOptionForModal()
    {
        if (pendingPA == null) return -1;
        
        string res = pendingPA.Result;
        bool isOut = res == "K" || res == "KF" || res == "GO" || res == "FO" || res == "SF";
        
        if (isOut)
        {
            // For flyouts/groundouts, default is to stay at current base
            // Unless it's the batter (but batter isn't queued for outs)
            return runnerToAdvanceBase;
        }
        else if (res == "1B" || res == "FC")
        {
            return runnerToAdvanceBase + 1; // E.g., Batter to 1B, 1B to 2B
        }
        else if (res == "2B")
        {
            return runnerToAdvanceBase + 2; // E.g., Batter to 2B, 1B to 3B
        }
        else if (res == "3B")
        {
            return runnerToAdvanceBase + 3; 
        }
        
        return -1;
    }

    private async Task SavePendingPA()
    {
        if (pendingPA != null)
        {
            // Smart play detection
            if (pendingPA.Result == "FO" && pendingPA.RunsScored > 0)
            {
                pendingPA.Result = "SF";
            }
            else if ((pendingPA.Result == "1B" || pendingPA.Result == "2B" || pendingPA.Result == "3B") && pendingPA.OutsRecorded > 0)
            {
                pendingPA.Result = "FC";
            }

            if (pendingPA.OutsBefore + pendingPA.OutsRecorded >= 3)
            {
                pendingPA.EndsInning = true;
            }

            if (viewingPaIndex != null)
            {
                await StatsRepository.UpdatePlateAppearanceAsync(pendingPA);
                await RippleStateAsync();
            }
            else
            {
                PlateAppearance savedPa = await StatsRepository.AddPlateAppearanceAsync(pendingPA);
                plateAppearances.Add(savedPa);
                // viewingPaIndex = null; // Auto-advance to next batter
            }
            
            RecalculateState();
            pendingPA = null;
            StateHasChanged();
        }
    }

    private void CloseModal()
    {
        isModalVisible = false;
        runnersToAdvance.Clear();
        pendingPA = null;
    }



    private void PrevPlay()
    {
        if (plateAppearances.Count == 0) return;
        int current = viewingPaIndex ?? plateAppearances.Count;
        if (current > 0)
        {
            viewingPaIndex = current - 1;
            RecalculateState();
        }
    }

    private void NextPlay()
    {
        if (viewingPaIndex == null) return;
        if (viewingPaIndex < plateAppearances.Count - 1)
        {
            viewingPaIndex++;
            RecalculateState();
        }
        else
        {
            viewingPaIndex = null; // Back to Live
            RecalculateState();
        }
    }
    
    private void GoToLive()
    {
        viewingPaIndex = null;
        RecalculateState();
    }



    private async Task ClearPlay()
    {
        if (viewingPaIndex != null && viewingPaIndex >= 0 && viewingPaIndex < plateAppearances.Count)
        {
            var pa = plateAppearances[viewingPaIndex.Value];
            
            // Just reset the play's data instead of deleting it, to preserve the timeline sequence
            pa.Result = ""; // Empty string acts as a blank/placeholder play
            pa.OutsRecorded = 0;
            pa.RunsScored = 0;
            pa.RunnerOn1B_End = pa.RunnerOn1B;
            pa.RunnerOn2B_End = pa.RunnerOn2B;
            pa.RunnerOn3B_End = pa.RunnerOn3B;
            pa.EndsInning = false;
            
            await StatsRepository.UpdatePlateAppearanceAsync(pa);
            
            await RippleStateAsync();
            RecalculateState();
            StateHasChanged();
        }
    }

    private async Task DeletePlay()
    {
        if (viewingPaIndex != null && viewingPaIndex >= 0 && viewingPaIndex < plateAppearances.Count)
        {
            var pa = plateAppearances[viewingPaIndex.Value];
            await StatsRepository.DeletePlateAppearanceAsync(pa.Id);
            plateAppearances.RemoveAt(viewingPaIndex.Value);
            
            // If we deleted the very last play, go back to live batter
            if (viewingPaIndex.Value >= plateAppearances.Count)
            {
                viewingPaIndex = null;
            }
            
            await RippleStateAsync();
            RecalculateState();
            StateHasChanged();
        }
    }

    private bool IsPlayResultMatch(string actualResult, string buttonResult)
    {
        if (actualResult == buttonResult) return true;
        if (actualResult == "FC" && buttonResult == "1B") return true;
        if (actualResult == "SF" && buttonResult == "FO") return true;
        return false;
    }

    private string GetPlayButtonClass(string result)
    {
        string css = "view-btn play-btn w-100 py-3 fs-5";
        bool isOut = result == "GO" || result == "FO" || result == "K" || result == "KF" || result == "SF";
        
        if (isOut) 
            css += " play-btn-out";
        else 
            css += " play-btn-hit";
            
        if (viewingPaIndex != null && plateAppearances.Count > viewingPaIndex.Value && IsPlayResultMatch(plateAppearances[viewingPaIndex.Value].Result, result))
        {
            css += " active-play"; // Could add a custom CSS class in the future
        }
        return css;
    }



    private (List<string> Scored, List<(string Name, int StartBase)> Outs) GetRunnersHomeAndOut(PlateAppearance pa)
    {
        var starters = new List<(int PlayerId, int Base)>();
        if (pa.RunnerOn3B.HasValue) starters.Add((pa.RunnerOn3B.Value, 3));
        if (pa.RunnerOn2B.HasValue) starters.Add((pa.RunnerOn2B.Value, 2));
        if (pa.RunnerOn1B.HasValue) starters.Add((pa.RunnerOn1B.Value, 1));
        starters.Add((pa.PlayerId, 0)); // Batter

        var enders = new HashSet<int>();
        if (pa.RunnerOn1B_End.HasValue) enders.Add(pa.RunnerOn1B_End.Value);
        if (pa.RunnerOn2B_End.HasValue) enders.Add(pa.RunnerOn2B_End.Value);
        if (pa.RunnerOn3B_End.HasValue) enders.Add(pa.RunnerOn3B_End.Value);

        var missing = starters.Where(s => !enders.Contains(s.PlayerId))
                              .OrderByDescending(s => s.Base)
                              .ToList();

        var scored = new List<string>();
        var outs = new List<(string Name, int StartBase)>();
        
        int runs = pa.RunsScored;

        for (int i = 0; i < missing.Count; i++)
        {
            if (i < runs)
            {
                scored.Add(GetPlayerName(missing[i].PlayerId));
            }
            else
            {
                outs.Add((GetPlayerName(missing[i].PlayerId), missing[i].Base));
            }
        }

        return (scored, outs);
    }

    private bool IsEndsInningToggled()
    {
        if (viewingPaIndex != null && viewingPaIndex.Value < plateAppearances.Count)
        {
            return plateAppearances[viewingPaIndex.Value].EndsInning;
        }
        return false;
    }

    private async Task ToggleEndInning()
    {
        if (viewingPaIndex != null && viewingPaIndex.Value < plateAppearances.Count)
        {
            PlateAppearance pa = plateAppearances[viewingPaIndex.Value];
            pa.EndsInning = !pa.EndsInning;
            await StatsRepository.UpdatePlateAppearanceAsync(pa);
            
            await RippleStateAsync();
            RecalculateState();
            StateHasChanged();
        }
    }

    private async Task RippleStateAsync()
    {
        int tempInning = 1;
        int tempOuts = 0;
        int? temp1B = null;
        int? temp2B = null;
        int? temp3B = null;

        foreach (var pa in plateAppearances)
        {
            bool changed = false;
            if (pa.RunnerOn1B != temp1B) { pa.RunnerOn1B = temp1B; changed = true; }
            if (pa.RunnerOn2B != temp2B) { pa.RunnerOn2B = temp2B; changed = true; }
            if (pa.RunnerOn3B != temp3B) { pa.RunnerOn3B = temp3B; changed = true; }
            if (pa.Inning != tempInning) { pa.Inning = tempInning; changed = true; }
            if (pa.OutsBefore != tempOuts) { pa.OutsBefore = tempOuts; changed = true; }
            
            if (changed)
            {
                // Clear ghost runners from End states
                if (pa.RunnerOn1B_End != null && pa.RunnerOn1B_End != pa.RunnerOn1B && pa.RunnerOn1B_End != pa.RunnerOn2B && pa.RunnerOn1B_End != pa.RunnerOn3B && pa.RunnerOn1B_End != pa.PlayerId) pa.RunnerOn1B_End = null;
                if (pa.RunnerOn2B_End != null && pa.RunnerOn2B_End != pa.RunnerOn1B && pa.RunnerOn2B_End != pa.RunnerOn2B && pa.RunnerOn2B_End != pa.RunnerOn3B && pa.RunnerOn2B_End != pa.PlayerId) pa.RunnerOn2B_End = null;
                if (pa.RunnerOn3B_End != null && pa.RunnerOn3B_End != pa.RunnerOn1B && pa.RunnerOn3B_End != pa.RunnerOn2B && pa.RunnerOn3B_End != pa.RunnerOn3B && pa.RunnerOn3B_End != pa.PlayerId) pa.RunnerOn3B_End = null;
                
                await StatsRepository.UpdatePlateAppearanceAsync(pa);
            }

            tempInning = pa.Inning;
            tempOuts += pa.OutsRecorded;
            
            temp1B = pa.RunnerOn1B_End;
            temp2B = pa.RunnerOn2B_End;
            temp3B = pa.RunnerOn3B_End;
            
            if (pa.EndsInning)
            {
                tempOuts = 0;
                tempInning++;
                temp1B = null;
                temp2B = null;
                temp3B = null;
            }
        }
    }

}
