                                                    @if (stat.H > 0) { <div class="stat-badge @(uiState.SortColumn == "H" ? "active" : "")"><span class="stat-badge-val">@stat.H</span><span class="stat-badge-lbl">H</span></div> }
                                                    @if (stat.H2B > 0) { <div class="stat-badge @(uiState.SortColumn == "2B" ? "active" : "")"><span class="stat-badge-val">@stat.H2B</span><span class="stat-badge-lbl">2B</span></div> }
                                                    @if (stat.H3B > 0) { <div class="stat-badge @(uiState.SortColumn == "3B" ? "active" : "")"><span class="stat-badge-val">@stat.H3B</span><span class="stat-badge-lbl">3B</span></div> }
                                                    @if (stat.H4B > 0) { <div class="stat-badge @(uiState.SortColumn == "4B" ? "active" : "")"><span class="stat-badge-val">@stat.H4B</span><span class="stat-badge-lbl">4B</span></div> }
                                                    @if (stat.HR > 0) { <div class="stat-badge @(uiState.SortColumn == "HR" ? "active" : "")"><span class="stat-badge-val">@stat.HR</span><span class="stat-badge-lbl">HR</span></div> }
                                                    @if (stat.RBI > 0) { <div class="stat-badge @(uiState.SortColumn == "RBI" ? "active" : "")"><span class="stat-badge-val">@stat.RBI</span><span class="stat-badge-lbl">RBI</span></div> }
                                                    @if (stat.BB > 0) { <div class="stat-badge @(uiState.SortColumn == "BB" ? "active" : "")"><span class="stat-badge-val">@stat.BB</span><span class="stat-badge-lbl">BB</span></div> }
                                                    @if (stat.K > 0) { <div class="stat-badge @(uiState.SortColumn == "K" ? "active" : "")"><span class="stat-badge-val">@stat.K</span><span class="stat-badge-lbl">K</span></div> }
