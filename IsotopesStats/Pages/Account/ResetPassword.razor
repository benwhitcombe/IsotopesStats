@page "/account/reset-password"
@using IsotopesStats.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Isotopes - Reset Password</PageTitle>

<div style="max-width: 450px; margin: 4rem auto; padding: 0 1rem;">
    <div class="stat-card view-fade-in" style="padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🔄</div>
            <h3 style="margin:0; color: var(--isotopes-dark); font-weight: 800; letter-spacing: 1px;">RESET PASSWORD</h3>
            <p style="color: #666; font-size: 0.9rem; margin-top: 0.5rem;">Enter your new secure password</p>
        </div>
        
        @if (isSuccess)
        {
            <div class="view-fade-in" style="background: #f0fdf4; color: #166534; padding: 1.5rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #dcfce7; text-align: center;">
                <p style="font-weight: bold; margin-bottom: 0.5rem;">Success!</p>
                Password reset successfully. You can now login with your new password.
            </div>
            <a href="/account/login" class="view-btn active" style="display: block; text-align: center; background-color: var(--isotopes-accent); border-color: var(--isotopes-accent); text-decoration: none;">Go to Login</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                    @errorMessage
                </div>
            }

            <div class="form-group">
                <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">New Password</label>
                <div style="position: relative;">
                    <input type="@(showNewPassword ? "text" : "password")" class="form-control" @bind="newPassword" autocomplete="new-password" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; padding-right: 3rem;" />
                    <button type="button" @onclick="() => showNewPassword = !showNewPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                        <PasswordToggleIcon IsVisible="@showNewPassword" />
                    </button>
                </div>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
                <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">Confirm Password</label>
                <div style="position: relative;">
                    <input type="@(showConfirmPassword ? "text" : "password")" class="form-control" @bind="confirmPassword" autocomplete="new-password" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; padding-right: 3rem;" />
                    <button type="button" @onclick="() => showConfirmPassword = !showConfirmPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                        <PasswordToggleIcon IsVisible="@showConfirmPassword" />
                    </button>
                </div>
            </div>

            <button class="view-btn active" @onclick="HandleResetPassword" style="margin-top: 2rem; width: 100%; padding: 1rem; font-size: 1.1rem; background-color: var(--isotopes-red); border-color: var(--isotopes-red);">Update Password</button>
        }
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private bool isSuccess = false;
    private bool showNewPassword = false;
    private bool showConfirmPassword = false;

    private async Task HandleResetPassword()
    {
        errorMessage = "";
        
        if (string.IsNullOrEmpty(Token))
        {
            errorMessage = "Invalid or missing token.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (newPassword.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters.";
            return;
        }

        bool result = await AuthService.ResetPasswordAsync(Token, newPassword);
        
        if (result)
        {
            isSuccess = true;
        }
        else
        {
            errorMessage = "Invalid or expired token.";
        }
    }
}
