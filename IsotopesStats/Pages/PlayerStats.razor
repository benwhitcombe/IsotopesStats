@page "/"
@page "/playerstats"
@using IsotopesStats.Models
@using IsotopesStats.Services
@inject IStatsService StatsService
@inject SharedSessionState SharedState
@inject PlayerStatsState SessionState
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Isotopes - Player Stats</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h3 style="margin:0">Player Statistics</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <div class="desktop-only" style="display: flex; gap: 1rem; align-items: center;">
            <label style="margin:0; font-weight: bold;">Season:</label>
            <select class="form-control" style="width: auto;" value="@SharedState.SelectedSeasonId" @onchange="OnSeasonChange">
                <option value="-1">All Seasons</option>
                @foreach (Season season in seasons)
                {
                    <option value="@season.Id">@season.Name</option>
                }
            </select>
        </div>
        <div class="mobile-only">
             <button class="view-btn" style="background: var(--isotopes-accent); color: white; border: none; padding: 0.5rem 1rem;" @onclick="ToggleSeasonModal"> 
                🗓️ @(SharedState.SelectedSeasonId == -1 ? "All Seasons" : seasons.FirstOrDefault(s => s.Id == SharedState.SelectedSeasonId)?.Name)
            </button>
        </div>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                <div class="sort-option @(SharedState.SelectedSeasonId == -1 ? "active" : "")" @onclick="() => SelectMobileSeason(-1)">
                    All Seasons
                </div>
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(SharedState.SelectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div style="text-align: center; padding: 5rem;">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (!allStats.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Stats Found</h4>
            <p>Try a different season.</p>
        </div>
    }
    else
    {
        <div class="stat-card" style="animation-delay: 0.1s; margin-bottom: 1.5rem;">
            <div class="leader-highlights" style="margin-bottom: 1.5rem;">
                <div class="leader-card" @onclick='() => Sort("AVG", false)' style="cursor:pointer; animation-delay: 0.1s;">
                    <div class="leader-category">Batting Average</div>
                    @if (avgLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(avgLeader.PlayerName)' @onclick:stopPropagation="true">@avgLeader.PlayerName</div>
                        <div class="leader-value">@avgLeader.AVG.ToString(".000")</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
                <div class="leader-card" @onclick='() => Sort("OPS", false)' style="cursor:pointer; background: linear-gradient(135deg, #333, #000); animation-delay: 0.2s;">
                    <div class="leader-category">On-Base Plus Slugging</div>
                    @if (opsLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(opsLeader.PlayerName)' @onclick:stopPropagation="true">@opsLeader.PlayerName</div>
                        <div class="leader-value">@opsLeader.OPS.ToString(".000")</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
                <div class="leader-card" @onclick='() => Sort("HR", false)' style="cursor:pointer; background: linear-gradient(135deg, var(--isotopes-red), #990000); animation-delay: 0.3s;">
                    <div class="leader-category">Home Runs</div>
                    @if (hrLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(hrLeader.PlayerName)' @onclick:stopPropagation="true">@hrLeader.PlayerName</div>
                        <div class="leader-value">@hrLeader.HR.ToString()</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
                <div class="leader-card" @onclick='() => Sort("RBI", false)' style="cursor:pointer; background: linear-gradient(135deg, #666, #444); animation-delay: 0.4s;">
                    <div class="leader-category">Runs Batted In</div>
                    @if (rbiLeader != null)
                    {
                        <div class="leader-name" @onclick='() => NavigateToLog(rbiLeader.PlayerName)' @onclick:stopPropagation="true">@rbiLeader.PlayerName</div>
                        <div class="leader-value">@rbiLeader.RBI.ToString()</div>
                    }
                    else
                    {
                        <div style="min-height: 4.5rem; display: flex; align-items: center; justify-content: center; opacity: 0.5; font-size: 2rem;">---</div>
                    }
                </div>
            </div>

            <hr style="margin: 0; opacity: 0.1;" />

            <div class="desktop-only" style="margin-top: 1.5rem;">
                <div class="table-container box-score-table-wrapper" style="padding: 0;">
                    <table class="box-score-table table-sm">
                    <thead>
                        <tr>
                            <th style="width: 30px; text-align: center;">#</th>
                            <th class="player-name sticky-col @(currentSortColumn == "PlayerName" ? "active-sort-header" : "")" @onclick='() => Sort("PlayerName")'>
                                <span style="position: relative; display: inline-block;">
                                    Player<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("PlayerName"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("GP")' class="sortable-header group-divider narrow-col @(currentSortColumn == "GP" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    GP<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("GP"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("PA")' class="sortable-header narrow-col @(currentSortColumn == "PA" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    PA<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("PA"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("AB")' class="sortable-header narrow-col @(currentSortColumn == "AB" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    AB<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("AB"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("R")' class="sortable-header group-divider narrow-col @(currentSortColumn == "R" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    R<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("R"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("H")' class="sortable-header narrow-col @(currentSortColumn == "H" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    H<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("H"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("2B")' class="sortable-header narrow-col @(currentSortColumn == "2B" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    2B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("2B"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("3B")' class="sortable-header narrow-col @(currentSortColumn == "3B" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    3B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("3B"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("4B")' class="sortable-header narrow-col @(currentSortColumn == "4B" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    4B<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("4B"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("HR")' class="sortable-header narrow-col @(currentSortColumn == "HR" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    HR<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("HR"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("RBI")' class="sortable-header narrow-col @(currentSortColumn == "RBI" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    RBI<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("RBI"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("BB")' class="sortable-header group-divider narrow-col @(currentSortColumn == "BB" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    BB<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("BB"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("K")' class="sortable-header narrow-col @(currentSortColumn == "K" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    K<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("K"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("KF")' class="sortable-header narrow-col @(currentSortColumn == "KF" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    KF<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("KF"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("SF")' class="sortable-header group-divider narrow-col @(currentSortColumn == "SF" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    SF<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("SF"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("FC")' class="sortable-header narrow-col @(currentSortColumn == "FC" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    FC<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("FC"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("GO")' class="sortable-header narrow-col @(currentSortColumn == "GO" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    GO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("GO"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("FO")' class="sortable-header narrow-col @(currentSortColumn == "FO" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    FO<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("FO"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("AVG")' class="sortable-header group-divider @(currentSortColumn == "AVG" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    AVG<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("AVG"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("OBP")' class="sortable-header @(currentSortColumn == "OBP" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    OBP<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("OBP"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("SLG")' class="sortable-header @(currentSortColumn == "SLG" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    SLG<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("SLG"))</span>
                                </span>
                            </th>
                            <th @onclick='() => Sort("OPS")' class="sortable-header @(currentSortColumn == "OPS" ? "active-sort-header" : "")">
                                <span style="position: relative; display: inline-block;">
                                    OPS<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("OPS"))</span>
                                </span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < allStats.Count; i++)
                        {
                            PlayerStatsSummary player = allStats[i];
                            <tr>
                                <td style="color: #999; font-weight: bold; text-align: center;">@(i + 1)</td>
                                <td class="player-name sticky-col">
                                    <a href="/playerlogs/@Uri.EscapeDataString(player.PlayerName)" style="text-decoration: none; color: inherit;">        
                                        @player.PlayerName
                                    </a>
                                </td>
                                <td class="group-divider narrow-col @(currentSortColumn == "GP" ? "active-sort-col" : "")">@player.GamesPlayed</td>
                                <td class="narrow-col @(currentSortColumn == "PA" ? "active-sort-col" : "")">@player.PA</td>
                                <td class="narrow-col @(currentSortColumn == "AB" ? "active-sort-col" : "")">@player.AB</td>
                                <td class="group-divider narrow-col @(currentSortColumn == "R" ? "active-sort-col" : "")">@player.R</td>
                                <td class="narrow-col @(currentSortColumn == "H" ? "active-sort-col" : "")">@player.H</td>
                                <td class="narrow-col @(currentSortColumn == "2B" ? "active-sort-col" : "")">@player.H2B</td>
                                <td class="narrow-col @(currentSortColumn == "3B" ? "active-sort-col" : "")">@player.H3B</td>
                                <td class="narrow-col @(currentSortColumn == "4B" ? "active-sort-col" : "")">@player.H4B</td>
                                <td class="narrow-col @(currentSortColumn == "HR" ? "active-sort-col" : "")">@player.HR</td>
                                <td class="narrow-col @(currentSortColumn == "RBI" ? "active-sort-col" : "")">@player.RBI</td>
                                <td class="group-divider narrow-col @(currentSortColumn == "BB" ? "active-sort-col" : "")">@player.BB</td>
                                <td class="narrow-col @(currentSortColumn == "K" ? "active-sort-col" : "")">@player.K</td>
                                <td class="narrow-col @(currentSortColumn == "KF" ? "active-sort-col" : "")">@player.KF</td>
                                <td class="group-divider narrow-col @(currentSortColumn == "SF" ? "active-sort-col" : "")">@player.SF</td>
                                <td class="narrow-col @(currentSortColumn == "FC" ? "active-sort-col" : "")">@player.FC</td>
                                <td class="narrow-col @(currentSortColumn == "GO" ? "active-sort-col" : "")">@player.GO</td>
                                <td class="narrow-col @(currentSortColumn == "FO" ? "active-sort-col" : "")">@player.FO</td>
                                <td class="group-divider @(currentSortColumn == "AVG" ? "active-sort-col" : "")">@player.AVG.ToString(".000")</td>
                                <td class="@(currentSortColumn == "OBP" ? "active-sort-col" : "")">@player.OBP.ToString(".000")</td>
                                <td class="@(currentSortColumn == "SLG" ? "active-sort-col" : "")">@player.SLG.ToString(".000")</td>
                                <td class="@(currentSortColumn == "OPS" ? "active-sort-col" : "")">@player.OPS.ToString(".000")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="game-summary-row">
                            <td colspan="2" class="sticky-col">TEAM TOTALS</td>
                            <td class="group-divider narrow-col">-</td>
                            <td class="narrow-col">@teamTotals.PA</td>
                            <td class="narrow-col">@teamTotals.AB</td>
                            <td class="group-divider narrow-col">@teamTotals.R</td>
                            <td class="narrow-col">@teamTotals.H</td>
                            <td class="narrow-col">@teamTotals.H2B</td>
                            <td class="narrow-col">@teamTotals.H3B</td>
                            <td class="narrow-col">@teamTotals.H4B</td>
                            <td class="narrow-col">@teamTotals.HR</td>
                            <td class="narrow-col">@teamTotals.RBI</td>
                            <td class="group-divider narrow-col">@teamTotals.BB</td>
                            <td class="narrow-col">@teamTotals.K</td>
                            <td class="narrow-col">@teamTotals.KF</td>
                            <td class="group-divider narrow-col">@teamTotals.SF</td>
                            <td class="narrow-col">@teamTotals.FC</td>
                            <td class="narrow-col">@teamTotals.GO</td>
                            <td class="narrow-col">@teamTotals.FO</td>
                            <td class="group-divider">@teamTotals.AVG.ToString(".000")</td>
                            <td>@teamTotals.OBP.ToString(".000")</td>
                            <td>@teamTotals.SLG.ToString(".000")</td>
                            <td>@teamTotals.OPS.ToString(".000")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            </div>

            <div class="mobile-only" style="margin-top: 1.5rem;">
                <div class="mobile-list-container view-fade-in">
                    <div class="mobile-list-header">
                        <div class="mobile-list-rank">#</div>
                        <div class="mobile-list-name">Player</div>
                        <div class="mobile-list-value" @onclick="() => Sort(currentSortColumn, true)" style="cursor: pointer; position: relative; display: flex; align-items: center; justify-content: center;">
                            @currentSortColumn 
                            <span class="sort-icon" style="position: absolute; right: 12px;">
                                @(isAscending ? "▲" : "▼")
                            </span>
                        </div>
                    </div>
                    @for (int i = 0; i < allStats.Count; i++)
                    {
                        PlayerStatsSummary player = allStats[i];
                        <div class="mobile-list-item" @onclick='() => NavigateToLog(player.PlayerName)'>
                            <div class="mobile-list-rank">@(i + 1)</div>
                            <div class="mobile-list-name">@player.PlayerName</div>
                            <div class="mobile-list-value">@GetStatValue(player, currentSortColumn)</div>
                        </div>
                    }
                    <div class="mobile-list-item team-totals-item">
                        <div class="mobile-list-name" style="font-weight: 900; text-align: left;">@(new[] { "AVG", "OBP", "SLG", "OPS" }.Contains(currentSortColumn) ? "Team Average" : "Team Totals")</div>
                        <div class="mobile-list-value">@GetStatValue(teamTotals, currentSortColumn)</div>
                    </div>
                </div>

                <!-- Bottom Drawer for Stat Selection -->
                <div id="stat-drawer" class="mobile-stat-drawer @(isDrawerExpanded ? "expanded" : "")">
                    <div id="drawer-handle" class="drawer-handle-container" @onclick="ToggleDrawer">
                        <div class="drawer-handle"></div>
                    </div>
                    
                    <div class="stat-carousel">
                        @foreach (string stat in AllSortableStats)
                        {
                            <button class="stat-btn @(currentSortColumn == stat ? "active" : "")" @onclick="() => SelectMobileSort(stat)" @onclick:stopPropagation="true">@stat</button>
                        }
                    </div>
                    
                    <div class="drawer-expanded-content">
                        <div class="drawer-section-title">Hitting Stats</div>
                        <div class="stat-grid-full">
                            @foreach (string stat in AllSortableStats)
                            {
                                <button class="stat-btn @(currentSortColumn == stat ? "active" : "")" @onclick="() => SelectMobileSort(stat)" @onclick:stopPropagation="true">@stat</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<PlayerStatsSummary> allStats = new();
    private List<Season> seasons = new();
    private PlayerStatsSummary teamTotals = new();
    private string currentSortColumn = "AVG";
    private bool isAscending = false;
    private bool showSeasonModal = false;
    private bool isDrawerExpanded = false;
    private bool isLoading = true;
    private bool isFirstDataLoad = true;
    private DotNetObjectReference<PlayerStats>? objRef;

    // Leader references
    private PlayerStatsSummary? avgLeader;
    private PlayerStatsSummary? opsLeader;
    private PlayerStatsSummary? hrLeader;
    private PlayerStatsSummary? rbiLeader;

    private readonly string[] AllSortableStats = {
        "AVG", "OBP", "SLG", "OPS", "HR", "RBI", "R", "H", "1B", "2B", "3B", "4B", "GP", "PA", "AB", "BB", "K", "KF", "SF", "FC", "GO", "FO"
    };

    protected override async Task OnInitializedAsync()
    {
        SharedState.ReturnUrl = "playerstats";
        seasons = await StatsService.GetSeasonsAsync();

        if (SharedState.SelectedSeasonId == 0)
        {
            int recentSeasonId = await StatsService.GetMostRecentStatsSeasonIdAsync();
            if (recentSeasonId != 0)
            {
                SharedState.SelectedSeasonId = recentSeasonId;
            }
            else if (seasons.Any())
            {
                SharedState.SelectedSeasonId = seasons.First().Id;
            }
        }

        currentSortColumn = SessionState.CurrentSortColumn;
        isAscending = SessionState.IsAscending;

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            allStats = await StatsService.GetStatsSummaryAsync(SharedState.SelectedSeasonId);
            teamTotals = await StatsService.GetTeamTotalsAsync(SharedState.SelectedSeasonId);
            CalculateLeaders();
            Sort(currentSortColumn, false);
        }
        catch (Exception)
        {
            allStats = new List<PlayerStatsSummary>();
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && allStats.Any())
        {
            if (objRef == null)
            {
                objRef = DotNetObjectReference.Create(this);
            }
            await JSRuntime.InvokeVoidAsync("drawerDragging.init", objRef, isDrawerExpanded);
            
            if (isFirstDataLoad)
            {
                isFirstDataLoad = false;
                // JavaScript now handles timing via requestAnimationFrame, no Task.Delay needed
                await JSRuntime.InvokeVoidAsync("drawerDragging.scrollToActive", true);
            }
        }
    }

    [JSInvokable]
    public void SetDrawerState(bool expanded)
    {
        if (isDrawerExpanded != expanded)
        {
            isDrawerExpanded = expanded;
            StateHasChanged();
        }
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            SharedState.SelectedSeasonId = id;
            await LoadData();
        }
    }

    private void ToggleSeasonModal() => showSeasonModal = !showSeasonModal;

    private async Task SelectMobileSeason(int id)
    {
        SharedState.SelectedSeasonId = id;
        showSeasonModal = false;
        await LoadData();
    }

    private void CalculateLeaders()
    {
        if (!allStats.Any()) return;

        avgLeader = allStats.Where(p => p.AB > 0).OrderByDescending(p => p.AVG).FirstOrDefault();
        opsLeader = allStats.Where(p => p.PA > 0).OrderByDescending(p => p.OPS).FirstOrDefault();
        hrLeader = allStats.Where(p => p.HR > 0).OrderByDescending(p => p.HR).FirstOrDefault();
        rbiLeader = allStats.Where(p => p.RBI > 0).OrderByDescending(p => p.RBI).FirstOrDefault();
    }

    private async Task ToggleDrawer()
    {
        isDrawerExpanded = !isDrawerExpanded;
        await JSRuntime.InvokeVoidAsync("drawerDragging.updateState", isDrawerExpanded);
    }

    private async Task SelectMobileSort(string column)
    {
        Sort(column, false);
        isDrawerExpanded = false;
        await JSRuntime.InvokeVoidAsync("drawerDragging.updateState", false);
        await JSRuntime.InvokeVoidAsync("drawerDragging.scrollToActive");
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }

    private void Sort(string column, bool toggle = true)
    {
        if (toggle)
        {
            if (currentSortColumn == column)
            {
                isAscending = !isAscending;
            }
            else
            {
                currentSortColumn = column;
                isAscending = false;
            }
        }
        else
        {
            currentSortColumn = column;
            isAscending = false;
        }

        switch (column)
        {
            case "PlayerName": allStats = isAscending ? allStats.OrderBy(p => p.PlayerName).ToList() : allStats.OrderByDescending(p => p.PlayerName).ToList(); break;
            case "GP": allStats = isAscending ? allStats.OrderBy(p => p.GamesPlayed).ToList() : allStats.OrderByDescending(p => p.GamesPlayed).ToList(); break;   
            case "PA": allStats = isAscending ? allStats.OrderBy(p => p.PA).ToList() : allStats.OrderByDescending(p => p.PA).ToList(); break;
            case "AB": allStats = isAscending ? allStats.OrderBy(p => p.AB).ToList() : allStats.OrderByDescending(p => p.AB).ToList(); break;
            case "H": allStats = isAscending ? allStats.OrderBy(p => p.H).ToList() : allStats.OrderByDescending(p => p.H).ToList(); break;
            case "H1B": case "1B": allStats = isAscending ? allStats.OrderBy(p => p.H1B).ToList() : allStats.OrderByDescending(p => p.H1B).ToList(); break;       
            case "H2B": case "2B": allStats = isAscending ? allStats.OrderBy(p => p.H2B).ToList() : allStats.OrderByDescending(p => p.H2B).ToList(); break;       
            case "H3B": case "3B": allStats = isAscending ? allStats.OrderBy(p => p.H3B).ToList() : allStats.OrderByDescending(p => p.H3B).ToList(); break;       
            case "H4B": case "4B": allStats = isAscending ? allStats.OrderBy(p => p.H4B).ToList() : allStats.OrderByDescending(p => p.H4B).ToList(); break;       
            case "HR": allStats = isAscending ? allStats.OrderBy(p => p.HR).ToList() : allStats.OrderByDescending(p => p.HR).ToList(); break;
            case "RBI": allStats = isAscending ? allStats.OrderBy(p => p.RBI).ToList() : allStats.OrderByDescending(p => p.RBI).ToList(); break;
            case "R": allStats = isAscending ? allStats.OrderBy(p => p.R).ToList() : allStats.OrderByDescending(p => p.R).ToList(); break;
            case "AVG": allStats = isAscending ? allStats.OrderBy(p => p.AVG).ToList() : allStats.OrderByDescending(p => p.AVG).ToList(); break;
            case "OPS": allStats = isAscending ? allStats.OrderBy(p => p.OPS).ToList() : allStats.OrderByDescending(p => p.OPS).ToList(); break;
            case "SLG": allStats = isAscending ? allStats.OrderBy(p => p.SLG).ToList() : allStats.OrderByDescending(p => p.SLG).ToList(); break;
            case "OBP": allStats = isAscending ? allStats.OrderBy(p => p.OBP).ToList() : allStats.OrderByDescending(p => p.OBP).ToList(); break;
            case "BB": allStats = isAscending ? allStats.OrderBy(p => p.BB).ToList() : allStats.OrderByDescending(p => p.BB).ToList(); break;
            case "SF": allStats = isAscending ? allStats.OrderBy(p => p.SF).ToList() : allStats.OrderByDescending(p => p.SF).ToList(); break;
            case "FC": allStats = isAscending ? allStats.OrderBy(p => p.FC).ToList() : allStats.OrderByDescending(p => p.FC).ToList(); break;
            case "K": allStats = isAscending ? allStats.OrderBy(p => p.K).ToList() : allStats.OrderByDescending(p => p.K).ToList(); break;
            case "KF": allStats = isAscending ? allStats.OrderBy(p => p.KF).ToList() : allStats.OrderByDescending(p => p.KF).ToList(); break;
            case "GO": allStats = isAscending ? allStats.OrderBy(p => p.GO).ToList() : allStats.OrderByDescending(p => p.GO).ToList(); break;
            case "FO": allStats = isAscending ? allStats.OrderBy(p => p.FO).ToList() : allStats.OrderByDescending(p => p.FO).ToList(); break;
        }

        currentSortColumn = column;
        SessionState.CurrentSortColumn = column;
        SessionState.IsAscending = isAscending;
    }

    private string GetStatValue(PlayerStatsSummary player, string stat)
    {
        if (player == null) return "";
        return stat switch
        {
            "GP" => player.GamesPlayed.ToString(),
            "PA" => player.PA.ToString(),
            "AB" => player.AB.ToString(),
            "H" => player.H.ToString(),
            "1B" => player.H1B.ToString(),
            "2B" => player.H2B.ToString(),
            "3B" => player.H3B.ToString(),
            "4B" => player.H4B.ToString(),
            "HR" => player.HR.ToString(),
            "RBI" => player.RBI.ToString(),
            "R" => player.R.ToString(),
            "BB" => player.BB.ToString(),
            "SF" => player.SF.ToString(),
            "FC" => player.FC.ToString(),
            "K" => player.K.ToString(),
            "KF" => player.KF.ToString(),
            "GO" => player.GO.ToString(),
            "FO" => player.FO.ToString(),
            "AVG" => player.AVG.ToString(".000"),
            "OBP" => player.OBP.ToString(".000"),
            "SLG" => player.SLG.ToString(".000"),
            "OPS" => player.OPS.ToString(".000"),
            _ => ""
        };
    }

    private string GetSortIcon(string column)
    {
        if (currentSortColumn != column) return "";
        return isAscending ? "▲" : "▼";
    }

    private void NavigateToLog(string? playerName)
    {
        if (string.IsNullOrEmpty(playerName)) return;
        SharedState.ReturnUrl = "playerstats";
        NavigationManager.NavigateTo($"/playerlogs/{Uri.EscapeDataString(playerName)}");
    }
