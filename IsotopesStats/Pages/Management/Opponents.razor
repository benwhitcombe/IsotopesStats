@page "/management/opponents"
@page "/management/opponents/{Action}"
@page "/management/opponents/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@attribute [Authorize(Policy = "Manage Opponents")]
@inject IStatsRepository StatsRepository
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject SessionStorageService SessionStorage

<PageTitle>Isotopes - Manage Opponents</PageTitle>

<DeleteManager TItem="Opponent" TId="int" @ref="deleteManager" OnDeleted="LoadOpponents" DeleteAction="StatsRepository.DeleteOpponentAsync" />

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Opponents</h3>
    @if (!isLoading && !isAdding && !isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Opponent</button>
    }
</div>

@if (isLoading)
{
    <LoadingIndicator Message="Loading Opponents..." Padding="5" />
}
else if (isAdding || isEditing)
{
    <ModelEditor 
        TItem="Opponent"
        @ref="modelEditor"
        Title="@($"{(isAdding ? "Add" : "Edit")} Opponent")"
        Item="editingOpponent"
        OriginalItem="originalOpponent"
        BasePath="/management/opponents"
        CheckUniqueAsync="CheckUniqueOpponent"
        OnSave="SaveOpponent"
        OnDelete="DeleteOpponent"
        ExtraState="extraState"
        HasCustomChanges="HasExtraStateChanges">

        <div class="form-group">
            <label>Full Name</label>
            <InputText class="form-control" @bind-Value="editingOpponent.Name" placeholder="e.g. Springfield Atoms" />
            <ValidationMessage For="@(() => editingOpponent.Name)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label>Short Name (Optional)</label>
            <InputText class="form-control" @bind-Value="editingOpponent.ShortName" placeholder="e.g. Atoms" />
            <span style="font-size: 0.75rem; color: #888;">Used in scoreboards when space is limited.</span>
        </div>
        
        <div class="form-group" style="margin-top: 2rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Season History & Identity</label>
            
            <div class="desktop-only">
                <div class="table-container" style="border: 1px solid #eee; border-radius: 8px; background: white;">
                    <table class="table" style="margin-bottom: 0;">
                        <thead>
                            <tr style="background: #f8f9fa;">
                                <th style="width: 50px; text-align: center;">Active</th>
                                <th>Season</th>
                                <th>Name in Season</th>
                                <th>Short Name in Season</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Season season in allSeasons)
                            {
                                bool isActive = extraState.Ids.Contains(season.Id);
                                <tr>
                                    <td style="text-align: center; vertical-align: middle;">
                                        <input type="checkbox" 
                                               style="width: 18px; height: 18px; cursor: pointer;"
                                               checked="@isActive" 
                                               @onchange="@((e) => ToggleSeason(season.Id, (bool)(e.Value ?? false)))" />
                                    </td>
                                    <td style="vertical-align: middle; font-weight: bold; color: @(isActive ? "var(--isotopes-accent)" : "#999");">
                                        @season.Name
                                    </td>
                                    <td>
                                        @if (isActive)
                                        {
                                            <input type="text" 
                                                   class="form-control form-control-sm" 
                                                   placeholder="Enter season name..." 
                                                   value="@GetSeasonName(season.Id)" 
                                                   @oninput='@((e) => UpdateSeasonOverride(season.Id, e.Value?.ToString(), "name"))' />
                                        }
                                        else
                                        {
                                            <span style="color: #ccc; font-style: italic; font-size: 0.9rem;">Not in season</span>
                                        }
                                    </td>
                                    <td>
                                        @if (isActive)
                                        {
                                            <input type="text" 
                                                   class="form-control form-control-sm" 
                                                   placeholder="Enter short name..." 
                                                   value="@GetSeasonShortName(season.Id)" 
                                                   @oninput='@((e) => UpdateSeasonOverride(season.Id, e.Value?.ToString(), "short"))' />
                                        }
                                        else
                                        {
                                            <span style="color: #ccc; font-style: italic; font-size: 0.9rem;">Not in season</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mobile-only">
                @foreach (Season season in allSeasons)
                {
                    bool isActive = extraState.Ids.Contains(season.Id);
                    <div class="mobile-player-card" style="margin-bottom: 0.75rem;">
                        <div class="mobile-card-header" style="border-bottom: @(isActive ? "1px solid #f0f0f0" : "none"); margin-bottom: @(isActive ? "0.75rem" : "0"); padding-bottom: @(isActive ? "0.5rem" : "0");">
                            <div class="mobile-card-name" style="color: @(isActive ? "var(--isotopes-accent)" : "#999");">@season.Name</div>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-size: 0.7rem; color: #999; text-transform: uppercase; font-weight: bold;">Active</span>
                                <input type="checkbox" 
                                       style="width: 20px; height: 20px; cursor: pointer;"
                                       checked="@isActive" 
                                       @onchange="@((e) => ToggleSeason(season.Id, (bool)(e.Value ?? false)))" />
                            </div>
                        </div>
                        @if (isActive)
                        {
                            <div class="form-group" style="margin-bottom: 0.75rem;">
                                <label style="font-size: 0.7rem; color: #999; text-transform: uppercase; font-weight: bold; margin-bottom: 0.25rem;">Name in Season</label>
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="Enter season name..." 
                                       value="@GetSeasonName(season.Id)" 
                                       @oninput='@((e) => UpdateSeasonOverride(season.Id, e.Value?.ToString(), "name"))' />
                            </div>
                            <div class="form-group" style="margin-bottom: 0;">
                                <label style="font-size: 0.7rem; color: #999; text-transform: uppercase; font-weight: bold; margin-bottom: 0.25rem;">Short Name in Season</label>
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="Enter short name..." 
                                       value="@GetSeasonShortName(season.Id)" 
                                       @oninput='@((e) => UpdateSeasonOverride(season.Id, e.Value?.ToString(), "short"))' />
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </ModelEditor>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: left;">Seasons Played</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Opponent opponent in opponents)
                        {
                            <tr>
                                <td style="text-align: left; cursor: pointer;" @onclick='() => StartEdit("edit", opponent.Id)'>
                                    <div style="font-weight: bold; color: var(--isotopes-accent);">@opponent.Name</div>
                                    @if (!string.IsNullOrEmpty(opponent.ShortName))
                                    {
                                        <div style="font-size: 0.75rem; color: #888;">Short: @opponent.ShortName</div>
                                    }
                                </td>
                                <td style="text-align: left; font-size: 0.85rem; color: #666;">
                                    @GetSeasonSummary(opponent.Id)
                                </td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", opponent.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(opponent)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Opponent opponent in opponents)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header" style="flex-direction: column; align-items: flex-start;">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", opponent.Id)'>@opponent.Name</div>
                        @if (!string.IsNullOrEmpty(opponent.ShortName))
                        {
                            <div style="font-size: 0.7rem; color: #888; font-weight: bold; text-transform: uppercase;">Short: @opponent.ShortName</div>
                        }
                        <div style="font-size: 0.75rem; color: #888; margin-top: 0.2rem;">@GetSeasonSummary(opponent.Id)</div>
                    </div>
                    <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", opponent.Id)'>Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(opponent)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private DeleteManager<Opponent, int> deleteManager = null!;
    private List<Opponent> opponents = new();
    private List<Season> allSeasons = new();
    private List<SeasonOpponents> allMappings = new();
    private Opponent editingOpponent = new();
    private Opponent originalOpponent = new Opponent();
    private bool isAdding = false;
    private bool isEditing = false;
    private ModelEditor<Opponent> modelEditor = null!;
    private OpponentExtraState extraState = new();
    private OpponentExtraState originalExtraState = new();

    private bool HasExtraStateChanges() => !extraState.Equals(originalExtraState);

    protected override async Task OnInitializedAsync()
    {
        allSeasons = await StatsRepository.GetSeasonsAsync();
        await LoadOpponents();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasAdding = isAdding;
        bool wasEditing = isEditing;
        
        bool nextAdding = Action == "add";
        bool nextEditing = Action == "edit";

        if (nextAdding || nextEditing)
        {
            if (nextAdding && !wasAdding)
            {
                isAdding = false;
                isEditing = false;
                await LoadNewOpponent();
            }
            else if (nextEditing && (!wasEditing || (Id.HasValue && Id != editingOpponent.Id)))
            {
                isAdding = false;
                isEditing = false;
                await LoadEditingOpponent();
            }
        }
        else
        {
            editingOpponent = new Opponent();
            originalOpponent = new Opponent();
            extraState = new();
            originalExtraState = new();
        }

        isAdding = nextAdding;
        isEditing = nextEditing;
    }

    private async Task LoadNewOpponent()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        editingOpponent = new Opponent();
        originalOpponent = new Opponent();
        extraState = new();
        originalExtraState = new();
        await HydrateTempState();
    }

    private async Task LoadEditingOpponent()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            Opponent? opponent = opponents.FirstOrDefault(o => o.Id == Id);
            if (opponent == null)
            {
                opponent = (await StatsRepository.GetAllOpponentsAsync()).FirstOrDefault(o => o.Id == Id);
            }

            if (opponent != null)
            {
                editingOpponent = opponent with { };
                originalOpponent = opponent with { };
                extraState = new();
                originalExtraState = new();

                List<SeasonOpponents> opponentSeasons = await StatsRepository.GetSeasonsForOpponentAsync(opponent.Id);
                foreach (SeasonOpponents s in opponentSeasons)
                {
                    extraState.Ids.Add(s.SeasonId);
                    extraState.Names[s.SeasonId] = s.Name;
                    extraState.Shorts[s.SeasonId] = s.ShortName;
                }
                originalExtraState = extraState with { 
                    Ids = extraState.Ids.ToHashSet(),
                    Names = new Dictionary<int, string?>(extraState.Names),
                    Shorts = new Dictionary<int, string?>(extraState.Shorts)
                };
            }
        }
        else
        {
            editingOpponent = new Opponent();
            originalOpponent = new Opponent();
            extraState = new();
            originalExtraState = new();
        }
        await HydrateTempState();
    }

    private async Task HydrateTempState()
    {
        try
        {
            Opponent? persisted = await SessionStorage.GetItemAsync<Opponent>($"EditState_Opponent_{Id ?? 0}");
            if (persisted != null) editingOpponent = persisted;

            OpponentExtraState? extra = await SessionStorage.GetItemAsync<OpponentExtraState>($"EditState_Opponent_{Id ?? 0}_Extra");
            if (extra != null) extraState = extra;

            StateHasChanged();
        }
        catch { }
    }

    private bool isLoading = true;

    private async Task LoadOpponents()
    {
        isLoading = true;
        try
        {
            opponents = await StatsRepository.GetAllOpponentsAsync();
            allMappings.Clear();
            foreach (Opponent o in opponents)
            {
                List<SeasonOpponents> maps = await StatsRepository.GetSeasonsForOpponentAsync(o.Id);
                allMappings.AddRange(maps);
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetSeasonSummary(int opponentId)
    {
        List<SeasonOpponents> maps = allMappings.Where(m => m.OpponentId == opponentId).ToList();
        if (!maps.Any()) return "No seasons assigned";
        
        List<string> summaries = new List<string>();
        foreach (SeasonOpponents m in maps)
        {
            Season? s = allSeasons.FirstOrDefault(x => x.Id == m.SeasonId);
            if (s != null)
            {
                summaries.Add(s.Name);
            }
        }
        return string.Join(", ", summaries);
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/opponents/add");
        else Navigation.NavigateTo($"/management/opponents/edit/{id}");
    }

    private async Task<string?> CheckUniqueOpponent(Opponent model)
    {
        if (model.Id == 0) return null;
        if (string.IsNullOrWhiteSpace(model.Name)) return null;
        bool isUnique = await StatsRepository.IsOpponentNameUniqueAsync(model.Name, model.Id);
        return isUnique ? null : "Another opponent with this master name already exists.";
    }

    private async Task ToggleSeason(int seasonId, bool isChecked)
    {
        if (isChecked) 
        {
            extraState.Ids.Add(seasonId);
            if (!extraState.Names.ContainsKey(seasonId))
            {
                extraState.Names[seasonId] = editingOpponent.Name;
            }
            if (!extraState.Shorts.ContainsKey(seasonId))
            {
                extraState.Shorts[seasonId] = editingOpponent.ShortName;
            }
        }
        else 
        {
            extraState.Ids.Remove(seasonId);
        }
        if (modelEditor != null) 
        {
            await modelEditor.SaveExtraState();
        }
    }

    private string? GetSeasonName(int seasonId)
    {
        return extraState.Names.TryGetValue(seasonId, out string? name) ? name : editingOpponent.Name;
    }

    private string? GetSeasonShortName(int seasonId)
    {
        return extraState.Shorts.TryGetValue(seasonId, out string? name) ? name : editingOpponent.ShortName;
    }

    private async Task UpdateSeasonOverride(int seasonId, string? value, string type)
    {
        if (type == "name") extraState.Names[seasonId] = value;
        else extraState.Shorts[seasonId] = value;

        if (modelEditor != null)
        {
            await modelEditor.SaveExtraState();
        }
    }

    private async Task SaveOpponent()
    {
        int opponentId;
        if (editingOpponent.Id == 0)
        {
            opponentId = await StatsRepository.AddOpponentAsync(editingOpponent, 0);
            foreach (int sid in extraState.Ids)
            {
                extraState.Names.TryGetValue(sid, out string? name);
                extraState.Shorts.TryGetValue(sid, out string? sname);
                await StatsRepository.AddOpponentToSeasonAsync(opponentId, sid, name ?? editingOpponent.Name, sname ?? editingOpponent.ShortName);
            }
        }
        else
        {
            opponentId = editingOpponent.Id;
            await StatsRepository.UpdateOpponentAsync(editingOpponent);
            
            foreach (int sid in extraState.Ids)
            {
                extraState.Names.TryGetValue(sid, out string? name);
                extraState.Shorts.TryGetValue(sid, out string? sname);
                string currentName = name ?? editingOpponent.Name;
                string? currentShortName = sname ?? editingOpponent.ShortName;

                bool hasChanged = true;
                if (originalExtraState.Ids.Contains(sid))
                {
                    originalExtraState.Names.TryGetValue(sid, out string? oldName);
                    originalExtraState.Shorts.TryGetValue(sid, out string? oldShortName);
                    if (currentName == oldName && currentShortName == oldShortName)
                    {
                        hasChanged = false;
                    }
                }

                if (hasChanged)
                {
                    await StatsRepository.DeleteOpponentFromSeasonAsync(opponentId, sid);
                    await StatsRepository.AddOpponentToSeasonAsync(opponentId, sid, currentName, currentShortName);
                }
            }
            
            foreach (int sid in originalExtraState.Ids.Except(extraState.Ids))
            {
                await StatsRepository.DeleteOpponentFromSeasonAsync(opponentId, sid);
            }
        }
        await LoadOpponents();
    }

    private async Task DeleteOpponent()
    {
        await StatsRepository.DeleteOpponentAsync(editingOpponent.Id);
        await LoadOpponents();
    }

    public record OpponentExtraState
    {
        public HashSet<int> Ids { get; set; } = new();
        public Dictionary<int, string?> Names { get; set; } = new();
        public Dictionary<int, string?> Shorts { get; set; } = new();

        public virtual bool Equals(OpponentExtraState? other)
        {
            if (other is null) return false;
            if (!Ids.SetEquals(other.Ids)) return false;
            if (Names.Count != other.Names.Count) return false;
            if (Shorts.Count != other.Shorts.Count) return false;

            foreach (KeyValuePair<int, string?> kvp in Names)
            {
                if (!other.Names.TryGetValue(kvp.Key, out string? otherVal) || kvp.Value != otherVal) return false;
            }
            foreach (KeyValuePair<int, string?> kvp in Shorts)
            {
                if (!other.Shorts.TryGetValue(kvp.Key, out string? otherVal) || kvp.Value != otherVal) return false;
            }
            return true;
        }
        public override int GetHashCode() => Ids.Count ^ Names.Count ^ Shorts.Count;
    }
}

