@using Microsoft.AspNetCore.Components.Web
@inherits ErrorBoundary

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <!-- The JS displayGlobalError function will take over the UI -->
}

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    private string UserAgent { get; set; } = "Loading...";

    protected override async Task OnInitializedAsync()
    {
        try { UserAgent = await JSRuntime.InvokeAsync<string>("getUserAgent"); }
        catch { UserAgent = "Error getting UA"; }
    }

    protected override async Task OnErrorAsync(Exception exception)
    {
        await base.OnErrorAsync(exception);
        try 
        {
            string message = $"ERROR: {exception.Message}\n\nStack Trace:\n{exception.StackTrace}";
            await JSRuntime.InvokeVoidAsync("displayGlobalError", "BLAZOR EXCEPTION", message);
        }
        catch { }
    }
}
