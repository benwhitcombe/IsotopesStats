@page "/stats"
@using IsotopesStats.Data
@using IsotopesStats.Models
@inject StatsService StatsService

<h3>Player Leaderboard</h3>

<div class="view-switcher">
    <button class="view-btn @(activeView == "Standard" ? "active" : "")" @onclick="@(() => activeView = "Standard")">Standard</button>
    <button class="view-btn @(activeView == "Hits" ? "active" : "")" @onclick="@(() => activeView = "Hits")">Hits</button>
    <button class="view-btn @(activeView == "Outcomes" ? "active" : "")" @onclick="@(() => activeView = "Outcomes")">Plate Outcomes</button>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th @onclick="@(() => Sort("PlayerName"))" style="cursor:pointer">Player @(GetSortIcon("PlayerName"))</th>
                @if (activeView == "Standard")
                {
                    <th @onclick="@(() => Sort("GP"))" style="cursor:pointer">GP @(GetSortIcon("GP"))</th>
                    <th @onclick="@(() => Sort("PA"))" style="cursor:pointer">PA @(GetSortIcon("PA"))</th>
                    <th @onclick="@(() => Sort("AB"))" style="cursor:pointer">AB @(GetSortIcon("AB"))</th>
                    <th @onclick="@(() => Sort("H"))" style="cursor:pointer">H @(GetSortIcon("H"))</th>
                    <th @onclick="@(() => Sort("HR"))" style="cursor:pointer">HR @(GetSortIcon("HR"))</th>
                    <th @onclick="@(() => Sort("RBI"))" style="cursor:pointer">RBI @(GetSortIcon("RBI"))</th>
                    <th @onclick="@(() => Sort("R"))" style="cursor:pointer">R @(GetSortIcon("R"))</th>
                    <th @onclick="@(() => Sort("AVG"))" style="cursor:pointer">AVG @(GetSortIcon("AVG"))</th>
                    <th @onclick="@(() => Sort("OPS"))" style="cursor:pointer">OPS @(GetSortIcon("OPS"))</th>
                }
                else if (activeView == "Hits")
                {
                    <th @onclick="@(() => Sort("H1B"))" style="cursor:pointer">1B @(GetSortIcon("H1B"))</th>
                    <th @onclick="@(() => Sort("H2B"))" style="cursor:pointer">2B @(GetSortIcon("H2B"))</th>
                    <th @onclick="@(() => Sort("H3B"))" style="cursor:pointer">3B @(GetSortIcon("H3B"))</th>
                    <th @onclick="@(() => Sort("H4B"))" style="cursor:pointer">4B @(GetSortIcon("H4B"))</th>
                    <th @onclick="@(() => Sort("HR"))" style="cursor:pointer">HR @(GetSortIcon("HR"))</th>
                    <th @onclick="@(() => Sort("SLG"))" style="cursor:pointer">SLG @(GetSortIcon("SLG"))</th>
                }
                else if (activeView == "Outcomes")
                {
                    <th @onclick="@(() => Sort("BB"))" style="cursor:pointer">BB @(GetSortIcon("BB"))</th>
                    <th @onclick="@(() => Sort("SF"))" style="cursor:pointer">SF @(GetSortIcon("SF"))</th>
                    <th @onclick="@(() => Sort("FC"))" style="cursor:pointer">FC @(GetSortIcon("FC"))</th>
                    <th @onclick="@(() => Sort("K"))" style="cursor:pointer">K @(GetSortIcon("K"))</th>
                    <th @onclick="@(() => Sort("KF"))" style="cursor:pointer">KF @(GetSortIcon("KF"))</th>
                    <th @onclick="@(() => Sort("TB"))" style="cursor:pointer">TB @(GetSortIcon("TB"))</th>
                    <th @onclick="@(() => Sort("GO"))" style="cursor:pointer">GO @(GetSortIcon("GO"))</th>
                    <th @onclick="@(() => Sort("FO"))" style="cursor:pointer">FO @(GetSortIcon("FO"))</th>
                    <th @onclick="@(() => Sort("O"))" style="cursor:pointer">O @(GetSortIcon("O"))</th>
                    <th @onclick="@(() => Sort("OBP"))" style="cursor:pointer">OBP @(GetSortIcon("OBP"))</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (PlayerStatsSummary player in allStats)
            {
                <tr>
                    <td class="player-name">@player.PlayerName</td>
                    @if (activeView == "Standard")
                    {
                        <td>@player.GamesPlayed</td>
                        <td>@player.PA</td>
                        <td>@player.AB</td>
                        <td>@player.H</td>
                        <td>@player.HR</td>
                        <td>@player.RBI</td>
                        <td>@player.R</td>
                        <td>@player.AVG.ToString(".000")</td>
                        <td>@player.OPS.ToString(".000")</td>
                    }
                    else if (activeView == "Hits")
                    {
                        <td>@player.H1B</td>
                        <td>@player.H2B</td>
                        <td>@player.H3B</td>
                        <td>@player.H4B</td>
                        <td>@player.HR</td>
                        <td>@player.SLG.ToString(".000")</td>
                    }
                    else if (activeView == "Outcomes")
                    {
                        <td>@player.BB</td>
                        <td>@player.SF</td>
                        <td>@player.FC</td>
                        <td>@player.K</td>
                        <td>@player.KF</td>
                        <td>@player.TB</td>
                        <td>@player.GO</td>
                        <td>@player.FO</td>
                        <td>@player.O</td>
                        <td>@player.OBP.ToString(".000")</td>
                    }
                </tr>
            }
        </tbody>
        <tfoot>
            <tr style="background-color: #f8f9fa; font-weight: bold; border-top: 2px solid #ddd;">
                <td>TEAM TOTALS</td>
                @if (activeView == "Standard")
                {
                    <td>@teamTotals.GamesPlayed</td>
                    <td>@teamTotals.PA</td>
                    <td>@teamTotals.AB</td>
                    <td>@teamTotals.H</td>
                    <td>@teamTotals.HR</td>
                    <td>@teamTotals.RBI</td>
                    <td>@teamTotals.R</td>
                    <td>@teamTotals.AVG.ToString(".000")</td>
                    <td>@teamTotals.OPS.ToString(".000")</td>
                }
                else if (activeView == "Hits")
                {
                    <td>@teamTotals.H1B</td>
                    <td>@teamTotals.H2B</td>
                    <td>@teamTotals.H3B</td>
                    <td>@teamTotals.H4B</td>
                    <td>@teamTotals.HR</td>
                    <td>@teamTotals.SLG.ToString(".000")</td>
                }
                else if (activeView == "Outcomes")
                {
                    <td>@teamTotals.BB</td>
                    <td>@teamTotals.SF</td>
                    <td>@teamTotals.FC</td>
                    <td>@teamTotals.K</td>
                    <td>@teamTotals.KF</td>
                    <td>@teamTotals.TB</td>
                    <td>@teamTotals.GO</td>
                    <td>@teamTotals.FO</td>
                    <td>@teamTotals.O</td>
                    <td>@teamTotals.OBP.ToString(".000")</td>
                }
            </tr>
        </tfoot>
    </table>
</div>

@code {
    private List<PlayerStatsSummary> allStats = new();
    private PlayerStatsSummary teamTotals = new();
    private string activeView = "Standard";
    private string currentSortColumn = "AVG";
    private bool isAscending = false;

    protected override void OnInitialized()
    {
        try 
        {
            allStats = StatsService.GetStatsSummary();
            teamTotals = StatsService.GetTeamTotals();
            Sort(currentSortColumn, false);
        }
        catch (Exception)
        {
            allStats = new List<PlayerStatsSummary>();
            teamTotals = new PlayerStatsSummary();
        }
    }

    private void Sort(string column, bool toggle = true)
    {
        if (toggle)
        {
            if (currentSortColumn == column)
            {
                isAscending = !isAscending;
            }
            else
            {
                currentSortColumn = column;
                isAscending = false;
            }
        }

        switch (column)
        {
            case "PlayerName":
                allStats = isAscending ? allStats.OrderBy(p => p.PlayerName).ToList() : allStats.OrderByDescending(p => p.PlayerName).ToList();
                break;
            case "GP":
                allStats = isAscending ? allStats.OrderBy(p => p.GamesPlayed).ToList() : allStats.OrderByDescending(p => p.GamesPlayed).ToList();
                break;
            case "PA":
                allStats = isAscending ? allStats.OrderBy(p => p.PA).ToList() : allStats.OrderByDescending(p => p.PA).ToList();
                break;
            case "AB":
                allStats = isAscending ? allStats.OrderBy(p => p.AB).ToList() : allStats.OrderByDescending(p => p.AB).ToList();
                break;
            case "H":
                allStats = isAscending ? allStats.OrderBy(p => p.H).ToList() : allStats.OrderByDescending(p => p.H).ToList();
                break;
            case "H1B":
                allStats = isAscending ? allStats.OrderBy(p => p.H1B).ToList() : allStats.OrderByDescending(p => p.H1B).ToList();
                break;
            case "H2B":
                allStats = isAscending ? allStats.OrderBy(p => p.H2B).ToList() : allStats.OrderByDescending(p => p.H2B).ToList();
                break;
            case "H3B":
                allStats = isAscending ? allStats.OrderBy(p => p.H3B).ToList() : allStats.OrderByDescending(p => p.H3B).ToList();
                break;
            case "H4B":
                allStats = isAscending ? allStats.OrderBy(p => p.H4B).ToList() : allStats.OrderByDescending(p => p.H4B).ToList();
                break;
            case "HR":
                allStats = isAscending ? allStats.OrderBy(p => p.HR).ToList() : allStats.OrderByDescending(p => p.HR).ToList();
                break;
            case "BB":
                allStats = isAscending ? allStats.OrderBy(p => p.BB).ToList() : allStats.OrderByDescending(p => p.BB).ToList();
                break;
            case "SF":
                allStats = isAscending ? allStats.OrderBy(p => p.SF).ToList() : allStats.OrderByDescending(p => p.SF).ToList();
                break;
            case "FC":
                allStats = isAscending ? allStats.OrderBy(p => p.FC).ToList() : allStats.OrderByDescending(p => p.FC).ToList();
                break;
            case "K":
                allStats = isAscending ? allStats.OrderBy(p => p.K).ToList() : allStats.OrderByDescending(p => p.K).ToList();
                break;
            case "KF":
                allStats = isAscending ? allStats.OrderBy(p => p.KF).ToList() : allStats.OrderByDescending(p => p.KF).ToList();
                break;
            case "TB":
                allStats = isAscending ? allStats.OrderBy(p => p.TB).ToList() : allStats.OrderByDescending(p => p.TB).ToList();
                break;
            case "GO":
                allStats = isAscending ? allStats.OrderBy(p => p.GO).ToList() : allStats.OrderByDescending(p => p.GO).ToList();
                break;
            case "FO":
                allStats = isAscending ? allStats.OrderBy(p => p.FO).ToList() : allStats.OrderByDescending(p => p.FO).ToList();
                break;
            case "O":
                allStats = isAscending ? allStats.OrderBy(p => p.O).ToList() : allStats.OrderByDescending(p => p.O).ToList();
                break;
            case "RBI":
                allStats = isAscending ? allStats.OrderBy(p => p.RBI).ToList() : allStats.OrderByDescending(p => p.RBI).ToList();
                break;
            case "R":
                allStats = isAscending ? allStats.OrderBy(p => p.R).ToList() : allStats.OrderByDescending(p => p.R).ToList();
                break;
            case "AVG":
                allStats = isAscending ? allStats.OrderBy(p => p.AVG).ToList() : allStats.OrderByDescending(p => p.AVG).ToList();
                break;
            case "OBP":
                allStats = isAscending ? allStats.OrderBy(p => p.OBP).ToList() : allStats.OrderByDescending(p => p.OBP).ToList();
                break;
            case "SLG":
                allStats = isAscending ? allStats.OrderBy(p => p.SLG).ToList() : allStats.OrderByDescending(p => p.SLG).ToList();
                break;
            case "OPS":
                allStats = isAscending ? allStats.OrderBy(p => p.OPS).ToList() : allStats.OrderByDescending(p => p.OPS).ToList();
                break;
        }
    }

    private string GetSortIcon(string column)
    {
        if (currentSortColumn != column) return "↕️";
        return isAscending ? "🔼" : "🔽";
    }
}
