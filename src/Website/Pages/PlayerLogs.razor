@page "/player/{PlayerName}/{SeasonId:int}"
@page "/playerlogs/{PlayerName}"
@using IsotopesStats.Website.Services
@using IsotopesStats.Domain.Models
@inject IStatsRepository StatsRepository
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject SharedSessionState SharedState

<PageTitle>Isotopes - @PlayerName Game Log</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">@PlayerName - Game Log</h3>
    <button class="view-btn" @onclick="GoBack">Back to Stats</button>
</div>

@if (isLoading)
{
    <LoadingIndicator />
}
else
{
    @if (logs == null || !logs.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 5rem; color: #999;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">⚾</div>
            <h4>No Games Found</h4>
            <p>This player doesn't have any stats for the selected season.</p>
        </div>
    }
    else
    {
        <div class="stat-card view-fade-in" style="margin-bottom: 1.5rem;">
            <div class="stat-grid">
                <div class="stat-item">
                    <span class="stat-value">@logs.Count</span>
                    <span class="stat-label">Games</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">@logs.Sum(l => l.H)</span>
                    <span class="stat-label">Hits</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">@logs.Sum(l => l.HR)</span>
                    <span class="stat-label">HR</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">@logs.Sum(l => l.RBI)</span>
                    <span class="stat-label">RBI</span>
                </div>
            </div>
        </div>

        <div class="desktop-only">
            <div class="table-container view-fade-in" style="animation-delay: 0.2s;">
                <div class="box-score-table-wrapper">
                    <table class="box-score-table table-sm">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Opponent</th>
                                <th title="@StatDefinitions.GetDefinition("PA")">PA</th>
                                <th title="@StatDefinitions.GetDefinition("AB")">AB</th>
                                <th title="@StatDefinitions.GetDefinition("H")">H</th>
                                <th title="@StatDefinitions.GetDefinition("2B")">2B</th>
                                <th title="@StatDefinitions.GetDefinition("3B")">3B</th>
                                <th title="@StatDefinitions.GetDefinition("HR")">HR</th>
                                <th title="@StatDefinitions.GetDefinition("IPHR")">IPHR</th>
                                <th title="@StatDefinitions.GetDefinition("RBI")">RBI</th>
                                <th title="@StatDefinitions.GetDefinition("BB")">BB</th>
                                <th title="@StatDefinitions.GetDefinition("K")">K</th>
                                <th title="@StatDefinitions.GetDefinition("KF")">KF</th>
                                <th title="@StatDefinitions.GetDefinition("R")">R</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (GameStatsExtendedView log in logs)
                            {
                                <tr>
                                    <td style="color: #666;">@log.Date.ToString("MMM dd")</td>
                                    <td style="font-weight: bold; text-align: left;">
                                        <div class="smart-name-container">
                                            <span class="full-name">@log.OpponentName</span>
                                            @if (!string.IsNullOrEmpty(log.OpponentShortName))
                                            {
                                                <span class="short-name">@log.OpponentShortName</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@log.PA</td>
                                    <td>@log.AB</td>
                                    <td>@log.H</td>
                                    <td>@log.H2B</td>
                                    <td>@log.H3B</td>
                                    <td>@log.HR</td>
                                    <td>@log.IPHR</td>
                                    <td>@log.RBI</td>
                                    <td>@log.BB</td>
                                    <td>@log.K</td>
                                    <td>@log.KF</td>
                                    <td>@log.R</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mobile-only">
            <div class="game-cards-list">
                @for (int i = 0; i < logs.Count; i++)
                {
                    GameStatsExtendedView log = logs[i];
                    double currentDelay = i * 0.1;

                    <div class="game-card view-fade-in" style="animation-delay: @(currentDelay)s; margin-bottom: 1rem;">
                        <div class="game-card-header" style="cursor: default; padding: 1.25rem !important; display: block;">
                            <div class="mobile-scoreboard">
                                <div class="scoreboard-meta">
                                    <span>GAME #@log.GameNumber</span>
                                    <span>@log.Date.ToString("MMM dd @ h:mm tt")</span>
                                    <GameResultBadge OurScore="log.OurScore" OpponentScore="log.OpponentScore" Style="margin: 0; font-size: 0.65rem; padding: 2px 6px;" />
                                </div>
                                <div class="scoreboard-matchup">
                                    <div class="scoreboard-team visitor smart-name-container">
                                        <span class="full-name">@(log.IsHome ? log.OpponentName : "Isotopes")</span>
                                        @if (log.IsHome && !string.IsNullOrEmpty(log.OpponentShortName))
                                        {
                                            <span class="short-name">@log.OpponentShortName</span>
                                        }
                                        else if (!log.IsHome)
                                        {
                                            <span class="short-name">Isotopes</span>
                                        }
                                    </div>
                                    <div class="scoreboard-scores">
                                        <span class="scoreboard-score">@(log.VisitingTeamScore?.ToString() ?? "0")</span>
                                        <span class="scoreboard-divider">-</span>
                                        <span class="scoreboard-score">@(log.HomeTeamScore?.ToString() ?? "0")</span>
                                    </div>
                                    <div class="scoreboard-team home smart-name-container">
                                        <span class="full-name">@(log.IsHome ? "Isotopes" : log.OpponentName)</span>
                                        @if (!log.IsHome && !string.IsNullOrEmpty(log.OpponentShortName))
                                        {
                                            <span class="short-name">@log.OpponentShortName</span>
                                        }
                                        else if (log.IsHome)
                                        {
                                            <span class="short-name">Isotopes</span>
                                        }
                                    </div>
                                </div>
                                <div class="scoreboard-location">
                                    <span>📍 @log.Diamond</span>
                                </div>
                            </div>
                        </div>

                        <div class="game-card-detail expanded" style="border-top: 1px solid #eee; padding: 1.25rem; background: white;">
                            <div class="stat-badge-list">
                                @if (log.PA > 0) { <div class="stat-badge primary-stat"><span class="stat-badge-val">@log.PA</span><span class="stat-badge-lbl">PA</span></div> }
                                @if (log.AB > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.AB</span><span class="stat-badge-lbl">AB</span></div> }
                                @if (log.R > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.R</span><span class="stat-badge-lbl">R</span></div> }
                                @if (log.H > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H</span><span class="stat-badge-lbl">H</span></div> }
                                @if (log.H2B > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H2B</span><span class="stat-badge-lbl">2B</span></div> }
                                @if (log.H3B > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.H3B</span><span class="stat-badge-lbl">3B</span></div> }
                                @if (log.HR > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.HR</span><span class="stat-badge-lbl">HR</span></div> }
                                @if (log.IPHR > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.IPHR</span><span class="stat-badge-lbl">IPHR</span></div> }
                                @if (log.RBI > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.RBI</span><span class="stat-badge-lbl">RBI</span></div> }
                                @if (log.BB > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.BB</span><span class="stat-badge-lbl">BB</span></div> }
                                @if (log.K > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.K</span><span class="stat-badge-lbl">K</span></div> }
                                @if (log.KF > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.KF</span><span class="stat-badge-lbl">KF</span></div> }
                                @if (log.SF > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.SF</span><span class="stat-badge-lbl">SF</span></div> }
                                @if (log.FC > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.FC</span><span class="stat-badge-lbl">FC</span></div> }
                                @if (log.GO > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.GO</span><span class="stat-badge-lbl">GO</span></div> }
                                @if (log.FO > 0) { <div class="stat-badge"><span class="stat-badge-val">@log.FO</span><span class="stat-badge-lbl">FO</span></div> }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string PlayerName { get; set; } = string.Empty;
    [Parameter] public int? SeasonId { get; set; }

    private List<GameStatsExtendedView>? logs;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        int targetSeasonId = SeasonId ?? SharedState.SelectedSeasonId;

        if (targetSeasonId == SharedSessionState.AllSeasonsId)
        {
            logs = await StatsRepository.GetAllPlayerGameLogAsync(PlayerName);
        }
        else if (targetSeasonId != 0)
        {
            logs = await StatsRepository.GetPlayerGameLogAsync(PlayerName, targetSeasonId);
        }
        else
        {
            List<Season> seasons = await StatsRepository.GetSeasonsAsync();
            int recentSeasonId = await StatsRepository.GetMostRecentStatsSeasonIdAsync();
            
            if (recentSeasonId != 0)
            {
                targetSeasonId = recentSeasonId;
            }
            else if (seasons.Any())
            {
                targetSeasonId = seasons.First().Id;
            }

            if (targetSeasonId != 0)
            {
                logs = await StatsRepository.GetPlayerGameLogAsync(PlayerName, targetSeasonId);
            }
            else
            {
                logs = new List<GameStatsExtendedView>();
            }
        }
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("drawerDragging.initOpponentNames");
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/" + SharedState.ReturnUrl);
    }
}

