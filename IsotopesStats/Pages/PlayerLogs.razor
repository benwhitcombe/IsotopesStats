@page "/playerlogs/{PlayerName}"
@using IsotopesStats.Models
@using IsotopesStats.Services
@inject StatsService StatsService
@inject SharedSessionState SessionState
@inject NavigationManager Navigation

<PageTitle>Isotopes - @PlayerName Logs</PageTitle>

<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
    <button class="view-btn" @onclick="GoBack">← Back</button>
    <h3 style="margin:0">@PlayerName's Game Log</h3>
</div>

@if (stats == null)
{
    <div style="text-align: center; padding: 5rem;">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!stats.Any())
{
    <div class="stat-card" style="text-align: center; padding: 3rem; color: #999;">
        No game logs found for this season.
    </div>
}
else
{
    <div class="stat-card view-fade-in" style="padding: 0; overflow: hidden;">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th style="text-align: left;">Date</th>
                        <th style="text-align: left;">Opponent</th>
                        <th>BO</th>
                        <th>H</th>
                        <th>RBI</th>
                        <th>R</th>
                        <th>BB</th>
                        <th style="text-align: left;">Outs</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (GameStatsExtendedView stat in stats)
                    {
                        <tr>
                            <td style="text-align: left; font-weight: bold;">@stat.Date.ToString("MMM dd")</td>
                            <td style="text-align: left;">@stat.OpponentName</td>
                            <td style="font-weight: 800; color: #999;">@stat.BO</td>
                            <td style="font-weight: bold; color: var(--isotopes-accent);">@GetHitsSummary(stat)</td>
                            <td>@stat.RBI</td>
                            <td>@stat.R</td>
                            <td>@stat.BB</td>
                            <td style="text-align: left; font-size: 0.85rem; color: #666;">@GetOutsSummary(stat)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public string PlayerName { get; set; } = "";
    private List<GameStatsExtendedView>? stats;

    protected override async Task OnInitializedAsync()
    {
        if (SessionState.SelectedSeasonId != 0)
        {
            List<GameStatsExtendedView> allStats = await StatsService.GetAllGameStatsAsync(SessionState.SelectedSeasonId);
            stats = allStats.Where(s => s.ExtendedPlayerName == PlayerName).ToList();
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/" + SessionState.ReturnUrl);
    }

    private string GetHitsSummary(StatEntry s)
    {
        int totalHits = s.H1B + s.H2B + s.H3B + s.H4B + s.HR;
        if (totalHits == 0) return "0";
        
        List<string> parts = new List<string>();
        if (s.HR > 0) parts.Add($"{s.HR}HR");
        if (s.H4B > 0) parts.Add($"{s.H4B}4B");
        if (s.H3B > 0) parts.Add($"{s.H3B}3B");
        if (s.H2B > 0) parts.Add($"{s.H2B}2B");
        if (s.H1B > 0) parts.Add($"{s.H1B}1B");
        
        return $"{totalHits} ({string.Join(",", parts)})";
    }

    private string GetOutsSummary(StatEntry s)
    {
        List<string> parts = new List<string>();
        if (s.K > 0) parts.Add($"{s.K}K");
        if (s.KF > 0) parts.Add($"{s.KF}KF");
        if (s.GO > 0) parts.Add($"{s.GO}GO");
        if (s.FO > 0) parts.Add($"{s.FO}FO");
        if (s.FC > 0) parts.Add($"{s.FC}FC");
        
        return string.Join(", ", parts);
    }
}
