@page "/management/opponents"
@page "/management/opponents/{Action}"
@page "/management/opponents/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "ManageOpponents")]
@inject StatsService StatsService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Opponents</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Opponents</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Opponent</button>
    }
</div>

@if (isEditing)
{
    <ManagementEditCard 
        Title="@($"{(editingOpponent.Id == 0 ? "Add" : "Edit")} Opponent")"
        IsEdit="@(editingOpponent.Id != 0)"
        SaveText="Save Opponent"
        OnSave="SaveOpponent"
        OnCancel="HandleCancel"
        OnDelete="@(() => ShowDeleteConfirm(editingOpponent.Id))">

        <div class="form-group">
            <label>Opponent Name</label>
            <input type="text" class="form-control" @bind="editingOpponent.Name" @bind:event="oninput" @onkeyup="HandleInput" placeholder="e.g. Springfield Atoms" />
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Seasons Faced</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.5rem; border-radius: 8px;">
                @foreach (Season season in allSeasons)
                {
                    <CheckboxButton 
                        Id="@($"s-{season.Id}")" 
                        Text="@season.Name" 
                        Checked="@assignedSeasonIds.Contains(season.Id)" 
                        CheckedChanged="@((bool val) => ToggleSeason(season.Id, val))" />
                }
            </div>
        </div>
    </ManagementEditCard>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Opponent opponent in opponents)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", opponent.Id)'>@opponent.Name</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", opponent.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(opponent.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Opponent opponent in opponents)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", opponent.Id)'>@opponent.Name</div>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", opponent.Id)'>Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(opponent.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete Opponent" 
    Message="Are you sure you want to delete this opponent?"
    OnConfirm="DeleteOpponent"
    OnCancel="() => showConfirm = false" />

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private List<Opponent> opponents = new();
    private List<Season> allSeasons = new();
    private HashSet<int> assignedSeasonIds = new();
    private HashSet<int> originalSeasonIds = new();
    private Opponent editingOpponent = new();
    private bool isEditing = false;
    private bool showConfirm = false;
    private bool showDiscardConfirm = false;
    private int opponentIdToDelete;
    private bool hasChanges = false;

    private class OpponentEditState
    {
        public Opponent Opponent { get; set; } = new();
        public HashSet<int> AssignedSeasonIds { get; set; } = new();
        public HashSet<int> OriginalSeasonIds { get; set; } = new();
        public bool IsEditing { get; set; }
        public bool HasChanges { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        allSeasons = await StatsService.GetSeasonsAsync();
        await LoadOpponents();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasEditing = isEditing;
        isEditing = Action == "add" || Action == "edit";

        if (isEditing)
        {
            if (!wasEditing || (Id.HasValue && Id != editingOpponent.Id))
            {
                await LoadEditingOpponent();
            }
        }
        else
        {
            editingOpponent = new Opponent();
            assignedSeasonIds.Clear();
            originalSeasonIds.Clear();
            hasChanges = false;
        }
    }

    private async Task LoadEditingOpponent()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            Opponent? opponent = opponents.FirstOrDefault(o => o.Id == Id);
            if (opponent == null)
            {
                opponent = (await StatsService.GetAllOpponentsAsync()).FirstOrDefault(o => o.Id == Id);
            }

            if (opponent != null)
            {
                editingOpponent = new Opponent { Id = opponent.Id, Name = opponent.Name, IsDeleted = opponent.IsDeleted };
                assignedSeasonIds.Clear();
                originalSeasonIds.Clear();

                List<Season> opponentSeasons = await StatsService.GetSeasonsForOpponentAsync(opponent.Id);
                foreach (Season s in opponentSeasons)
                {
                    assignedSeasonIds.Add(s.Id);
                    originalSeasonIds.Add(s.Id);
                }
            }
        }
        else
        {
            editingOpponent = new Opponent();
            assignedSeasonIds.Clear();
            originalSeasonIds.Clear();
        }

        hasChanges = false;
        await HydrateTempState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && isEditing)
        {
            await HydrateTempState();
        }
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<OpponentEditState> result = await ProtectedSessionStore.GetAsync<OpponentEditState>("OpponentEditState");
            if (result.Success && result.Value != null && result.Value.IsEditing)
            {
                if (result.Value.Opponent.Id == (Id ?? 0))
                {
                    editingOpponent = result.Value.Opponent;
                    assignedSeasonIds = result.Value.AssignedSeasonIds;
                    originalSeasonIds = result.Value.OriginalSeasonIds;
                    hasChanges = result.Value.HasChanges;
                    StateHasChanged();
                }
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            OpponentEditState state = new OpponentEditState
            {
                Opponent = editingOpponent,
                AssignedSeasonIds = assignedSeasonIds,
                OriginalSeasonIds = originalSeasonIds,
                IsEditing = isEditing,
                HasChanges = hasChanges
            };
            await ProtectedSessionStore.SetAsync("OpponentEditState", state);
        }
        catch (Exception) { }
    }

    private async Task HandleInput()
    {
        hasChanges = true;
        await SaveTempState();
    }

    private async Task ClearTempState()
    {
        hasChanges = false;
        try
        {
            await ProtectedSessionStore.DeleteAsync("OpponentEditState");
        }
        catch (Exception) { }
    }

    private async Task LoadOpponents()
    {
        opponents = await StatsService.GetAllOpponentsAsync();
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/opponents/add");
        else Navigation.NavigateTo($"/management/opponents/edit/{id}");
    }

    private async Task HandleCancel()
    {
        if (hasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        Navigation.NavigateTo("/management/opponents");
    }

    private async Task CancelEdit() => await HandleCancel();

    private async Task ToggleSeason(int seasonId, bool isChecked)
    {
        hasChanges = true;
        if (isChecked) assignedSeasonIds.Add(seasonId);
        else assignedSeasonIds.Remove(seasonId);
        await SaveTempState();
    }

    private async Task SaveOpponent()
    {
        if (string.IsNullOrEmpty(editingOpponent.Name)) return;

        if (editingOpponent.Id == 0)
        {
            int firstSeasonId = assignedSeasonIds.FirstOrDefault();
            await StatsService.AddOpponentAsync(editingOpponent, firstSeasonId);
            List<Opponent> all = await StatsService.GetAllOpponentsAsync();
            Opponent? newO = all.FirstOrDefault(o => o.Name == editingOpponent.Name);
            if (newO != null)
            {
                foreach (int sid in assignedSeasonIds.Where(id => id != firstSeasonId))
                    await StatsService.AddOpponentToSeasonAsync(newO.Id, sid);
            }
        }
        else
        {
            await StatsService.UpdateOpponentAsync(editingOpponent);
            foreach (int sid in assignedSeasonIds.Except(originalSeasonIds))
                await StatsService.AddOpponentToSeasonAsync(editingOpponent.Id, sid);
            foreach (int sid in originalSeasonIds.Except(assignedSeasonIds))
                await StatsService.DeleteOpponentFromSeasonAsync(editingOpponent.Id, sid);
        }

        await ClearTempState();
        Navigation.NavigateTo("/management/opponents");
        await LoadOpponents();
    }

    private void ShowDeleteConfirm(int id)
    {
        opponentIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeleteOpponent()
    {
        showConfirm = false;
        await StatsService.DeleteOpponentAsync(opponentIdToDelete);
        await LoadOpponents();
    }
}
