@page "/account/forgot-password"
@using IsotopesStats.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Isotopes - Forgot Password</PageTitle>

<div style="max-width: 450px; margin: 4rem auto; padding: 0 1rem;">
    <div class="stat-card view-fade-in" style="padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📧</div>
            <h3 style="margin:0; color: var(--isotopes-dark); font-weight: 800; letter-spacing: 1px;">FORGOT PASSWORD</h3>
            <p style="color: #666; font-size: 0.9rem; margin-top: 0.5rem;">Enter your email to receive a reset link</p>
        </div>
        
        @if (isSubmitted)
        {
            <div class="view-fade-in" style="background: #f0fdf4; color: #166534; padding: 1.5rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #dcfce7; text-align: center;">
                <p style="font-weight: bold; margin-bottom: 0.5rem;">Request Received</p>
                If an account exists for that email, we have sent a password reset link. (Simulation: Check console for token)
            </div>
            <a href="/account/login" class="view-btn active" style="display: block; text-align: center; background-color: var(--isotopes-accent); border-color: var(--isotopes-accent); text-decoration: none;">Return to Login</a>
        }
        else
        {
            <div class="form-group">
                <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">Email Address</label>
                <input type="email" class="form-control" @bind="email" placeholder="email@isotopes.com" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee;" />
            </div>

            <button class="view-btn active" @onclick="SendResetLink" style="margin-top: 2rem; width: 100%; padding: 1rem; font-size: 1.1rem; background-color: var(--isotopes-red); border-color: var(--isotopes-red);">Send Reset Link</button>
            
            <div style="text-align: center; margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1.5rem;">
                <a href="/account/login" style="font-size: 0.9rem; color: #888; text-decoration: none; font-weight: 600;">Back to Login</a>
            </div>
        }
    </div>
</div>

@code {
    private string email = "";
    private bool isSubmitted = false;

    private async Task SendResetLink()
    {
        if (string.IsNullOrEmpty(email)) return;
        
        string token = await AuthService.GeneratePasswordResetTokenAsync(email);
        
        if (!string.IsNullOrEmpty(token))
        {
            // Simulation: In a real app, this would be an email.
            Console.WriteLine("--------------------------------------------------");
            Console.WriteLine($"PASSWORD RESET REQUEST FOR: {email}");
            Console.WriteLine($"TOKEN: {token}");
            Console.WriteLine($"URL: {Navigation.BaseUri}account/reset-password?token={token}");
            Console.WriteLine("--------------------------------------------------");
        }
        
        isSubmitted = true;
    }
}
