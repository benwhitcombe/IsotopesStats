<div class="loading-indicator-wrapper @(IsFullPage ? "full-page" : "")">
    <div class="spinner-border @(ColorClass)" role="status">
        <span class="visually-hidden"></span>
    </div>
</div>

@code {
    [Parameter] public bool IsFullPage { get; set; } = false;
    [Parameter] public string ColorClass { get; set; } = "text-danger";
}

<style>
    .loading-indicator-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        min-height: 60vh;
        flex: 1;
    }

    .loading-indicator-wrapper.full-page {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.7);
        z-index: 9999;
        min-height: 100vh;
    }
</style>
