@page "/management/roles"
@page "/management/roles/{Action}"
@page "/management/roles/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "ManageRoles")]
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage User Roles</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">User Role Management</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Role</button>
    }
</div>

@if (isEditing)
{
    <ManagementEditCard 
        Title="@($"{(editingRole.Id == 0 ? "Add" : "Edit")} User Role")"
        IsEdit="@(editingRole.Id != 0)"
        SaveText="Save Role"
        OnSave="SaveRole"
        OnCancel="HandleCancel"
        OnDelete="@(() => ShowDeleteConfirm(editingRole.Id))">

        <div class="form-group">
            <label>Role Name</label>
            <input type="text" class="form-control" @bind="editingRole.Name" @bind:event="oninput" @onkeyup="HandleInput" placeholder="e.g. Moderator" />
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Permissions</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.5rem; border-radius: 8px;">
                @foreach (Permission permission in allPermissions)
                {
                    <CheckboxButton 
                        Id="@($"p-{permission.Id}")" 
                        Text="@permission.Name" 
                        Checked="@IsPermissionSelected(permission.Id)" 
                        CheckedChanged="@((bool val) => OnPermissionToggled(permission, val))" />
                }
            </div>
        </div>
    </ManagementEditCard>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Role Name</th>
                            <th style="text-align: left;">Permissions</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (UserRole role in roles)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", role.Id)'>@role.Name</td>
                                <td style="text-align: left;">
                                    <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                                        @foreach (Permission p in role.Permissions)
                                        {
                                            <span class="badge bg-light text-dark" style="border: 1px solid #ddd;">@p.Name</span>
                                        }
                                    </div>
                                </td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", role.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(role.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (UserRole role in roles)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", role.Id)'>@role.Name</div>
                    </div>
                    <div style="margin-bottom: 1rem; font-size: 0.85rem;">
                        <div style="color: #888; font-weight: bold; margin-bottom: 0.3rem;">Permissions:</div>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                            @foreach (Permission p in role.Permissions)
                            {
                                <span class="badge bg-light text-dark" style="border: 1px solid #ddd; font-size: 0.7rem;">@p.Name</span>
                            }
                        </div>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", role.Id)'>Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(role.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete Role" 
    Message="Are you sure you want to delete this role? Users assigned to this role will lose their permissions."
    OnConfirm="DeleteRole"
    OnCancel="() => showConfirm = false" />

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private List<UserRole> roles = new();
    private List<Permission> allPermissions = new();
    private UserRole editingRole = new();
    private bool isEditing = false;
    private bool showConfirm = false;
    private bool showDiscardConfirm = false;
    private int roleIdToDelete;
    private bool hasChanges = false;

    private class RoleEditState
    {
        public UserRole Role { get; set; } = new();
        public bool IsEditing { get; set; }
        public bool HasChanges { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasEditing = isEditing;
        isEditing = Action == "add" || Action == "edit";

        if (isEditing)
        {
            if (!wasEditing || (Id.HasValue && Id != editingRole.Id))
            {
                await LoadEditingRole();
            }
        }
        else
        {
            editingRole = new UserRole();
            hasChanges = false;
        }
    }

    private async Task LoadEditingRole()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            UserRole? role = roles.FirstOrDefault(r => r.Id == Id);
            if (role == null)
            {
                role = (await AuthService.GetUserRolesAsync()).FirstOrDefault(r => r.Id == Id);
            }

            if (role != null)
            {
                editingRole = new UserRole 
                { 
                    Id = role.Id, 
                    Name = role.Name,
                    IsDeleted = role.IsDeleted,
                    Permissions = new List<Permission>(role.Permissions)
                };
            }
        }
        else
        {
            editingRole = new UserRole();
        }

        hasChanges = false;
        await HydrateTempState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && isEditing)
        {
            await HydrateTempState();
        }
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<RoleEditState> result = await ProtectedSessionStore.GetAsync<RoleEditState>("RoleEditState");
            if (result.Success && result.Value != null && result.Value.IsEditing)
            {
                if (result.Value.Role.Id == (Id ?? 0))
                {
                    editingRole = result.Value.Role;
                    hasChanges = result.Value.HasChanges;
                    StateHasChanged();
                }
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            RoleEditState state = new RoleEditState
            {
                Role = editingRole,
                IsEditing = isEditing,
                HasChanges = hasChanges
            };
            await ProtectedSessionStore.SetAsync("RoleEditState", state);
        }
        catch (Exception) { }
    }

    private async Task HandleInput()
    {
        hasChanges = true;
        await SaveTempState();
    }

    private async Task ClearTempState()
    {
        hasChanges = false;
        try
        {
            await ProtectedSessionStore.DeleteAsync("RoleEditState");
        }
        catch (Exception) { }
    }

    private async Task LoadData()
    {
        roles = await AuthService.GetUserRolesAsync();
        allPermissions = await AuthService.GetPermissionsAsync();
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/roles/add");
        else Navigation.NavigateTo($"/management/roles/edit/{id}");
    }

    private async Task HandleCancel()
    {
        if (hasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        Navigation.NavigateTo("/management/roles");
    }

    private async Task CancelEdit() => await HandleCancel();

    private bool IsPermissionSelected(int permissionId)
    {
        return editingRole.Permissions.Any(p => p.Id == permissionId);
    }

    private async Task OnPermissionToggled(Permission permission, bool isChecked)
    {
        hasChanges = true;
        if (isChecked)
        {
            if (!editingRole.Permissions.Any(p => p.Id == permission.Id))
                editingRole.Permissions.Add(permission);
        }
        else
        {
            editingRole.Permissions.RemoveAll(p => p.Id == permission.Id);
        }
        await SaveTempState();
    }

    private async Task SaveRole()
    {
        if (string.IsNullOrEmpty(editingRole.Name)) return;

        if (editingRole.Id == 0) await AuthService.AddUserRoleAsync(editingRole);
        else await AuthService.UpdateUserRoleAsync(editingRole);

        await ClearTempState();
        Navigation.NavigateTo("/management/roles");
        await LoadData();
    }

    private void ShowDeleteConfirm(int id)
    {
        roleIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeleteRole()
    {
        showConfirm = false;
        await AuthService.DeleteUserRoleAsync(roleIdToDelete);
        await LoadData();
    }
}
