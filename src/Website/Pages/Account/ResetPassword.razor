@page "/account/reset-password"
@page "/account/reset-password/{Token}"
@using IsotopesStats.Website.Services
@using IsotopesStats.Domain.Models
@using System.ComponentModel.DataAnnotations
@inject IAuthRepository IAuthRepository
@inject NavigationManager Navigation

<PageTitle>Isotopes - Reset Password</PageTitle>

<div style="max-width: 450px; margin: 4rem auto; padding: 0 1rem;">
    <div class="stat-card view-fade-in" style="padding: 2.5rem; position: relative; overflow: hidden;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🔒</div>
            <h3 style="margin:0; color: var(--isotopes-dark); font-weight: 800; letter-spacing: 1px;">RESET PASSWORD</h3>
            <p style="color: #666; font-size: 0.9rem; margin-top: 0.5rem;">Enter your new password below.</p>
        </div>

        @if (isProcessing)
        {
            <LoadingIndicator IsFullPage="true" />
        }

        @if (isSuccess)
        {
            <div class="view-fade-in" style="text-align: center;">
                <div style="background: #e6fffa; color: #2c7a7b; padding: 1.5rem; border-radius: 12px; margin-bottom: 1.5rem; border: 1px solid #b2f5ea;">
                    <h5 style="margin-top: 0; font-weight: bold;">Password Reset!</h5>
                    <p style="margin-bottom: 0; font-size: 0.9rem;">Your password has been successfully reset.</p>
                </div>
                <button class="view-btn active" style="width: 100%;" @onclick='() => Navigation.NavigateTo("/account/login")'>Log In Now</button>
            </div>
        }
        else
        {
            <EditForm Model="resetModel" OnValidSubmit="HandleReset">
                <DataAnnotationsValidator />

                <!-- Hidden username field to allow password managers to associate the new password with the correct email -->
                <div style="display: none;" aria-hidden="true">
                    <input type="text" name="username" autocomplete="username" value="@userEmail" tabindex="-1" />
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 1.5rem;">
                    <div class="form-group">
                        <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">New Password</label>
                        <div style="position: relative;">
                            <InputText type="@(showPassword ? "text" : "password")" class="form-control" autocomplete="new-password" readonly="@isReadonlyHack" @onfocus="() => isReadonlyHack = false" @bind-Value="resetModel.Password" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; transition: border-color 0.3s; padding-right: 3rem; width: 100%;" disabled="@isProcessing" />
                            <div @onclick="() => showPassword = !showPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center; height: 100%;">
                                <PasswordToggleIcon IsVisible="showPassword" />
                            </div>
                        </div>
                        <ValidationMessage For="@(() => resetModel.Password)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                    </div>

                    <div class="form-group">
                        <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">Confirm Password</label>
                        <div style="position: relative;">
                            <InputText type="@(showPassword ? "text" : "password")" class="form-control" autocomplete="new-password" readonly="@isReadonlyHack" @onfocus="() => isReadonlyHack = false" @bind-Value="resetModel.ConfirmPassword" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; transition: border-color 0.3s; padding-right: 3rem; width: 100%;" disabled="@isProcessing" />
                            <div @onclick="() => showPassword = !showPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center; height: 100%;">
                                <PasswordToggleIcon IsVisible="showPassword" />
                            </div>
                        </div>
                        <ValidationMessage For="@(() => resetModel.ConfirmPassword)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                        @errorMessage
                    </div>
                }

                <button type="submit" class="view-btn active @(isProcessing ? "loading" : "")" style="margin-top: 1rem; width: 100%; padding: 1rem; font-size: 1.1rem; background-color: var(--isotopes-accent); border-color: var(--isotopes-accent);" disabled="@isProcessing">
                    Reset Password
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public string? Token { get; set; }

    private ResetPasswordViewModel resetModel = new();
    private bool isProcessing = false;
    private bool isSuccess = false;
    private bool showPassword = false;
    private bool isReadonlyHack = true;
    private string? errorMessage;

    private string? userEmail;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        string query = uri.Query.TrimStart('?');
        
        foreach (var param in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = param.Split('=', 2);
            if (parts.Length == 2 && parts[0].ToLower() == "email")
            {
                userEmail = Uri.UnescapeDataString(parts[1]);
                break;
            }
        }
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(Token))
        {
            errorMessage = "Invalid or expired reset token.";
            return;
        }

        if (string.IsNullOrEmpty(userEmail))
        {
            errorMessage = "Invalid link: missing email address.";
            return;
        }

        isProcessing = true;
        errorMessage = null;

        try
        {
            bool success = await IAuthRepository.ResetPasswordAsync(userEmail, Token, resetModel.Password);
            if (success)
            {
                isSuccess = true;
                Navigation.NavigateTo("/account/login");
            }
            else
            {
                errorMessage = "Failed to reset password. The link may be expired.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }

    public class ResetPasswordViewModel
    {
        [Required(ErrorMessage = "Password is required")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = "";

        [Compare("Password", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }
}

