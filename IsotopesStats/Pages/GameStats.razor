                                                </div>
                                            </div>
                                        }
                                        <div class="mobile-player-row" style="background: #f0f7ff; border-top: 2px solid var(--isotopes-accent);">
                                            <div class="player-row-header">
                                                <span class="player-row-name" style="color: var(--isotopes-dark)">TEAM TOTALS</span>
                                                <span class="player-row-avg" style="color: var(--isotopes-dark)">AVG @teamAVG.ToString(".000") | OBP @teamOBP.ToString(".000")</span>
                                            </div>
                                            <div class="stat-badge-list">
                                                <div class="stat-badge primary-stat"><span class="stat-badge-val">@summary.TeamPA</span><span class="stat-badge-lbl">PA</span></div>
                                                <div class="stat-badge"><span class="stat-badge-val">@summary.TeamAB</span><span class="stat-badge-lbl">AB</span></div>
                                                <div class="stat-badge"><span class="stat-badge-val">@summary.TeamRuns</span><span class="stat-badge-lbl">R</span></div>
                                                <div class="stat-badge"><span class="stat-badge-val">@summary.TeamHits</span><span class="stat-badge-lbl">H</span></div>
                                                <div class="stat-badge"><span class="stat-badge-val">@summary.TeamHRs</span><span class="stat-badge-lbl">HR</span></div>
                                                <div class="stat-badge"><span class="stat-badge-val">@summary.TeamRBI</span><span class="stat-badge-lbl">RBI</span></div>
                                                <div class="stat-badge"><span class="stat-badge-val">@summary.TeamBBs</span><span class="stat-badge-lbl">BB</span></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }

                        @if (!uiState.IsExpanded)
                        {
                            <div class="game-card-footer">
                                <div class="footer-stat">
                                    <span class="footer-stat-label">AVG:</span> @teamAVG.ToString(".000")
                                </div>
                                <div class="footer-stat">
                                    <span class="footer-stat-label">H:</span> @summary.TeamHits
                                </div>
                                <div class="footer-stat">
                                    <span class="footer-stat-label">HR:</span> @summary.TeamHRs
