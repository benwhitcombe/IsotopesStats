@page "/management/logs"
@using IsotopesStats.Website.Services
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Shared
@attribute [Authorize(Policy = "Manage Logs")]
@inject IAuthRepository IAuthRepository

<PageTitle>Isotopes - User Logs</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">User Action Logs</h3>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
        <input type="text" class="form-control" @bind="searchTerm" @bind:event="oninput" placeholder="Search logs..." style="max-width: 250px;" />
        <button class="view-btn active" @onclick="LoadLogs">Refresh</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
        @errorMessage
    </div>
}

<div class="stat-card view-fade-in" style="padding: 0; overflow: hidden;">
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th style="text-align: left;">Timestamp</th>
                    <th style="text-align: left;">User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th style="text-align: left;">Description</th>
                </tr>
            </thead>
            <tbody>
                @if (!filteredLogs.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 3rem; color: #999;">
                            No log entries found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (UserLog log in filteredLogs)
                    {
                        <tr>
                            <td style="text-align: left; font-size: 0.85rem; white-space: nowrap;">
                                @log.Timestamp.ToLocalTime().ToString("MMM dd, h:mm:ss tt")
                            </td>
                            <td style="text-align: left; font-weight: 600; font-size: 0.85rem;">
                                @log.UserEmail
                            </td>
                            <td>
                                <span class="badge @GetActionBadgeClass(log.Action)" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                    @log.Action
                                </span>
                            </td>
                            <td style="font-size: 0.85rem; color: #666;">
                                @log.EntityType
                            </td>
                            <td style="text-align: left; font-size: 0.85rem;">
                                @log.Description
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<UserLog> logs = new();
    private string searchTerm = "";
    private string? errorMessage;

    private IEnumerable<UserLog> filteredLogs => string.IsNullOrWhiteSpace(searchTerm) 
        ? logs 
        : logs.Where(l => 
            l.UserEmail.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
            l.Action.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
            l.EntityType.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
            l.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        try
        {
            errorMessage = null;
            logs = await IAuthRepository.GetUserLogsAsync(200);
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading logs: " + ex.Message;
        }
    }

    private string GetActionBadgeClass(UserLogAction action) => action switch
    {
        UserLogAction.Created => "bg-success",
        UserLogAction.Updated => "bg-primary",
        UserLogAction.Deleted => "bg-danger",
        _ => "bg-secondary"
    };
}

