@page "/account/forgot-password"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using System.ComponentModel.DataAnnotations
@inject IAuthRepository IAuthRepository
@inject NavigationManager Navigation

<PageTitle>Isotopes - Forgot Password</PageTitle>

<div class="auth-container view-fade-in">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <JerseyIcon Number="?" Color="var(--isotopes-red)" Size="60px" />
            </div>
            <h3>Forgot Password</h3>
            <p>Enter your email and we'll send you a reset link.</p>
        </div>

        @if (isSuccess)
        {
            <div class="view-fade-in" style="text-align: center;">
                <div style="background: #e6fffa; color: #2c7a7b; padding: 1.5rem; border-radius: 12px; margin-bottom: 1.5rem; border: 1px solid #b2f5ea;">
                    <h5 style="margin-top: 0; font-weight: bold;">Check your email!</h5>
                    <p style="margin-bottom: 0; font-size: 0.9rem;">We've sent a password reset link to <strong>@email</strong>.</p>
                </div>
                <button class="view-btn active" style="width: 100%;" @onclick='() => Navigation.NavigateTo("/account/login")'>Return to Login</button>
            </div>
        }
        else
        {
            <EditForm Model="this" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label>Email Address</label>
                    <InputText class="form-control" @bind-Value="email" placeholder="your@email.com" />
                    <ValidationMessage For="@(() => email)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                        @errorMessage
                    </div>
                }

                <button type="submit" class="view-btn active @(isProcessing ? "loading" : "")" style="width: 100%; padding: 0.8rem;" disabled="@isProcessing">
                    @(isProcessing ? "Sending..." : "Send Reset Link")
                </button>

                <div style="text-align: center; margin-top: 1.5rem;">
                    <a href="/account/login" style="color: #666; font-size: 0.9rem; text-decoration: none;">Back to Login</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Required(ErrorMessage = "Email is required")]
    [EmailAddress(ErrorMessage = "Invalid email address")]
    private string email { get; set; } = "";

    private bool isProcessing = false;
    private bool isSuccess = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        isProcessing = true;
        errorMessage = null;

        try
        {
            bool success = await IAuthRepository.GeneratePasswordResetTokenAsync(email);
            if (success)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = "Could not find an account with that email address.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}

