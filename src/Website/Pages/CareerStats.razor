@code {
    [Parameter] public string PlayerName { get; set; } = string.Empty;
    [Parameter] public string SeasonName { get; set; } = string.Empty;

    private List<GameStatsExtendedView>? logs;
    private List<GameStatsExtendedView>? allLogs;
    private bool isLoading = true;
    private List<Season> seasons = new();
    private List<PlayerStatsSummary> teamStats = new();
    private PlayerStatsSummary? playerSummary;
    private PlayerStatsSummary overallCareerStats = new();
    private List<SeasonPlayerStats> perSeasonStats = new();
    private Dictionary<int, List<PlayerStatsSummary>> allSeasonTeamStats = new();

    private string careerSortColumn = "Season";
    private bool careerIsAscending = true;
    private string logSortColumn = "Date";
    private bool logIsAscending = true;

    private string activeView = "Stats";
    private string mobileStatSortColumn = "Default";
    private bool mobileStatIsAscending = true;
    private readonly string[] AllSortableStats = {
        "AVG", "OBP", "SLG", "OPS", "GP", "PA", "AB", "R", "H", "1B", "2B", "3B", "HR", "IPHR", "RBI", "BB", "K", "KF", "SF", "FC", "GO", "FO"
    };

    public class SeasonPlayerStats {
        public int SeasonId { get; set; }
        public string SeasonName { get; set; } = string.Empty;
        public PlayerStatsSummary Stats { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        seasons = await StatsRepository.GetSeasonsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        int targetSeasonId = GetSeasonId(SeasonName);

        if (targetSeasonId == SharedSessionState.AllSeasonsId)
        {
            logs = await StatsRepository.GetAllPlayerGameLogAsync(PlayerName);
            teamStats = await StatsRepository.GetAllStatsSummaryAsync();
        }
        else if (targetSeasonId != 0)
        {
            logs = await StatsRepository.GetPlayerGameLogAsync(PlayerName, targetSeasonId);
            teamStats = await StatsRepository.GetStatsSummaryAsync(targetSeasonId);
        }
        else
        {
            int recentSeasonId = await StatsRepository.GetMostRecentStatsSeasonIdAsync();
            if (recentSeasonId == 0 && seasons.Any())
            {
                recentSeasonId = seasons.First().Id;
            }

            if (recentSeasonId != 0)
            {
                string name = GetSeasonName(recentSeasonId);
                NavigationManager.NavigateTo($"/career/{Uri.EscapeDataString(PlayerName)}/{Uri.EscapeDataString(name)}", replace: true);
                return;
            }
            
            logs = new List<GameStatsExtendedView>();
            teamStats = new List<PlayerStatsSummary>();
        }

        playerSummary = teamStats.FirstOrDefault((PlayerStatsSummary s) => s.PlayerName == PlayerName);
        
        // Ensure current season is in the cache
        if (targetSeasonId != 0) 
        {
            allSeasonTeamStats[targetSeasonId] = teamStats;
        }

        if (allLogs == null || allLogs.Count == 0 || allLogs[0].PlayerName != PlayerName)
        {
            allLogs = await StatsRepository.GetAllPlayerGameLogAsync(PlayerName);
            CalculatePerSeasonStats();
            _ = Task.Run(async () => await LoadAllSeasonTeamStats());
        }

        if (SharedState.SelectedSeasonId != targetSeasonId)
        {
            SharedState.SelectedSeasonId = targetSeasonId;
        }

        isLoading = false;
    }

    private async Task LoadAllSeasonTeamStats()
    {
        // Load "All Seasons" stats first for career medals
        if (!allSeasonTeamStats.ContainsKey(SharedSessionState.AllSeasonsId))
        {
            List<PlayerStatsSummary> stats = await StatsRepository.GetAllStatsSummaryAsync();
            allSeasonTeamStats[SharedSessionState.AllSeasonsId] = stats;
            await InvokeAsync(StateHasChanged);
        }

        foreach (SeasonPlayerStats s in perSeasonStats)
        {
            if (!allSeasonTeamStats.ContainsKey(s.SeasonId))
            {
                List<PlayerStatsSummary> stats = await StatsRepository.GetStatsSummaryAsync(s.SeasonId);
                allSeasonTeamStats[s.SeasonId] = stats;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void CalculatePerSeasonStats()
    {
        perSeasonStats = new List<SeasonPlayerStats>();
        if (seasons == null) return;

        foreach (Season season in seasons)
        {
            List<GameStatsExtendedView> seasonLogs = allLogs?.Where(l => l.SeasonId == season.Id).ToList() ?? new List<GameStatsExtendedView>();
            
            perSeasonStats.Add(new SeasonPlayerStats {
                SeasonId = season.Id,
                SeasonName = season.Name,
                Stats = new PlayerStatsSummary {
                    PlayerName = PlayerName,
                    GamesPlayed = seasonLogs.Select(x => x.GameId).Distinct().Count(),
                    H1B = seasonLogs.Sum(x => x.H1B),
                    H2B = seasonLogs.Sum(x => x.H2B),
                    H3B = seasonLogs.Sum(x => x.H3B),
                    IPHR = seasonLogs.Sum(x => x.IPHR),
                    HR = seasonLogs.Sum(x => x.HR),
                    BB = seasonLogs.Sum(x => x.BB),
                    K = seasonLogs.Sum(x => x.K),
                    KF = seasonLogs.Sum(x => x.KF),
                    R = seasonLogs.Sum(x => x.R),
                    RBI = seasonLogs.Sum(x => x.RBI),
                    SF = seasonLogs.Sum(x => x.SF),
                    FC = seasonLogs.Sum(x => x.FC),
                    GO = seasonLogs.Sum(x => x.GO),
                    FO = seasonLogs.Sum(x => x.FO)
                }
            });
        }

        perSeasonStats = perSeasonStats.OrderByDescending(x => x.SeasonName).ToList();
        overallCareerStats = GetCareerTotals();
    }

    private void SortCareer(string column)
    {
        if (careerSortColumn == column)
        {
            careerIsAscending = !careerIsAscending;
        }
        else
        {
            careerSortColumn = column;
            careerIsAscending = false;
        }
    }

    private IEnumerable<SeasonPlayerStats> ApplyCareerSorting()
    {
        if (perSeasonStats == null) return Enumerable.Empty<SeasonPlayerStats>();

        Func<SeasonPlayerStats, object> selectorFunc = careerSortColumn switch
        {
            "Season" => s => s.SeasonName,
            "GP" => s => s.Stats.GamesPlayed,
            "PA" => s => s.Stats.PA,
            "AB" => s => s.Stats.AB,
            "R" => s => s.Stats.R,
            "H" => s => s.Stats.H,
            "1B" => s => s.Stats.H1B,
            "2B" => s => s.Stats.H2B,
            "3B" => s => s.Stats.H3B,
            "HR" => s => s.Stats.HR,
            "IPHR" => s => s.Stats.IPHR,
            "RBI" => s => s.Stats.RBI,
            "BB" => s => s.Stats.BB,
            "K" => s => s.Stats.K,
            "KF" => s => s.Stats.KF,
            "SF" => s => s.Stats.SF,
            "FC" => s => s.Stats.FC,
            "GO" => s => s.Stats.GO,
            "FO" => s => s.Stats.FO,
            "AVG" => s => s.Stats.AVG,
            "OBP" => s => s.Stats.OBP,
            "SLG" => s => s.Stats.SLG,
            "OPS" => s => s.Stats.OPS,
            _ => s => s.SeasonName
        };

        return careerIsAscending ? perSeasonStats.OrderBy(selectorFunc) : perSeasonStats.OrderByDescending(selectorFunc);
    }

    private void SortMobileStats(string column)
    {
        if (mobileStatSortColumn == column)
        {
            mobileStatIsAscending = !mobileStatIsAscending;
        }
        else
        {
            mobileStatSortColumn = column;
            mobileStatIsAscending = true;
        }
    }

    private IEnumerable<string> ApplyMobileStatsSorting()
    {
        int targetSeasonId = GetSeasonId(SeasonName);
        PlayerStatsSummary? statsToUse = targetSeasonId == SharedSessionState.AllSeasonsId ? overallCareerStats : playerSummary;
        bool hasPlayedInSeason = statsToUse != null && (targetSeasonId == SharedSessionState.AllSeasonsId ? statsToUse.GamesPlayed > 0 : statsToUse.PA > 0);

        if (mobileStatSortColumn == "Stat")
        {
            return mobileStatIsAscending ? AllSortableStats.OrderBy(s => s) : AllSortableStats.OrderByDescending(s => s);
        }
        
        if (mobileStatSortColumn == "Rank")
        {
            Func<string, int> rankSelector = s => {
                string rank = hasPlayedInSeason ? GetRankForSeason(s, targetSeasonId, statsToUse!) : "-";
                if (rank == "N/A" || rank == "-") return 999;
                string numericPart = new string(rank.TakeWhile(char.IsDigit).ToArray());
                return int.TryParse(numericPart, out int r) ? r : 999;
            };
            return mobileStatIsAscending ? AllSortableStats.OrderBy(rankSelector) : AllSortableStats.OrderByDescending(rankSelector);
        }

        return mobileStatIsAscending ? AllSortableStats : AllSortableStats.Reverse();
    }

    private void SortLogs(string column)
    {
        if (logSortColumn == column)
        {
            logIsAscending = !logIsAscending;
        }
        else
        {
            logSortColumn = column;
            logIsAscending = false;
        }
    }

    private IEnumerable<GameStatsExtendedView> ApplyLogSorting()
    {
        if (logs == null) return Enumerable.Empty<GameStatsExtendedView>();

        return logs.SortByColumn(logSortColumn, logIsAscending);
    }

    private string GetSortIcon(string currentColumn, bool isAscending, string targetColumn)
    {
        if (currentColumn != targetColumn) return "";
        return isAscending ? " ▲" : " ▼";
    }

    private string GetSeasonName(int id)
    {
        if (id == SharedSessionState.AllSeasonsId) return "all";
        return seasons.FirstOrDefault(s => s.Id == id)?.Name ?? "all";
    }

    private int GetSeasonId(string name)
    {
        if (string.Equals(name, "all", StringComparison.OrdinalIgnoreCase)) return SharedSessionState.AllSeasonsId;
        return seasons.FirstOrDefault(s => string.Equals(s.Name, name, StringComparison.OrdinalIgnoreCase))?.Id ?? 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("drawerDragging.initOpponentNames");
    }

    private string GetStatValue(PlayerStatsSummary player, string stat)
    {
        if (player == null) return "";
        return stat switch
        {
            "GP" => player.GamesPlayed.ToString(),
            "PA" => player.PA.ToString(),
            "AB" => player.AB.ToString(),
            "H" => player.H.ToString(),
            "1B" => player.H1B.ToString(),
            "2B" => player.H2B.ToString(),
            "3B" => player.H3B.ToString(),
            "IPHR" => player.IPHR.ToString(),
            "HR" => player.HR.ToString(),
            "RBI" => player.RBI.ToString(),
            "R" => player.R.ToString(),
            "BB" => player.BB.ToString(),
            "SF" => player.SF.ToString(),
            "FC" => player.FC.ToString(),
            "K" => player.K.ToString(),
            "KF" => player.KF.ToString(),
            "GO" => player.GO.ToString(),
            "FO" => player.FO.ToString(),
            "AVG" => player.AVG.ToString(".000"),
            "OBP" => player.OBP.ToString(".000"),
            "SLG" => player.SLG.ToString(".000"),
            "OPS" => player.OPS.ToString(".000"),
            _ => ""
        };
    }

    private void OnSeasonSelected(int id)
    {
        SharedState.SelectedSeasonId = id;
        string name = GetSeasonName(id);
        NavigationManager.NavigateTo($"/career/{Uri.EscapeDataString(PlayerName)}/{Uri.EscapeDataString(name)}");
    }

    private PlayerStatsSummary GetCareerTotals()
    {
        return new PlayerStatsSummary {
            PlayerName = PlayerName,
            GamesPlayed = perSeasonStats.Sum(x => x.Stats.GamesPlayed),
            H1B = perSeasonStats.Sum(x => x.Stats.H1B),
            H2B = perSeasonStats.Sum(x => x.Stats.H2B),
            H3B = perSeasonStats.Sum(x => x.Stats.H3B),
            HR = perSeasonStats.Sum(x => x.Stats.HR),
            IPHR = perSeasonStats.Sum(x => x.Stats.IPHR),
            BB = perSeasonStats.Sum(x => x.Stats.BB),
            K = perSeasonStats.Sum(x => x.Stats.K),
            KF = perSeasonStats.Sum(x => x.Stats.KF),
            R = perSeasonStats.Sum(x => x.Stats.R),
            RBI = perSeasonStats.Sum(x => x.Stats.RBI),
            SF = perSeasonStats.Sum(x => x.Stats.SF),
            FC = perSeasonStats.Sum(x => x.Stats.FC),
            GO = perSeasonStats.Sum(x => x.Stats.GO),
            FO = perSeasonStats.Sum(x => x.Stats.FO)
        };
    }

    private string GetRank(string category)
    {
        return CalculateRank(category, playerSummary, teamStats);
    }

    private string GetRankForSeason(string category, int seasonId, PlayerStatsSummary pSummary)
    {
        if (!allSeasonTeamStats.TryGetValue(seasonId, out List<PlayerStatsSummary>? sTeamStats)) return "N/A";
        return CalculateRank(category, pSummary, sTeamStats);
    }

    private string CalculateRank(string category, PlayerStatsSummary? pSummary, List<PlayerStatsSummary> currentTeamStats)
    {
        if (pSummary == null || !currentTeamStats.Any()) return "N/A";

        Func<PlayerStatsSummary, double> selector = category switch
        {
            "AVG" => s => s.AVG,
            "OBP" => s => s.OBP,
            "SLG" => s => s.SLG,
            "OPS" => s => s.OPS,
            "H" => s => (double)s.H,
            "1B" => s => (double)s.H1B,
            "HR" => s => (double)s.HR,
            "RBI" => s => (double)s.RBI,
            "R" => s => (double)s.R,
            "BB" => s => (double)s.BB,
            "2B" => s => (double)s.H2B,
            "3B" => s => (double)s.H3B,
            "IPHR" => s => (double)s.IPHR,
            "GP" => s => (double)s.GamesPlayed,
            "PA" => s => (double)s.PA,
            "AB" => s => (double)s.AB,
            "K" => s => (double)s.K,
            "KF" => s => (double)s.KF,
            "SF" => s => (double)s.SF,
            "FC" => s => (double)s.FC,
            "GO" => s => (double)s.GO,
            "FO" => s => (double)s.FO,
            _ => s => 0
        };

        List<PlayerStatsSummary> sorted = currentTeamStats.OrderByDescending(selector).ToList();
        double playerValue = selector(pSummary);

        // If the player has 0 in a volume category, don't give them a rank
        if (playerValue == 0 && !new[] { "AVG", "OBP", "SLG", "OPS" }.Contains(category)) return "-";

        int rank = 1;
        foreach (PlayerStatsSummary s in sorted)
        {
            double val = selector(s);
            if (val > playerValue)
            {
                rank++;
            }
        }

        string suffix = rank switch
        {
            1 => "st",
            2 => "nd",
            3 => "rd",
            _ => "th"
        };
        
        if (rank % 100 >= 11 && rank % 100 <= 13) suffix = "th";

        return rank + suffix;
    }

    private bool isTopRank(string rank)
    {
        return rank.Contains("1st") || rank.Contains("2nd") || rank.Contains("3rd");
    }

    private RenderFragment RenderStatWithMedal(string category, string value, int seasonId, PlayerStatsSummary pStats) => __builder => {
        string rank = value == "-" ? "N/A" : GetRankForSeason(category, seasonId, pStats);
        bool isTop = isTopRank(rank);
        
        <div class="history-cell-content">
            <div class="history-value">@value</div>
            <div class="history-medal-wrap">
                @if (isTop && value != "-") {
                    <span class="history-medal" title="Ranked @rank in team">
                        @(rank.Contains("1st") ? "🥇" : rank.Contains("2nd") ? "🥈" : "🥉")
                    </span>
                }
            </div>
        </div>
    };
}

