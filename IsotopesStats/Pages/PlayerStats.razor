@page "/"
@page "/players"
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject StatsService StatsService

<h3>Player Statistics</h3>

@if (allStats.Any())
{
    <div class="leader-highlights">
        <div class="leader-card">
            <div class="leader-category">Batting Average</div>
            <div class="leader-name">@avgLeader?.PlayerName</div>
            <div class="leader-value">@avgLeader?.AVG.ToString(".000")</div>
        </div>
        <div class="leader-card" style="background: linear-gradient(135deg, var(--isotopes-red), #990000);">
            <div class="leader-category">Home Runs</div>
            <div class="leader-name">@hrLeader?.PlayerName</div>
            <div class="leader-value">@hrLeader?.HR</div>
        </div>
        <div class="leader-card">
            <div class="leader-category">RBIs</div>
            <div class="leader-name">@rbiLeader?.PlayerName</div>
            <div class="leader-value">@rbiLeader?.RBI</div>
        </div>
        <div class="leader-card" style="background: linear-gradient(135deg, #333, #000);">
            <div class="leader-category">OPS</div>
            <div class="leader-name">@opsLeader?.PlayerName</div>
            <div class="leader-value">@opsLeader?.OPS.ToString(".000")</div>
        </div>
    </div>
}

<div class="stat-card">
    <div class="view-switcher">
        <button class="view-btn @(activeView == "Standard" ? "active" : "")" @onclick="@(() => activeView = "Standard")">Standard</button>
        <button class="view-btn @(activeView == "Hits" ? "active" : "")" @onclick="@(() => activeView = "Hits")">Hits</button>
        <button class="view-btn @(activeView == "Outcomes" ? "active" : "")" @onclick="@(() => activeView = "Outcomes")">Plate Outcomes</button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th @onclick="@(() => Sort("PlayerName"))" style="cursor:pointer">Player @(GetSortIcon("PlayerName"))</th>
                    @if (activeView == "Standard")
                    {
                        <th @onclick="@(() => Sort("GP"))">GP</th>
                        <th @onclick="@(() => Sort("PA"))">PA</th>
                        <th @onclick="@(() => Sort("AB"))">AB</th>
                        <th @onclick="@(() => Sort("H"))">H</th>
                        <th @onclick="@(() => Sort("HR"))">HR</th>
                        <th @onclick="@(() => Sort("RBI"))">RBI</th>
                        <th @onclick="@(() => Sort("R"))">R</th>
                        <th @onclick="@(() => Sort("AVG"))">AVG</th>
                        <th @onclick="@(() => Sort("OPS"))">OPS</th>
                    }
                    else if (activeView == "Hits")
                    {
                        <th @onclick="@(() => Sort("H1B"))">1B</th>
                        <th @onclick="@(() => Sort("H2B"))">2B</th>
                        <th @onclick="@(() => Sort("H3B"))">3B</th>
                        <th @onclick="@(() => Sort("H4B"))">4B</th>
                        <th @onclick="@(() => Sort("HR"))">HR</th>
                        <th @onclick="@(() => Sort("SLG"))">SLG</th>
                    }
                    else if (activeView == "Outcomes")
                    {
                        <th @onclick="@(() => Sort("BB"))">BB</th>
                        <th @onclick="@(() => Sort("SF"))">SF</th>
                        <th @onclick="@(() => Sort("FC"))">FC</th>
                        <th @onclick="@(() => Sort("K"))">K</th>
                        <th @onclick="@(() => Sort("KF"))">KF</th>
                        <th @onclick="@(() => Sort("TB"))">TB</th>
                        <th @onclick="@(() => Sort("GO"))">GO</th>
                        <th @onclick="@(() => Sort("FO"))">FO</th>
                        <th @onclick="@(() => Sort("OBP"))">OBP</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (PlayerStatsSummary player in allStats)
                {
                    <tr>
                        <td class="player-name">@player.PlayerName</td>
                        @if (activeView == "Standard")
                        {
                            <td>@player.GamesPlayed</td>
                            <td>@player.PA</td>
                            <td>@player.AB</td>
                            <td>@player.H</td>
                            <td>@player.HR</td>
                            <td>@player.RBI</td>
                            <td>@player.R</td>
                            <td>@player.AVG.ToString(".000")</td>
                            <td>@player.OPS.ToString(".000")</td>
                        }
                        else if (activeView == "Hits")
                        {
                            <td>@player.H1B</td>
                            <td>@player.H2B</td>
                            <td>@player.H3B</td>
                            <td>@player.H4B</td>
                            <td>@player.HR</td>
                            <td>@player.SLG.ToString(".000")</td>
                        }
                        else if (activeView == "Outcomes")
                        {
                            <td>@player.BB</td>
                            <td>@player.SF</td>
                            <td>@player.FC</td>
                            <td>@player.K</td>
                            <td>@player.KF</td>
                            <td>@player.TB</td>
                            <td>@player.GO</td>
                            <td>@player.FO</td>
                            <td>@player.OBP.ToString(".000")</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<PlayerStatsSummary> allStats = new();
    private string activeView = "Standard";
    private string currentSortColumn = "AVG";
    private bool isAscending = false;

    // Leader references
    private PlayerStatsSummary? avgLeader;
    private PlayerStatsSummary? hrLeader;
    private PlayerStatsSummary? rbiLeader;
    private PlayerStatsSummary? opsLeader;

    protected override void OnInitialized()
    {
        try 
        {
            allStats = StatsService.GetStatsSummary();
            CalculateLeaders();
            Sort(currentSortColumn, false);
        }
        catch (Exception)
        {
            allStats = new List<PlayerStatsSummary>();
        }
    }

    private void CalculateLeaders()
    {
        if (!allStats.Any()) return;

        avgLeader = allStats.OrderByDescending(p => p.AVG).FirstOrDefault();
        hrLeader = allStats.OrderByDescending(p => p.HR).FirstOrDefault();
        rbiLeader = allStats.OrderByDescending(p => p.RBI).FirstOrDefault();
        opsLeader = allStats.OrderByDescending(p => p.OPS).FirstOrDefault();
    }

    private void Sort(string column, bool toggle = true)
    {
        if (toggle)
        {
            if (currentSortColumn == column) isAscending = !isAscending;
            else { currentSortColumn = column; isAscending = false; }
        }

        switch (column)
        {
            case "PlayerName": allStats = isAscending ? allStats.OrderBy(p => p.PlayerName).ToList() : allStats.OrderByDescending(p => p.PlayerName).ToList(); break;
            case "GP": allStats = isAscending ? allStats.OrderBy(p => p.GamesPlayed).ToList() : allStats.OrderByDescending(p => p.GamesPlayed).ToList(); break;
            case "PA": allStats = isAscending ? allStats.OrderBy(p => p.PA).ToList() : allStats.OrderByDescending(p => p.PA).ToList(); break;
            case "AB": allStats = isAscending ? allStats.OrderBy(p => p.AB).ToList() : allStats.OrderByDescending(p => p.AB).ToList(); break;
            case "H": allStats = isAscending ? allStats.OrderBy(p => p.H).ToList() : allStats.OrderByDescending(p => p.H).ToList(); break;
            case "H1B": allStats = isAscending ? allStats.OrderBy(p => p.H1B).ToList() : allStats.OrderByDescending(p => p.H1B).ToList(); break;
            case "H2B": allStats = isAscending ? allStats.OrderBy(p => p.H2B).ToList() : allStats.OrderByDescending(p => p.H2B).ToList(); break;
            case "H3B": allStats = isAscending ? allStats.OrderBy(p => p.H3B).ToList() : allStats.OrderByDescending(p => p.H3B).ToList(); break;
            case "H4B": allStats = isAscending ? allStats.OrderBy(p => p.H4B).ToList() : allStats.OrderByDescending(p => p.H4B).ToList(); break;
            case "HR": allStats = isAscending ? allStats.OrderBy(p => p.HR).ToList() : allStats.OrderByDescending(p => p.HR).ToList(); break;
            case "RBI": allStats = isAscending ? allStats.OrderBy(p => p.RBI).ToList() : allStats.OrderByDescending(p => p.RBI).ToList(); break;
            case "R": allStats = isAscending ? allStats.OrderBy(p => p.R).ToList() : allStats.OrderByDescending(p => p.R).ToList(); break;
            case "AVG": allStats = isAscending ? allStats.OrderBy(p => p.AVG).ToList() : allStats.OrderByDescending(p => p.AVG).ToList(); break;
            case "OPS": allStats = isAscending ? allStats.OrderBy(p => p.OPS).ToList() : allStats.OrderByDescending(p => p.OPS).ToList(); break;
            case "SLG": allStats = isAscending ? allStats.OrderBy(p => p.SLG).ToList() : allStats.OrderByDescending(p => p.SLG).ToList(); break;
            case "OBP": allStats = isAscending ? allStats.OrderBy(p => p.OBP).ToList() : allStats.OrderByDescending(p => p.OBP).ToList(); break;
            case "BB": allStats = isAscending ? allStats.OrderBy(p => p.BB).ToList() : allStats.OrderByDescending(p => p.BB).ToList(); break;
            case "SF": allStats = isAscending ? allStats.OrderBy(p => p.SF).ToList() : allStats.OrderByDescending(p => p.SF).ToList(); break;
            case "FC": allStats = isAscending ? allStats.OrderBy(p => p.FC).ToList() : allStats.OrderByDescending(p => p.FC).ToList(); break;
            case "K": allStats = isAscending ? allStats.OrderBy(p => p.K).ToList() : allStats.OrderByDescending(p => p.K).ToList(); break;
            case "KF": allStats = isAscending ? allStats.OrderBy(p => p.KF).ToList() : allStats.OrderByDescending(p => p.KF).ToList(); break;
            case "TB": allStats = isAscending ? allStats.OrderBy(p => p.TB).ToList() : allStats.OrderByDescending(p => p.TB).ToList(); break;
            case "GO": allStats = isAscending ? allStats.OrderBy(p => p.GO).ToList() : allStats.OrderByDescending(p => p.GO).ToList(); break;
            case "FO": allStats = isAscending ? allStats.OrderBy(p => p.FO).ToList() : allStats.OrderByDescending(p => p.FO).ToList(); break;
        }
    }

    private string GetSortIcon(string column)
    {
        if (currentSortColumn != column) return "↕️";
        return isAscending ? "🔼" : "🔽";
    }
}
