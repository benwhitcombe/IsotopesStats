@page "/defense"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Services
@inject IStatsRepository StatsRepository
@inject SharedSessionState SharedState
@inject SessionStorageService SessionStorage
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Defense</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Defense</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <SeasonSelector 
            Seasons="@seasons" 
            SelectedSeasonId="@selectedSeasonId" 
            OnSeasonSelected="OnSeasonSelected"
            AllowAllSeasons="false" />
    </div>
</div>

@if (isLoading)
{
    <LoadingIndicator />
}
else
{
    <div class="stat-card mb-4" style="padding: 1.25rem; position: relative; z-index: @(showSuggestions ? "1100" : "10");">
        <div class="d-flex justify-content-between align-items-center clickable-header" @onclick="ToggleQuickSelect">
            <div>
                <h5 class="m-0" style="color: var(--isotopes-accent);">Quick Select</h5>
                @if (isQuickSelectCollapsed)
                {
                    <div class="d-md-none" style="font-size: 0.8rem; color: #666; margin-top: 2px;">Expand to access quick select</div>
                }
            </div>
            <div class="expand-icon d-md-none" style="color: #ccc; font-size: 0.8rem; width: 20px; text-align: center;">@(isQuickSelectCollapsed ? "▼" : "▲")</div>
        </div>
        
        <div class="collapsible-content @(isQuickSelectCollapsed ? "" : "expanded")">
            <div style="padding-top: 1.5rem;">
                <div class="filter-container mb-4 d-none d-md-block" style="max-width: 400px;">
                    <div class="search-container">
                    <div class="autocomplete-wrapper">
                        <div class="ghost-text">
                            <span style="visibility: hidden;">@searchQuery</span>
                            <span class="suggestion">@suggestionSuffix</span>
                        </div>
                        <input class="form-control" 
                               autocomplete="off"
                               @bind="searchQuery"
                               @bind:event="oninput"
                               @onkeydown="HandleKeyDown"
                               @onblur="OnSearchBlur"
                               placeholder="Quick select player..." />
                    </div>
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <button class="clear-button" @onclick="ClearSearch">✕</button>
                    }
                    
                    @if (showSuggestions && filteredSuggestions.Any())
                    {
                        <div class="custom-autocomplete-dropdown">
                            @for (int i = 0; i < filteredSuggestions.Count; i++)
                            {
                                int index = i;
                                Player player = filteredSuggestions[i];
                                <div class="suggestion-item @(index == activeSuggestionIndex ? "active" : "")"
                                     @onclick="() => SelectSuggestion(player)">
                                    @player.Name
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="form-text mt-2" style="font-size: 0.85rem; color: #666;">Type a name and press Enter to select the top suggestion.</div>
            </div>

            <div class="selectable-grid mb-2">
                @foreach (Player player in players.OrderBy(p => p.Name))
                {
                    <div class="selectable-item-container" @key="player.Id">
                        <CheckboxButton 
                            Id="@($"av-{player.Id}")" 
                            Text="@GetPlayerLabel(player)" 
                            Checked="@availablePlayerIds.Contains(player.Id)" 
                            CheckedChanged="@((bool val) => TogglePlayerAvailability(player.Id, val))" />
                    </div>
                }
            </div>
            </div>
        </div>
    </div>

    <div class="defense-main-layout">
        <div class="lineup-pane">
            <div class="lineup-card-container">
                <div class="lineup-card-header">
                    <div class="team-name">ISOTOPES</div>
                    <div class="card-title">LINEUP CARD</div>
                </div>
                <table class="lineup-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th style="width: 60px;">POS</th>
                            <th>PLAYER NAME</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < assignments.Count; i++)
                        {
                            int index = i;
                            var assignment = assignments[index];
                            <tr @key="assignment.PositionLabel">
                                <td class="pos-num">@assignment.PositionNumber</td>
                                <td class="pos-abbr">@assignment.PositionAbbreviation</td>
                                <td class="player-select-cell">
                                    <PlayerAutocompleteCell 
                                        @ref="autocompleteCells[index]"
                                        Value="@(players.FirstOrDefault(p => p.Id == assignment.PlayerId)?.Name ?? string.Empty)"
                                        Players="@players"
                                        PlayerAssignments="@playerAssignments"
                                        OnSelected="@(p => HandleStarterSelection(assignment, p))"
                                        OnCommit="@(() => FocusNextPosition(index))" />
                                </td>
                            </tr>
                        }
                        
                        @{
                            var currentBenchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
                            int totalBenchRows = currentBenchIds.Count + (players.Count > availablePlayerIds.Count ? 1 : 0);
                        }
                        @for (int j = 0; j < totalBenchRows; j++)
                        {
                            int benchIndex = j;
                            int posNum = 11 + benchIndex;
                            int cellIndex = 10 + benchIndex;
                            int? playerId = benchIndex < currentBenchIds.Count ? currentBenchIds[benchIndex] : null;
                            
                            <tr @key="@($"bench-{benchIndex}")">
                                <td class="pos-num">@posNum</td>
                                <td class="pos-abbr">B</td>
                                <td class="player-select-cell">
                                    <PlayerAutocompleteCell 
                                        @ref="autocompleteCells[cellIndex]"
                                        Value="@(players.FirstOrDefault(p => p.Id == playerId)?.Name ?? string.Empty)"
                                        Players="@players"
                                        PlayerAssignments="@playerAssignments"
                                        OnSelected="@(p => HandleBenchSelection(playerId, p))"
                                        OnCommit="@(() => FocusNextPosition(cellIndex))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="field-pane d-none d-xl-block">
            <div class="field-container-sticky">
                <DefenseField 
                    Assignments="@fieldAssignments" 
                    BenchPlayers="@benchPlayerNames" 
                    SelectedIndex="@selectedIndex" 
                    SelectedFromBench="@selectedFromBench" 
                    AnimationCounters="@animationCounters" 
                    OnPlayerClick="@(e => HandleFieldClick(e.Index, e.FromBench))"
                    IsEditable="true"
                    MaxWidth="800" />
                
                <div class="mt-4 d-flex gap-2 justify-content-center">
                    <button class="view-btn" @onclick="ClearAll" style="padding: 0.6rem 1.5rem; font-size: 0.9rem;">Clear All</button>
                    <button class="view-btn active" @onclick="SaveAndView" disabled="@(!IsDefenseComplete)" style="padding: 0.6rem 1.5rem; font-size: 0.9rem; opacity: @(IsDefenseComplete ? "1" : "0.5");">Save & View Defense</button>
                </div>
            </div>
        </div>

        @if (isBenchDropdownOpen)
        {
            <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:999; background:transparent;" @onclick="() => isBenchDropdownOpen = false"></div>
        }
    </div>

    <div class="d-xl-none mt-4">
        <div class="mt-4 d-flex gap-2 justify-content-end">
            <button class="view-btn" @onclick="ClearAll" style="padding: 0.8rem 2rem;">Clear All</button>
            <button class="view-btn active" @onclick="SaveAndView" disabled="@(!IsDefenseComplete)" style="padding: 0.8rem 2rem; opacity: @(IsDefenseComplete ? "1" : "0.5"); cursor: @(IsDefenseComplete ? "pointer" : "not-allowed");">Save & View Defense</button>
        </div>
    </div>
    
    @if (!IsDefenseComplete)
    {
        <div class="alert alert-info mt-4">
            Please select a player for all 10 positions to view the defense.
        </div>
    }
}

@code {
    [Parameter] [SupplyParameterFromQuery(Name = "p")] public string? DefenseData { get; set; }

    private List<Season> seasons = new List<Season>();
    private List<Player> players = new List<Player>();
    private List<int> availablePlayerIds = new List<int>();
    private int selectedSeasonId;
    private bool isLoading = true;
    private bool isInitializing = false;
    private bool isQuickSelectCollapsed = true;

    private void ToggleQuickSelect()
    {
        isQuickSelectCollapsed = !isQuickSelectCollapsed;
    }

    private bool isBenchDropdownOpen = false;

    private void ToggleBenchDropdown()
    {
        isBenchDropdownOpen = !isBenchDropdownOpen;
    }

    private bool IsOnBench(int playerId)
    {
        return availablePlayerIds.Contains(playerId) && !IsPlayerAssigned(playerId);
    }

    private void ToggleBenchPlayer(int playerId, bool isChecked)
    {
        if (isChecked)
        {
            if (!availablePlayerIds.Contains(playerId))
            {
                availablePlayerIds.Add(playerId);
            }
            // Clear from any assigned position
            foreach (PositionAssignment a in assignments)
            {
                if (a.PlayerId == playerId) a.PlayerId = null;
            }
        }
        else
        {
            // Only remove from availability if it was on bench
            if (!IsPlayerAssigned(playerId))
            {
                availablePlayerIds.Remove(playerId);
            }
        }
        StateHasChanged();
        UpdateUrl();
    }

    private string GetBenchSummary()
    {
        int benchCount = availablePlayerIds.Count(id => !IsPlayerAssigned(id));
        return benchCount == 0 ? "-- Select Bench --" : $"{benchCount} Player{(benchCount == 1 ? "" : "s")} Selected";
    }

    private string _searchQuery = string.Empty;
    private string searchQuery 
    {
        get => _searchQuery;
        set 
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                UpdateSuggestion();
            }
        }
    }

    private string suggestionSuffix = string.Empty;
    private Player? firstMatch = null;
    private int activeSuggestionIndex = 0;
    private bool showSuggestions = false;
    private List<Player> filteredSuggestions = new List<Player>();
    private ElementReference searchInput = default!;
    private bool hasFocused = false;

    private void UpdateSuggestion()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            suggestionSuffix = string.Empty;
            firstMatch = null;
            filteredSuggestions.Clear();
            showSuggestions = false;
            return;
        }

        filteredSuggestions = players
            .Where(p => !availablePlayerIds.Contains(p.Id) && p.Name.StartsWith(searchQuery, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.Name)
            .ToList();

        firstMatch = filteredSuggestions.FirstOrDefault(p => p.Name.StartsWith(searchQuery, StringComparison.OrdinalIgnoreCase)) 
                     ?? filteredSuggestions.FirstOrDefault();

        if (firstMatch != null && firstMatch.Name.StartsWith(searchQuery, StringComparison.OrdinalIgnoreCase))
        {
            suggestionSuffix = firstMatch.Name.Substring(searchQuery.Length);
        }
        else
        {
            suggestionSuffix = string.Empty;
        }

        activeSuggestionIndex = 0;
        showSuggestions = filteredSuggestions.Any();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !hasFocused)
        {
            try
            {
                await Task.Delay(100); // Small delay to ensure DOM is ready
                await searchInput.FocusAsync();
                hasFocused = true;
            }
            catch
            {
                // Ignore if focus fails
            }
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (showSuggestions && filteredSuggestions.Any())
            {
                SelectSuggestion(filteredSuggestions[activeSuggestionIndex]);
            }
        }
        else if (e.Key == "ArrowDown")
        {
            if (showSuggestions && activeSuggestionIndex < filteredSuggestions.Count - 1)
            {
                activeSuggestionIndex++;
            }
        }
        else if (e.Key == "ArrowUp")
        {
            if (showSuggestions && activeSuggestionIndex > 0)
            {
                activeSuggestionIndex--;
            }
        }
        else if (e.Key == "Escape")
        {
            showSuggestions = false;
        }
    }

    private void SelectSuggestion(Player player)
    {
        TogglePlayerAvailability(player.Id, true);
        searchQuery = string.Empty;
        suggestionSuffix = string.Empty;
        firstMatch = null;
        showSuggestions = false;
    }

    private async Task OnSearchBlur()
    {
        // Delay to allow @onclick on suggestion items to fire
        await Task.Delay(200);
        showSuggestions = false;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        searchQuery = string.Empty;
    }

    private Dictionary<int, PlayerAutocompleteCell> autocompleteCells = new();

    private async Task FocusNextPosition(int currentIndex)
    {
        int nextIndex = currentIndex + 1;
        await Task.Yield(); // Give Blazor a chance to render new row if added
        if (autocompleteCells.TryGetValue(nextIndex, out var cell) && cell != null)
        {
            await cell.FocusAsync();
        }
    }

    private void HandleStarterSelection(PositionAssignment assignment, Player? newPlayer)
    {
        // 1. If we are replacing an existing player in this spot, remove them from the game
        if (assignment.PlayerId.HasValue && (newPlayer == null || assignment.PlayerId != newPlayer.Id))
        {
            availablePlayerIds.Remove(assignment.PlayerId.Value);
        }

        // 2. Set the new player (this triggers HandleAssignmentChange via the property setter)
        assignment.PlayerId = newPlayer?.Id;

        StateHasChanged();
        UpdateUrl();
    }

    private void HandleBenchSelection(int? oldPlayerId, Player? newPlayer)
    {
        if (oldPlayerId.HasValue)
        {
            availablePlayerIds.Remove(oldPlayerId.Value);
        }

        if (newPlayer != null)
        {
            if (!availablePlayerIds.Contains(newPlayer.Id))
            {
                availablePlayerIds.Add(newPlayer.Id);
            }

            // Ensure they aren't assigned to a starter spot
            foreach (var a in assignments)
            {
                if (a.PlayerId == newPlayer.Id) a.PlayerId = null;
            }
        }

        StateHasChanged();
        UpdateUrl();
    }

    private bool IsPlayerAssigned(int playerId)
    {
        foreach (PositionAssignment a in assignments)
        {
            if (a.PlayerId == playerId) return true;
        }
        return false;
    }

    private int? selectedIndex;
    private bool? selectedFromBench;
    private Dictionary<(int Index, bool FromBench), int> animationCounters = new();

    private List<DefenseField.FieldPositionAssignment> fieldAssignments => assignments.Select(a => new DefenseField.FieldPositionAssignment
    {
        PlayerName = players.FirstOrDefault(p => p.Id == a.PlayerId)?.Name ?? string.Empty,
        X = a.X,
        Y = a.Y
    }).ToList();

    private Dictionary<int, string> playerAssignments 
    {
        get 
        {
            var dict = assignments
                .Where(a => a.PlayerId.HasValue)
                .ToDictionary(a => a.PlayerId!.Value, a => a.PositionAbbreviation);
            
            foreach (var id in availablePlayerIds)
            {
                if (!dict.ContainsKey(id))
                {
                    dict[id] = "B";
                }
            }
            return dict;
        }
    }

    private List<string> benchPlayerNames => availablePlayerIds
        .Where(id => !IsPlayerAssigned(id))
        .Select(id => players.FirstOrDefault(p => p.Id == id)?.Name ?? string.Empty)
        .Where(name => !string.IsNullOrEmpty(name))
        .ToList();

    private async Task HandleFieldClick(int index, bool fromBench)
    {
        if (selectedIndex == null)
        {
            selectedIndex = index;
            selectedFromBench = fromBench;
            return;
        }

        if (selectedIndex == index && selectedFromBench == fromBench)
        {
            selectedIndex = null;
            selectedFromBench = null;
            return;
        }

        // Capture indices for animation
        int idx1 = selectedIndex!.Value;
        bool bench1 = selectedFromBench!.Value;
        int idx2 = index;
        bool bench2 = fromBench;

        if (selectedFromBench == true)
        {
            int? sourcePlayerId = GetBenchPlayerId(selectedIndex.Value);
            if (fromBench)
            {
                // Swap bench with bench - no-op for now as bench is just a list of names
            }
            else
            {
                int? targetPlayerId = assignments[index].PlayerId;
                assignments[index].PlayerId = sourcePlayerId;
                // If the bench player was replaced, we don't need to do much as bench is derived
            }
        }
        else
        {
            int? sourcePlayerId = assignments[selectedIndex.Value].PlayerId;
            if (fromBench)
            {
                int? targetPlayerId = GetBenchPlayerId(index);
                assignments[selectedIndex.Value].PlayerId = targetPlayerId;
            }
            else
            {
                int? targetPlayerId = assignments[index].PlayerId;
                assignments[selectedIndex.Value].PlayerId = targetPlayerId;
                assignments[index].PlayerId = sourcePlayerId;
            }
        }

        selectedIndex = null;
        selectedFromBench = null;
        
        // Trigger animations
        _ = TriggerAnimation(idx1, bench1);
        _ = TriggerAnimation(idx2, bench2);
        
        StateHasChanged();
        UpdateUrl();
        await Task.CompletedTask;
    }

    private int? GetBenchPlayerId(int benchIndex)
    {
        var benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
        if (benchIndex >= 0 && benchIndex < benchIds.Count)
        {
            return benchIds[benchIndex];
        }
        return null;
    }

    private async Task TriggerAnimation(int index, bool fromBench)
    {
        (int Index, bool FromBench) key = (index, fromBench);
        if (animationCounters.ContainsKey(key)) animationCounters[key]++;
        else animationCounters[key] = 1;
        
        StateHasChanged();
        await Task.Delay(600);
        
        if (animationCounters.ContainsKey(key))
        {
            animationCounters[key]--;
            if (animationCounters[key] <= 0) animationCounters.Remove(key);
            StateHasChanged();
        }
    }

    private string GetPlayerLabel(Player player)
    {
        // 1. Check if assigned to a position
        for (int i = 0; i < assignments.Count; i++)
        {
            if (assignments[i].PlayerId == player.Id)
            {
                return $"{i + 1}. {player.Name} ({assignments[i].PositionAbbreviation})";
            }
        }
        
        // 2. If available but not assigned, it's on the bench
        if (availablePlayerIds.Contains(player.Id))
        {
            // Get all players on the bench (available but not assigned)
            // We maintain the order they were added to the available list
            List<int> benchPlayerIds = availablePlayerIds
                .Where(id => !IsPlayerAssigned(id))
                .ToList();
                
            int benchIndex = benchPlayerIds.IndexOf(player.Id);
            if (benchIndex != -1)
            {
                return $"{11 + benchIndex}. {player.Name} (B)";
            }
        }
        
        return player.Name;
    }

    private class PositionAssignment
    {
        public int PositionNumber { get; set; }
        public string PositionLabel { get; set; } = string.Empty;
        public string PositionAbbreviation { get; set; } = string.Empty;
        public double X { get; set; }
        public double Y { get; set; }
        
        private int? _playerId;
        public int? PlayerId 
        { 
            get => _playerId;
            set 
            {
                if (_playerId != value)
                {
                    _playerId = value;
                    OnAssignmentChanged?.Invoke(this);
                }
            }
        }

        public Action<PositionAssignment>? OnAssignmentChanged { get; set; }
    }

    private List<PositionAssignment> assignments = new List<PositionAssignment>();

    private void InitializeAssignments()
    {
        assignments = new List<PositionAssignment>()
        {
            new PositionAssignment { PositionNumber = 1, PositionLabel = "Pitcher", PositionAbbreviation = "P", X = 50, Y = 62, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 2, PositionLabel = "Catcher", PositionAbbreviation = "C", X = 50, Y = 92, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 3, PositionLabel = "1st Base", PositionAbbreviation = "1B", X = 70, Y = 62, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 4, PositionLabel = "2nd Base", PositionAbbreviation = "2B", X = 65, Y = 48, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 5, PositionLabel = "Third Base", PositionAbbreviation = "3B", X = 30, Y = 62, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 6, PositionLabel = "Short Stop", PositionAbbreviation = "SS", X = 35, Y = 48, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 7, PositionLabel = "Left Field", PositionAbbreviation = "LF", X = 15, Y = 35, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 8, PositionLabel = "Left Center Field", PositionAbbreviation = "LC", X = 38, Y = 15, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 9, PositionLabel = "Right Center Field", PositionAbbreviation = "RC", X = 62, Y = 15, OnAssignmentChanged = HandleAssignmentChange },
            new PositionAssignment { PositionNumber = 10, PositionLabel = "Right Field", PositionAbbreviation = "RF", X = 85, Y = 35, OnAssignmentChanged = HandleAssignmentChange }
        };
    }

    private void HandleAssignmentChange(PositionAssignment assignment)
    {
        if (assignment.PlayerId.HasValue)
        {
            int playerId = assignment.PlayerId.Value;
            
            // Mark as available if not already
            if (!availablePlayerIds.Contains(playerId))
            {
                availablePlayerIds.Add(playerId);
            }

            // Bulletproof: Clear this player from every OTHER position
            foreach (PositionAssignment a in assignments)
            {
                if (a != assignment && a.PlayerId == playerId)
                {
                    a.PlayerId = null;
                }
            }
        }
        StateHasChanged();
        UpdateUrl();
    }

    private string GetCurrentDefenseData()
    {
        if (!availablePlayerIds.Any() && !assignments.Any(a => a.PlayerId.HasValue))
        {
            return string.Empty;
        }

        List<int> ids = assignments.Select(a => a.PlayerId ?? 0).ToList();
        List<int> benchIds = availablePlayerIds.Where(id => !IsPlayerAssigned(id)).ToList();
        ids.AddRange(benchIds);
        return DefenseEncoder.Encode(ids, players);
    }

    private void UpdateUrl()
    {
        if (isInitializing) return;
        
        string data = GetCurrentDefenseData();
        string? queryValue = string.IsNullOrEmpty(data) ? null : data;
        _ = JSRuntime.InvokeVoidAsync("updateUrlQuery", "p", queryValue);
    }

    private string? _appliedDefenseData;

    private void ApplyQueryParameters()
    {
        if (string.IsNullOrEmpty(DefenseData) || players == null || !players.Any()) return;

        List<int> ids = DefenseEncoder.Decode(DefenseData, players);
        if (ids == null || !ids.Any()) return;
        
        // Full reset before applying query parameters
        availablePlayerIds.Clear();
        foreach (var a in assignments)
        {
            a.PlayerId = null;
        }

        for (int i = 0; i < ids.Count; i++)
        {
            int id = ids[i];
            
            // Set starters (0-9)
            if (i < 10 && i < assignments.Count)
            {
                assignments[i].PlayerId = id > 0 ? id : null;
            }
            
            // Track all available players (starters + bench)
            if (id > 0)
            {
                if (!availablePlayerIds.Contains(id))
                {
                    availablePlayerIds.Add(id);
                }
            }
        }
        _appliedDefenseData = DefenseData;
    }

    private bool IsDefenseComplete => assignments.All(a => a.PlayerId.HasValue);
    private IEnumerable<Player> AvailablePlayersForSelection => players.Where(p => availablePlayerIds.Contains(p.Id));
    private IEnumerable<Player> BenchPlayers => AvailablePlayersForSelection.Where(p => !IsPlayerAssigned(p.Id));

    protected override async Task OnInitializedAsync()
    {
        isInitializing = true;
        InitializeAssignments();
        seasons = await StatsRepository.GetSeasonsAsync();
        selectedSeasonId = SharedState.SelectedSeasonId;
        
        if (selectedSeasonId == 0 && seasons.Any())
        {
            selectedSeasonId = seasons.First().Id;
        }

        await LoadPlayers();
        await LoadStateFromStorage();
        ApplyQueryParameters();
        
        isInitializing = false;
        UpdateUrl();
        StateHasChanged();
    }

    protected override void OnParametersSet()
    {
        if (isInitializing) return;

        if (DefenseData != _appliedDefenseData)
        {
            ApplyQueryParameters();
            StateHasChanged();
        }
    }

    private async Task OnSeasonSelected(int seasonId)
    {
        isInitializing = true;
        selectedSeasonId = seasonId;
        SharedState.SelectedSeasonId = seasonId;
        await LoadPlayers();
        ClearAllInternal();
        await LoadStateFromStorage();
        isInitializing = false;
        UpdateUrl();
    }

    private async Task LoadPlayers()
    {
        isLoading = true;
        players = await StatsRepository.GetPlayersAsync(selectedSeasonId);
        isLoading = false;
    }

    private void ClearPosition(PositionAssignment assignment)
    {
        assignment.PlayerId = null;
        UpdateUrl();
    }

    private void TogglePlayerAvailability(int playerId, bool isChecked)
    {
        Player? player = players.FirstOrDefault(p => p.Id == playerId);
        if (player == null) return;

        if (isChecked)
        {
            // If already in list, do nothing to prevent logic double-fire
            if (availablePlayerIds.Contains(playerId)) return;
            availablePlayerIds.Add(playerId);
            
            // Only auto-assign if NOT already assigned to any position
            if (!IsPlayerAssigned(player.Id))
            {
                // Find the first spot with NO name
                PositionAssignment? firstEmpty = assignments.FirstOrDefault(a => !a.PlayerId.HasValue);
                if (firstEmpty != null)
                {
                    firstEmpty.PlayerId = player.Id;
                }
            }
        }
        else
        {
            availablePlayerIds.Remove(playerId);
            // Clear player from all positions
            foreach (PositionAssignment a in assignments)
            {
                if (a.PlayerId == player.Id)
                {
                    a.PlayerId = null;
                }
            }
        }
        StateHasChanged();
        UpdateUrl();
    }

    private async Task SaveAndView()
    {
        await SessionStorage.SetItemAsync($"defense_av_{selectedSeasonId}", availablePlayerIds);
        List<string> playerNames = assignments.Select(a => {
            Player? p = players.FirstOrDefault(x => x.Id == a.PlayerId);
            return p?.Name ?? string.Empty;
        }).ToList();
        await SessionStorage.SetItemAsync($"defense_pos_{selectedSeasonId}", playerNames);

        List<string> benchNames = availablePlayerIds
            .Where(id => !IsPlayerAssigned(id))
            .Select(id => players.FirstOrDefault(p => p.Id == id)?.Name ?? string.Empty)
            .Where(name => !string.IsNullOrEmpty(name))
            .ToList();
        await SessionStorage.SetItemAsync($"defense_bn_{selectedSeasonId}", benchNames);

        string data = GetCurrentDefenseData();
        NavigationManager.NavigateTo($"/defense/view?p={data}");
    }

    private async Task LoadStateFromStorage()
    {
        List<int>? savedAvail = await SessionStorage.GetItemAsync<List<int>>($"defense_av_{selectedSeasonId}");
        if (savedAvail != null)
        {
            availablePlayerIds = savedAvail;
        }

        List<string>? savedNames = await SessionStorage.GetItemAsync<List<string>>($"defense_pos_{selectedSeasonId}");
        if (savedNames != null && savedNames.Count == assignments.Count)
        {
            for (int i = 0; i < assignments.Count; i++)
            {
                string name = savedNames[i];
                if (!string.IsNullOrEmpty(name))
                {
                    Player? player = players.FirstOrDefault(p => string.Equals(p.Name, name, StringComparison.OrdinalIgnoreCase));
                    if (player != null)
                    {
                        assignments[i].PlayerId = player.Id;
                    }
                }
            }
        }
    }

    private void ClearAllInternal()
    {
        availablePlayerIds.Clear();
        foreach (PositionAssignment a in assignments)
        {
            a.PlayerId = null;
        }
    }

    private void ClearAll()
    {
        ClearAllInternal();
        StateHasChanged();
        UpdateUrl();
    }
}

