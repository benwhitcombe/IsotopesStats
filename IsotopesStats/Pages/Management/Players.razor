@page "/management/players"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "ManagePlayers")]
@inject StatsService StatsService
@inject IJSRuntime JSRuntime
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Players</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Players</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick="() => StartEdit(new Player())">Add New Player</button>
    }
</div>

@if (isEditing)
{
    <div class="stat-card view-fade-in" style="margin-bottom: 2rem;">
        <h4 style="margin-top:0">@(editingPlayer.Id == 0 ? "Add" : "Edit") Player</h4>
        <div class="form-group">
            <label>Player Name</label>
            <input type="text" class="form-control" @bind="editingPlayer.Name" @bind:event="oninput" @onkeyup="HandleInput" placeholder="e.g. John Doe" />
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Seasons Participation</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.5rem; border-radius: 8px;">
                @foreach (Season season in allSeasons)
                {
                    <CheckboxButton 
                        Id="@($"s-{season.Id}")" 
                        Text="@season.Name" 
                        Checked="@assignedSeasonIds.Contains(season.Id)" 
                        CheckedChanged="@((bool val) => ToggleSeason(season.Id, val))" />
                }
            </div>
        </div>

        <div style="display: flex; gap: 1rem; margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1.5rem; justify-content: center;">
            <button class="view-btn active" style="padding: 0.8rem 2rem;" @onclick="SavePlayer">Save Player</button>
            <button class="view-btn" style="padding: 0.8rem 2rem;" @onclick="HandleCancel">Cancel</button>
        </div>
    </div>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Player player in players)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@player.Name</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick="() => StartEdit(player)">Edit / Seasons</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(player.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Player player in players)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name">@player.Name</div>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick="() => StartEdit(player)">Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(player.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete Player" 
    Message="Are you sure you want to delete this player?"
    OnConfirm="DeletePlayer"
    OnCancel="() => showConfirm = false" />

<ConfirmDialog 
    IsVisible="showDiscardConfirm" 
    Title="Discard Changes" 
    Message="You have unsaved changes. Are you sure you want to discard them?"
    OnConfirm="DiscardChanges"
    OnCancel="() => showDiscardConfirm = false" />

@code {
    private List<Player> players = new();
    private List<Season> allSeasons = new();
    private HashSet<int> assignedSeasonIds = new();
    private HashSet<int> originalSeasonIds = new();
    private Player editingPlayer = new();
    private bool isEditing = false;
    private bool showConfirm = false;
    private bool showDiscardConfirm = false;
    private int playerIdToDelete;
    private bool hasChanges = false;

    private class PlayerEditState
    {
        public Player Player { get; set; } = new();
        public HashSet<int> AssignedSeasonIds { get; set; } = new();
        public HashSet<int> OriginalSeasonIds { get; set; } = new();
        public bool IsEditing { get; set; }
        public bool HasChanges { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        allSeasons = await StatsService.GetSeasonsAsync();
        await LoadPlayers();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HydrateTempState();
        }
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<PlayerEditState> result = await ProtectedSessionStore.GetAsync<PlayerEditState>("PlayerEditState");
            if (result.Success && result.Value != null && result.Value.IsEditing)
            {
                editingPlayer = result.Value.Player;
                assignedSeasonIds = result.Value.AssignedSeasonIds;
                originalSeasonIds = result.Value.OriginalSeasonIds;
                isEditing = result.Value.IsEditing;
                hasChanges = result.Value.HasChanges;
                StateHasChanged();
            }
        }
        catch (Exception) { }
    }

    private async Task SaveTempState()
    {
        try
        {
            PlayerEditState state = new PlayerEditState
            {
                Player = editingPlayer,
                AssignedSeasonIds = assignedSeasonIds,
                OriginalSeasonIds = originalSeasonIds,
                IsEditing = isEditing,
                HasChanges = hasChanges
            };
            await ProtectedSessionStore.SetAsync("PlayerEditState", state);
        }
        catch (Exception) { }
    }

    private async Task HandleInput()
    {
        hasChanges = true;
        await SaveTempState();
    }

    private async Task ClearTempState()
    {
        hasChanges = false;
        isEditing = false;
        try
        {
            await ProtectedSessionStore.DeleteAsync("PlayerEditState");
        }
        catch (Exception) { }
    }

    private async Task LoadPlayers()
    {
        players = await StatsService.GetAllPlayersAsync();
    }

    private async Task StartEdit(Player player)
    {
        editingPlayer = new Player { Id = player.Id, Name = player.Name, IsDeleted = player.IsDeleted };
        assignedSeasonIds.Clear();
        originalSeasonIds.Clear();

        if (player.Id != 0)
        {
            List<Season> playerSeasons = await StatsService.GetSeasonsForPlayerAsync(player.Id);
            foreach (Season s in playerSeasons)
            {
                assignedSeasonIds.Add(s.Id);
                originalSeasonIds.Add(s.Id);
            }
        }

        isEditing = true;
        hasChanges = false;
        await SaveTempState();
    }

    private async Task HandleCancel()
    {
        if (hasChanges) showDiscardConfirm = true;
        else await DiscardChanges();
    }

    private async Task DiscardChanges()
    {
        showDiscardConfirm = false;
        await ClearTempState();
        editingPlayer = new Player();
        assignedSeasonIds.Clear();
    }

    private async Task CancelEdit() => await HandleCancel();

    private async Task ToggleSeason(int seasonId, bool isChecked)
    {
        hasChanges = true;
        if (isChecked) assignedSeasonIds.Add(seasonId);
        else assignedSeasonIds.Remove(seasonId);
        await SaveTempState();
    }

    private async Task SavePlayer()
    {
        if (string.IsNullOrEmpty(editingPlayer.Name)) return;

        if (editingPlayer.Id == 0)
        {
            int firstSeasonId = assignedSeasonIds.FirstOrDefault();
            await StatsService.AddPlayerAsync(editingPlayer, firstSeasonId);
            List<Player> all = await StatsService.GetAllPlayersAsync();
            Player? newP = all.FirstOrDefault(p => p.Name == editingPlayer.Name);
            if (newP != null)
            {
                foreach (int sid in assignedSeasonIds.Where(id => id != firstSeasonId))
                    await StatsService.AddPlayerToSeasonAsync(newP.Id, sid);
            }
        }
        else
        {
            await StatsService.UpdatePlayerAsync(editingPlayer);
            foreach (int sid in assignedSeasonIds.Except(originalSeasonIds))
                await StatsService.AddPlayerToSeasonAsync(editingPlayer.Id, sid);
            foreach (int sid in originalSeasonIds.Except(assignedSeasonIds))
                await StatsService.DeletePlayerFromSeasonAsync(editingPlayer.Id, sid);
        }

        await ClearTempState();
        await LoadPlayers();
    }

    private void ShowDeleteConfirm(int id)
    {
        playerIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeletePlayer()
    {
        showConfirm = false;
        await StatsService.DeletePlayerAsync(playerIdToDelete);
        await LoadPlayers();
    }
}
