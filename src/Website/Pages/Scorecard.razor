@page "/management/games/{GameId:int}/scorecard"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Domain.Interfaces
@inject IStatsRepository StatsRepository
@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@inject IJSRuntime JS

<PageTitle>Scorecard - Isotopes</PageTitle>

@if (isLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-dark" role="status"></div>
        <p class="mt-2 text-dark">Loading scorecard...</p>
    </div>
}
else if (game == null)
{
    <div class="alert alert-danger">Game not found.</div>
}
else
{
    <div class="scorecard-wrapper">
        <div class="d-flex flex-row justify-content-between align-items-center no-print mb-3 gap-2">
            <h2 class="mb-0">Scorecard</h2>
            <div class="d-flex flex-wrap justify-content-center gap-2">
                @if (canManageGames)
                {
                    <a href="/management/games/@GameId/scorekeeping" class="view-btn active">Scorekeeper</a>
                }
            </div>
        </div>

        @if (canManageGames && isOutOfSync)
        {
            <div class="alert alert-warning d-flex justify-content-between align-items-center mb-3 no-print border-warning">
                <div>
                    <strong class="text-dark">Warning:</strong> The official game stats do not match the play-by-play plate appearances.
                </div>
                <button class="view-btn active" style="background-color: var(--isotopes-accent); color: white; border: none;" @onclick="OpenSyncModal">Reconcile Stats</button>
            </div>
        }

        <div class="zoom-viewport" style="overflow: hidden; width: 100%;">
            <div class="scorecard-container" id="scorecard-zoom-container">
                <!-- Unified Header Section -->
            <div class="d-flex w-100" style="padding: 10px;">
                <!-- Details Box -->
                <div class="flex-grow-1 d-flex flex-column pe-4 justify-content-between" style="line-height: 1.5;">
                    <div class="d-flex align-items-end mb-2 border-bottom border-dark border-2 pb-1" style="min-height: 2rem;">
                        <div class="fw-bold me-2 fs-5 text-start">Teams:</div>
                        <div class="flex-grow-1 text-start fw-bold fs-5 ps-2">
                            @(game.IsHome ? $"{opponentName} vs. Isotopes" : $"Isotopes @ {opponentName}")
                        </div>
                    </div>
                    <div class="d-flex align-items-end mb-2 border-bottom border-dark border-2 pb-1" style="min-height: 2rem;">
                        <div class="fw-bold me-2 fs-5 text-start">Date:</div>
                        <div class="text-start fw-bold fs-5 flex-grow-1 ps-2">
                            @game.Date.ToString("MMMM dd, yyyy")
                        </div>
                        <div class="fw-bold mx-2 fs-5">Start Time:</div>
                        <div class="text-start fw-bold fs-5 flex-grow-1 ps-2">
                            @game.Date.ToString("h:mm tt")
                        </div>
                        <div class="fw-bold mx-2 fs-5">End Time:</div>
                        <div class="text-start fw-bold fs-5 flex-grow-1 ps-2">
                            @game.Date.AddHours(1.5).ToString("h:mm tt")
                        </div>
                        <div class="fw-bold mx-2 fs-5">Diamond:</div>
                        <div class="text-start fw-bold fs-5 flex-grow-1 ps-2">
                            @(game.Diamond ?? "")
                        </div>
                    </div>
                    <div class="d-flex align-items-end mb-2 border-bottom border-dark border-2 pb-1" style="min-height: 2rem;">
                        <div class="fw-bold me-2 fs-5 text-start">Weather:</div>
                        <div class="flex-grow-1"></div>
                    </div>
                    <div class="d-flex align-items-end mb-2 border-bottom border-dark border-2 pb-1" style="min-height: 2rem;">
                        <div class="fw-bold me-2 fs-5 text-start">Umpire:</div>
                        <div class="flex-grow-1"></div>
                    </div>
                </div>
                <!-- Logo Box -->
                <div class="d-flex align-items-center justify-content-center" style="width: 120px;">
                    <svg viewBox="0 0 100 100" width="100" height="100" style="fill:none; stroke:#000; stroke-width:5;">
                        <circle cx="50" cy="50" r="5" fill="#000" stroke="none"/>
                        <ellipse cx="50" cy="50" rx="45" ry="15" />
                        <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(60 50 50)" />
                        <ellipse cx="50" cy="50" rx="45" ry="15" transform="rotate(120 50 50)" />
                    </svg>
                </div>
            </div>

            <!-- Main Scorecard Grid -->
            @{
                int tableWidth = 40 + 250 + 45 + (TotalColumns * 90);
            }
            <table class="scorecard-grid" style="width: 100%; min-width: @(tableWidth)px;">
                <colgroup>
                    <col style="width: 40px;" />
                    <col style="width: auto;" />
                    <col style="width: 45px;" />
                    @for (int i = 1; i <= TotalColumns; i++)
                    {
                        <col style="width: 90px;" />
                    }
                </colgroup>
                <thead>
                    <tr>
                        <th class="pos-col fs-5" style="border-top: none;"></th>
                        <th class="player-col fs-5 text-start ps-2" style="border-top: none;">Player</th>
                        <th class="hr-col" style="border-top: none;">HRs</th>
                        @for (int i = 1; i <= TotalColumns; i++)
                        {
                            <th class="inning-col fs-4" style="border-top: none;">@(columnInnings.ContainsKey(i) ? columnInnings[i].ToString() : "")</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int row = 1; row <= TotalBatters; row++)
                    {
                        int batterIndex = row;
                        int? playerId = GetPlayerIdForBattingOrder(batterIndex);
                        
                        <tr>
                            <td class="player-num">
                                <div>@batterIndex</div>
                            </td>
                            <td class="player-name">
                                <div>@(playerId.HasValue ? GetPlayerName(playerId.Value) : "")</div>
                            </td>
                            <td class="hr-cell text-center align-middle fw-bold fs-5">
                                @(playerId.HasValue ? GetPlayerTotalHR(playerId.Value) : "")
                            </td>
                            
                            @for (int col = 1; col <= TotalColumns; col++)
                            {
                                int currentColumn = col;
                                PlateAppearance? pa = null;
                                if (playerId.HasValue && paMatrix.ContainsKey((playerId.Value, currentColumn)))
                                {
                                    pa = paMatrix[(playerId.Value, currentColumn)];
                                }
                                
                                bool isThirdOut = pa != null && (pa.OutsBefore + pa.OutsRecorded) >= 3;
                                bool isPreviousThirdOut = false;
                                if (currentColumn > 1)
                                {
                                    PlateAppearance? prevPa = null;
                                    if (playerId.HasValue && paMatrix.ContainsKey((playerId.Value, currentColumn - 1)))
                                    {
                                        prevPa = paMatrix[(playerId.Value, currentColumn - 1)];
                                    }
                                    isPreviousThirdOut = prevPa != null && (prevPa.OutsBefore + prevPa.OutsRecorded) >= 3;
                                }

                                <td class="pa-cell @(pa != null && canManageGames ? "pa-clickable" : "")" @onclick="() => HandleCellClick(pa)">
                                    <div class="pa-cell-content">
                                        @if (pa != null)
                                        {
                                            var pathStatus = GetBasePathStatus(pa);
                                            int furthest = pathStatus.Furthest;
                                            bool gotOut = pathStatus.GotOut;
                                            string result = pa.Result;
                                            
                                            <div class="pa-top-labels">
                                                <span class="circleable @(result == "1B" ? "circled" : "")">1B</span>
                                                <span class="circleable @(result == "2B" ? "circled" : "")">2B</span>
                                                <span class="circleable @(result == "3B" ? "circled" : "")">3B</span>
                                                <span class="circleable @(result == "HR" ? "circled" : "")">HR</span>
                                            </div>
                                            
                                            <div class="pa-right-labels">
                                                @if (result == "FC") { <span class="circleable circled">FC</span> }
                                                @if (result == "IPHR") { <span class="circleable-wide circled">IPHR</span> }
                                            </div>

                                            <div class="pa-left-labels">
                                                @if (result == "GO") { <span class="circleable circled">GO</span> }
                                                @if (result == "FO") { <span class="circleable circled">FO</span> }
                                                @if (result == "SF") { <span class="circleable circled">SF</span> }
                                            </div>
                                            
                                            @if (result != "Skip")
                                            {
                                                <svg viewBox="0 0 100 100" class="pa-diamond">
                                                    @if (result == "GO" || result == "FO" || result == "K" || result == "KF" || result == "SF")
                                                    {
                                                        <line x1="5" y1="5" x2="95" y2="95" stroke="#000" stroke-width="6" />
                                                        <line x1="95" y1="5" x2="5" y2="95" stroke="#000" stroke-width="6" />
                                                    }
                                                    
                                                    <polygon points="50,90 90,50 50,10 10,50" fill="none" stroke="#000" stroke-width="1" stroke-dasharray="2 2" />
                                                    @if (furthest >= 1) { <line x1="50" y1="90" x2="90" y2="50" stroke="#000" stroke-width="5" /> }
                                                    @if (furthest >= 2) { <line x1="90" y1="50" x2="50" y2="10" stroke="#000" stroke-width="5" /> }
                                                    @if (furthest >= 3) { <line x1="50" y1="10" x2="10" y2="50" stroke="#000" stroke-width="5" /> }
                                                    @if (furthest >= 4) { 
                                                        <line x1="10" y1="50" x2="50" y2="90" stroke="#000" stroke-width="5" /> 
                                                        <polygon points="50,90 90,50 50,10 10,50" fill="#666" stroke="#000" stroke-width="5" />
                                                    }
                                                    
                                                    @if (gotOut) {
                                                        @if (furthest == 1) { 
                                                            <line x1="90" y1="50" x2="70" y2="30" stroke="#000" stroke-width="5" /> 
                                                            <line x1="60" y1="20" x2="80" y2="40" stroke="#000" stroke-width="4" />
                                                            <line x1="80" y1="20" x2="60" y2="40" stroke="#000" stroke-width="4" />
                                                        }
                                                        else if (furthest == 2) { 
                                                            <line x1="50" y1="10" x2="30" y2="30" stroke="#000" stroke-width="5" /> 
                                                            <line x1="20" y1="20" x2="40" y2="40" stroke="#000" stroke-width="4" />
                                                            <line x1="40" y1="20" x2="20" y2="40" stroke="#000" stroke-width="4" />
                                                        }
                                                        else if (furthest == 3) { 
                                                            <line x1="10" y1="50" x2="30" y2="70" stroke="#000" stroke-width="5" /> 
                                                            <line x1="20" y1="60" x2="40" y2="80" stroke="#000" stroke-width="4" />
                                                            <line x1="40" y1="60" x2="20" y2="80" stroke="#000" stroke-width="4" />
                                                        }
                                                        else if (furthest == 0) {
                                                            <line x1="50" y1="90" x2="70" y2="70" stroke="#000" stroke-width="5" />
                                                            <line x1="60" y1="60" x2="80" y2="80" stroke="#000" stroke-width="4" />
                                                            <line x1="80" y1="60" x2="60" y2="80" stroke="#000" stroke-width="4" />
                                                        }
                                                    }
                                                </svg>
                                            }
                                            
                                            <div class="pa-bottom-labels align-items-center">
                                                <span class="circleable @(result == "K" || result == "KF" ? "circled" : "")">@(result == "KF" ? "KF" : "K")</span>
                                                @if (pa.RunsScored > 0)
                                                {
                                                    <span style="font-size: 10px; font-weight: bold; white-space: nowrap; line-height: 1.3;">@(pa.RunsScored) RBI</span>
                                                }
                                                else
                                                {
                                                    <span style="visibility: hidden; font-size: 10px; font-weight: bold; white-space: nowrap; line-height: 1.3;">0 RBI</span>
                                                }
                                                <span class="circleable @(result == "BB" ? "circled" : "")">BB</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Blank cell template -->
                                            <div class="pa-top-labels">
                                                <span class="circleable">1B</span> 
                                                <span class="circleable">2B</span> 
                                                <span class="circleable">3B</span> 
                                                <span class="circleable">HR</span>
                                            </div>
                                            <div class="pa-right-labels">
                                            </div>
                                            <svg viewBox="0 0 100 100" class="pa-diamond">
                                                <polygon points="50,90 90,50 50,10 10,50" fill="none" stroke="#000" stroke-width="1" stroke-dasharray="2 2" />
                                            </svg>
                                            <div class="pa-bottom-labels align-items-end">
                                                <span class="circleable">K</span>
                                                <span class="circleable">BB</span>
                                            </div>
                                        }
                                        @if (isThirdOut || isPreviousThirdOut || (pa != null && pa.Result == "Skip"))
                                        {
                                            <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10;" viewBox="0 0 100 100" preserveAspectRatio="none">
                                                @if (pa != null && pa.Result == "Skip")
                                                {
                                                    <line x1="0" y1="50" x2="100" y2="50" stroke="#000" stroke-width="4" />
                                                }
                                                @if (isThirdOut)
                                                {
                                                    <line x1="0" y1="98" x2="100" y2="98" stroke="#000" stroke-width="5" />
                                                }
                                                @if (isPreviousThirdOut)
                                                {
                                                    <line x1="0" y1="100" x2="20" y2="80" stroke="#000" stroke-width="5" stroke-linecap="round" />
                                                }
                                            </svg>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                    
                    <!-- Runs Row -->
                    <tr class="runs-row" style="height: 50px;">
                        <td colspan="3" class="text-end fw-bold fs-4 pe-2 align-middle border-bottom-0 border-start-0 border-end-0">Runs</td>
                        @for (int col = 1; col <= TotalColumns; col++)
                        {
                            <td class="p-0 m-0" style="position: relative; height: 50px;">
                                <svg viewBox="0 0 100 100" preserveAspectRatio="none" style="position: absolute; top:0; left:0; width:100%; height:100%; z-index: 0;">
                                    <line x1="100" y1="0" x2="0" y2="100" stroke="#000" stroke-width="1.5" />
                                </svg>
                                <div class="position-absolute" style="top: 2px; left: 8px; z-index: 1;">
                                    <span class="fw-bold fs-5">@GetRunsInColumn(col)</span>
                                </div>
                                <div class="position-absolute" style="bottom: 2px; right: 8px; z-index: 1;">
                                    <span class="fw-bold fs-5">@GetCumulativeRuns(col)</span>
                                </div>
                            </td>
                        }
                    </tr>
                    
                    <!-- Opponent Runs Row -->
                    <tr class="runs-row" style="height: 50px;">
                        <td colspan="3" class="text-end fw-bold fs-4 pe-2 align-middle border-start-0 border-end-0">Opponent</td>
                        @for (int col = 1; col <= TotalColumns; col++)
                        {
                            int currentColumn = col;
                            <td class="p-0 m-0" style="position: relative; height: 50px;">
                                @if (canManageGames)
                                {
                                    <svg viewBox="0 0 100 100" preserveAspectRatio="none" style="position: absolute; top:0; left:0; width:100%; height:100%; z-index: 0; pointer-events: none;">
                                        <line x1="100" y1="0" x2="0" y2="100" stroke="#000" stroke-width="1.5" />
                                    </svg>
                                    <div class="position-absolute" style="top: 0px; left: 2px; z-index: 1; width: 45px;">
                                        <input type="number" min="0" max="99"
                                               class="form-control text-start fw-bold fs-5 p-0 m-0 no-print" 
                                               style="background: transparent; box-shadow: none; border: none; height: 26px;"
                                               value="@GetOpponentScoreForColumn(currentColumn)"
                                               @onchange="@(e => UpdateOpponentScoreForColumn(currentColumn, e.Value))" />
                                        <div class="d-none d-print-block fw-bold fs-5" style="margin-left: 6px; margin-top: 2px;">
                                            @GetOpponentScoreForColumn(currentColumn)
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <svg viewBox="0 0 100 100" preserveAspectRatio="none" style="position: absolute; top:0; left:0; width:100%; height:100%; z-index: 0; pointer-events: none;">
                                        <line x1="100" y1="0" x2="0" y2="100" stroke="#000" stroke-width="1.5" />
                                    </svg>
                                    <div class="position-absolute" style="top: 2px; left: 8px; z-index: 1;">
                                        <span class="fw-bold fs-5">@GetOpponentScoreForColumn(currentColumn)</span>
                                    </div>
                                }
                                <div class="position-absolute" style="bottom: 2px; right: 8px; z-index: 1; pointer-events: none;">
                                    <span class="fw-bold fs-5">@GetCumulativeOpponentRuns(currentColumn)</span>
                                </div>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
        </div>
    </div>
}

@if (isSyncModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Reconcile Game Stats</h5>
                    <button type="button" class="btn-close" @onclick="CloseSyncModal"></button>
                </div>
                <div class="modal-body">
                    <p>The following players have discrepancies between the official game stats and the stats calculated from the plate appearances recorded in the scorekeeper.</p>
                    <table class="table table-bordered table-sm text-center">
                        <thead class="table-light">
                            <tr>
                                <th>Player</th>
                                <th>Source</th>
                                <th>1B</th><th>2B</th><th>3B</th><th>IPHR</th><th>HR</th><th>BB</th><th>K</th><th>KF</th><th>R</th><th>RBI</th><th>FC</th><th>SF</th><th>GO</th><th>FO</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mismatch in mismatchedPlayers)
                            {
                                var existing = gameStats.FirstOrDefault(s => s.PlayerId == mismatch.PlayerId) ?? new StatEntry();
                                var calc = calculatedStats.FirstOrDefault(s => s.PlayerId == mismatch.PlayerId) ?? new StatEntry();
                                
                                <tr>
                                    <td rowspan="2" class="align-middle fw-bold text-start">@GetPlayerName(mismatch.PlayerId)</td>
                                    <td class="text-start">Calculated</td>
                                    <td class="@(existing.H1B != calc.H1B ? "text-danger fw-bold" : "")">@calc.H1B</td>
                                    <td class="@(existing.H2B != calc.H2B ? "text-danger fw-bold" : "")">@calc.H2B</td>
                                    <td class="@(existing.H3B != calc.H3B ? "text-danger fw-bold" : "")">@calc.H3B</td>
                                    <td class="@(existing.IPHR != calc.IPHR ? "text-danger fw-bold" : "")">@calc.IPHR</td>
                                    <td class="@(existing.HR != calc.HR ? "text-danger fw-bold" : "")">@calc.HR</td>
                                    <td class="@(existing.BB != calc.BB ? "text-danger fw-bold" : "")">@calc.BB</td>
                                    <td class="@(existing.K != calc.K ? "text-danger fw-bold" : "")">@calc.K</td>
                                    <td class="@(existing.KF != calc.KF ? "text-danger fw-bold" : "")">@calc.KF</td>
                                    <td class="@(existing.R != calc.R ? "text-danger fw-bold" : "")">@calc.R</td>
                                    <td class="@(existing.RBI != calc.RBI ? "text-danger fw-bold" : "")">@calc.RBI</td>
                                    <td class="@(existing.FC != calc.FC ? "text-danger fw-bold" : "")">@calc.FC</td>
                                    <td class="@(existing.SF != calc.SF ? "text-danger fw-bold" : "")">@calc.SF</td>
                                    <td class="@(existing.GO != calc.GO ? "text-danger fw-bold" : "")">@calc.GO</td>
                                    <td class="@(existing.FO != calc.FO ? "text-danger fw-bold" : "")">@calc.FO</td>
                                </tr>
                                <tr>
                                    <td class="text-start">Existing</td>
                                    <td>@existing.H1B</td>
                                    <td>@existing.H2B</td>
                                    <td>@existing.H3B</td>
                                    <td>@existing.IPHR</td>
                                    <td>@existing.HR</td>
                                    <td>@existing.BB</td>
                                    <td>@existing.K</td>
                                    <td>@existing.KF</td>
                                    <td>@existing.R</td>
                                    <td>@existing.RBI</td>
                                    <td>@existing.FC</td>
                                    <td>@existing.SF</td>
                                    <td>@existing.GO</td>
                                    <td>@existing.FO</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="alert alert-info mt-3 mb-0">
                        <strong>Note:</strong> Clicking "Sync Calculated Stats" will permanently overwrite the official box score stats for all players in this game with the calculated values above.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseSyncModal">Cancel</button>
                    <button type="button" class="btn fw-bold text-dark" style="background-color: var(--isotopes-accent);" @onclick="SyncAllStats">Sync Calculated Stats</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .scorecard-wrapper {
        width: 100%;
        overflow-x: auto;
        text-align: center;
        padding-bottom: 2rem;
    }
    .scorecard-container {
        display: inline-block;
        background: #fff;
        color: #000;
        border: 4px solid #000;
        margin: 0 auto;
        text-align: left;
    }
    @@media (min-width: 1024px) {
        .scorecard-container {
            display: block;
            width: 100%;
        }
    }
    .header-table td {
        padding: 5px 0;
        line-height: 1.2;
    }
    .scorecard-grid {
        table-layout: fixed;
        border-collapse: collapse;
        border-top: 4px solid #000;
    }
    .scorecard-grid th, .scorecard-grid td {
        border: 2px solid #000;
        background-color: transparent !important;
    }
    .scorecard-grid th {
        text-align: center;
        padding: 5px;
        font-weight: bold;
        border-bottom: 4px solid #000;
        color: #000 !important;
    }
    .pos-col { width: 40px; min-width: 40px; }
    .player-col { min-width: 250px; }
    .hr-col { width: 45px; min-width: 45px; border-right: 4px solid #000 !important; }
    .inning-col { width: 90px; min-width: 90px; }
    
    .player-num {
        text-align: center;
        font-weight: bold;
        font-size: 1.75rem;
        padding: 0;
    }
    .player-name {
        font-weight: bold;
        font-size: 1.75rem;
        text-transform: uppercase;
        padding-left: 5px;
    }
    
    .pa-cell {
        height: 90px;
        padding: 0;
        vertical-align: top;
    }
    .pa-clickable {
        cursor: pointer;
    }
    .pa-cell-content {
        position: relative;
        width: 100%;
        height: 90px;
        padding: 2px;
        overflow: hidden;
    }
    
    .pa-top-labels {
        font-size: 10px;
        display: flex;
        justify-content: space-around;
        position: absolute;
        top: 2px;
        width: 100%;
        left: 0;
        font-family: monospace;
    }
    
    .pa-right-labels {
        font-size: 10px;
        position: absolute;
        right: 2px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 2px;
        font-family: monospace;
    }
    
    .pa-bottom-labels {
        font-size: 10px;
        display: flex;
        justify-content: space-between;
        position: absolute;
