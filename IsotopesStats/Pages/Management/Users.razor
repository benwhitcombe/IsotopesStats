@page "/management/users"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@attribute [Authorize(Policy = "ManageUsers")]
@inject AuthService AuthService
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Manage Users</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">User Management</h3>
    @if (!isAdding)
    {
        <button class="view-btn active" @onclick="() => isAdding = true">Add New User</button>
    }
</div>

@if (isAdding)
{
    <div class="stat-card view-fade-in" style="margin-bottom: 2rem;">
        <h4 style="margin-top:0">Add User</h4>
        <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control" @bind="newUserEmail" placeholder="user@isotopes.com" autocomplete="off" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <div style="position: relative;">
                <input type="@(showNewUserPassword ? "text" : "password")" class="form-control" @bind="newUserPassword" placeholder="••••••••" autocomplete="new-password" style="padding-right: 3rem;" />
                <button type="button" @onclick="() => showNewUserPassword = !showNewUserPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #888; display: flex; align-items: center; justify-content: center;">
                    <PasswordToggleIcon IsVisible="@showNewUserPassword" />
                </button>
            </div>
        </div>
        <div class="form-group">
            <label>Role</label>
            <select class="form-control" @bind="newUserRoleId">
                <option value="0">-- Select Role --</option>
                @foreach (UserRole role in availableRoles)
                {
                    <option value="@role.Id">@role.Name</option>
                }
            </select>
        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                @errorMessage
            </div>
        }

        <div style="display: flex; gap: 1rem; margin-top: 1rem;">
            <button class="view-btn active" @onclick="AddUser">Create User</button>
            <button class="view-btn" @onclick="() => isAdding = false">Cancel</button>
        </div>
    </div>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Email</th>
                            <th>Role</th>
                            <th style="text-align: left;">Created</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (User user in users)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@user.Email</td>
                                <td>
                                    <span class="badge @GetRoleBadgeClass(user.Role?.Name)" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                        @(user.Role?.Name ?? "Unknown")
                                    </span>
                                </td>
                                <td style="text-align: left;">@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => ShowDeleteConfirm(user.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (User user in users)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name">@user.Email</div>
                        <span class="badge @GetRoleBadgeClass(user.Role?.Name)" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">
                            @(user.Role?.Name ?? "Unknown")
                        </span>
                    </div>
                    <div style="margin-bottom: 1rem; color: #666; font-size: 0.9rem;">
                        <strong>Created:</strong> @user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                    <div style="text-align: right;">
                        <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red); width: 100%;" @onclick="() => ShowDeleteConfirm(user.Id)">Delete User</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<ConfirmDialog 
    IsVisible="showConfirm" 
    Title="Delete User" 
    Message="Are you sure you want to delete this user? They will no longer be able to log in."
    OnConfirm="DeleteUser"
    OnCancel="() => showConfirm = false" />

@code {
    private List<User> users = new();
    private List<UserRole> availableRoles = new();
    private bool isAdding = false;
    private string newUserEmail = "";
    private string newUserPassword = "";
    private bool showNewUserPassword = false;
    private int newUserRoleId = 0;
    private string errorMessage = "";
    private bool showConfirm = false;
    private int userIdToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        users = await AuthService.GetUsersAsync();
        availableRoles = await AuthService.GetUserRolesAsync(true);
    }

    private string GetRoleBadgeClass(string? roleName) => roleName switch
    {
        "Administrator" => "bg-dark",
        "Team Rep" => "bg-primary",
        "Scorekeeper" => "bg-warning",
        "Player" => "bg-info",
        _ => "bg-secondary"
    };

    private async Task AddUser()
    {
        errorMessage = "";
        if (string.IsNullOrEmpty(newUserEmail) || string.IsNullOrEmpty(newUserPassword) || newUserRoleId == 0)
        {
            errorMessage = "Email, password, and role are required.";
            return;
        }

        bool result = await AuthService.RegisterAsync(newUserEmail, newUserPassword, newUserRoleId);
        if (result)
        {
            isAdding = false;
            newUserEmail = "";
            newUserPassword = "";
            newUserRoleId = 0;
            await LoadData();
        }
        else
        {
            errorMessage = "Error creating user. Email might already exist.";
        }
    }

    private void ShowDeleteConfirm(int id)
    {
        userIdToDelete = id;
        showConfirm = true;
    }

    private async Task DeleteUser()
    {
        showConfirm = false;
        await AuthService.DeleteUserAsync(userIdToDelete);
        await LoadData();
    }
}
