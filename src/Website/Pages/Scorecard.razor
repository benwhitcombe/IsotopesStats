@code {
    [Parameter]
    public int GameId { get; set; }

    private bool isLoading = true;
    private Game? game;
    private List<Player> roster = new();
    private List<Opponent> opponents = new();
    private List<StatEntry> gameStats = new();
    private List<PlateAppearance> plateAppearances = new();
    private List<StatEntry> calculatedStats = new();
    private List<StatEntry> mismatchedPlayers = new();
    private bool isOutOfSync = false;
    private bool isSyncModalVisible = false;
    private bool zoomInitialized = false;
    
    private string opponentName = "Unknown";
    
    private int TotalBatters => Math.Max(15, gameStats.Count > 0 ? gameStats.Max(s => s.BO) : 0);
    private int TotalColumns = 10;
    private Dictionary<(int PlayerId, int ColumnIndex), PlateAppearance> paMatrix = new();
    private Dictionary<int, int> columnInnings = new();
    private bool canManageGames = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "Manage Games");
        canManageGames = authResult.Succeeded;

        try
        {
            game = await StatsRepository.GetGameAsync(GameId);
            if (game != null)
            {
                roster = await StatsRepository.GetPlayersAsync(game.SeasonId);
                opponents = await StatsRepository.GetOpponentsAsync(game.SeasonId);
                
                Opponent? opp = opponents.FirstOrDefault(o => o.Id == game.OpponentId);
                if (opp != null) opponentName = opp.Name;
                
                gameStats = await StatsRepository.GetGameStatsAsync(GameId);
                plateAppearances = await StatsRepository.GetPlateAppearancesAsync(GameId);
                calculatedStats = await StatsRepository.CalculateStatsFromPlateAppearancesAsync(GameId);
                BuildScorecardGrid();
                CalculateDifferences();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private int? GetPlayerIdForBattingOrder(int bo)
    {
        return gameStats.FirstOrDefault(s => s.BO == bo)?.PlayerId;
    }

    private string GetPlayerName(int id)
    {
        return roster.FirstOrDefault(p => p.Id == id)?.Name ?? "Unknown";
    }
    
    private string GetPlayerTotalHR(int playerId)
    {
        int hrs = plateAppearances.Count(pa => pa.PlayerId == playerId && (pa.Result == "HR" || pa.Result == "IPHR"));
        return hrs > 0 ? hrs.ToString() : "";
    }

    private void BuildScorecardGrid()
    {
        paMatrix.Clear();
        columnInnings.Clear();
        
        int currentColumnIndex = 1;
        int currentInning = 1;
        columnInnings[currentColumnIndex] = currentInning;
        HashSet<int> playersInCurrentColumn = new HashSet<int>();
        
        var sortedPAs = plateAppearances.OrderBy(p => p.OrderNumber).ToList();
        
        foreach (var pa in sortedPAs)
        {
            while (currentInning < pa.Inning)
            {
                currentColumnIndex++;
                currentInning++;
                columnInnings[currentColumnIndex] = currentInning;
                playersInCurrentColumn.Clear();
            }
            
            if (playersInCurrentColumn.Contains(pa.PlayerId))
            {
                currentColumnIndex++;
                columnInnings[currentColumnIndex] = currentInning;
                playersInCurrentColumn.Clear();
            }
            
            playersInCurrentColumn.Add(pa.PlayerId);
            paMatrix[(pa.PlayerId, currentColumnIndex)] = pa;
        }
        
        TotalColumns = Math.Max(10, currentColumnIndex);
        
        for (int c = currentColumnIndex + 1; c <= TotalColumns; c++)
        {
            currentInning++;
            columnInnings[c] = currentInning;
        }
    }

    private (int Furthest, bool GotOut) GetBasePathStatus(PlateAppearance initialPa)
    {
        int batterId = initialPa.PlayerId;
        int furthest = 0;
        bool gotOut = false;
        
        if (initialPa.Result == "1B" || initialPa.Result == "BB" || initialPa.Result == "FC") furthest = 1;
        else if (initialPa.Result == "2B") furthest = 2;
        else if (initialPa.Result == "3B") furthest = 3;
        else if (initialPa.Result == "HR" || initialPa.Result == "IPHR") return (4, false);
        
        var subsequentPAs = plateAppearances
            .Where(p => p.Inning == initialPa.Inning && p.OrderNumber > initialPa.OrderNumber)
            .OrderBy(p => p.OrderNumber)
            .ToList();
            
        foreach (var pa in subsequentPAs)
        {
            if (pa.RunnerOn1B_End == batterId) furthest = Math.Max(furthest, 1);
            if (pa.RunnerOn2B_End == batterId) furthest = Math.Max(furthest, 2);
            if (pa.RunnerOn3B_End == batterId) furthest = Math.Max(furthest, 3);
            
            List<int> runnersBefore = new List<int>();
            if (pa.RunnerOn3B.HasValue) runnersBefore.Add(pa.RunnerOn3B.Value);
            if (pa.RunnerOn2B.HasValue) runnersBefore.Add(pa.RunnerOn2B.Value);
            if (pa.RunnerOn1B.HasValue) runnersBefore.Add(pa.RunnerOn1B.Value);
            
            if (runnersBefore.Contains(batterId))
            {
                HashSet<int> runnersAfter = new HashSet<int>();
                if (pa.RunnerOn3B_End.HasValue) runnersAfter.Add(pa.RunnerOn3B_End.Value);
                if (pa.RunnerOn2B_End.HasValue) runnersAfter.Add(pa.RunnerOn2B_End.Value);
                if (pa.RunnerOn1B_End.HasValue) runnersAfter.Add(pa.RunnerOn1B_End.Value);
                
                if (!runnersAfter.Contains(batterId))
                {
                    int baseRuns = pa.RunsScored - ((pa.Result == "HR" || pa.Result == "IPHR") ? 1 : 0);
                    bool scored = false;
                    if (baseRuns > 0)
                    {
                        List<int> leftBases = runnersBefore.Where(r => !runnersAfter.Contains(r)).ToList();
                        int index = leftBases.IndexOf(batterId);
                        if (index >= 0 && index < baseRuns)
                        {
                            scored = true;
                            furthest = 4;
                        }
                    }
                    
                    if (!scored)
                    {
                        gotOut = true;
                        break;
                    }
                }
            }
        }
        
        return (furthest, gotOut);
    }
    
    private string GetRunsInColumn(int colIndex)
    {
        int runs = paMatrix.Where(kvp => kvp.Key.ColumnIndex == colIndex).Sum(kvp => kvp.Value.RunsScored);
        bool hasAnyInCol = paMatrix.Any(kvp => kvp.Key.ColumnIndex == colIndex);
        return hasAnyInCol ? runs.ToString() : "";
    }
    
    private string GetCumulativeRuns(int colIndex)
    {
        bool hasAnyInCol = paMatrix.Any(kvp => kvp.Key.ColumnIndex == colIndex);
        if (!hasAnyInCol) return "";
        int total = paMatrix.Where(kvp => kvp.Key.ColumnIndex <= colIndex).Sum(kvp => kvp.Value.RunsScored);
        return total.ToString();
    }
    
    private string GetOpponentScoreForColumn(int colIndex)
    {
        if (game == null) return "";
        var scores = game.GetOpponentInningScores();
        return scores.ContainsKey(colIndex) ? scores[colIndex].ToString() : "";
    }
    
    private string GetCumulativeOpponentRuns(int colIndex)
    {
        if (game == null) return "";
        var scores = game.GetOpponentInningScores();
        if (!scores.ContainsKey(colIndex)) return "";
        
        int total = scores.Where(kvp => kvp.Key <= colIndex).Sum(kvp => kvp.Value);
        return total.ToString();
    }
    
    private async Task UpdateOpponentScoreForColumn(int colIndex, object? value)
    {
        if (game == null) return;
        
        var scores = game.GetOpponentInningScores();
        if (value != null && int.TryParse(value.ToString(), out int score))
        {
            scores[colIndex] = score;
        }
        else
        {
            scores.Remove(colIndex);
        }
        
        game.SetOpponentInningScores(scores);
        game.VisitingTeamScore = game.IsHome ? scores.Values.Sum() : game.VisitingTeamScore;
        game.HomeTeamScore = game.IsHome ? game.HomeTeamScore : scores.Values.Sum();
        
        await StatsRepository.UpdateGameAsync(game);
    }
    
    private void HandleCellClick(PlateAppearance? pa)
    {
        if (pa != null && canManageGames)
        {
            int index = plateAppearances.OrderBy(p => p.Id).ToList().IndexOf(pa);
            if (index >= 0)
            {
                NavigationManager.NavigateTo($"/management/games/{GameId}/scorekeeping?paIndex={index}");
            }
            else
            {
                NavigationManager.NavigateTo($"/management/games/{GameId}/scorekeeping");
            }
        }
    }

    private void CalculateDifferences()
    {
        mismatchedPlayers.Clear();
        foreach (var calc in calculatedStats)
        {
            var existing = gameStats.FirstOrDefault(s => s.PlayerId == calc.PlayerId);
            if (existing == null || 
                existing.H1B != calc.H1B || existing.H2B != calc.H2B || 
                existing.H3B != calc.H3B || existing.IPHR != calc.IPHR || existing.HR != calc.HR ||
                existing.BB != calc.BB || existing.K != calc.K || existing.KF != calc.KF ||
                existing.R != calc.R || existing.RBI != calc.RBI ||
                existing.FO != calc.FO || existing.GO != calc.GO ||
                existing.FC != calc.FC || existing.SF != calc.SF)
            {
                mismatchedPlayers.Add(calc);
            }
        }
        foreach (var existing in gameStats)
        {
            if (!calculatedStats.Any(s => s.PlayerId == existing.PlayerId))
            {
                mismatchedPlayers.Add(new StatEntry { PlayerId = existing.PlayerId, BO = existing.BO });
            }
        }
        isOutOfSync = mismatchedPlayers.Count > 0;
    }

    private void OpenSyncModal() => isSyncModalVisible = true;
    private void CloseSyncModal() => isSyncModalVisible = false;

    private async Task SyncAllStats()
    {
        await StatsRepository.SyncGameStatsFromPlateAppearancesAsync(GameId);
        gameStats = await StatsRepository.GetGameStatsAsync(GameId);
        CalculateDifferences();
        BuildScorecardGrid();
        CloseSyncModal();
        StateHasChanged();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !zoomInitialized)
        {
            zoomInitialized = true;
            try
            {
                var module = await JS.InvokeAsync<IJSObjectReference>("import", $"./js/scorecard-zoom.js?v={Guid.NewGuid()}");
                await module.InvokeVoidAsync("init", "scorecard-zoom-container");
            }
            catch (Exception ex)
            {
                // Ignore JS errors if panning isn't loaded or prerendering
                Console.WriteLine(ex.Message);
            }
        }
    }
}
