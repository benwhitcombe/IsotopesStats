@using IsotopesStats.Domain.Models

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-dark">
                <div class="modal-header">
                    <h5 class="modal-title">Where did @RunnerName go?</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <p class="fs-5 mb-4">Starting from <strong>@GetBaseName(CurrentBase)</strong></p>
                    
                    <div class="d-flex flex-column gap-3">
                        @foreach (var dest in GetOrderedDestinations())
                        {
                            <button class="@GetButtonClass(dest)" @onclick="() => SelectDestination(dest)">@GetDestinationLabel(dest)</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public int CurrentBase { get; set; } // 0 for Batter, 1 for 1B, 2 for 2B, 3 for 3B
    [Parameter] public string RunnerName { get; set; } = "the runner";
    [Parameter] public int MinBase { get; set; } = 1;
    [Parameter] public int MaxBase { get; set; } = 4;
    [Parameter] public int TopOption { get; set; } = -1;
    [Parameter] public EventCallback<int> OnDestinationSelected { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string GetBaseName(int b) => b switch
    {
        0 => "Home Plate",
        1 => "1st",
        2 => "2nd",
        3 => "3rd",
        _ => "Base"
    };

    private string GetDestinationLabel(int dest) => dest switch
    {
        -1 => "Out at 1st",
        -2 => "Out at 2nd",
        -3 => "Out at 3rd",
        -4 => "Out at Home",
        1 => CurrentBase == 1 ? "Stayed on 1st" : "1st Base",
        2 => CurrentBase == 2 ? "Stayed on 2nd" : "2nd Base",
        3 => CurrentBase == 3 ? "Stayed on 3rd" : "3rd Base",
        4 => "Home (Scores!)",
        _ => "Stayed"
    };

    private string GetButtonClass(int dest)
    {
        if (dest < 0) return "btn btn-outline-danger btn-lg";
        if (dest == 4) return "btn btn-outline-success btn-lg";
        if (dest == CurrentBase && dest != 0) return "btn btn-outline-secondary btn-lg";
        return "btn btn-outline-primary btn-lg";
    }

    private List<int> GetOrderedDestinations()
    {
        var options = new List<int>();
        
        // 1. Advancing bases
        for (int i = CurrentBase + 1; i <= MaxBase; i++)
        {
            if (i >= MinBase) options.Add(i);
        }
        
        // 2. Out options (starting from CurrentBase up to MaxBase)
        int minOutBase = Math.Max(1, CurrentBase); // 1st base minimum
        // If they are on a base, they can be picked off at their current base
        for (int i = minOutBase; i <= MaxBase; i++)
        {
            options.Add(-i);
        }
        
        // 3. Stayed on current base (if valid and not the batter)
        if (CurrentBase >= MinBase && CurrentBase <= MaxBase && CurrentBase != 0)
        {
            options.Add(CurrentBase);
        }
        
        // 4. Move preferred option to the top
        if (options.Contains(TopOption))
        {
            options.Remove(TopOption);
            options.Insert(0, TopOption);
        }
        
        return options;
    }

    private async Task SelectDestination(int destinationBase)
    {
        await OnDestinationSelected.InvokeAsync(destinationBase);
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}
