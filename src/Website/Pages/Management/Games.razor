@page "/management/games"
@page "/management/games/{Action}"
@page "/management/games/{Action}/{Id:int}"
@using IsotopesStats.Website.Services
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Shared
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Policy = "Manage Games")]
@inject IStatsRepository StatsRepository
@inject IAuthRepository AuthSvc
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject SessionStorageService SessionStorage

<PageTitle>Isotopes - Manage Games</PageTitle>

<DeleteManager TItem="Game" TId="int" @ref="deleteManager" OnDeleted="LoadGames" DeleteAction="StatsRepository.DeleteGameAsync" />

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Games</h3>
    @if (!isLoading && !isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Game</button>
    }
</div>

@if (isLoading)
{
    <LoadingIndicator />
}
else if (isEditing)
{
    <ModelEditor 
        TItem="Game"
        @ref="modelEditor"
        Title="@($"{(editingGame.Id == 0 ? "Add New" : "Edit")} Game")"
        Item="editingGame"
        OriginalItem="originalGame"
        BasePath="/management/games"
        DeleteWarning="This will delete all associated player stats from this game."
        OnSave="SaveGame"
        OnDelete="DeleteGame"
        ExtraState="playerStats"
        HasCustomChanges="@(() => !playerStats.SequenceEqual(originalStats))">

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">

            <div class="form-group">
                <label>Season</label>
                <InputSelect class="form-control" @bind-Value="editingGame.SeasonId" @bind-Value:after="OnEditingSeasonChanged">
                    @foreach (Season season in activeSeasons)
                    {
                        <option value="@season.Id">@season.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => editingGame.SeasonId)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
            <div class="form-group">
                <label>Date & Time</label>
                <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="editingGame.Date" />
                <ValidationMessage For="@(() => editingGame.Date)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
            <div class="form-group">
                <label>Opponent</label>
                <InputSelect class="form-control" @bind-Value="editingGame.OpponentId">
                    <option value="0">-- Select Opponent --</option>
                    @foreach (Opponent opponent in availableOpponents)
                    {
                        <option value="@opponent.Id">@opponent.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => editingGame.OpponentId)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
            <div class="form-group">
                <label>Game Number</label>
                <InputNumber class="form-control" @bind-Value="editingGame.GameNumber" />
                <ValidationMessage For="@(() => editingGame.GameNumber)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
            <div class="form-group">
                <label>Diamond</label>
                <InputText class="form-control" @bind-Value="editingGame.Diamond" placeholder="e.g. Diamond 1" />
                <ValidationMessage For="@(() => editingGame.Diamond)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>
            <div class="form-group" style="display: flex; align-items: flex-end; padding-bottom: 0.5rem;">
                <div class="form-check">
                    <InputCheckbox id="ishome" class="form-check-input" @bind-Value="editingGame.IsHome" />
                    <label class="form-check-label" for="ishome" style="font-weight: bold; margin-bottom: 0;">Home Game?</label>
                </div>
            </div>
            <div class="form-group">
                <label>Game Type</label>
                <InputSelect class="form-control" @bind-Value="editingGame.GameType">
                    @foreach (GameType type in Enum.GetValues<GameType>())
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
            </div>
            <div class="form-group">
                <label>@(editingGame.IsHome ? "Isotopes Score" : "Opponent Score")</label>
                <InputNumber class="form-control" @bind-Value="editingGame.HomeTeamScore" />
            </div>
            <div class="form-group">
                <label>@(!editingGame.IsHome ? "Isotopes Score" : "Opponent Score")</label>
                <InputNumber class="form-control" @bind-Value="editingGame.VisitingTeamScore" />
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 2rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Select Game Lineup</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.75rem; border-radius: 12px; border: 1px solid #eee;">
                @foreach (Player player in seasonRoster)
                {
                    <CheckboxButton 
                        Id="@($"gl-{player.Id}")" 
                        Text="@player.Name" 
                        Checked="@IsPlayerInLineup(player.Id)" 
                        CheckedChanged="@((bool val) => TogglePlayerInLineup(player, val))" />
                }
            </div>
        </div>

        <h5 style="margin-bottom: 1rem; color: var(--isotopes-accent);">Player Stats</h5>
        
        <div class="desktop-only">
            <div class="table-container" style="padding: 0; overflow: hidden;">
                <table class="table table-sm admin-stats-table" style="margin-bottom: 0;">
                    <thead>
                        <tr>
                            <th style="width: 200px; border-right: 2px solid #ddd;">Player</th>
                            <th title="@StatDefinitions.GetDefinition("PA")">PA</th>
                            <th title="@StatDefinitions.GetDefinition("AB")">AB</th>
                            <th style="border-right: 2px solid #ddd;" title="@StatDefinitions.GetDefinition("H")">H</th>
                            <th title="@StatDefinitions.GetDefinition("1B")">1B</th>
                            <th title="@StatDefinitions.GetDefinition("2B")">2B</th>
                            <th title="@StatDefinitions.GetDefinition("3B")">3B</th>
                            <th title="@StatDefinitions.GetDefinition("HR")">HR</th>
                            <th style="border-right: 2px solid #ddd;" title="@StatDefinitions.GetDefinition("IPHR")">IPHR</th>
                            <th title="@StatDefinitions.GetDefinition("BB")">BB</th>
                            <th title="@StatDefinitions.GetDefinition("K")">K</th>
                            <th style="border-right: 2px solid #ddd;" title="@StatDefinitions.GetDefinition("KF")">KF</th>
                            <th title="@StatDefinitions.GetDefinition("SF")">SF</th>
                            <th title="@StatDefinitions.GetDefinition("FC")">FC</th>
                            <th title="@StatDefinitions.GetDefinition("GO")">GO</th>
                            <th style="border-right: 2px solid #ddd;" title="@StatDefinitions.GetDefinition("FO")">FO</th>
                            <th title="@StatDefinitions.GetDefinition("R")">R</th>
                            <th title="@StatDefinitions.GetDefinition("RBI")">RBI</th>
                        </tr>
                    </thead>
                    <tbody @ondragover:preventdefault="true" @ondrop:preventdefault="true">
                        @for (int i = 0; i < playerStats.Count; i++)
                        {
                            StatEntry stat = playerStats[i];
                            int index = i;
                            bool paWarning = i > 0 && stat.PA > playerStats[i - 1].PA;

                            <tr @key="stat.PlayerId"
                                draggable="true" 
                                @ondragstart="() => HandleDragStart(stat)" 
                                @ondragover="() => HandleDragOver(stat)"
                                @ondragover:preventdefault="true"
                                @ondragenter:preventdefault="true"
                                @ondrop="() => HandleDrop(stat)"
                                class="reorderable-row @(stat == targetStat ? "drag-over" : "")">
                                <td class="player-col" style="border-right: 2px solid #ddd;">@(index + 1). @stat.PlayerName</td>
                                <td style="vertical-align: middle; font-weight: bold; background-color: @(paWarning ? "var(--isotopes-red)" : "transparent"); color: @(paWarning ? "white" : "#666");">@stat.PA</td>
                                <td style="vertical-align: middle; font-weight: bold; color: #666;">@stat.AB</td>
                                <td style="border-right: 2px solid #ddd; font-weight: bold; color: var(--isotopes-accent);">@stat.H</td>
                                <td class="@(activeColumnIndex == 1 ? "active-col" : "")"><input type="number" value="@stat.H1B" @oninput="(e) => HandleStatChange(stat, nameof(stat.H1B), e.Value)" @onfocus="() => activeColumnIndex = 1" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 2 ? "active-col" : "")"><input type="number" value="@stat.H2B" @oninput="(e) => HandleStatChange(stat, nameof(stat.H2B), e.Value)" @onfocus="() => activeColumnIndex = 2" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 3 ? "active-col" : "")"><input type="number" value="@stat.H3B" @oninput="(e) => HandleStatChange(stat, nameof(stat.H3B), e.Value)" @onfocus="() => activeColumnIndex = 3" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 4 ? "active-col" : "")"><input type="number" value="@stat.HR" @oninput="(e) => HandleStatChange(stat, nameof(stat.HR), e.Value)" @onfocus="() => activeColumnIndex = 4" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 5 ? "active-col" : "")" style="border-right: 2px solid #ddd;"><input type="number" value="@stat.IPHR" @oninput="(e) => HandleStatChange(stat, nameof(stat.IPHR), e.Value)" @onfocus="() => activeColumnIndex = 5" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 6 ? "active-col" : "")"><input type="number" value="@stat.BB" @oninput="(e) => HandleStatChange(stat, nameof(stat.BB), e.Value)" @onfocus="() => activeColumnIndex = 6" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 7 ? "active-col" : "")"><input type="number" value="@stat.K" @oninput="(e) => HandleStatChange(stat, nameof(stat.K), e.Value)" @onfocus="() => activeColumnIndex = 7" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 8 ? "active-col" : "")" style="border-right: 2px solid #ddd;"><input type="number" value="@stat.KF" @oninput="(e) => HandleStatChange(stat, nameof(stat.KF), e.Value)" @onfocus="() => activeColumnIndex = 8" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 9 ? "active-col" : "")"><input type="number" value="@stat.SF" @oninput="(e) => HandleStatChange(stat, nameof(stat.SF), e.Value)" @onfocus="() => activeColumnIndex = 9" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 10 ? "active-col" : "")"><input type="number" value="@stat.FC" @oninput="(e) => HandleStatChange(stat, nameof(stat.FC), e.Value)" @onfocus="() => activeColumnIndex = 10" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 11 ? "active-col" : "")"><input type="number" value="@stat.GO" @oninput="(e) => HandleStatChange(stat, nameof(stat.GO), e.Value)" @onfocus="() => activeColumnIndex = 11" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 12 ? "active-col" : "")" style="border-right: 2px solid #ddd;"><input type="number" value="@stat.FO" @oninput="(e) => HandleStatChange(stat, nameof(stat.FO), e.Value)" @onfocus="() => activeColumnIndex = 12" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" /></td>
                                <td class="@(activeColumnIndex == 13 ? "active-col" : "")"><input type="number" value="@stat.R" @oninput="(e) => HandleStatChange(stat, nameof(stat.R), e.Value)" @onfocus="() => activeColumnIndex = 13" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" style="color: var(--isotopes-red); font-weight: bold;" /></td>
                                <td class="@(activeColumnIndex == 14 ? "active-col" : "")"><input type="number" value="@stat.RBI" @oninput="(e) => HandleStatChange(stat, nameof(stat.RBI), e.Value)" @onfocus="() => activeColumnIndex = 14" @onblur="() => activeColumnIndex = null" class="form-control form-control-sm" style="color: var(--isotopes-red); font-weight: bold;" /></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background: #f8f9fa; font-weight: bold; border-top: 2px solid #ddd;">
                        <tr>
                            <td style="border-right: 2px solid #ddd;">TEAM TOTALS</td>
                            <td>@playerStats.Sum(s => s.PA)</td>
                            <td>@playerStats.Sum(s => s.AB)</td>
                            <td style="border-right: 2px solid #ddd; color: var(--isotopes-accent);">@playerStats.Sum(s => s.H)</td>
                            <td class="@(activeColumnIndex == 1 ? "active-col" : "")">@playerStats.Sum(s => s.H1B)</td>
                            <td class="@(activeColumnIndex == 2 ? "active-col" : "")">@playerStats.Sum(s => s.H2B)</td>
                            <td class="@(activeColumnIndex == 3 ? "active-col" : "")">@playerStats.Sum(s => s.H3B)</td>
                            <td class="@(activeColumnIndex == 4 ? "active-col" : "")">@playerStats.Sum(s => s.HR)</td>
                            <td class="@(activeColumnIndex == 5 ? "active-col" : "")" style="border-right: 2px solid #ddd;">@playerStats.Sum(s => s.IPHR)</td>
                            <td class="@(activeColumnIndex == 6 ? "active-col" : "")">@playerStats.Sum(s => s.BB)</td>
                            <td class="@(activeColumnIndex == 7 ? "active-col" : "")">@playerStats.Sum(s => s.K)</td>
                            <td class="@(activeColumnIndex == 8 ? "active-col" : "")" style="border-right: 2px solid #ddd;">@playerStats.Sum(s => s.KF)</td>
                            <td class="@(activeColumnIndex == 9 ? "active-col" : "")">@playerStats.Sum(s => s.SF)</td>
                            <td class="@(activeColumnIndex == 10 ? "active-col" : "")">@playerStats.Sum(s => s.FC)</td>
                            <td class="@(activeColumnIndex == 11 ? "active-col" : "")">@playerStats.Sum(s => s.GO)</td>
                            <td class="@(activeColumnIndex == 12 ? "active-col" : "")" style="border-right: 2px solid #ddd;">@playerStats.Sum(s => s.FO)</td>
                            <td class="@(activeColumnIndex == 13 ? "active-col" : "")" style="color: var(--isotopes-red);">@playerStats.Sum(s => s.R)</td>
                            <td class="@(activeColumnIndex == 14 ? "active-col" : "")" style="color: var(--isotopes-red);">@playerStats.Sum(s => s.RBI)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="mobile-only">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
                @for (int i = 0; i < playerStats.Count; i++)
                {
                    StatEntry stat = playerStats[i];
                    int index = i;
                    bool paWarning = i > 0 && stat.PA > playerStats[i - 1].PA;

                    <div class="stat-card" style="margin-bottom: 0; padding: 1rem; border: 1px solid #eee;">
                        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f0f0f0; margin-bottom: 0.5rem; padding-bottom: 0.3rem;">
                            <div style="color: var(--isotopes-accent); font-weight: bold;">@(index + 1). @stat.PlayerName</div>
                            <div style="font-size: 0.8rem; display: flex; gap: 8px;">
                                <span class="badge @(paWarning ? "bg-danger" : "bg-light text-dark")">PA: @stat.PA</span>
                                <span class="badge bg-light text-dark">AB: @stat.AB</span>
                                <span class="badge bg-primary">H: @stat.H</span>
                            </div>
                        </div>
                        <div class="admin-stats-grid">
                            <div class="admin-stat-input"><label>1B</label><input type="number" value="@stat.H1B" @oninput="(e) => HandleStatChange(stat, nameof(stat.H1B), e.Value)" @onfocus="() => activeColumnIndex = 1" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>2B</label><input type="number" value="@stat.H2B" @oninput="(e) => HandleStatChange(stat, nameof(stat.H2B), e.Value)" @onfocus="() => activeColumnIndex = 2" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>3B</label><input type="number" value="@stat.H3B" @oninput="(e) => HandleStatChange(stat, nameof(stat.H3B), e.Value)" @onfocus="() => activeColumnIndex = 3" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>HR</label><input type="number" value="@stat.HR" @oninput="(e) => HandleStatChange(stat, nameof(stat.HR), e.Value)" @onfocus="() => activeColumnIndex = 4" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>IPHR</label><input type="number" value="@stat.IPHR" @oninput="(e) => HandleStatChange(stat, nameof(stat.IPHR), e.Value)" @onfocus="() => activeColumnIndex = 5" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>BB</label><input type="number" value="@stat.BB" @oninput="(e) => HandleStatChange(stat, nameof(stat.BB), e.Value)" @onfocus="() => activeColumnIndex = 6" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>K</label><input type="number" value="@stat.K" @oninput="(e) => HandleStatChange(stat, nameof(stat.K), e.Value)" @onfocus="() => activeColumnIndex = 7" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>KF</label><input type="number" value="@stat.KF" @oninput="(e) => HandleStatChange(stat, nameof(stat.KF), e.Value)" @onfocus="() => activeColumnIndex = 8" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>SF</label><input type="number" value="@stat.SF" @oninput="(e) => HandleStatChange(stat, nameof(stat.SF), e.Value)" @onfocus="() => activeColumnIndex = 9" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>FC</label><input type="number" value="@stat.FC" @oninput="(e) => HandleStatChange(stat, nameof(stat.FC), e.Value)" @onfocus="() => activeColumnIndex = 10" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>GO</label><input type="number" value="@stat.GO" @oninput="(e) => HandleStatChange(stat, nameof(stat.GO), e.Value)" @onfocus="() => activeColumnIndex = 11" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>FO</label><input type="number" value="@stat.FO" @oninput="(e) => HandleStatChange(stat, nameof(stat.FO), e.Value)" @onfocus="() => activeColumnIndex = 12" @onblur="() => activeColumnIndex = null" class="form-control" /></div>
                            <div class="admin-stat-input"><label>R</label><input type="number" value="@stat.R" @oninput="(e) => HandleStatChange(stat, nameof(stat.R), e.Value)" @onfocus="() => activeColumnIndex = 13" @onblur="() => activeColumnIndex = null" class="form-control" style="font-weight: bold; color: var(--isotopes-red);" /></div>
                            <div class="admin-stat-input"><label>RBI</label><input type="number" value="@stat.RBI" @oninput="(e) => HandleStatChange(stat, nameof(stat.RBI), e.Value)" @onfocus="() => activeColumnIndex = 14" @onblur="() => activeColumnIndex = null" class="form-control" style="font-weight: bold; color: var(--isotopes-red);" /></div>
                        </div>
                    </div>
                }

                <div class="stat-card" style="margin-bottom: 0; padding: 1rem; border: 2px solid var(--isotopes-accent); background: #f0f7ff;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--isotopes-accent); margin-bottom: 0.5rem; padding-bottom: 0.3rem;">
                        <div style="color: var(--isotopes-accent); font-weight: 900;">TEAM TOTALS</div>
                        <div style="font-size: 0.8rem; display: flex; gap: 8px;">
                            <span class="badge bg-light text-dark">PA: @playerStats.Sum(s => s.PA)</span>
                            <span class="badge bg-light text-dark">AB: @playerStats.Sum(s => s.AB)</span>
                            <span class="badge bg-primary">H: @playerStats.Sum(s => s.H)</span>
                        </div>
                    </div>
                    <div class="admin-stats-grid">
                        <div class="admin-stat-input"><label>1B</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.H1B)</div></div>
                        <div class="admin-stat-input"><label>2B</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.H2B)</div></div>
                        <div class="admin-stat-input"><label>3B</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.H3B)</div></div>
                        <div class="admin-stat-input"><label>HR</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.HR)</div></div>
                        <div class="admin-stat-input"><label>IPHR</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.IPHR)</div></div>
                        <div class="admin-stat-input"><label>BB</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.BB)</div></div>
                        <div class="admin-stat-input"><label>K</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.K)</div></div>
                        <div class="admin-stat-input"><label>KF</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.KF)</div></div>
                        <div class="admin-stat-input"><label>SF</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.SF)</div></div>
                        <div class="admin-stat-input"><label>FC</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.FC)</div></div>
                        <div class="admin-stat-input"><label>GO</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.GO)</div></div>
                        <div class="admin-stat-input"><label>FO</label><div class="form-control" style="background:#eee">@playerStats.Sum(s => s.FO)</div></div>
                        <div class="admin-stat-input"><label>R</label><div class="form-control" style="background: white; font-weight: bold; color: var(--isotopes-red);">@playerStats.Sum(s => s.R)</div></div>
                        <div class="admin-stat-input"><label>RBI</label><div class="form-control" style="background: white; font-weight: bold; color: var(--isotopes-red);">@playerStats.Sum(s => s.RBI)</div></div>
                    </div>
                </div>
            </div>
        </div>
    </ModelEditor>
}
else
{
    <div class="stat-card view-fade-in">
        <div class="form-group" style="max-width: 300px; margin-bottom: 0;">
            <label>Season</label>
            <select class="form-control" @onchange="OnSeasonChange">
                @foreach (Season season in activeSeasons)
                {
                    <option value="@season.Id" selected="@(selectedSeasonId == season.Id)">@season.Name</option>
                }
            </select>
        </div>
    </div>


    <div class="desktop-only" style="margin-top: 1rem;">

        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th class="@(sortColumn == "#" ? "active-sort-header" : "")" style="text-align: left; cursor: pointer; user-select: none; padding-left: 1rem;" @onclick='() => Sort("#")'>
                                <span style="position: relative; display: inline-block;">
                                    #<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("#"))</span>
                                </span>
                            </th>
                            <th class="@(sortColumn == "Date" ? "active-sort-header" : "")" style="text-align: left; cursor: pointer; user-select: none;" @onclick='() => Sort("Date")'>
                                <span style="position: relative; display: inline-block;">
                                    Date<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("Date"))</span>
                                </span>
                            </th>
                            <th class="@(sortColumn == "Game" ? "active-sort-header" : "")" style="text-align: left; cursor: pointer; user-select: none;" @onclick='() => Sort("Game")'>
                                <span style="position: relative; display: inline-block;">
                                    Game<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("Game"))</span>
                                </span>
                            </th>
                            <th class="@(sortColumn == "Score" ? "active-sort-header" : "")" style="text-align: center; cursor: pointer; user-select: none;" @onclick='() => Sort("Score")'>
                                <span style="position: relative; display: inline-block;">
                                    Score<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("Score"))</span>
                                </span>
                            </th>
                            <th class="@(sortColumn == "Result" ? "active-sort-header" : "")" style="text-align: center; cursor: pointer; user-select: none;" @onclick='() => Sort("Result")'>
                                <span style="position: relative; display: inline-block;">
                                    Result<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("Result"))</span>
                                </span>
                            </th>
                            <th class="@(sortColumn == "Diamond" ? "active-sort-header" : "")" style="text-align: center; cursor: pointer; user-select: none;" @onclick='() => Sort("Diamond")'>
                                <span style="position: relative; display: inline-block;">
                                    Diamond<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("Diamond"))</span>
                                </span>
                            </th>
                            <th class="@(sortColumn == "Type" ? "active-sort-header" : "")" style="cursor: pointer; user-select: none;" @onclick='() => Sort("Type")'>
                                <span style="position: relative; display: inline-block;">
                                    Type<span class="sort-icon" style="left: 100%; margin-left: 2px;">@(GetSortIcon("Type"))</span>
                                </span>
                            </th>
                            <th style="text-align: center; padding-right: 1rem; width: 1%; white-space: nowrap;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Game game in SortedGames)
                        {
                            <tr style="vertical-align: middle;">
                                <td style="text-align: left; padding-left: 1rem;">@game.GameNumber</td>
                                <td style="text-align: left;">@game.Date.ToString("ddd, MMM dd, yyyy")</td>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", game.Id)'>
                                    @{
                                        string opName = !string.IsNullOrEmpty(game.Opponent?.ShortName) ? game.Opponent.ShortName : (game.Opponent?.Name ?? "Unknown");
                                        string matchup = game.IsHome ? $"{opName} vs. Isotopes" : $"Isotopes vs. {opName}";
                                    }
                                    @matchup
                                </td>
                                <td style="text-align: center; font-weight: bold;">
                                    @(game.VisitingTeamScore?.ToString() ?? "-") - @(game.HomeTeamScore?.ToString() ?? "-")
                                </td>
                                <td style="text-align: center; padding: 0;">
                                    <GameResultBadge OurScore="@(game.IsHome ? game.HomeTeamScore : game.VisitingTeamScore)" OpponentScore="@(game.IsHome ? game.VisitingTeamScore : game.HomeTeamScore)" />
                                </td>
                                <td style="text-align: center;">@game.Diamond</td>
                                <td>
                                    <span class="badge @(game.GameType == GameType.League ? "bg-primary" : "bg-warning")" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                        @game.GameType
                                    </span>
                                </td>
                                <td style="text-align: right; padding-right: 1rem; width: 1%; white-space: nowrap;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", game.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(game)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only" style="margin-top: 1rem;">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Game game in SortedGames)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;" @onclick='() => StartEdit("edit", game.Id)'>
                            @{
                                string opName = !string.IsNullOrEmpty(game.Opponent?.ShortName) ? game.Opponent.ShortName : (game.Opponent?.Name ?? "Unknown");
                                string matchup = game.IsHome ? $"{opName} vs. Isotopes" : $"Isotopes vs. {opName}";
                            }
                            @matchup
                            <GameResultBadge OurScore="@(game.IsHome ? game.HomeTeamScore : game.VisitingTeamScore)" OpponentScore="@(game.IsHome ? game.VisitingTeamScore : game.HomeTeamScore)" />
                        </div>
                        <div class="rank-badge">#@game.GameNumber</div>
                    </div>
                    <div class="mobile-card-stats" style="grid-template-columns: 1fr 1fr 1fr; margin-bottom: 1rem;">
                        <div class="m-stat" style="align-items: flex-start;">
                            <span class="m-stat-label">Date</span>
                            <span class="m-stat-val" style="font-size: 0.9rem;">@game.Date.ToString("ddd, MMM dd")</span>
                        </div>
                        <div class="m-stat" style="align-items: flex-start;">
                            <span class="m-stat-label">Score</span>
                            <span class="m-stat-val" style="font-size: 0.9rem; font-weight: bold;">@(game.VisitingTeamScore?.ToString() ?? "-") - @(game.HomeTeamScore?.ToString() ?? "-")</span>
                        </div>
                        <div class="m-stat" style="align-items: flex-start;">
                            <span class="m-stat-label">Diamond</span>
                            <span class="m-stat-val" style="font-size: 0.9rem;">@game.Diamond</span>
                        </div>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
                        <span class="badge @(game.GameType == GameType.League ? "bg-primary" : "bg-warning")" style="padding: 0.3rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">
                            @game.GameType
                        </span>
                        <div style="display: flex; gap: 0.5rem;">
                            <button class="view-btn" @onclick='() => StartEdit("edit", game.Id)'>Edit</button>
                            <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red); padding: 0.3rem 0.8rem;" @onclick="() => deleteManager.ConfirmDelete(game)">Delete</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<style>
    .active-sort-header { font-weight: 900 !important; }
    .drag-over { background-color: #f0f7ff !important; border-top: 2px solid var(--isotopes-accent) !important; }
    .admin-stats-table tr:focus-within { background-color: rgba(23, 162, 184, 0.08) !important; }
    .admin-stats-table td.active-col { background-color: rgba(23, 162, 184, 0.08) !important; }
    .admin-stats-table th, .admin-stats-table td { text-align: center !important; vertical-align: middle !important; height: 45px !important; padding: 4px !important; }
    .admin-stats-table th:not(.player-col), .admin-stats-table td:not(.player-col) { width: 45px !important; min-width: 45px !important; }
    .admin-stats-table .player-col { text-align: left !important; font-weight: bold; white-space: nowrap; padding-left: 12px !important; }
    .admin-stats-table .form-control-sm { padding: 2px !important; height: 32px !important; }
    
    /* Mobile highlight */
    .mobile-only .stat-card:focus-within { border-color: var(--isotopes-accent) !important; background-color: #f0f7ff !important; }
</style>

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private DeleteManager<Game, int> deleteManager = null!;
    private ModelEditor<Game> modelEditor = null!;
    private List<Season> allSeasons = new();
    private List<Season> activeSeasons => allSeasons.Where(s => !s.IsDeleted).ToList();
    private List<Game> games = new();
    private List<StatEntry> playerStats = new();
    private List<StatEntry> originalStats = new();
    private List<Player> seasonRoster = new();
    private List<Opponent> availableOpponents = new();
    private Game editingGame = new() { Date = DateTime.Now };
    private Game originalGame = new() { Date = DateTime.Now };
    private int selectedSeasonId;
    private bool isEditing = false;

    private StatEntry? draggedStat;
    private StatEntry? targetStat;

    private int? activeColumnIndex;

    private string sortColumn = "#";
    private bool sortDescending = false;

    private IEnumerable<Game> SortedGames => sortColumn switch
    {
        "#" => sortDescending ? games.OrderByDescending(g => g.GameNumber) : games.OrderBy(g => g.GameNumber),
        "Date" => sortDescending ? games.OrderByDescending(g => g.Date).ThenBy(g => g.GameNumber) : games.OrderBy(g => g.Date).ThenBy(g => g.GameNumber),
        "Game" => sortDescending ? games.OrderByDescending(g => g.Opponent?.Name).ThenBy(g => g.GameNumber) : games.OrderBy(g => g.Opponent?.Name).ThenBy(g => g.GameNumber),
        "Score" => sortDescending ? games.OrderByDescending(g => (g.VisitingTeamScore ?? 0) + (g.HomeTeamScore ?? 0)).ThenBy(g => g.GameNumber) : games.OrderBy(g => (g.VisitingTeamScore ?? 0) + (g.HomeTeamScore ?? 0)).ThenBy(g => g.GameNumber),
        "Result" => sortDescending ? games.OrderByDescending(g => g.IsHome ? (g.HomeTeamScore ?? 0) - (g.VisitingTeamScore ?? 0) : (g.VisitingTeamScore ?? 0) - (g.HomeTeamScore ?? 0)).ThenBy(g => g.GameNumber) : games.OrderBy(g => g.IsHome ? (g.HomeTeamScore ?? 0) - (g.VisitingTeamScore ?? 0) : (g.VisitingTeamScore ?? 0) - (g.HomeTeamScore ?? 0)).ThenBy(g => g.GameNumber),
        "Diamond" => sortDescending ? games.OrderByDescending(g => g.Diamond).ThenBy(g => g.GameNumber) : games.OrderBy(g => g.Diamond).ThenBy(g => g.GameNumber),
        "Type" => sortDescending ? games.OrderByDescending(g => g.GameType).ThenBy(g => g.GameNumber) : games.OrderBy(g => g.GameType).ThenBy(g => g.GameNumber),
        _ => games.OrderBy(g => g.GameNumber)
    };

    private void Sort(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column) return "";
        return sortDescending ? "▼" : "▲";
    }

    protected override async Task OnInitializedAsync()
    {
        allSeasons = await StatsRepository.GetSeasonsAsync();
        if (activeSeasons.Any())
        {
            selectedSeasonId = activeSeasons.First().Id;
            editingGame.SeasonId = selectedSeasonId;
            await LoadGames();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasEditing = isEditing;
        bool nextEditing = Action == "add" || Action == "edit";

        if (nextEditing)
        {
            if (!wasEditing || (Id.HasValue && Id != editingGame.Id))
            {
                isEditing = false;
                await LoadEditingGame();
            }
        }
        else
        {
            editingGame = new Game { Date = DateTime.Now, SeasonId = selectedSeasonId };
            originalGame = new Game { Date = editingGame.Date, SeasonId = selectedSeasonId };
            playerStats.Clear();
            originalStats.Clear();
            seasonRoster.Clear();
        }

        isEditing = nextEditing;
    }

    private async Task LoadEditingGame()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            Game? game = await StatsRepository.GetGameAsync(Id.Value);
            if (game != null)
            {
                editingGame = game with { };
                originalGame = game with { };
                await LoadSeasonRoster();
                await LoadAvailableOpponents();
                playerStats = await StatsRepository.GetGameStatsAsync(game.Id);
                playerStats = playerStats.OrderBy(s => s.BO).ToList();
                originalStats = playerStats.Select(s => s with { }).Cast<StatEntry>().ToList();
            }
        }
        else
        {
            editingGame = new Game { Date = DateTime.Now, SeasonId = selectedSeasonId };
            originalGame = new Game { Date = editingGame.Date, SeasonId = selectedSeasonId };
            
            editingGame.GameNumber = await StatsRepository.GetNextGameNumberAsync(editingGame.SeasonId);

            await LoadSeasonRoster();
            await LoadAvailableOpponents();
            playerStats = new List<StatEntry>();
            originalStats = new List<StatEntry>();
        }
        await HydrateTempState();
    }

    private async Task HydrateTempState()
    {
        try
        {
            Game? persisted = await SessionStorage.GetItemAsync<Game>($"EditState_Game_{Id ?? 0}");
            if (persisted != null)
            {
                editingGame = persisted;
            }

            List<StatEntry>? persistedExtra = await SessionStorage.GetItemAsync<List<StatEntry>>($"EditState_Game_{Id ?? 0}_Extra");
            if (persistedExtra != null)
            {
                playerStats = persistedExtra;
            }
            StateHasChanged();
        }
        catch { }
    }

    private bool isLoading = true;

    private async Task LoadGames()
    {
        isLoading = true;
        try
        {
            games = await StatsRepository.GetGamesBySeasonAsync(selectedSeasonId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedSeasonId = id;
            await LoadGames();
        }
    }

    private async Task OnEditingSeasonChanged()
    {
        await LoadSeasonRoster();
        await LoadAvailableOpponents();
        playerStats = playerStats.Where(ps => seasonRoster.Any(r => r.Id == ps.PlayerId)).ToList();
        ReassignBO();

        if (editingGame.Id == 0)
        {
            editingGame.GameNumber = await StatsRepository.GetNextGameNumberAsync(editingGame.SeasonId);
        }

        if (modelEditor != null) await modelEditor.SaveExtraState();
    }

    private async Task LoadSeasonRoster() => seasonRoster = await StatsRepository.GetPlayersAsync(editingGame.SeasonId);
    private async Task LoadAvailableOpponents() => availableOpponents = await StatsRepository.GetOpponentsAsync(editingGame.SeasonId);

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/games/add");
        else Navigation.NavigateTo($"/management/games/edit/{id}");
    }

    private bool IsPlayerInLineup(int playerId) => playerStats.Any(ps => ps.PlayerId == playerId);

    private async Task TogglePlayerInLineup(Player player, bool isChecked)
    {
        if (isChecked)
        {
            if (!playerStats.Any(ps => ps.PlayerId == player.Id))
                playerStats.Add(new StatEntry { PlayerId = player.Id, Player = player, BO = playerStats.Count + 1 });
        }
        else
        {
            playerStats.RemoveAll(ps => ps.PlayerId == player.Id);
            ReassignBO();
        }
        if (modelEditor != null) await modelEditor.SaveExtraState();
    }

    private void ReassignBO()
    {
        for (int i = 0; i < playerStats.Count; i++) playerStats[i].BO = i + 1;
    }

    private async Task HandleStatChange(StatEntry stat, string propertyName, object? value)
    {
        if (value == null) return;
        System.Reflection.PropertyInfo? prop = typeof(StatEntry).GetProperty(propertyName);
        if (prop != null)
        {
            try {
                object? typedValue = Convert.ChangeType(value.ToString(), prop.PropertyType);
                prop.SetValue(stat, typedValue);
                if (modelEditor != null) await modelEditor.SaveExtraState();
            } catch { }
        }
    }

    private void HandleDragStart(StatEntry stat) => draggedStat = stat;
    private void HandleDragOver(StatEntry stat) => targetStat = stat;

    private async Task HandleDrop(StatEntry dropTargetStat)
    {
        if (draggedStat == null || draggedStat == dropTargetStat) { targetStat = null; return; }
        int oldIndex = playerStats.IndexOf(draggedStat);
        int newIndex = playerStats.IndexOf(dropTargetStat);
        if (oldIndex != -1 && newIndex != -1)
        {
            playerStats.RemoveAt(oldIndex);
            playerStats.Insert(newIndex, draggedStat);
            ReassignBO();
            if (modelEditor != null) await modelEditor.SaveExtraState();
        }
        draggedStat = null;
        targetStat = null;
    }

    private async Task SaveGame()
    {
        if (editingGame.Id == 0) await StatsRepository.AddGameWithStatsAsync(editingGame, playerStats);
        else await StatsRepository.UpdateGameWithStatsAsync(editingGame, playerStats);
        await LoadGames();
    }

    private async Task DeleteGame()
    {
        await AuthSvc.AddLogAsync(new UserLog { Action = UserLogAction.Deleted, EntityType = "Game", EntityId = editingGame.Id.ToString(), Description = $"Deleted game {editingGame.GameNumber}" });
        await StatsRepository.DeleteGameAsync(editingGame.Id);
        await LoadGames();
    }
}

