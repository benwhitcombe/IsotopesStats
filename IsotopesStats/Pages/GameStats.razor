@page "/gamestats"
@using IsotopesStats.Services
@using IsotopesStats.Models
@inject StatsService StatsService

<h3>Detailed Game Stats</h3>

<div class="stat-card">
    <div class="form-group">
        <label>Filter by Player or Opponent:</label>
        <input type="text" class="form-control" @bind="filterText" @bind:event="oninput" placeholder="Search..." />
    </div>
</div>

<div class="table-container">
    <table class="table-sm">
        <thead>
            <tr>
                <th>Player</th>
                <th>BO</th>
                <th>PA</th>
                <th>AB</th>
                <th>H</th>
                <th>1B</th>
                <th>2B</th>
                <th>3B</th>
                <th>4B</th>
                <th>HR</th>
                <th>FC</th>
                <th>BB</th>
                <th>SF</th>
                <th>K</th>
                <th>KF</th>
                <th>GO</th>
                <th>FO</th>
                <th>R</th>
                <th>RBI</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var group in GroupedStats)
            {
                var gameInfo = group.First().Game;
                var isExpanded = expandedGames.Contains(gameInfo?.Id ?? 0);
                
                <tr class="game-header-row @(isExpanded ? "" : "collapsed")" @onclick="() => ToggleGame(gameInfo?.Id ?? 0)">
                    <th colspan="19">
                        <span class="expand-icon">▼</span>
                        Game #@gameInfo?.GameNumber - @gameInfo?.Date.ToString("yyyy-MM-dd HH:mm") vs @gameInfo?.Opponent (@gameInfo?.Diamond)
                    </th>
                </tr>

                @if (isExpanded)
                {
                    @foreach (StatEntry stat in group)
                    {
                        <tr>
                            <td class="player-name">@stat.Player?.Name</td>
                            <td>@stat.BO</td>
                            <td>@stat.PA</td>
                            <td>@stat.AB</td>
                            <td>@stat.H</td>
                            <td>@stat.H1B</td>
                            <td>@stat.H2B</td>
                            <td>@stat.H3B</td>
                            <td>@stat.H4B</td>
                            <td>@stat.HR</td>
                            <td>@stat.FC</td>
                            <td>@stat.BB</td>
                            <td>@stat.SF</td>
                            <td>@stat.K</td>
                            <td>@stat.KF</td>
                            <td>@stat.GO</td>
                            <td>@stat.FO</td>
                            <td>@stat.R</td>
                            <td>@stat.RBI</td>
                        </tr>
                    }
                    
                    <tr class="game-summary-row">
                        <td>GAME TOTALS</td>
                        <td>-</td>
                        <td>@group.Sum(s => s.PA)</td>
                        <td>@group.Sum(s => s.AB)</td>
                        <td>@group.Sum(s => s.H)</td>
                        <td>@group.Sum(s => s.H1B)</td>
                        <td>@group.Sum(s => s.H2B)</td>
                        <td>@group.Sum(s => s.H3B)</td>
                        <td>@group.Sum(s => s.H4B)</td>
                        <td>@group.Sum(s => s.HR)</td>
                        <td>@group.Sum(s => s.FC)</td>
                        <td>@group.Sum(s => s.BB)</td>
                        <td>@group.Sum(s => s.SF)</td>
                        <td>@group.Sum(s => s.K)</td>
                        <td>@group.Sum(s => s.KF)</td>
                        <td>@group.Sum(s => s.GO)</td>
                        <td>@group.Sum(s => s.FO)</td>
                        <td>@group.Sum(s => s.R)</td>
                        <td>@group.Sum(s => s.RBI)</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private List<StatEntry> allStats = new();
    private HashSet<int> expandedGames = new();
    private string filterText = "";

    protected override void OnInitialized()
    {
        try 
        {
            allStats = StatsService.GetAllGameStats();
            // Expand the most recent game by default
            var latestGame = allStats.FirstOrDefault()?.Game;
            if (latestGame != null)
            {
                expandedGames.Add(latestGame.Id);
            }
        }
        catch (Exception)
        {
            allStats = new List<StatEntry>();
        }
    }

    private IEnumerable<IGrouping<int, StatEntry>> GroupedStats => allStats
        .Where(s => string.IsNullOrWhiteSpace(filterText) 
            || (s.Player?.Name?.Contains(filterText, StringComparison.OrdinalIgnoreCase) ?? false) 
            || (s.Game?.Opponent?.Contains(filterText, StringComparison.OrdinalIgnoreCase) ?? false))
        .GroupBy(s => s.GameId);

    private void ToggleGame(int gameId)
    {
        if (expandedGames.Contains(gameId))
        {
            expandedGames.Remove(gameId);
        }
        else
        {
            expandedGames.Add(gameId);
        }
    }

    private string GetSortIcon(string column)
    {
        // Sorting is disabled for the grouped view to maintain game integrity
        return "↕️";
    }
}
