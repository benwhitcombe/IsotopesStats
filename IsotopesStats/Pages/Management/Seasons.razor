@page "/management/seasons"
@using IsotopesStats.Services
@using IsotopesStats.Models
@attribute [Authorize(Policy = "ManageSeasons")]
@inject StatsService StatsService
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Manage Seasons</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Seasons</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick="() => StartEdit(new Season())">Add New Season</button>
    }
</div>

@if (isEditing)
{
    <div class="stat-card view-fade-in" style="margin-bottom: 2rem;">
        <h4 style="margin-top:0">@(editingSeason.Id == 0 ? "Add" : "Edit") Season</h4>
        <div class="form-group">
            <label>Season Name</label>
            <input type="text" class="form-control" @bind="editingSeason.Name" placeholder="e.g. 2026" />
        </div>

        <div class="form-group" style="display: flex; gap: 0.5rem; align-items: center; margin: 1rem 0;">
            <input type="checkbox" @bind="editingSeason.IsActive" id="isSeasonActive" style="width: 20px; height: 20px;" />
            <label for="isSeasonActive" style="margin:0; font-weight: bold;">Active Season</label>
        </div>

        @if (editingSeason.Id != 0)
        {
            <div class="form-group" style="margin-top: 1.5rem;">
                <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Season Roster</label>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; background: #f9f9f9; padding: 1rem; border-radius: 8px; max-height: 400px; overflow-y: auto;">
                    @foreach (Player player in allPlayers)
                    {
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <input type="checkbox" id="p-@player.Id" 
                                   checked="@assignedPlayerIds.Contains(player.Id)"
                                   @onchange="(e) => TogglePlayer(player.Id, e)"
                                   style="width: 18px; height: 18px;" />
                            <label for="p-@player.Id" style="margin:0; cursor: pointer;">@player.Name</label>
                        </div>
                    }
                </div>
            </div>
        }

        <div style="display: flex; gap: 1rem; margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1.5rem;">
            <button class="view-btn active" @onclick="SaveSeason">Save Season</button>
            <button class="view-btn" @onclick="CancelEdit">Cancel</button>
        </div>
    </div>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">ID</th>
                            <th style="text-align: left;">Name</th>
                            <th>Status</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Season season in seasons)
                        {
                            <tr>
                                <td style="text-align: left;">@season.Id</td>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent);">@season.Name</td>
                                <td>
                                    <span class="badge @(season.IsActive ? "bg-success" : "bg-secondary")" style="padding: 0.4rem 0.8rem; border-radius: 20px;">
                                        @(season.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick="() => StartEdit(season)">Edit / Roster</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => DeleteSeason(season.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Season season in seasons)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name">@season.Name</div>
                        <span class="badge @(season.IsActive ? "bg-success" : "bg-secondary")" style="padding: 0.2rem 0.6rem; font-size: 0.7rem; border-radius: 10px;">
                            @(season.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick="() => StartEdit(season)">Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => DeleteSeason(season.Id)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Season> seasons = new();
    private List<Player> allPlayers = new();
    private HashSet<int> assignedPlayerIds = new();
    private HashSet<int> originalPlayerIds = new();
    private Season editingSeason = new();
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
        allPlayers = await StatsService.GetAllPlayersAsync();
    }

    private async Task LoadSeasons()
    {
        seasons = await StatsService.GetSeasonsAsync();
    }

    private async Task StartEdit(Season season)
    {
        editingSeason = new Season 
        { 
            Id = season.Id, 
            Name = season.Name,
            IsActive = season.IsActive
        };
        
        assignedPlayerIds.Clear();
        originalPlayerIds.Clear();

        if (season.Id != 0)
        {
            List<Player> seasonPlayers = await StatsService.GetPlayersAsync(season.Id);
            foreach (Player p in seasonPlayers)
            {
                assignedPlayerIds.Add(p.Id);
                originalPlayerIds.Add(p.Id);
            }
        }

        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
        editingSeason = new Season();
        assignedPlayerIds.Clear();
    }

    private void TogglePlayer(int playerId, ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        if (isChecked) assignedPlayerIds.Add(playerId);
        else assignedPlayerIds.Remove(playerId);
    }

    private async Task SaveSeason()
    {
        if (string.IsNullOrEmpty(editingSeason.Name)) return;

        if (editingSeason.Id == 0)
        {
            await StatsService.AddSeasonAsync(editingSeason);
        }
        else
        {
            await StatsService.UpdateSeasonAsync(editingSeason);

            // Handle additions
            foreach (int playerId in assignedPlayerIds.Except(originalPlayerIds))
            {
                await StatsService.AddPlayerToSeasonAsync(playerId, editingSeason.Id);
            }

            // Handle removals
            foreach (int playerId in originalPlayerIds.Except(assignedPlayerIds))
            {
                await StatsService.DeletePlayerFromSeasonAsync(playerId, editingSeason.Id);
            }
        }

        isEditing = false;
        await LoadSeasons();
    }

    private async Task DeleteSeason(int id)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this season? This will delete ALL associated games and stats!");
        if (confirmed)
        {
            await StatsService.DeleteSeasonAsync(id);
            await LoadSeasons();
        }
    }
}
