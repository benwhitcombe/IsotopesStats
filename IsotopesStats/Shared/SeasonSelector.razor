@using IsotopesStats.Models
@using IsotopesStats.Services

<div class="season-selector-container @(isReady ? "ready" : "loading")" style="min-width: @(MinWidth)px;">
    @if (isReady)
    {
        <div class="desktop-only" style="width: 100%;">
            <select class="form-control season-select" value="@SelectedSeasonId" @onchange="HandleSeasonChange">
                @if (AllowAllSeasons)
                {
                    <option value="@SharedSessionState.AllSeasonsId">All Seasons</option>
                }
                @foreach (var season in Seasons)
                {
                    <option value="@season.Id">@season.Name</option>
                }
            </select>
        </div>

        <div class="mobile-only" style="width: 100%;">
            <button class="view-btn season-mobile-btn" @onclick="ToggleModal">
                🗓️ @GetCurrentSeasonName()
            </button>
        </div>

        @if (showModal)
        {
            <div class="sort-modal-overlay" @onclick="ToggleModal">
                <div class="sort-modal" @onclick:stopPropagation="true">
                    <div class="sort-modal-header" style="position: relative; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; width: 100%;">
                        <h4 style="margin:0; font-weight: 800; color: var(--isotopes-dark);">Select Season</h4>
                        <button type="button" @onclick="ToggleModal" 
                                style="position: absolute; right: -0.5rem; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 2.5rem; color: #ccc; cursor: pointer; line-height: 1; padding: 0.5rem; display: flex; align-items: center; justify-content: center;" 
                                title="Close">&times;</button>
                    </div>
                    <div class="sort-grid">
                        @if (AllowAllSeasons)
                        {
                            <div class="sort-option @(SelectedSeasonId == SharedSessionState.AllSeasonsId ? "active" : "")" 
                                 @onclick="() => SelectMobileSeason(SharedSessionState.AllSeasonsId)">
                                All Seasons
                            </div>
                        }
                        @foreach (var season in Seasons)
                        {
                            <div class="sort-option @(SelectedSeasonId == season.Id ? "active" : "")" 
                                 @onclick="() => SelectMobileSeason(season.Id)">
                                @season.Name
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<Season> Seasons { get; set; } = new();
    [Parameter] public int SelectedSeasonId { get; set; }
    [Parameter] public EventCallback<int> OnSeasonSelected { get; set; }
    [Parameter] public bool AllowAllSeasons { get; set; } = false;
    [Parameter] public int MinWidth { get; set; } = 120;

    private bool showModal = false;
    private bool isReady = false;

    protected override void OnParametersSet()
    {
        if (Seasons != null && Seasons.Any())
        {
            isReady = true;
        }
    }

    private string GetCurrentSeasonName()
    {
        if (SelectedSeasonId == SharedSessionState.AllSeasonsId) return "All Seasons";
        return Seasons.FirstOrDefault(s => s.Id == SelectedSeasonId)?.Name ?? "Select Season";
    }

    private async Task HandleSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            await OnSeasonSelected.InvokeAsync(id);
        }
    }

    private void ToggleModal() => showModal = !showModal;

    private async Task SelectMobileSeason(int id)
    {
        showModal = false;
        await OnSeasonSelected.InvokeAsync(id);
    }
}

<style>
    .season-selector-container {
        display: inline-block;
        transition: opacity 0.2s;
        width: auto;
    }

    .season-selector-container.loading {
        opacity: 0;
    }

    .season-selector-container.ready {
        opacity: 1;
    }

    .season-select {
        text-align: center;
        text-align-last: center;
        font-weight: bold;
        cursor: pointer;
        height: auto !important;
        /* Symmetric horizontal padding to allow text-align: center to work perfectly */
        padding: 0.4rem 0 0.4rem 0 !important;
        line-height: 1.5;
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        /* Place arrow 8px from the right edge without affecting text flow */
        background-position: calc(100% - 8px) center;
        background-size: 14px;
        width: 100%;
    }

    .season-mobile-btn {
        background: var(--isotopes-accent); 
        color: white; 
        border: none; 
        padding: 0.5rem 1rem;
        width: 100%;
        text-align: center;
    }

    select.season-select option {
        text-align: center;
        direction: ltr;
    }
</style>
