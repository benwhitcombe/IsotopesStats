<div class="position-relative mx-auto mb-4 mt-2" style="width: 200px; height: 200px;">
    <div class="diamond-container h-100 w-100">
        <svg viewBox="0 0 100 100" style="width: 100%; height: 100%;">
            <!-- Base paths -->
            <polygon points="50,90 90,50 50,10 10,50" fill="none" stroke="#ddd" stroke-width="2" />
            <!-- 1B -->
            <polygon points="90,50 85,45 80,50 85,55" fill="@(RunnerOn1B != null ? "var(--isotopes-accent)" : "#fff")" stroke="#aaa" />
            <!-- 2B -->
            <polygon points="50,10 45,15 50,20 55,15" fill="@(RunnerOn2B != null ? "var(--isotopes-accent)" : "#fff")" stroke="#aaa" />
            <!-- 3B -->
            <polygon points="10,50 15,45 20,50 15,55" fill="@(RunnerOn3B != null ? "var(--isotopes-accent)" : "#fff")" stroke="#aaa" />
            <!-- Home Plate (pointing down) -->
            <polygon points="45,85 55,85 55,90 50,95 45,90" fill="#fff" stroke="#aaa" />
        </svg>
    </div>
    
    <!-- Runner Names Overlays -->
    @if (RunnerOn2B != null)
    {
        <div class="position-absolute badge badge-fade" style="background-color: var(--isotopes-accent); left: 50%; bottom: 90%; transform: translateX(-50%); z-index: 10;">
            @RunnerOn2B
        </div>
    }
    @if (RunnerOn3B != null)
    {
        <div class="position-absolute badge badge-fade" style="background-color: var(--isotopes-accent); right: 90%; top: 50%; transform: translateY(-50%); z-index: 10;">
            @RunnerOn3B
        </div>
    }
    @if (RunnerOn1B != null)
    {
        <div class="position-absolute badge badge-fade" style="background-color: var(--isotopes-accent); left: 90%; top: 50%; transform: translateY(-50%); z-index: 10;">
            @RunnerOn1B
        </div>
    }

    @if (ScoredRunners != null && ScoredRunners.Any())
    {
        <div class="position-absolute d-flex flex-row gap-1 align-items-center justify-content-center badge-fade" style="left: 50%; top: 95%; transform: translateX(-50%); z-index: 10;">
            @foreach (string p in ScoredRunners)
            {
                <div class="badge bg-success shadow-sm">@p</div>
            }
        </div>
    }

    @if (OutRunners != null)
    {
        @foreach (var o in OutRunners)
        {
            if (o.OutBase == 1)
            {
                <div class="position-absolute badge bg-danger badge-fade" style="left: 75%; top: 75%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
            }
            else if (o.OutBase == 2)
            {
                <div class="position-absolute badge bg-danger badge-fade" style="left: 75%; top: 25%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
            }
            else if (o.OutBase == 3)
            {
                <div class="position-absolute badge bg-danger badge-fade" style="left: 25%; top: 25%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
            }
            else if (o.OutBase == 4)
            {
                <div class="position-absolute badge bg-danger badge-fade" style="left: 25%; top: 75%; transform: translate(-50%, -50%); z-index: 10;">@o.Name</div>
            }
        }
    }
</div>

@code {
    [Parameter] public string? RunnerOn1B { get; set; }
    [Parameter] public string? RunnerOn2B { get; set; }
    [Parameter] public string? RunnerOn3B { get; set; }
    [Parameter] public IEnumerable<string> ScoredRunners { get; set; } = Array.Empty<string>();
    [Parameter] public IEnumerable<(string Name, int OutBase)> OutRunners { get; set; } = Array.Empty<(string Name, int OutBase)>();
}
