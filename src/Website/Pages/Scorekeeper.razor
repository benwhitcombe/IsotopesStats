@page "/games/{GameId:int}/scorekeeping"
@using IsotopesStats.Domain.Interfaces
@using IsotopesStats.Website.Services
@using IsotopesStats.Website.Shared
@using IsotopesStats.Website.Shared.Models
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Policy = "Manage Scorekeeping")]
@inject IStatsRepository StatsRepository
@inject IAuthRepository AuthSvc
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Scorekeeping - Isotopes</PageTitle>

@if (provider != null)
{
    <ScorekeeperApp DataProvider="provider" EnableLiveSync="true" GameId="GameId" ScorecardUrl="@($"/games/{GameId}/scorecard")" paIndex="paIndex" />
}
else
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@code {
    [Parameter] public int GameId { get; set; }
    [Parameter] [SupplyParameterFromQuery] public int? paIndex { get; set; }

    private LiveScorekeeperProvider? provider;

    protected override void OnInitialized()
    {
        provider = new LiveScorekeeperProvider(StatsRepository, AuthSvc, AuthStateProvider, GameId);
    }
}
