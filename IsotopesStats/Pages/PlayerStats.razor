@page "/players"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject StatsService StatsService
@inject PlayerStatsState SessionState
@inject SharedSessionState SharedState
@inject ProtectedSessionStorage ProtectedSessionStore
@inject NavigationManager NavigationManager

<PageTitle>Isotopes - Player Stats</PageTitle>

<div class="header-with-filter">
    <div class="filter-container">
        <div class="search-container">
            <span class="search-icon">🔍</span>
            <input type="text" class="form-control search-input" placeholder="Filter by player name..." 
                   @bind-value="filterText" @bind-value:event="oninput" @onkeyup="UpdateFilterState" />
            @if (!string.IsNullOrEmpty(filterText))
            {
                <button class="clear-button" @onclick="ClearFilter">✕</button>
            }
        </div>
    </div>

    <div class="desktop-only" style="display: flex; gap: 10px;">
        <select class="form-control" style="width: auto; min-width: 120px;" @onchange="OnSeasonChange">
            @foreach (Season season in seasons)
            {
                <option value="@season.Id" selected="@(SharedState.SelectedSeasonId == season.Id)">@season.Name</option>
            }
        </select>
    </div>

    <div class="mobile-only" style="width: 100%; display: flex; gap: 10px; margin-top: 10px;">
        <button class="view-btn" style="flex: 1; background: var(--isotopes-accent); color: white; border: none; padding: 0.5rem 1rem;" @onclick="ToggleSeasonModal">
            📅 Season: @(seasons.FirstOrDefault(s => s.Id == SharedState.SelectedSeasonId)?.Name ?? "Select")
        </button>
        <button class="view-btn" style="flex: 1; background: var(--isotopes-accent); color: white; border: none; padding: 0.5rem;" @onclick="ToggleSortModal">
            ⇅ Sort By: @currentSortColumn
        </button>
    </div>
</div>

@if (showSeasonModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSeasonModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Select Season</h4>
                <button class="view-btn" @onclick="ToggleSeasonModal">Close</button>
            </div>
            <div class="sort-grid">
                @foreach (Season season in seasons)
                {
                    <div class="sort-option @(SharedState.SelectedSeasonId == season.Id ? "active" : "")" @onclick="() => SelectMobileSeason(season.Id)">
                        @season.Name
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (showSortModal)
{
    <div class="sort-modal-overlay" @onclick="ToggleSortModal">
        <div class="sort-modal" @onclick:stopPropagation="true">
            <div class="sort-modal-header">
                <h4 style="margin:0">Sort Players By</h4>
                <button class="view-btn" @onclick="ToggleSortModal">Close</button>
            </div>
            <div class="sort-grid">
                @foreach (string stat in AllSortableStats)
                {
                    <div class="sort-option @(currentSortColumn == stat ? "active" : "")" @onclick='() => { Sort(stat); showSortModal = false; }'>
                        @stat
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="player-stats-container">
    @if (isLoading && !showSkeleton)
    {
        @* Initial quiet load *@
    }
    else if (showSkeleton)
    {
        <div class="stat-card">
            <div class="skeleton-header"></div>
            @for (int i = 0; i < 5; i++)
            {
                <div class="skeleton-line"></div>
            }
        </div>
    }
    else if (!players.Any())
    {
        <div class="stat-card" style="text-align: center; padding: 3rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">👥</div>
            <p style="color: #666;">No players found for this season.</p>
        </div>
    }
    else
    {
        <div class="stat-card view-fade-in" style="padding: 0;">
            <div class="desktop-only">
                <table class="box-score-table" style="border: none; border-radius: 12px; overflow: hidden;">
                    <thead>
                        <tr>
                            <th @onclick='() => Sort("Name")' style="text-align:left">Player @GetSortIcon("Name")</th>
                            <th @onclick='() => Sort("GP")' title="Games Played">GP @GetSortIcon("GP")</th>
                            <th @onclick='() => Sort("PA")' title="Plate Appearances">PA @GetSortIcon("PA")</th>
                            <th @onclick='() => Sort("AB")' title="At Bats">AB @GetSortIcon("AB")</th>
                            <th @onclick='() => Sort("R")' title="Runs">R @GetSortIcon("R")</th>
                            <th @onclick='() => Sort("H")' title="Hits">H @GetSortIcon("H")</th>
                            <th @onclick='() => Sort("2B")' title="Doubles">2B @GetSortIcon("2B")</th>
                            <th @onclick='() => Sort("3B")' title="Triples">3B @GetSortIcon("3B")</th>
                            <th @onclick='() => Sort("HR")' title="Home Runs">HR @GetSortIcon("HR")</th>
                            <th @onclick='() => Sort("RBI")' title="Runs Batted In">RBI @GetSortIcon("RBI")</th>
                            <th @onclick='() => Sort("BB")' title="Walks">BB @GetSortIcon("BB")</th>
                            <th @onclick='() => Sort("K")' title="Strikeouts">K @GetSortIcon("K")</th>
                            <th @onclick='() => Sort("AVG")' title="Batting Average">AVG @GetSortIcon("AVG")</th>
                            <th @onclick='() => Sort("OBP")' title="On Base Percentage">OBP @GetSortIcon("OBP")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (PlayerStatsSummary player in FilteredPlayers)
                        {
                            <tr>
                                <td style="text-align:left; font-weight: 600; color: var(--isotopes-accent); cursor: pointer;" @onclick="() => NavigateToLogs(player.PlayerName)">
                                    @player.PlayerName
                                </td>
                                <td>@player.GamesPlayed</td>
                                <td>@player.PA</td>
                                <td>@player.AB</td>
                                <td style="color: var(--isotopes-red); font-weight: bold;">@player.R</td>
                                <td style="font-weight: 600;">@player.H</td>
                                <td>@player.H2B</td>
                                <td>@player.H3B</td>
                                <td>@player.HR</td>
                                <td style="color: var(--isotopes-red); font-weight: bold;">@player.RBI</td>
                                <td>@player.BB</td>
                                <td>@player.K</td>
                                <td style="font-weight: bold; background: #fcfcfc;">@player.AVG.ToString(".000")</td>
                                <td style="background: #fcfcfc;">@player.OBP.ToString(".000")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background: #f8f9fa; font-weight: 800; border-top: 2px solid #ddd;">
                            <td style="text-align:left">TEAM TOTALS</td>
                            <td>-</td>
                            <td>@teamTotals.PA</td>
                            <td>@teamTotals.AB</td>
                            <td>@teamTotals.R</td>
                            <td>@teamTotals.H</td>
                            <td>@teamTotals.H2B</td>
                            <td>@teamTotals.H3B</td>
                            <td>@teamTotals.HR</td>
                            <td>@teamTotals.RBI</td>
                            <td>@teamTotals.BB</td>
                            <td>@teamTotals.K</td>
                            <td>@teamTotals.AVG.ToString(".000")</td>
                            <td>@teamTotals.OBP.ToString(".000")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mobile-only">
                <div class="mobile-player-grid view-fade-in" @key="SharedState.SelectedSeasonId">
                    @foreach (PlayerStatsSummary player in FilteredPlayers)
                    {
                        <div class="mobile-player-card" @onclick="() => NavigateToLogs(player.PlayerName)">
                            <div class="mobile-card-header">
                                <div class="mobile-card-name">@player.PlayerName</div>
                                <div class="rank-badge">GP: @player.GamesPlayed</div>
                            </div>
                            <div class="mobile-card-stats">
                                <div class="m-stat"><span class="m-stat-label">AVG</span><span class="m-stat-val">@player.AVG.ToString(".000")</span></div>
                                <div class="m-stat"><span class="m-stat-label">OBP</span><span class="m-stat-val">@player.OBP.ToString(".000")</span></div>
                                <div class="m-stat"><span class="m-stat-label">H</span><span class="m-stat-val">@player.H</span></div>
                                <div class="m-stat"><span class="m-stat-label">R</span><span class="m-stat-val">@player.R</span></div>
                                <div class="m-stat"><span class="m-stat-label">RBI</span><span class="m-stat-val">@player.RBI</span></div>
                                <div class="m-stat"><span class="m-stat-label">HR</span><span class="m-stat-val">@player.HR</span></div>
                            </div>
                        </div>
                    }
                    
                    @* Mobile Team Totals *@
                    <div class="mobile-player-card" style="border: 2px solid var(--isotopes-accent); background: #f0f7ff;">
                        <div class="mobile-card-header">
                            <div class="mobile-card-name" style="color: var(--isotopes-accent)">TEAM TOTALS</div>
                        </div>
                        <div class="mobile-card-stats">
                            <div class="m-stat"><span class="m-stat-label">AVG</span><span class="m-stat-val">@teamTotals.AVG.ToString(".000")</span></div>
                            <div class="m-stat"><span class="m-stat-label">OBP</span><span class="m-stat-val">@teamTotals.OBP.ToString(".000")</span></div>
                            <div class="m-stat"><span class="m-stat-label">H</span><span class="m-stat-val">@teamTotals.H</span></div>
                            <div class="m-stat"><span class="m-stat-label">R</span><span class="m-stat-val">@teamTotals.R</span></div>
                            <div class="m-stat"><span class="m-stat-label">RBI</span><span class="m-stat-val">@teamTotals.RBI</span></div>
                            <div class="m-stat"><span class="m-stat-label">HR</span><span class="m-stat-val">@teamTotals.HR</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Season> seasons = new();
    private List<PlayerStatsSummary> players = new();
    private PlayerStatsSummary teamTotals = new();
    private string filterText = "";
    private bool isLoading = true;
    private bool showSkeleton = false;
    private bool showSeasonModal = false;
    private bool showSortModal = false;

    private string currentSortColumn = "AVG";
    private bool isAscending = false;

    private string[] AllSortableStats = { "Name", "GP", "PA", "AB", "R", "H", "2B", "3B", "HR", "RBI", "BB", "K", "AVG", "OBP" };

    private IEnumerable<PlayerStatsSummary> FilteredPlayers => 
        players.Where(p => string.IsNullOrEmpty(filterText) || 
                          p.PlayerName.Contains(filterText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            List<Season> allSeasons = await StatsService.GetSeasonsAsync();
            seasons = allSeasons.Where(s => s.IsActive).ToList();

            if (SharedState.SelectedSeasonId == 0 && seasons.Any())
            {
                SharedState.SelectedSeasonId = seasons.First().Id;
            }

            ProtectedBrowserStorageResult<int> seasonResult = await ProtectedSessionStore.GetAsync<int>("SelectedSeasonId");
            if (seasonResult.Success && seasons.Any(s => s.Id == seasonResult.Value))
            {
                SharedState.SelectedSeasonId = seasonResult.Value;
            }

            ProtectedBrowserStorageResult<string> filterResult = await ProtectedSessionStore.GetAsync<string>("PlayerFilterText");
            if (filterResult.Success && !string.IsNullOrEmpty(filterResult.Value))
            {
                filterText = filterResult.Value;
                SessionState.FilterText = filterText;
            }

            currentSortColumn = SessionState.OutcomesSortColumn;
            isAscending = SessionState.OutcomesIsAscending;
        }
        catch (Exception)
        {
            // Defaults handled
        }

        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        isLoading = true;
        showSkeleton = false;

        _ = Task.Run(async () => {
            await Task.Delay(250);
            if (isLoading) 
            {
                showSkeleton = true;
                await InvokeAsync(StateHasChanged);
            }
        });

        try 
        {
            players = await StatsService.GetStatsSummaryAsync(SharedState.SelectedSeasonId);
            teamTotals = await StatsService.GetTeamTotalsAsync(SharedState.SelectedSeasonId);
            filterText = SessionState.FilterText;
            Sort(currentSortColumn, false);
        }
        catch (Exception)
        {
            players = new List<PlayerStatsSummary>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSeasonChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            SharedState.SelectedSeasonId = id;
            await ProtectedSessionStore.SetAsync("SelectedSeasonId", id);
            await LoadData();
        }
    }

    private void ToggleSeasonModal() => showSeasonModal = !showSeasonModal;
    private void ToggleSortModal() => showSortModal = !showSortModal;

    private async Task SelectMobileSeason(int id)
    {
        SharedState.SelectedSeasonId = id;
        await ProtectedSessionStore.SetAsync("SelectedSeasonId", id);
        showSeasonModal = false;
        await LoadData();
    }

    private async Task ClearFilter()
    {
        filterText = "";
        await UpdateFilterState();
    }

    private async Task UpdateFilterState()
    {
        SessionState.FilterText = filterText;
        await ProtectedSessionStore.SetAsync("PlayerFilterText", filterText);
    }

    private void NavigateToLogs(string playerName)
    {
        NavigationManager.NavigateTo($"playerlogs/{Uri.EscapeDataString(playerName)}");
    }

    private void Sort(string column, bool toggle = true)
    {
        if (toggle)
        {
            if (currentSortColumn == column) isAscending = !isAscending;
            else { currentSortColumn = column; isAscending = column == "Name"; }
        }

        players = column switch
        {
            "Name" => isAscending ? players.OrderBy(p => p.PlayerName).ToList() : players.OrderByDescending(p => p.PlayerName).ToList(),
            "GP" => isAscending ? players.OrderBy(p => p.GamesPlayed).ToList() : players.OrderByDescending(p => p.GamesPlayed).ToList(),
            "PA" => isAscending ? players.OrderBy(p => p.PA).ToList() : players.OrderByDescending(p => p.PA).ToList(),
            "AB" => isAscending ? players.OrderBy(p => p.AB).ToList() : players.OrderByDescending(p => p.AB).ToList(),
            "R" => isAscending ? players.OrderBy(p => p.R).ToList() : players.OrderByDescending(p => p.R).ToList(),
            "H" => isAscending ? players.OrderBy(p => p.H).ToList() : players.OrderByDescending(p => p.H).ToList(),
            "2B" => isAscending ? players.OrderBy(p => p.H2B).ToList() : players.OrderByDescending(p => p.H2B).ToList(),
            "3B" => isAscending ? players.OrderBy(p => p.H3B).ToList() : players.OrderByDescending(p => p.H3B).ToList(),
            "HR" => isAscending ? players.OrderBy(p => p.HR).ToList() : players.OrderByDescending(p => p.HR).ToList(),
            "RBI" => isAscending ? players.OrderBy(p => p.RBI).ToList() : players.OrderByDescending(p => p.RBI).ToList(),
            "BB" => isAscending ? players.OrderBy(p => p.BB).ToList() : players.OrderByDescending(p => p.BB).ToList(),
            "K" => isAscending ? players.OrderBy(p => p.K).ToList() : players.OrderByDescending(p => p.K).ToList(),
            "AVG" => isAscending ? players.OrderBy(p => p.AVG).ToList() : players.OrderByDescending(p => p.AVG).ToList(),
            "OBP" => isAscending ? players.OrderBy(p => p.OBP).ToList() : players.OrderByDescending(p => p.OBP).ToList(),
            _ => players
        };

        if (toggle) { SessionState.OutcomesSortColumn = column; SessionState.OutcomesIsAscending = isAscending; }
    }

    private string GetSortIcon(string column)
    {
        if (currentSortColumn != column) return "";
        return isAscending ? "▴" : "▾";
    }
}

<style>
    .header-with-filter {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .filter-container {
        flex: 1;
        max-width: 400px;
    }

    .search-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .clear-button {
        position: absolute;
        right: 10px;
        background: #eee;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #666;
        font-size: 12px;
        transition: background 0.2s;
    }

    .clear-button:hover {
        background: #ddd;
        color: #333;
    }
</style>
