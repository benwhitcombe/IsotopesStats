@page "/lineup"
@using IsotopesStats.Domain.Models
@using IsotopesStats.Website.Services
@inject IStatsRepository StatsRepository
@inject SharedSessionState SharedState
@inject SessionStorageService SessionStorage
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@implements IDisposable

<PageTitle>Isotopes - Lineup</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Lineup</h3>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <SeasonSelector 
            Seasons="@seasons" 
            SelectedSeasonId="@selectedSeasonId" 
            OnSeasonSelected="OnSeasonSelected"
            AllowAllSeasons="false" />
    </div>
</div>

@if (isLoading)
{
    <LoadingIndicator />
}
else
{
    <CustomErrorBoundary>
    <div class="lineup-card-container">
                <div class="lineup-card-header">
                    <div class="team-name">ISOTOPES</div>
                    <div class="card-title">LINEUP CARD</div>
                </div>
                
                <div class="lineup-content-wrapper">
                    <div class="table-pane @(activeViewMode == "lineup" ? "d-flex" : "d-none d-xl-flex") @(selectedBattingIndex != null ? "table-active" : "")">
                        <div class="lineup-table-wrapper">
                            <table class="lineup-table">
                                <thead>
                                    <tr>
                                        <th style="width: 40px;">#</th>
                                        <th>BATTING ORDER</th>
                                        <th style="width: 80px;">POS</th>
                                    </tr>
                                </thead>
                                <tbody @ref="tbodyRef">
                                    @for (int i = 0; i < battingOrder.Count; i++)
                                    {
                                        int index = i;
                                        BattingOrderEntry entry = battingOrder[index];
                                        bool isEntrySelected = IsEntrySelected(entry);
                                        
                                        DefenseField.AnimationState? rowState = null;
                                        rowAnimations.TryGetValue(entry, out rowState);
                                        bool isRowSwapping = rowState?.Type == DefenseField.AnimationType.Swapped;
                                        bool isRowRemoving = rowState?.Type == DefenseField.AnimationType.Removed;

                                        DefenseField.AnimationState? posState = null;
                                        posAnimations.TryGetValue(entry, out posState);
                                        bool isPosSwapping = posState?.Type == DefenseField.AnimationType.Swapped;
                                        bool isPosRemoving = posState?.Type == DefenseField.AnimationType.Removed;

                                        <tr @key="entry"
                                            id="@($"row-{index}")"
                                            class="reorderable-row @(entry.PlayerId == null ? "empty-row" : "") @(entry == draggedEntry ? "dragging" : "") @((selectedBattingIndex == index && draggingType == DragMode.None) ? "selected" : "") @(isRowSwapping ? "just-swapped" : "") @(isRowRemoving ? "just-removed" : "")">
                                            <td class="pos-num" 
                                                @onclick="() => HandleNumberClick(index)"
                                                style="cursor: pointer;">
                                                @entry.OrderNumber
                                            </td>
                                            <td class="player-select-cell">
                                                <PlayerAutocompleteCell 
                                                    @ref="playerCells[index]"
                                                    Value="@(players?.FirstOrDefault(p => p.Id == entry.PlayerId)?.Name ?? string.Empty)"
                                                    Players="@players"
                                                    PlayerAssignments="@playerAssignments"
                                                    IsMobile="@isMobile"
                                                    OnSelected="@(p => HandleOrderSelection(entry, p))"
                                                    OnKeyDown="@(e => HandleKeyDown(index, e))"
                                                    OnCommit="@(() => FocusNextPlayer(index))"
                                                    OnFocused="@(() => HandleFocus(index))"
                                                    OnBlurred="@(() => HandleBlur(index))" />
                                            </td>
                                            <td class="pos-abbr @(entry.PlayerId == null ? "disabled" : "") @(isEntrySelected && isExplicitlySelected && draggingType == DragMode.None ? "selected" : "") @(isPosSwapping ? "just-swapped" : "") @(isPosRemoving ? "just-removed" : "")" 
                                                id="@($"pos-{index}")">
                                                <PositionAutocompleteCell 
                                                    @ref="posCells[index]"
                                                    Value="@GetEntryPosition(entry)"
                                                    AvailablePositions="@AvailablePositions"
                                                    IsMobile="@isMobile"
                                                    IsInherited="@IsPositionInherited(entry)"
                                                    OnSelected="@(val => HandlePositionChange(entry, val))"
                                                    IsDisabled="@(entry.PlayerId == null)"
                                                    OnFocused="@(() => HandleFocus(index))"
                                                    OnBlurred="@(() => HandleBlur(index))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="lineup-actions border-top">
                            <div class="d-flex flex-wrap gap-2 justify-content-center p-3">
                                <button class="view-btn" style="min-width: 100px;" @onclick="ClearAll">Clear All</button>
                                <button class="view-btn active d-xl-none" style="min-width: 100px;" @onclick='() => SetViewMode("field")'>View Defense</button>
                            </div>
                        </div>
                    </div>

                    <div class="field-pane @(activeViewMode == "field" ? "d-flex" : "d-none d-xl-flex")">

                        <div class="field-container-sticky">
                            <div class="field-header">
                                <div class="inning-selector-row">
                                    <div class="inning-label">INNING</div>
                                    <div class="inning-buttons">
                                        @for (int i = 1; i <= 7; i++)
                                        {
                                            int inning = i;
                                            <button class="inning-btn @(selectedInning == inning ? "active" : "")" @onclick="() => ToggleInning(inning)">@inning</button>
                                        }
                                    </div>
                                </div>
                            </div>

                            <DefenseField 
                                Assignments="@fieldAssignments" 
                                BenchPlayers="@benchPlayers" 
                                Players="@players"
                                BattingOrderPlayerIds="@availablePlayerIds"
                                PlayerAssignments="@playerAssignments"
                                SelectedIndex="@selectedIndex" 
                                SelectedFromBench="@selectedFromBench" 
                                IsExplicitlySelected="@isExplicitlySelected"
                                DragTargetIndex="@dragTargetIndex"
                                DragTargetFromBench="@dragTargetFromBench"
                                AnimationCounters="@animationCounters" 
                                OnPlayerClick="@(e => HandleFieldClick(e.Index, e.FromBench))"
                                OnDeselect="HandleDeselect"
                                IsEditable="true"
                                MaxWidth="680" />
                            
                            <div class="lineup-actions border-top">
                                <div class="d-flex flex-wrap gap-2 justify-content-center p-3">
                                    <button class="view-btn active d-xl-none" style="min-width: 100px;" @onclick='() => SetViewMode("lineup")'>View Lineup</button>
                                    <button class="view-btn" style="min-width: 100px;" @onclick="ResetInning">Reset Inning</button>
                                    <button class="view-btn" style="min-width: 100px;" @onclick="BenchAll">Bench All</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="mt-3 d-flex justify-content-center">
                <button class="view-btn active share-btn" @onclick="ShareLineup">Share</button>
            </div>
        </CustomErrorBoundary>

        @if (showToast)
        {
            <div class="toast-notification-simple">
                Copied to clipboard!
            </div>
        }
}

@code {
    [Parameter] [SupplyParameterFromQuery(Name = "p")] public string? LineupData { get; set; }

    private string activeViewMode = "lineup";
    private bool isMobile = false;

    private ElementReference tbodyRef;
    private DotNetObjectReference<Lineup>? objRef;
    private bool isSortableInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !isSortableInitialized)
        {
            try
            {
                isSortableInitialized = true;
                objRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("initLineupSortable", tbodyRef, objRef);
            }
            catch (Exception)
            {
                isSortableInitialized = false; // Retry on next render if failed
            }
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }

    [JSInvokable]
    public void OnRowReordered(int oldIndex, int newIndex)
    {
        if (oldIndex == newIndex || oldIndex < 0 || newIndex < 0 || oldIndex >= battingOrder.Count || newIndex >= battingOrder.Count) return;
        
        BattingOrderEntry draggedEntry = battingOrder[oldIndex];
        BattingOrderEntry targetEntry = battingOrder[newIndex];

        if (targetEntry.PlayerId == null)
        {
            // SWAP for empty rows
            battingOrder[oldIndex] = targetEntry;
            battingOrder[newIndex] = draggedEntry;
        }
        else
        {
            // INSERT for occupied rows
            battingOrder.Remove(draggedEntry);
            int insertIdx = battingOrder.IndexOf(targetEntry);
            battingOrder.Insert(insertIdx, draggedEntry);
        }

        ReassignOrderNumbers();
        
        _ = TriggerRowAnimation(draggedEntry, DefenseField.AnimationType.Swapped);
        
        AddEmptyRowIfLastRowFilled();
        TrimEmptyRows();
        _ = UpdateUrl();
        StateHasChanged();
    }

    [JSInvokable]
    public void OnPosSwapped(int oldIndex, int newIndex)
    {
        if (oldIndex == newIndex || oldIndex < 0 || newIndex < 0 || oldIndex >= battingOrder.Count || newIndex >= battingOrder.Count) return;
        
        BattingOrderEntry entry1 = battingOrder[oldIndex];
        BattingOrderEntry entry2 = battingOrder[newIndex];

        if (entry1.PlayerId == null && entry2.PlayerId == null) return;

        // Swap position abbreviations
        string tempPos = entry1.PositionAbbreviation;
        entry1.PositionAbbreviation = entry2.PositionAbbreviation;
        entry2.PositionAbbreviation = tempPos;

        // Cleanup if one was empty
        if (entry1.PlayerId == null) entry1.PositionAbbreviation = string.Empty;
        if (entry2.PlayerId == null) entry2.PositionAbbreviation = string.Empty;

        _ = TriggerPosAnimation(entry1, DefenseField.AnimationType.Swapped);
        _ = TriggerPosAnimation(entry2, DefenseField.AnimationType.Swapped);

        (int Index, bool FromBench)? loc1 = GetFieldOrBenchIndex(entry1);
        (int Index, bool FromBench)? loc2 = GetFieldOrBenchIndex(entry2);
        if (loc1.HasValue) _ = TriggerAnimation(loc1.Value.Index, loc1.Value.FromBench, DefenseField.AnimationType.Swapped);
        if (loc2.HasValue) _ = TriggerAnimation(loc2.Value.Index, loc2.Value.FromBench, DefenseField.AnimationType.Swapped);

        _ = UpdateUrl();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnTableDroppedOnField(int rowIndex, int? fieldIndex, bool fromBench)
    {
        if (rowIndex < 0 || rowIndex >= battingOrder.Count) return;
        var entry = battingOrder[rowIndex];
        if (entry.PlayerId == null) return;

        if (fromBench)
        {
            HandlePositionChange(entry, "B");
        }
        else if (fieldIndex.HasValue && fieldIndex >= 0 && fieldIndex < fieldPositions.Count)
        {
            HandlePositionChange(entry, fieldPositions[fieldIndex.Value].Abbreviation);
        }
        await Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnFieldSwap(int index1, bool fromBench1, int? index2, bool fromBench2)
    {
        // Simulate a click sequence to reuse HandleFieldClick logic
        // Reset current selection
        selectedIndex = index1;
        selectedFromBench = fromBench1;
        isExplicitlySelected = true;

        if (index2.HasValue)
        {
            await HandleFieldClick(index2.Value, fromBench2);
        }
        else if (fromBench2)
        {
            // Dropped on bench container but not a specific name
            // If fromBench1 was true, do nothing. If false, move to bench.
            if (!fromBench1)
            {
                await HandleFieldClick(index1, fromBench1); // Toggles to bench
            }
        }
        
        // Ensure cleanup
        selectedIndex = null;
        selectedFromBench = null;
        isExplicitlySelected = false;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnFieldDroppedOnTable(int fieldIndex, bool fromBench, int rowIndex)
    {
        if (rowIndex < 0 || rowIndex >= battingOrder.Count) return;
        
        int? playerId = fromBench 
            ? GetBenchPlayerId(fieldIndex) 
            : battingOrder.FirstOrDefault(le => GetEntryPosition(le) == fieldPositions[fieldIndex].Abbreviation)?.PlayerId;

        if (!playerId.HasValue) return;

        var targetEntry = battingOrder[rowIndex];
        var player = players?.FirstOrDefault(p => p.Id == playerId.Value);
        
        if (player != null)
        {
            await HandleOrderSelection(targetEntry, player);
        }
    }

    private enum DragMode { None, Row, Position }
    private DragMode draggingType = DragMode.None;

    private void SetViewMode(string mode)
    {
        activeViewMode = mode;
        StateHasChanged();
    }

    private List<Season> seasons = new List<Season>();
    private List<Player> players = new List<Player>();
    private List<int> availablePlayerIds = new List<int>();
    private int selectedSeasonId;
    private bool isLoading = true;
    private bool isInitializing = false;
    private bool showToast = false;

    private Dictionary<int, PlayerAutocompleteCell> playerCells = new();
    private Dictionary<int, PositionAutocompleteCell> posCells = new();

    private BattingOrderEntry? draggedEntry;
    private BattingOrderEntry? targetEntry;

    private int? dragTargetIndex;
    private bool? dragTargetFromBench;

    private bool IsEntrySelected(BattingOrderEntry entry)
    {
        if (selectedIndex == null) return false;
        
        if (selectedFromBench == true)
        {
            List<int> benchIds = GetBenchIds();
            if (selectedIndex >= 0 && selectedIndex < benchIds.Count)
            {
                return entry.PlayerId == benchIds[selectedIndex.Value];
            }
        }
        else if (selectedFromBench == false)
        {
            if (selectedIndex >= 0 && selectedIndex < fieldPositions.Count)
            {
                string abbr = fieldPositions[selectedIndex.Value].Abbreviation;
                return entry.PositionAbbreviation == abbr;
            }
        }
        return false;
    }

    private void ReassignOrderNumbers()
    {
        for (int i = 0; i < battingOrder.Count; i++)
        {
            battingOrder[i].OrderNumber = i + 1;
        }
    }

    private class BattingOrderEntry
    {
        public int OrderNumber { get; set; }
        public int? PlayerId { get; set; }
        public string PositionAbbreviation { get; set; } = string.Empty;
        public Dictionary<int, string> InningPositions { get; set; } = new();
    }

    private class FieldPosition
    {
        public string Abbreviation { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public double X { get; set; }
        public double Y { get; set; }
    }

    private List<BattingOrderEntry> battingOrder = new();
    private List<FieldPosition> fieldPositions = new();

    private static readonly List<(string Abbr, string Label)> AvailablePositions = new()
    {
        ("B", "Bench"), ("P", "Pitcher"), ("C", "Catcher"), ("1B", "1st Base"), ("2B", "2nd Base"),
        ("3B", "3rd Base"), ("SS", "Short Stop"), ("LF", "Left Field"), ("LC", "Left Center"),
        ("RC", "Right Center"), ("RF", "Right Field")
    };

    private int selectedInning = 1;

    private void ToggleInning(int inning)
    {
        selectedInning = inning;
        StateHasChanged();
    }

    private void ResetInning()
    {
        if (selectedInning == 1)
        {
            BenchAll();
            return;
        }

        bool changed = false;
        foreach (BattingOrderEntry entry in battingOrder)
        {
            if (entry.InningPositions.ContainsKey(selectedInning))
            {
                (int Index, bool FromBench)? oldLoc = GetFieldOrBenchIndex(entry);
                entry.InningPositions.Remove(selectedInning);
                (int Index, bool FromBench)? newLoc = GetFieldOrBenchIndex(entry);

                _ = TriggerPosAnimation(entry, DefenseField.AnimationType.Removed);
                if (oldLoc.HasValue && !oldLoc.Value.FromBench) _ = TriggerAnimation(oldLoc.Value.Index, false, DefenseField.AnimationType.Removed);
                if (newLoc.HasValue) _ = TriggerAnimation(newLoc.Value.Index, newLoc.Value.FromBench, DefenseField.AnimationType.Swapped);
                changed = true;
            }
        }

        if (changed)
        {
            StateHasChanged();
            _ = UpdateUrl();
        }
    }

    private void BenchAll()
    {
        bool changed = false;
        foreach (BattingOrderEntry entry in battingOrder)
        {
            if (entry.PlayerId == null) continue;

            string currentPos = GetEntryPosition(entry);
            if (currentPos == "B") continue;

            (int Index, bool FromBench)? oldLoc = GetFieldOrBenchIndex(entry);

            if (selectedInning == 1)
            {
                entry.PositionAbbreviation = "B";
            }
            else
            {
                entry.InningPositions[selectedInning] = "B";
            }

            (int Index, bool FromBench)? newLoc = GetFieldOrBenchIndex(entry);

            _ = TriggerPosAnimation(entry, DefenseField.AnimationType.Removed);
            if (oldLoc.HasValue && !oldLoc.Value.FromBench) _ = TriggerAnimation(oldLoc.Value.Index, false, DefenseField.AnimationType.Removed);
            if (newLoc.HasValue) _ = TriggerAnimation(newLoc.Value.Index, newLoc.Value.FromBench, DefenseField.AnimationType.Swapped);

            changed = true;
        }

        if (changed)
        {
            StateHasChanged();
            _ = UpdateUrl();
        }
    }

    private string GetEntryPosition(BattingOrderEntry entry, int inning = -1)
    {
        int targetInning = inning == -1 ? selectedInning : inning;

        // Waterfall: check current inning down to 2, then fallback to baseline (Inning 1)
        for (int i = targetInning; i >= 2; i--)
        {
            if (entry.InningPositions.TryGetValue(i, out string? pos) && !string.IsNullOrEmpty(pos))
            {
                return pos;
            }
        }
        return entry.PositionAbbreviation;
    }

    private bool IsPositionInherited(BattingOrderEntry entry, int inning = -1)
    {
        int targetInning = inning == -1 ? selectedInning : inning;
        if (targetInning <= 1) return false;
        return !entry.InningPositions.ContainsKey(targetInning);
    }

    private void InitializeBattingOrder()
    {
        battingOrder = new List<BattingOrderEntry>();
        for (int i = 1; i <= 10; i++)
        {
            battingOrder.Add(new BattingOrderEntry { OrderNumber = i });
        }

        fieldPositions = new List<FieldPosition>()
        {
            new FieldPosition { Abbreviation = "P", Label = "Pitcher", X = 50, Y = 62 },
            new FieldPosition { Abbreviation = "C", Label = "Catcher", X = 50, Y = 92 },
            new FieldPosition { Abbreviation = "1B", Label = "1st Base", X = 70, Y = 62 },
            new FieldPosition { Abbreviation = "2B", Label = "2nd Base", X = 65, Y = 48 },
            new FieldPosition { Abbreviation = "3B", Label = "3rd Base", X = 30, Y = 62 },
            new FieldPosition { Abbreviation = "SS", Label = "Short Stop", X = 35, Y = 48 },
            new FieldPosition { Abbreviation = "LF", Label = "Left Field", X = 15, Y = 35 },
            new FieldPosition { Abbreviation = "LC", Label = "Left Center", X = 38, Y = 15 },
            new FieldPosition { Abbreviation = "RC", Label = "Right Center", X = 62, Y = 15 },
            new FieldPosition { Abbreviation = "RF", Label = "Right Field", X = 85, Y = 35 }
        };
    }

    private async Task HandleKeyDown(int index, KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await FocusPlayer(index + 1);
        }
        else if (e.Key == "Tab" || e.Key == "ArrowRight")
        {
            if (!e.ShiftKey)
            {
                await FocusPlayer(index + 1);
            }
        }
        else if (e.Key == "ArrowLeft")
        {
            await FocusPlayer(index - 1);
        }
    }

    private async Task FocusPlayer(int index)
    {
        if (index < 0 || index >= battingOrder.Count) return;

        // Try to focus multiple times to account for Blazor's render cycle
        for (int i = 0; i < 10; i++)
        {
            if (playerCells.TryGetValue(index, out PlayerAutocompleteCell? cell) && cell != null)
            {
                try
                {
                    await cell.FocusAsync();
                    return;
                }
                catch (Exception)
                {
                    // Element might not be ready or valid yet
                }
            }
            await Task.Delay(20);
        }
    }

    private async Task FocusNextPlayer(int currentIndex)
    {
        await FocusPlayer(currentIndex + 1);
    }

    private void HandleFocus(int index)
    {
        focusedBattingIndex = index;
        
        if (!isExplicitlySelected)
        {
            BattingOrderEntry entry = battingOrder[index];
            (int Index, bool FromBench)? loc = GetFieldOrBenchIndex(entry);
            if (loc.HasValue)
            {
                selectedIndex = loc.Value.Index;
                selectedFromBench = loc.Value.FromBench;
            }
            else
            {
                selectedIndex = null;
                selectedFromBench = null;
            }
        }
    }

    private void HandleBlur(int index)
    {
        if (focusedBattingIndex == index)
        {
            focusedBattingIndex = null;
            if (!isExplicitlySelected)
            {
                selectedIndex = null;
                selectedFromBench = null;
            }
        }
        TrimEmptyRows();
    }

    private void TrimEmptyRows()
    {
        if (isInitializing || players == null) return;
        bool changed = false;
        
        int maxAllowedRows = players.Count;
        
        // 1. Never allow more rows than players
        while (battingOrder.Count > maxAllowedRows)
        {
            int lastIdx = battingOrder.Count - 1;
            battingOrder.RemoveAt(lastIdx);
            playerCells.Remove(lastIdx);
            posCells.Remove(lastIdx);
            changed = true;
        }

        // 2. Keep trimming as long as we have extra trailing empty rows and are above the 10-row minimum
        // (But only if we have at least 10 players to begin with)
        int minRows = Math.Min(10, maxAllowedRows);
        while (battingOrder.Count > minRows)
        {
            int lastIdx = battingOrder.Count - 1;
            bool lastEmpty = battingOrder[lastIdx].PlayerId == null;
            
            if (lastEmpty)
            {
                bool secondToLastEmpty = battingOrder[lastIdx - 1].PlayerId == null;
                bool anyUnassigned = players.Any(p => !battingOrder.Any(le => le.PlayerId == p.Id));
                
                // Remove if there are two trailing empty rows OR if there's one empty row but no more unassigned players
                if (secondToLastEmpty || !anyUnassigned)
                {
                    if (focusedBattingIndex == lastIdx) break;
                    
                    battingOrder.RemoveAt(lastIdx);
                    playerCells.Remove(lastIdx);
                    posCells.Remove(lastIdx);
                    changed = true;
                }
                else
                {
                    break;
                }
            }
            else
            {
                break;
            }
        }

        if (changed) StateHasChanged();
    }

    private void AddEmptyRowIfLastRowFilled()
    {
        if (players == null) return;
        
        if (battingOrder.Count > 0 && battingOrder.Last().PlayerId != null)
        {
            if (battingOrder.Count < players.Count)
            {
                bool anyUnassigned = players.Any(p => !battingOrder.Any(le => le.PlayerId == p.Id));
                if (anyUnassigned)
                {
                    battingOrder.Add(new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 });
                }
            }
        }
    }

    private async Task HandleOrderSelection(BattingOrderEntry entry, Player? newPlayer)
    {
        if (entry.PlayerId == newPlayer?.Id) return;

        (int Index, bool FromBench)? oldLoc = GetFieldOrBenchIndex(entry);
        int index = battingOrder.IndexOf(entry);
        int? oldPlayerId = entry.PlayerId;
        bool swapped = false;

        if (newPlayer != null)
        {
            int prevOrderIdx = battingOrder.FindIndex(le => le != entry && le.PlayerId == newPlayer.Id);
            if (prevOrderIdx != -1)
            {
                BattingOrderEntry prevEntry = battingOrder[prevOrderIdx];
                int? tempPlayerId = prevEntry.PlayerId;
                string tempPos = prevEntry.PositionAbbreviation;
                
                prevEntry.PlayerId = oldPlayerId;
                prevEntry.PositionAbbreviation = entry.PositionAbbreviation;
                
                entry.PlayerId = tempPlayerId;
                entry.PositionAbbreviation = tempPos;
                
                if (entry.PlayerId == null) entry.PositionAbbreviation = string.Empty;
                if (prevEntry.PlayerId == null) prevEntry.PositionAbbreviation = string.Empty;

                _ = TriggerRowAnimation(entry, DefenseField.AnimationType.Swapped);
                _ = TriggerRowAnimation(prevEntry, DefenseField.AnimationType.Swapped);

                (int Index, bool FromBench)? prevLoc = GetFieldOrBenchIndex(prevEntry);
                if (prevLoc.HasValue) _ = TriggerAnimation(prevLoc.Value.Index, prevLoc.Value.FromBench, DefenseField.AnimationType.Swapped);
                swapped = true;
            }
        }

        if (!swapped)
        {
            entry.PlayerId = newPlayer?.Id;
            if (newPlayer == null) 
            {
                entry.PositionAbbreviation = string.Empty;
                _ = TriggerRowAnimation(entry, DefenseField.AnimationType.Removed);
            }
            else 
            {
                if (string.IsNullOrEmpty(entry.PositionAbbreviation))
                {
                    entry.PositionAbbreviation = "B";
                }
                _ = TriggerRowAnimation(entry, DefenseField.AnimationType.Swapped);
            }

            if (oldPlayerId.HasValue && !IsPlayerInBattingOrder(oldPlayerId.Value))
            {
                availablePlayerIds.Remove(oldPlayerId.Value);
            }

            if (newPlayer != null && !availablePlayerIds.Contains(newPlayer.Id))
            {
                availablePlayerIds.Add(newPlayer.Id);
            }
        }

        AddEmptyRowIfLastRowFilled();
        TrimEmptyRows();

        (int Index, bool FromBench)? loc = GetFieldOrBenchIndex(entry);
        if (loc.HasValue)
        {
            _ = TriggerAnimation(loc.Value.Index, loc.Value.FromBench, entry.PlayerId == null ? DefenseField.AnimationType.Removed : DefenseField.AnimationType.Swapped);
        }
        else if (oldLoc.HasValue && entry.PlayerId == null && !oldLoc.Value.FromBench)
        {
            _ = TriggerAnimation(oldLoc.Value.Index, false, DefenseField.AnimationType.Removed);
        }
        
        StateHasChanged();
        await Task.Yield();
        _ = UpdateUrl();
    }

    private void HandlePositionChange(BattingOrderEntry entry, string? newPos)
    {
        if (entry.PlayerId == null) return;

        string pos = newPos ?? "B";
        string oldPos = GetEntryPosition(entry);
        if (pos == oldPos) return;

        int startInning = selectedInning;

        if (selectedInning == 1) // Baseline (Inning 1)
        {
            (int Index, bool FromBench)? oldLoc = GetFieldOrBenchIndex(entry);

            // SWAP logic: If target position is occupied, move that player to our old position
            if (!string.IsNullOrEmpty(pos) && pos != "B")
            {
                foreach (BattingOrderEntry le in battingOrder)
                {
                    if (le != entry && le.PositionAbbreviation == pos)
                    {
                        le.PositionAbbreviation = oldPos;
                        _ = TriggerPosAnimation(le, DefenseField.AnimationType.Swapped);
                        (int Index, bool FromBench)? otherNewLoc = GetFieldOrBenchIndex(le);
                        if (otherNewLoc.HasValue) _ = TriggerAnimation(otherNewLoc.Value.Index, otherNewLoc.Value.FromBench, DefenseField.AnimationType.Swapped);
                    }
                }
            }

            entry.PositionAbbreviation = pos;
            entry.InningPositions.Remove(1); // Ensure no override for inning 1, it IS the baseline

            _ = TriggerPosAnimation(entry, DefenseField.AnimationType.Swapped);
            (int Index, bool FromBench)? loc = GetFieldOrBenchIndex(entry);
            if (loc.HasValue) _ = TriggerAnimation(loc.Value.Index, loc.Value.FromBench, DefenseField.AnimationType.Swapped);
            if (oldLoc.HasValue && oldLoc.Value.FromBench == false && (loc == null || loc.Value.FromBench == true || loc.Value.Index != oldLoc.Value.Index))
            {
                _ = TriggerAnimation(oldLoc.Value.Index, false, DefenseField.AnimationType.Removed);
            }
        }
        else // Overrides (Innings 2-7)
        {
            (int Index, bool FromBench)? oldLoc = GetFieldOrBenchIndex(entry);

            // SWAP logic: If target position is occupied, move that player to our old position in this inning
            if (!string.IsNullOrEmpty(pos) && pos != "B")
            {
                foreach (BattingOrderEntry le in battingOrder)
                {
                    if (le != entry && GetEntryPosition(le) == pos)
                    {
                        le.InningPositions[selectedInning] = oldPos;
                        _ = TriggerPosAnimation(le, DefenseField.AnimationType.Swapped);
                        (int Index, bool FromBench)? otherNewLoc = GetFieldOrBenchIndex(le);
                        if (otherNewLoc.HasValue) _ = TriggerAnimation(otherNewLoc.Value.Index, otherNewLoc.Value.FromBench, DefenseField.AnimationType.Swapped);
                    }
                }
            }
            entry.InningPositions[selectedInning] = pos;

            _ = TriggerPosAnimation(entry, DefenseField.AnimationType.Swapped);
            (int Index, bool FromBench)? loc = GetFieldOrBenchIndex(entry);
            if (loc.HasValue) _ = TriggerAnimation(loc.Value.Index, loc.Value.FromBench, DefenseField.AnimationType.Swapped);
            if (oldLoc.HasValue && oldLoc.Value.FromBench == false && (loc == null || loc.Value.FromBench == true || loc.Value.Index != oldLoc.Value.Index))
            {
                _ = TriggerAnimation(oldLoc.Value.Index, false, DefenseField.AnimationType.Removed);
            }
        }
        // --- FUTURE CONFLICT RESOLUTION ---
        // If we just assigned a field position, ensure it doesn't conflict with future overrides.
        if (pos != "B" && !string.IsNullOrEmpty(pos))
        {
            for (int i = startInning + 1; i <= 7; i++)
            {
                // If entry has their own override here, the flow of the current change stops anyway.
                if (entry.InningPositions.ContainsKey(i)) break;

                // Check if anyone else has an EXPLICIT override for this position in this future inning.
                BattingOrderEntry? conflict = battingOrder.FirstOrDefault(le => le != entry && le.InningPositions.TryGetValue(i, out string? p) && p == pos);
                if (conflict != null)
                {
                    // entry can't flow into this inning because conflict 'wins' with their override.
                    // Move entry to bench here to stop the flow.
                    entry.InningPositions[i] = "B";
                    break;
                }
            }
        }

        StateHasChanged();
        _ = UpdateUrl();
    }

    private void HandleBenchSelection(int? oldPlayerId, Player? newPlayer)
    {
        if (oldPlayerId == newPlayer?.Id) return;

        if (newPlayer != null)
        {
            int prevOrderIdx = battingOrder.FindIndex(le => le.PlayerId == newPlayer.Id);
            if (prevOrderIdx != -1)
            {
                BattingOrderEntry prevEntry = battingOrder[prevOrderIdx];
                (int Index, bool FromBench)? prevLoc = GetFieldOrBenchIndex(prevEntry);
                
                prevEntry.PlayerId = null;
                prevEntry.PositionAbbreviation = string.Empty;
                
                _ = TriggerRowAnimation(prevEntry, DefenseField.AnimationType.Removed);

                if (prevLoc.HasValue && !prevLoc.Value.FromBench) _ = TriggerAnimation(prevLoc.Value.Index, false, DefenseField.AnimationType.Removed);
            }
        }

        if (newPlayer != null && !availablePlayerIds.Contains(newPlayer.Id))
        {
            availablePlayerIds.Add(newPlayer.Id);
        }

        StateHasChanged();
        _ = UpdateUrl();

        if (newPlayer != null)
        {
            List<int> benchIds = GetBenchIds();
            int newBenchIdx = benchIds.IndexOf(newPlayer.Id);
            if (newBenchIdx != -1) _ = TriggerAnimation(newBenchIdx, true, DefenseField.AnimationType.Swapped);
        }
    }

    private bool IsPlayerInBattingOrder(int playerId) => battingOrder.Any(le => le.PlayerId == playerId);
    
    private List<int> GetBenchIds()
    {
        return availablePlayerIds.Where(id => {
            BattingOrderEntry? entry = battingOrder.FirstOrDefault(le => le.PlayerId == id);
            if (entry == null) return true;
            string pos = GetEntryPosition(entry);
            return pos == "B" || string.IsNullOrEmpty(pos);
        }).ToList();
    }

    private (int Index, bool FromBench)? GetFieldOrBenchIndex(BattingOrderEntry entry)
    {
        if (entry.PlayerId == null) return null;
        
        if (string.IsNullOrEmpty(entry.PositionAbbreviation) || entry.PositionAbbreviation == "B")
        {
            List<int> benchIds = GetBenchIds();
            int benchIdx = benchIds.IndexOf(entry.PlayerId.Value);
            if (benchIdx != -1) return (benchIdx, true);
        }
        else
        {
            int fieldIdx = fieldPositions.FindIndex(fp => fp.Abbreviation == entry.PositionAbbreviation);
            if (fieldIdx != -1) return (fieldIdx, false);
        }
        return null;
    }

    private async Task TriggerRowAnimation(BattingOrderEntry entry, DefenseField.AnimationType type = DefenseField.AnimationType.Swapped)
    {
        try
        {
            if (rowAnimations.TryGetValue(entry, out DefenseField.AnimationState? state)) { state.Count++; state.Type = type; }
            else rowAnimations[entry] = new DefenseField.AnimationState { Count = 1, Type = type };
            StateHasChanged();
            await Task.Delay(600);
            if (rowAnimations.TryGetValue(entry, out state)) { state.Count--; if (state.Count <= 0) rowAnimations.Remove(entry); StateHasChanged(); }
        }
        catch (Exception) { /* Ignore unobserved exception */ }
    }

    private async Task TriggerPosAnimation(BattingOrderEntry entry, DefenseField.AnimationType type = DefenseField.AnimationType.Swapped)
    {
        try
        {
            if (posAnimations.TryGetValue(entry, out DefenseField.AnimationState? state)) { state.Count++; state.Type = type; }
            else posAnimations[entry] = new DefenseField.AnimationState { Count = 1, Type = type };
            StateHasChanged();
            await Task.Delay(600);
            if (posAnimations.TryGetValue(entry, out state)) { state.Count--; if (state.Count <= 0) posAnimations.Remove(entry); StateHasChanged(); }
        }
        catch (Exception) { /* Ignore unobserved exception */ }
    }

    private int? selectedIndex;
    private bool? selectedFromBench;
    private int? selectedBattingIndex;
    private int? focusedBattingIndex;
    private bool isExplicitlySelected;
    
    private Dictionary<BattingOrderEntry, DefenseField.AnimationState> rowAnimations = new();
    private Dictionary<BattingOrderEntry, DefenseField.AnimationState> posAnimations = new();
    private Dictionary<(int Index, bool FromBench), DefenseField.AnimationState> animationCounters = new();

    private List<DefenseField.FieldPositionAssignment> fieldAssignments => fieldPositions?.Select(fp => 
    {
        BattingOrderEntry? entry = battingOrder?.FirstOrDefault(le => GetEntryPosition(le) == fp.Abbreviation);
        return new DefenseField.FieldPositionAssignment
        {
            PlayerName = entry?.PlayerId != null && players != null ? players.FirstOrDefault(p => p.Id == entry.PlayerId)?.Name ?? string.Empty : string.Empty,
            X = fp.X,
            Y = fp.Y,
            IsInherited = entry != null && IsPositionInherited(entry)
        };
    }).ToList() ?? new List<DefenseField.FieldPositionAssignment>();

    private Dictionary<int, string> playerAssignments 
    {
        get 
        {
            Dictionary<int, string> dict = new Dictionary<int, string>();
            if (battingOrder != null)
            {
                foreach (BattingOrderEntry le in battingOrder.Where(le => le.PlayerId.HasValue))
                {
                    dict[le.PlayerId!.Value] = le.OrderNumber.ToString();
                }
            }
            return dict;
        }
    }

    private List<DefenseField.BenchPlayerAssignment> benchPlayers => (GetBenchIds() ?? new List<int>())
        .Select(id => 
        {
            BattingOrderEntry? entry = battingOrder.FirstOrDefault(le => le.PlayerId == id);
            return new DefenseField.BenchPlayerAssignment
            {
                PlayerName = players?.FirstOrDefault(p => p.Id == id)?.Name ?? string.Empty,
                IsInherited = entry != null && IsPositionInherited(entry)
            };
        })
        .Where(bp => !string.IsNullOrEmpty(bp.PlayerName))
        .ToList();

    private void HandleDeselect()
    {
        selectedIndex = null;
        selectedFromBench = null;
        selectedBattingIndex = null;
        isExplicitlySelected = false;
        StateHasChanged();
    }

    private void HandleNumberClick(int index)
    {
        if (selectedBattingIndex == index)
        {
            HandleDeselect();
            return;
        }

        if (selectedBattingIndex != null)
        {
            // INSERT and SHIFT objects in the list
            int idx1 = selectedBattingIndex.Value;
            int idx2 = index;

            if (idx1 >= 0 && idx1 < battingOrder.Count && idx2 >= 0 && idx2 < battingOrder.Count)
            {
                BattingOrderEntry entry1 = battingOrder[idx1];
                
                battingOrder.RemoveAt(idx1);
                battingOrder.Insert(idx2, entry1);
                
                ReassignOrderNumbers();

                _ = TriggerRowAnimation(entry1, DefenseField.AnimationType.Swapped);

                HandleDeselect();
                AddEmptyRowIfLastRowFilled();
                TrimEmptyRows();
                _ = UpdateUrl();
            }
        }
        else
        {
            // SELECT
            selectedBattingIndex = index;
            isExplicitlySelected = true;

            BattingOrderEntry entry = battingOrder[index];
            (int Index, bool FromBench)? loc = GetFieldOrBenchIndex(entry);
            if (loc.HasValue)
            {
                selectedIndex = loc.Value.Index;
                selectedFromBench = loc.Value.FromBench;
            }
            else
            {
                selectedIndex = null;
                selectedFromBench = null;
            }
        }
        StateHasChanged();
    }

    private async Task HandleFieldClick(int index, bool fromBench)
    {
        selectedBattingIndex = null;
        if (selectedIndex == null || !isExplicitlySelected)
        {
            selectedIndex = index;
            selectedFromBench = fromBench;
            isExplicitlySelected = true;
            StateHasChanged();
            return;
        }

        if (selectedIndex == index && selectedFromBench == fromBench)
        {
            if (!fromBench)
            {
                string pos = fieldPositions[index].Abbreviation;
                BattingOrderEntry? entry = battingOrder.FirstOrDefault(le => GetEntryPosition(le) == pos);
                if (entry != null) HandlePositionChange(entry, "B");
            }
            selectedIndex = null;
            selectedFromBench = null;
            isExplicitlySelected = false;
            StateHasChanged();
            return;
        }

        int idx1 = selectedIndex!.Value;
        bool bench1 = selectedFromBench!.Value;
        int idx2 = index;
        bool bench2 = fromBench;

        int? id1 = bench1 ? GetBenchPlayerId(idx1) : battingOrder.FirstOrDefault(le => GetEntryPosition(le) == fieldPositions[idx1].Abbreviation)?.PlayerId;
        int? id2 = bench2 ? GetBenchPlayerId(idx2) : battingOrder.FirstOrDefault(le => GetEntryPosition(le) == fieldPositions[idx2].Abbreviation)?.PlayerId;

        if (bench1 && bench2)
        {
            if (id1.HasValue && id2.HasValue)
            {
                int pos1 = availablePlayerIds.IndexOf(id1.Value);
                int pos2 = availablePlayerIds.IndexOf(id2.Value);
                if (pos1 != -1 && pos2 != -1) { int temp = availablePlayerIds[pos1]; availablePlayerIds[pos1] = availablePlayerIds[pos2]; availablePlayerIds[pos2] = temp; }
            }
        }
        else if (bench1 && !bench2)
        {
            string pos2 = fieldPositions[idx2].Abbreviation;
            BattingOrderEntry? entry1 = battingOrder.FirstOrDefault(le => le.PlayerId == id1);
            if (entry1 == null && id1.HasValue)
            {
                entry1 = battingOrder.FirstOrDefault(le => le.PlayerId == null);
                if (entry1 == null) { entry1 = new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 }; battingOrder.Add(entry1); }
                entry1.PlayerId = id1;
            }
            if (entry1 != null) HandlePositionChange(entry1, pos2);
        }
        else if (!bench1 && bench2)
        {
            string pos1 = fieldPositions[idx1].Abbreviation;
            BattingOrderEntry? entry1 = battingOrder.FirstOrDefault(le => GetEntryPosition(le) == pos1);
            if (entry1 != null) HandlePositionChange(entry1, "B");
            
            if (id2.HasValue)
            {
                BattingOrderEntry? entry2 = battingOrder.FirstOrDefault(le => le.PlayerId == id2);
                if (entry2 == null)
                {
                    entry2 = battingOrder.FirstOrDefault(le => le.PlayerId == null);
                    if (entry2 == null) { entry2 = new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 }; battingOrder.Add(entry2); }
                    entry2.PlayerId = id2;
                }
                if (entry2 != null) HandlePositionChange(entry2, pos1);
            }
        }
        else
        {
            string pos1 = fieldPositions[idx1].Abbreviation;
            string pos2 = fieldPositions[idx2].Abbreviation;
            BattingOrderEntry? entry1 = battingOrder.FirstOrDefault(le => GetEntryPosition(le) == pos1);
            BattingOrderEntry? entry2 = battingOrder.FirstOrDefault(le => GetEntryPosition(le) == pos2);
            if (entry1 != null) HandlePositionChange(entry1, pos2);
            if (entry2 != null) HandlePositionChange(entry2, pos1);
        }

        selectedIndex = null;
        selectedFromBench = null;
        isExplicitlySelected = false;
        AddEmptyRowIfLastRowFilled();
        TrimEmptyRows();
        StateHasChanged();
        await UpdateUrl();
    }

    private int? GetBenchPlayerId(int benchIndex)
    {
        List<int> benchIds = GetBenchIds();
        if (benchIndex >= 0 && benchIndex < benchIds.Count) return benchIds[benchIndex];
        return null;
    }

    private async Task TriggerAnimation(int index, bool fromBench, DefenseField.AnimationType type = DefenseField.AnimationType.Swapped)
    {
        try
        {
            (int Index, bool FromBench) key = (index, fromBench);
            if (animationCounters.TryGetValue(key, out DefenseField.AnimationState? state)) { state.Count++; state.Type = type; }
            else animationCounters[key] = new DefenseField.AnimationState { Count = 1, Type = type };
            StateHasChanged();
            await Task.Delay(600);
            if (animationCounters.TryGetValue(key, out state)) { state.Count--; if (state.Count <= 0) animationCounters.Remove(key); StateHasChanged(); }
        }
        catch (Exception) { /* Ignore unobserved exception */ }
    }

    private string GetCurrentLineupData()
    {
        if (!availablePlayerIds.Any() && !battingOrder.Any(le => le.PlayerId.HasValue && le.PlayerId.Value > 0)) return string.Empty;
        List<(int PlayerId, string Position, Dictionary<int, string>? InningPositions)> encodedOrder = battingOrder
            .Where(le => le.PlayerId.HasValue && le.PlayerId.Value > 0)
            .Select(le => (le.PlayerId!.Value, le.PositionAbbreviation, le.InningPositions.Any() ? le.InningPositions : (Dictionary<int, string>?)null))
            .ToList();
        List<int> benchIds = availablePlayerIds.Where(id => id > 0 && !IsPlayerInBattingOrder(id)).ToList(); 
        return LineupEncoder.Encode(encodedOrder, benchIds, players);
    }

    private async Task UpdateUrl()
    {
        if (isInitializing) return;
        try
        {
            string data = GetCurrentLineupData();
            string? queryValue = string.IsNullOrEmpty(data) ? null : data;
            _appliedLineupData = data;
            await JSRuntime.InvokeVoidAsync("updateUrlQuery", "p", queryValue);
            await SaveToStorage();
        }
        catch (Exception) { /* Ignore unobserved exception */ }
    }

    private async Task SaveToStorage()
    {
        await SessionStorage.SetItemAsync($"lineup_av_{selectedSeasonId}", availablePlayerIds.Where(id => id > 0).ToList());
        List<string> savedOrder = battingOrder
            .Where(le => le.PlayerId.HasValue && le.PlayerId.Value > 0)
            .Select(le => {
                string main = $"{le.PlayerId}:{le.PositionAbbreviation}";
                if (le.InningPositions.Any())
                {
                    string innings = string.Join(",", le.InningPositions.Select(kvp => $"{kvp.Key}={kvp.Value}"));
                    return $"{main}|{innings}";
                }
                return main;
            }).ToList();
        await SessionStorage.SetItemAsync($"lineup_order_{selectedSeasonId}", savedOrder);
    }

    private string? _appliedLineupData;

    private void ApplyQueryParameters()
    {
        try
        {
            if (string.IsNullOrEmpty(LineupData) || players == null || !players.Any()) return;
            (List<(int PlayerId, string Position, Dictionary<int, string> InningPositions)> Lineup, List<int> Bench) decoded = LineupEncoder.Decode(LineupData, players);
            
            battingOrder.Clear();
            for (int i = 0; i < decoded.Lineup.Count; i++)
            {
                (int PlayerId, string Position, Dictionary<int, string> InningPositions) item = decoded.Lineup[i];
                int? playerId = item.PlayerId > 0 ? item.PlayerId : null;
                string pos = item.Position;
                if (playerId != null && string.IsNullOrEmpty(pos)) pos = "B";

                battingOrder.Add(new BattingOrderEntry { 
                    OrderNumber = i + 1, 
                    PlayerId = playerId, 
                    PositionAbbreviation = pos,
                    InningPositions = item.InningPositions ?? new Dictionary<int, string>()
                });
            }
            while (battingOrder.Count < 10) battingOrder.Add(new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 });
            if (battingOrder.Any() && battingOrder.Last().PlayerId != null) 
            {
                bool anyUnassigned = players != null && players.Any(p => !battingOrder.Any(le => le.PlayerId == p.Id));
                if (anyUnassigned)
                {
                    battingOrder.Add(new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 });
                }
            }
            
            availablePlayerIds.Clear();
            foreach ((int PlayerId, string Position, Dictionary<int, string> InningPositions) item in decoded.Lineup) if (item.PlayerId > 0) availablePlayerIds.Add(item.PlayerId);
            foreach (int id in decoded.Bench) if (id > 0 && !availablePlayerIds.Contains(id)) availablePlayerIds.Add(id);
            
            _appliedLineupData = LineupData;
        }
        catch (Exception ex)
        {
            errorMessage = $"ApplyQuery Error: {ex.Message}";
            stackTrace = ex.StackTrace;
        }
    }

    private string? errorMessage;
    private string? stackTrace;

    private async Task SetMobileFlag()
    {
        try
        {
            string ua = await JSRuntime.InvokeAsync<string>("getUserAgent");
            isMobile = !string.IsNullOrEmpty(ua) && (ua.Contains("Android") || ua.Contains("iPhone") || ua.Contains("iPad") || ua.Contains("Mobile"));
        }
        catch { isMobile = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            isInitializing = true;
            InitializeBattingOrder();
            await SetMobileFlag();
            seasons = await StatsRepository.GetSeasonsAsync();
            selectedSeasonId = SharedState.SelectedSeasonId;
            if (selectedSeasonId == 0 && seasons.Any()) selectedSeasonId = seasons.First().Id;
            await LoadPlayers();
            await LoadStateFromStorage();
            ApplyQueryParameters();
            isInitializing = false;
            _ = UpdateUrl();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            stackTrace = ex.StackTrace;
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        try
        {
            if (isInitializing) return;
            if (LineupData != _appliedLineupData) 
            { 
                isInitializing = true;
                ApplyQueryParameters(); 
                isInitializing = false;
                StateHasChanged(); 
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Params Error: {ex.Message}";
            stackTrace = ex.StackTrace;
            StateHasChanged();
        }
    }

    private async Task OnSeasonSelected(int seasonId)
    {
        isInitializing = true;
        selectedSeasonId = seasonId;
        SharedState.SelectedSeasonId = seasonId;
        await LoadPlayers();
        ClearAllInternal();
        await LoadStateFromStorage();
        isInitializing = false;
        _ = UpdateUrl();
    }

    private async Task LoadPlayers()
    {
        isLoading = true;
        players = await StatsRepository.GetPlayersAsync(selectedSeasonId);
        isLoading = false;
    }

    private async Task LoadStateFromStorage()
    {
        List<int>? savedAvail = await SessionStorage.GetItemAsync<List<int>>($"lineup_av_{selectedSeasonId}");
        if (savedAvail != null) availablePlayerIds = savedAvail;

        List<string>? savedOrder = await SessionStorage.GetItemAsync<List<string>>($"lineup_order_{selectedSeasonId}");
        if (savedOrder != null)
        {
            battingOrder.Clear();
            for (int i = 0; i < savedOrder.Count; i++)
            {
                string[] mainParts = savedOrder[i].Split('|');
                string[] parts = mainParts[0].Split(':');
                if (parts.Length == 2 && int.TryParse(parts[0], out int pid))
                {
                    int? playerId = pid > 0 ? pid : null;
                    string pos = parts[1];
                    if (playerId != null && string.IsNullOrEmpty(pos)) pos = "B";

                    BattingOrderEntry entry = new BattingOrderEntry { 
                        OrderNumber = i + 1, 
                        PlayerId = playerId, 
                        PositionAbbreviation = pos 
                    };

                    if (mainParts.Length == 2)
                    {
                        string[] innParts = mainParts[1].Split(',');
                        foreach (string innPart in innParts)
                        {
                            string[] kvp = innPart.Split('=');
                            if (kvp.Length == 2 && int.TryParse(kvp[0], out int inn))
                            {
                                entry.InningPositions[inn] = kvp[1];
                            }
                        }
                    }

                    battingOrder.Add(entry);
                }
            }
            while (battingOrder.Count < 10) battingOrder.Add(new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 });
            if (battingOrder.Any() && battingOrder.Last().PlayerId != null) 
            {
                bool anyUnassigned = players != null && players.Any(p => !battingOrder.Any(le => le.PlayerId == p.Id));
                if (anyUnassigned)
                {
                    battingOrder.Add(new BattingOrderEntry { OrderNumber = battingOrder.Count + 1 });
                }
            }
        }
    }

    private void ClearAllInternal()
    {
        availablePlayerIds.Clear();
        InitializeBattingOrder();
        playerCells.Clear();
        posCells.Clear();
        rowAnimations.Clear();
        posAnimations.Clear();
        animationCounters.Clear();
        
        // Reset selection and focused state
        selectedIndex = null;
        selectedFromBench = null;
        selectedBattingIndex = null;
        focusedBattingIndex = null;
        isExplicitlySelected = false;

        // Reset drag state
        draggedEntry = null;
        targetEntry = null;
        dragTargetIndex = null;
        dragTargetFromBench = null;
        draggingType = DragMode.None;
        
        // Reset view state
        activeViewMode = "lineup";
        selectedInning = 1;
    }

    private void ClearAll()
    {
        ClearAllInternal();
        StateHasChanged();
        _ = UpdateUrl();
    }

