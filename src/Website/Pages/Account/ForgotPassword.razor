@page "/account/forgot-password"
@using IsotopesStats.Website.Services
@using IsotopesStats.Domain.Models
@using System.ComponentModel.DataAnnotations
@inject IAuthRepository IAuthRepository
@inject NavigationManager Navigation

<PageTitle>Isotopes - Forgot Password</PageTitle>

<div style="max-width: 450px; margin: 4rem auto; padding: 0 1rem;">
    <div class="stat-card view-fade-in" style="padding: 2.5rem; position: relative; overflow: hidden;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📧</div>
            <h3 style="margin:0; color: var(--isotopes-dark); font-weight: 800; letter-spacing: 1px;">FORGOT PASSWORD</h3>
            <p style="color: #666; font-size: 0.9rem; margin-top: 0.5rem;">Enter your email and we'll send you a reset link.</p>
        </div>
        @if (isProcessing)
        {
            <LoadingIndicator IsFullPage="true" />
        }

        @if (isSuccess)
        {
            <div class="view-fade-in" style="text-align: center;">
                <div style="background: #e6fffa; color: #2c7a7b; padding: 1.5rem; border-radius: 12px; margin-bottom: 1.5rem; border: 1px solid #b2f5ea;">
                    <h5 style="margin-top: 0; font-weight: bold;">Check your email!</h5>
                    <p style="margin-bottom: 0; font-size: 0.9rem;">We've sent a password reset link to <strong>@email</strong>.</p>
                </div>
                <button class="view-btn active" style="margin-top: 1rem; width: 100%; padding: 1rem; font-size: 1.1rem; background-color: var(--isotopes-accent); border-color: var(--isotopes-accent);" @onclick='() => Navigation.NavigateTo("/account/login")'>Return to Login</button>
            </div>
        }
        else
        {
            <EditForm Model="this" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888;">Email Address</label>
                    <InputText class="form-control" @bind-Value="email" placeholder="email@isotopes.com" style="padding: 1rem; border-radius: 12px; border: 2px solid #eee; transition: border-color 0.3s; width: 100%;" disabled="@isProcessing" />
                    <ValidationMessage For="@(() => email)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                        @errorMessage
                    </div>
                }

                <button type="submit" class="view-btn active @(isProcessing ? "loading" : "")" style="margin-top: 1rem; width: 100%; padding: 1rem; font-size: 1.1rem; background-color: var(--isotopes-accent); border-color: var(--isotopes-accent);" disabled="@isProcessing">
                    Send Reset Link
                </button>

                <div style="text-align: center; margin-top: 1.5rem;">
                    <a href="/account/login" style="color: #666; font-size: 0.9rem; text-decoration: none;">Back to Login</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Required(ErrorMessage = "Email is required")]
    [EmailAddress(ErrorMessage = "Invalid email address")]
    private string email { get; set; } = "";

    private bool isProcessing = false;
    private bool isSuccess = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        isProcessing = true;
        errorMessage = null;

        try
        {
            bool success = await IAuthRepository.GeneratePasswordResetTokenAsync(email);
            if (success)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = "We encountered a temporary server error. Please try again later.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}

