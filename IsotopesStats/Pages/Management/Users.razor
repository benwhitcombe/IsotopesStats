@page "/management/users"
@page "/management/users/{Action}"
@page "/management/users/{Action}/{Id}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Policy = "Manage Users")]
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Isotopes - Manage Users</PageTitle>

<DeleteManager TItem="UserRolesSummaryView" TId="string" @ref="deleteManager" OnDeleted="LoadData" DeleteAction="DeleteUserByIdAsync" />

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Users</h3>
    @if (!isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", "")'>Add New User</button>
    }
</div>

@if (isEditing)
{
    <ModelEditor 
        TItem="UserEditViewModel"
        Title="@($"{(string.IsNullOrEmpty(editViewModel.Id) ? "Add New" : "Edit")} User")"
        Item="editViewModel"
        OriginalItem="originalViewModel"
        BasePath="/management/users"
        OnSave="SaveUser"
        OnDelete="DeleteUser"
        CheckUniqueAsync="CheckEmailUnique">

        <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2rem;">
            <div class="form-group">
                <label>Email Address</label>
                <InputText class="form-control" @bind-Value="editViewModel.Email" placeholder="user@example.com" />
                <ValidationMessage For="@(() => editViewModel.Email)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
            </div>

            @if (string.IsNullOrEmpty(editViewModel.Id))
            {
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <div class="form-group">
                        <label>Password</label>
                        <div style="position: relative;">
                            <InputText type="@(showPassword ? "text" : "password")" class="form-control" @bind-Value="editViewModel.Password" />
                            <PasswordToggleIcon IsVisible="showPassword" OnToggle="() => showPassword = !showPassword" />
                        </div>
                        <ValidationMessage For="@(() => editViewModel.Password)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                    </div>
                    <div class="form-group">
                        <label>Confirm Password</label>
                        <InputText type="@(showPassword ? "text" : "password")" class="form-control" @bind-Value="editViewModel.ConfirmPassword" />
                        <ValidationMessage For="@(() => editViewModel.ConfirmPassword)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                    </div>
                </div>
            }
            else
            {
                <div class="stat-card" style="background: #f8f9fa; border: 1px dashed #ddd; padding: 1.25rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <h6 style="margin: 0 0 0.25rem 0; font-weight: bold;">Change Password</h6>
                            <p style="margin: 0; font-size: 0.8rem; color: #666;">Leave blank to keep current password.</p>
                        </div>
                        <button type="button" class="view-btn" @onclick="() => showPasswordFields = !showPasswordFields">
                            @(showPasswordFields ? "Cancel" : "Change")
                        </button>
                    </div>

                    @if (showPasswordFields)
                    {
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.25rem;" class="view-fade-in">
                            <div class="form-group">
                                <label>New Password</label>
                                <InputText type="password" class="form-control" @bind-Value="editViewModel.Password" />
                                <ValidationMessage For="@(() => editViewModel.Password)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                            </div>
                            <div class="form-group">
                                <label>Confirm New Password</label>
                                <InputText type="password" class="form-control" @bind-Value="editViewModel.ConfirmPassword" />
                                <ValidationMessage For="@(() => editViewModel.ConfirmPassword)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="form-group">
                <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Assigned Roles</label>
                <div class="selectable-grid">
                    @foreach (UserRole role in availableRoles)
                    {
                        <CheckboxButton 
                            Id="@($"role-{role.Id}")" 
                            Text="@role.Name" 
                            Checked="@editViewModel.RoleIds.Contains(role.Id)" 
                            CheckedChanged="@((bool val) => ToggleRole(role.Id, val))" />
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(saveError))
        {
            <div class="view-fade-in" style="background: #fff5f5; color: var(--isotopes-red); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; border: 1px solid #ffebeb; text-align: center; font-weight: 600;">
                @saveError
            </div>
        }
    </ModelEditor>
}
else
{
    <div class="stat-card view-fade-in" style="padding: 0; overflow: hidden;">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th style="text-align: left;">Email</th>
                        <th style="text-align: left;">Roles</th>
                        <th style="text-align: left;">Created</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (UserRolesSummaryView user in users)
                    {
                        <tr>
                            <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", user.Id)'>@user.Email</td>
                            <td style="text-align: left;">
                                @if (string.IsNullOrEmpty(user.RoleNames))
                                {
                                    <span style="color: #ccc; font-style: italic;">No roles assigned</span>
                                }
                                else
                                {
                                    @foreach (string role in user.RoleNames.Split(", "))
                                    {
                                        <span class="badge bg-light text-dark" style="margin-right: 4px; border: 1px solid #eee;">@role</span>
                                    }
                                }
                            </td>
                            <td style="text-align: left; font-size: 0.85rem; color: #666;">@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                            <td style="text-align: right;">
                                <button class="view-btn" @onclick='() => StartEdit("edit", user.Id)'>Edit</button>
                                <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(user)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public string? Id { get; set; }

    private DeleteManager<UserRolesSummaryView, string> deleteManager = null!;
    private List<UserRolesSummaryView> users = new();
    private List<UserRole> availableRoles = new();
    private UserEditViewModel editViewModel = new();
    private UserEditViewModel originalViewModel = new();
    private bool isEditing = false;
    private bool showPassword = false;
    private bool showPasswordFields = false;
    private string? saveError;

    protected override async Task OnInitializedAsync()
    {
        availableRoles = await AuthService.GetUserRolesAsync(true);
        await LoadData();
    }

    protected override Task OnParametersSetAsync()
    {
        isEditing = Action == "add" || Action == "edit";

        if (isEditing)
        {
            if (Action == "edit" && !string.IsNullOrEmpty(Id))
            {
                UserRolesSummaryView? userView = users.FirstOrDefault(u => u.Id == Id);
                if (userView != null)
                {
                    editViewModel = new UserEditViewModel
                    {
                        Id = userView.Id,
                        Email = userView.Email,
                        RoleIds = userView.RoleNames?.Split(", ")
                            .Select(name => availableRoles.FirstOrDefault(r => r.Name == name)?.Id ?? 0)
                            .Where(id => id != 0).ToList() ?? new List<int>()
                    };
                    originalViewModel = new UserEditViewModel
                    {
                        Id = editViewModel.Id,
                        Email = editViewModel.Email,
                        RoleIds = new List<int>(editViewModel.RoleIds)
                    };
                }
            }
            else
            {
                editViewModel = new UserEditViewModel();
                originalViewModel = new UserEditViewModel();
            }
        }

        return Task.CompletedTask;
    }

    private async Task LoadData()
    {
        users = await AuthService.GetUsersAsync();
    }

    private void StartEdit(string action, string id)
    {
        showPassword = false;
        showPasswordFields = false;
        saveError = null;
        if (action == "add") Navigation.NavigateTo("/management/users/add");
        else Navigation.NavigateTo($"/management/users/edit/{id}");
    }

    private void ToggleRole(int roleId, bool isChecked)
    {
        if (isChecked)
        {
            if (!editViewModel.RoleIds.Contains(roleId)) editViewModel.RoleIds.Add(roleId);
        }
        else
        {
            editViewModel.RoleIds.Remove(roleId);
        }
    }

    private async Task<string?> CheckEmailUnique(UserEditViewModel model)
    {
        bool isUnique = await AuthService.IsEmailUniqueAsync(model.Email, model.Id);
        return isUnique ? null : "This email address is already in use.";
    }

    private async Task SaveUser()
    {
        saveError = null;
        if (string.IsNullOrEmpty(editViewModel.Id))
        {
            bool success = await AuthService.RegisterAsync(editViewModel.Email, editViewModel.Password, editViewModel.RoleIds);
            if (!success)
            {
                saveError = "Failed to create user. Please check if the email is valid and try again.";
                return;
            }
        }
        else
        {
            User user = new User { Id = editViewModel.Id, Email = editViewModel.Email };
            await AuthService.UpdateUserAsync(user, editViewModel.RoleIds);
            
            if (showPasswordFields && !string.IsNullOrEmpty(editViewModel.Password))
            {
                await AuthService.UpdateUserPasswordAsync(editViewModel.Id, editViewModel.Password);
            }
        }

        await LoadData();
    }

    private async Task DeleteUser()
    {
        await AuthService.DeleteUserAsync(editViewModel.Id);
        await LoadData();
    }

    private async Task DeleteUserByIdAsync(string id)
    {
        await AuthService.DeleteUserAsync(id);
    }

    public class UserEditViewModel : IEntity<string>
    {
        public string Id { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = "";

        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = "";

        [Compare("Password", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";

        public List<int> RoleIds { get; set; } = new();

        public override bool Equals(object? obj)
        {
            if (obj is not UserEditViewModel other) return false;
            return Id == other.Id && 
                   Email == other.Email && 
                   Password == other.Password && 
                   RoleIds.SequenceEqual(other.RoleIds);
        }

        public override int GetHashCode() => Id?.GetHashCode() ?? 0;
    }
}
