@page "/management/seasons"
@page "/management/seasons/{Action}"
@page "/management/seasons/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@attribute [Authorize(Policy = "Manage Seasons")]
@inject IStatsService StatsService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject SessionStorageService SessionStorage

<PageTitle>Isotopes - Manage Seasons</PageTitle>

<DeleteManager TItem="Season" TId="int" @ref="deleteManager" OnDeleted="LoadSeasons" DeleteAction="StatsService.DeleteSeasonAsync" />

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Seasons</h3>
    @if (!isLoading && !isAdding && !isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Season</button>
    }
</div>

@if (isLoading)
{
    <LoadingIndicator Message="Loading Seasons..." Padding="5" />
}
else if (isAdding || isEditing)
{
    <ModelEditor 
        TItem="Season"
        @ref="modelEditor"
        Title="@($"{(isAdding ? "Add" : "Edit")} Season")"
        Item="editingSeason"
        OriginalItem="originalSeason"
        BasePath="/management/seasons"
        CheckUniqueAsync="CheckUniqueSeason"
        DeleteWarning="This will delete all associated games and stats."
        OnSave="SaveSeason"
        OnDelete="DeleteSeason"
        ExtraState="extraState"
        HasCustomChanges="@(() => !extraState.Equals(originalExtraState))">
        
        <div class="form-group">
            <label>Season Name</label>
            <InputText class="form-control" @bind-Value="editingSeason.Name" placeholder="e.g. 2026" />
            <ValidationMessage For="@(() => editingSeason.Name)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
        </div>


        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Season Roster</label>
            <div class="selectable-grid" style="padding: 0.5rem; background: #f9f9f9; border-radius: 8px;">
                @foreach (Player player in allPlayers)
                {
                    <CheckboxButton 
                        Id="@($"p-{player.Id}")" 
                        Text="@player.Name" 
                        Checked="@extraState.PlayerIds.Contains(player.Id)" 
                        CheckedChanged="@((bool val) => TogglePlayer(player.Id, val))" />
                }
            </div>
        </div>

        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Opponents This Season</label>
            <div class="selectable-grid" style="padding: 0.5rem; background: #f9f9f9; border-radius: 8px;">
                @foreach (Opponent opponent in allOpponents)
                {
                    <CheckboxButton 
                        Id="@($"o-{opponent.Id}")" 
                        Text="@opponent.Name" 
                        Checked="@extraState.OpponentIds.Contains(opponent.Id)" 
                        CheckedChanged="@((bool val) => ToggleOpponent(opponent.Id, val))" />
                }
            </div>
        </div>
    </ModelEditor>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">ID</th>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Season season in seasons)
                        {
                            <tr>
                                <td style="text-align: left;">@season.Id</td>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", season.Id)'>@season.Name</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", season.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(season)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Season season in seasons)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", season.Id)'>@season.Name</div>
                        <div class="rank-badge">ID: @season.Id</div>
                    </div>
                    <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", season.Id)'>Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(season)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private DeleteManager<Season, int> deleteManager = null!;
    private List<Season> seasons = new();
    private List<Player> allPlayers = new();
    private List<Opponent> allOpponents = new();
    private Season editingSeason = new();
    private Season originalSeason = new();
    private bool isAdding = false;
    private bool isEditing = false;
    private ModelEditor<Season> modelEditor = null!;
    private SeasonExtraState extraState = new();
    private SeasonExtraState originalExtraState = new();

    public record SeasonExtraState {
        public List<int> PlayerIds { get; set; } = new();
        public List<int> OpponentIds { get; set; } = new();

        public virtual bool Equals(SeasonExtraState? other) {
            if (other is null) return false;
            return PlayerIds.OrderBy(id => id).SequenceEqual(other.PlayerIds.OrderBy(id => id)) &&
                   OpponentIds.OrderBy(id => id).SequenceEqual(other.OpponentIds.OrderBy(id => id));
        }
        public override int GetHashCode() => PlayerIds.Count ^ OpponentIds.Count;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
        allPlayers = await StatsService.GetAllPlayersAsync();
        allOpponents = await StatsService.GetAllOpponentsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasAdding = isAdding;
        bool wasEditing = isEditing;
        
        bool nextAdding = Action == "add";
        bool nextEditing = Action == "edit";

        if (nextAdding || nextEditing)
        {
            if (nextAdding && !wasAdding)
            {
                isAdding = false;
                isEditing = false;
                await LoadNewSeason();
            }
            else if (nextEditing && (!wasEditing || (Id.HasValue && Id != editingSeason.Id)))
            {
                isAdding = false;
                isEditing = false;
                await LoadEditingSeason();
            }
        }
        else
        {
            editingSeason = new Season();
            originalSeason = new Season();
            extraState = new();
            originalExtraState = new();
        }

        isAdding = nextAdding;
        isEditing = nextEditing;
    }

    private async Task LoadNewSeason()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        editingSeason = new Season();
        originalSeason = new Season();
        extraState = new();
        originalExtraState = new();
        await HydrateTempState();
    }

    private async Task LoadEditingSeason()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            Season? season = seasons.FirstOrDefault(s => s.Id == Id);
            if (season == null)
            {
                season = (await StatsService.GetSeasonsAsync()).FirstOrDefault(s => s.Id == Id);
            }

            if (season != null)
            {
                editingSeason = season with { };
                originalSeason = season with { };

                List<Player> seasonPlayers = await StatsService.GetPlayersAsync(season.Id);
                List<Opponent> seasonOpponents = await StatsService.GetOpponentsAsync(season.Id);
                
                extraState = new SeasonExtraState { 
                    PlayerIds = seasonPlayers.Select(p => p.Id).ToList(), 
                    OpponentIds = seasonOpponents.Select(o => o.Id).ToList() 
                };
                originalExtraState = extraState with { 
                    PlayerIds = new List<int>(extraState.PlayerIds),
                    OpponentIds = new List<int>(extraState.OpponentIds)
                };
            }
        }
        else
        {
            editingSeason = new Season();
            originalSeason = new Season();
            extraState = new();
            originalExtraState = new();
        }
        await HydrateTempState();
    }

    private async Task HydrateTempState()
    {
        try
        {
            Season? persisted = await SessionStorage.GetItemAsync<Season>($"EditState_Season_{Id ?? 0}");
            if (persisted != null)
            {
                editingSeason = persisted;
            }

            SeasonExtraState? persistedExtra = await SessionStorage.GetItemAsync<SeasonExtraState>($"EditState_Season_{Id ?? 0}_Extra");
            if (persistedExtra != null)
            {
                extraState = persistedExtra;
            }
            StateHasChanged();
        }
        catch { }
    }

    private bool isLoading = true;

    private async Task LoadSeasons()
    {
        isLoading = true;
        try
        {
            seasons = await StatsService.GetSeasonsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/seasons/add");
        else Navigation.NavigateTo($"/management/seasons/edit/{id}");
    }

    private async Task<string?> CheckUniqueSeason(Season model)
    {
        if (string.IsNullOrWhiteSpace(model.Name)) return null;
        bool isUnique = await StatsService.IsSeasonNameUniqueAsync(model.Name, model.Id);
        return isUnique ? null : "A season with this name already exists.";
    }

    private async Task TogglePlayer(int playerId, bool isChecked)
    {
        if (isChecked) 
        {
            if (!extraState.PlayerIds.Contains(playerId)) extraState.PlayerIds.Add(playerId);
        }
        else extraState.PlayerIds.Remove(playerId);
        
        if (modelEditor != null) await modelEditor.SaveExtraState();
    }

    private async Task ToggleOpponent(int opponentId, bool isChecked)
    {
        if (isChecked)
        {
            if (!extraState.OpponentIds.Contains(opponentId)) extraState.OpponentIds.Add(opponentId);
        }
        else extraState.OpponentIds.Remove(opponentId);
        
        if (modelEditor != null) await modelEditor.SaveExtraState();
    }

    private async Task SaveSeason()
    {
        int seasonId;
        if (editingSeason.Id == 0)
        {
            seasonId = await StatsService.AddSeasonAsync(editingSeason);
            foreach (int playerId in extraState.PlayerIds)
                await StatsService.AddPlayerToSeasonAsync(playerId, seasonId);
            foreach (int opponentId in extraState.OpponentIds)
            {
                string opponentName = allOpponents.FirstOrDefault(o => o.Id == opponentId)?.Name ?? string.Empty;
                string? opponentShortName = allOpponents.FirstOrDefault(o => o.Id == opponentId)?.ShortName;
                await StatsService.AddOpponentToSeasonAsync(opponentId, seasonId, opponentName, opponentShortName);
            }
        }
        else
        {
            seasonId = editingSeason.Id;
            await StatsService.UpdateSeasonAsync(editingSeason);
            
            foreach (int playerId in extraState.PlayerIds.Except(originalExtraState.PlayerIds))
                await StatsService.AddPlayerToSeasonAsync(playerId, seasonId);
            foreach (int playerId in originalExtraState.PlayerIds.Except(extraState.PlayerIds))
                await StatsService.DeletePlayerFromSeasonAsync(playerId, seasonId);

            foreach (int opponentId in extraState.OpponentIds.Except(originalExtraState.OpponentIds))
            {
                string opponentName = allOpponents.FirstOrDefault(o => o.Id == opponentId)?.Name ?? string.Empty;
                string? opponentShortName = allOpponents.FirstOrDefault(o => o.Id == opponentId)?.ShortName;
                await StatsService.AddOpponentToSeasonAsync(opponentId, seasonId, opponentName, opponentShortName);
            }
            foreach (int opponentId in originalExtraState.OpponentIds.Except(extraState.OpponentIds))
                await StatsService.DeleteOpponentFromSeasonAsync(opponentId, seasonId);
        }
        await LoadSeasons();
    }

    private async Task DeleteSeason()
    {
        await StatsService.DeleteSeasonAsync(editingSeason.Id);
        await LoadSeasons();
    }
}
