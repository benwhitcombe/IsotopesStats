@using IsotopesStats.Domain.Models
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JSRuntime

<div class="autocomplete-cell-wrapper" @onclick:stopPropagation>
    @if (isMobile)
    {
        <select @ref="selectElement"
                class="native-player-select" 
                value="@(Players.FirstOrDefault(p => p.Name == Value)?.Id ?? 0)" 
                @onchange="HandleMobileSelect"
                @onfocus="OnFocused"
                @onblur="OnBlurred">
            <option value="0">-- Select Player --</option>
            @foreach (Player player in Players.OrderBy(p => IsAssigned(p.Id) ? 1 : 0).ThenBy(p => p.Name))
            {
                <option value="@player.Id">@GetPlayerDisplayName(player)</option>
            }
        </select>
    }
    else
    {
        <div class="input-container">
            <div class="ghost-text-container">
                <span class="invisible-content">@internalValue</span>
                <span class="suggestion-suffix">@suggestionSuffix</span>
            </div>
            <input @ref="inputElement"
                   class="autocomplete-input @(isInvalid ? "invalid" : "")"
                   value="@internalValue"
                   @oninput="HandleInput"
                   @onkeydown="HandleKeyDown"
                   @onblur="HandleBlur"
                   @onfocus="HandleFocus"
                   placeholder=""
                   autocomplete="off" />
            @if (!string.IsNullOrEmpty(Value))
            {
                <button class="clear-btn" @onclick="ClearValue" @onclick:stopPropagation type="button" tabindex="-1">✕</button>
            }
        </div>

        @if (showSuggestions && filteredPlayers.Any())
        {
            <div class="suggestions-dropdown">
                @for (int i = 0; i < filteredPlayers.Count; i++)
                {
                    int index = i;
                    Player player = filteredPlayers[i];
                    bool isAssigned = IsAssigned(player.Id);
                    <div class="suggestion-item @(index == activeIndex ? "active" : "") @(isAssigned ? "assigned" : "")"
                         @onclick="() => SelectPlayer(player)">
                        @GetPlayerDisplayName(player)
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public List<Player> Players { get; set; } = new();
    [Parameter] public Dictionary<int, string> PlayerAssignments { get; set; } = new();
    [Parameter] public EventCallback<Player?> OnSelected { get; set; }
    [Parameter] public EventCallback OnCommit { get; set; }
    [Parameter] public EventCallback OnFocused { get; set; }
    [Parameter] public EventCallback OnBlurred { get; set; }

    private ElementReference inputElement;
    private ElementReference selectElement;
    private List<Player> filteredPlayers = new();
    private int activeIndex = 0;
    private bool showSuggestions = false;
    private string suggestionSuffix = string.Empty;
    private string originalValue = string.Empty;
    private Player? originalPlayer = null;
    private string internalValue = string.Empty;
    private bool isFocused = false;
    private bool isMobile = false;

    private bool isInvalid => isFocused && !string.IsNullOrWhiteSpace(internalValue) && !filteredPlayers.Any();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isMobile = await JSRuntime.InvokeAsync<bool>("isMobileDevice");
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        if (!isFocused)
        {
            internalValue = Value;
        }
    }

    public async Task FocusAsync()
    {
        if (isMobile)
        {
            await selectElement.FocusAsync();
        }
        else
        {
            await inputElement.FocusAsync();
        }
    }

    private async Task HandleMobileSelect(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int playerId))
        {
            Player? player = Players.FirstOrDefault(p => p.Id == playerId);
            await SelectPlayer(player);
            await OnCommit.InvokeAsync();
        }
    }

    private void HandleInput(ChangeEventArgs e)
    {
        internalValue = e.Value?.ToString() ?? string.Empty;
        UpdateSuggestions();
    }

    private string GetPlayerDisplayName(Player player)
    {
        if (PlayerAssignments.TryGetValue(player.Id, out string? pos))
        {
            return $"{player.Name} ({pos})";
        }
        return player.Name;
    }

    private bool IsAssigned(int playerId) => PlayerAssignments.ContainsKey(playerId);

    private void UpdateSuggestions()
    {
        IEnumerable<Player> baseQuery = Players.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(internalValue))
        {
            baseQuery = baseQuery.Where(p => p.Name.StartsWith(internalValue, StringComparison.OrdinalIgnoreCase));
        }

        List<Player> results = baseQuery
            .OrderBy(p => IsAssigned(p.Id) ? 1 : 0) // Unassigned first
            .ThenBy(p => p.Name)
            .ToList();

        // Special case: if we just focused and haven't typed anything, put original player at top
        if (string.IsNullOrWhiteSpace(internalValue) && originalPlayer != null)
        {
            results.RemoveAll(p => p.Id == originalPlayer.Id);
            results.Insert(0, originalPlayer);
        }

        filteredPlayers = results;

        if (!string.IsNullOrWhiteSpace(internalValue))
        {
            Player? bestMatch = filteredPlayers.FirstOrDefault(p => p.Name.StartsWith(internalValue, StringComparison.OrdinalIgnoreCase));
            if (bestMatch != null)
            {
                suggestionSuffix = bestMatch.Name.Substring(internalValue.Length);
            }
            else
            {
                suggestionSuffix = string.Empty;
            }
        }
        else
        {
            suggestionSuffix = originalValue;
        }

        activeIndex = 0;
        showSuggestions = true;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            if (!showSuggestions) { showSuggestions = true; UpdateSuggestions(); }
            else if (activeIndex < filteredPlayers.Count - 1) activeIndex++;
        }
        else if (e.Key == "ArrowUp")
        {
            if (activeIndex > 0) activeIndex--;
        }
        else if (e.Key == "Enter" || e.Key == "Tab")
        {
            if (showSuggestions && filteredPlayers.Any())
            {
                await SelectPlayer(filteredPlayers[activeIndex]);
                if (e.Key == "Enter")
                {
                    await OnCommit.InvokeAsync();
                }
            }
        }
        else if (e.Key == "Escape")
        {
            showSuggestions = false;
        }
    }

    private async Task SelectPlayer(Player? player)
    {
        internalValue = player?.Name ?? string.Empty;
        suggestionSuffix = string.Empty;
        showSuggestions = false;
        originalValue = internalValue; // Update original value on selection
        originalPlayer = player;
        await OnSelected.InvokeAsync(player);
    }

    private async Task HandleFocus()
    {
        isFocused = true;
        originalValue = internalValue;
        originalPlayer = Players.FirstOrDefault(p => p.Name == originalValue);
        internalValue = string.Empty;
        UpdateSuggestions();
        showSuggestions = true;
        await OnFocused.InvokeAsync();
    }

    private async Task HandleBlur()
    {
        // Delay to allow click to register
        await Task.Delay(200);
        
        Player? matchedPlayer = Players.FirstOrDefault(p => p.Name.Equals(internalValue, StringComparison.OrdinalIgnoreCase));
        
        if (matchedPlayer != null)
        {
            // If it's a valid match, ensure it's selected properly
            await SelectPlayer(matchedPlayer);
        }
        else
        {
            // Revert to original value (which could be empty)
            internalValue = originalValue;
        }

        isFocused = false;
        showSuggestions = false;
        suggestionSuffix = string.Empty;
        await OnBlurred.InvokeAsync();
        StateHasChanged();
    }

    private async Task ClearValue()
    {
        internalValue = string.Empty;
        suggestionSuffix = string.Empty;
        await OnSelected.InvokeAsync(null);
    }
}

<style>
    .autocomplete-cell-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
    }

    .input-container {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
        height: 38px;
    }

    .ghost-text-container {
        position: absolute;
        left: 0;
        top: 0;
        right: 0;
        bottom: 0;
        padding: 0 0.75rem;
        display: flex;
        align-items: center;
        pointer-events: none;
        font-weight: bold;
        font-size: 0.9rem;
        white-space: nowrap;
        overflow: hidden;
    }

    .invisible-content {
        color: transparent;
    }

    .suggestion-suffix {
        color: #ccc;
    }

    .autocomplete-input {
        width: 100%;
        height: 100%;
        border: none;
        background: transparent;
        padding: 0 0.75rem;
        font-weight: bold;
        font-size: 0.9rem;
        outline: none;
        position: relative;
        z-index: 1;
    }

    .autocomplete-input.invalid {
        color: #dc3545;
        font-weight: 900;
    }

    .clear-btn {
        position: absolute;
        right: 0.5rem;
        background: none;
        border: none;
        color: black;
        font-size: 0.8rem;
        cursor: pointer;
        z-index: 2;
        padding: 0.2rem;
    }

    .suggestions-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 2px solid black;
        box-shadow: 4px 4px 0px rgba(0,0,0,0.1);
        z-index: 1000;
        max-height: 250px;
        overflow-y: auto;
    }

    .suggestion-item {
        padding: 0.5rem 0.75rem;
        cursor: pointer;
        font-size: 0.9rem;
        border-bottom: 1px solid black;
        text-align: left;
        color: black;
    }

    .suggestion-item.assigned {
        font-style: italic;
    }

    .suggestion-item:last-child {
        border-bottom: none;
    }

    .suggestion-item:hover, .suggestion-item.active {
        background: #f0f7ff;
        color: #007bff;
        font-weight: bold;
    }

    .native-player-select {
        width: 100%;
        height: 38px;
        border: none;
        background: transparent;
        padding: 0 0.5rem;
        font-weight: bold;
        font-size: 0.9rem;
        outline: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
    }
</style>
