@page "/management/players"
@page "/management/players/{Action}"
@page "/management/players/{Action}/{Id:int}"
@using IsotopesStats.Services
@using IsotopesStats.Models
@using IsotopesStats.Shared
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@attribute [Authorize(Policy = "Manage Players")]
@inject StatsService StatsService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ProtectedSessionStorage ProtectedSessionStore

<PageTitle>Isotopes - Manage Players</PageTitle>

<div class="header-with-filter" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h3 style="margin:0">Manage Players</h3>
    @if (!isAdding && !isEditing)
    {
        <button class="view-btn active" @onclick='() => StartEdit("add", 0)'>Add New Player</button>
    }
</div>

<DeleteManager TItem="Player" @ref="deleteManager" OnDeleted="LoadPlayers" DeleteAction="StatsService.DeletePlayerAsync" />

@if (isAdding || isEditing)
{
    <ModelEditor 
        TItem="Player"
        Title="@($"{(isAdding ? "Add" : "Edit")} Player")"
        Item="editingPlayer"
        OriginalItem="originalPlayer"
        BasePath="/management/players"
        OnSave="SavePlayer"
        OnDelete="DeletePlayer"
        HasCustomChanges="@(() => !assignedSeasonIds.SetEquals(originalSeasonIds))">

        <div class="form-group">
            <label>Player Name</label>
            <InputText class="form-control" @bind-Value="editingPlayer.Name" placeholder="e.g. John Doe" />
            <ValidationMessage For="@(() => editingPlayer.Name)" style="color: var(--isotopes-red); font-size: 0.8rem; margin-top: 0.25rem;" />
        </div>
        
        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="font-weight: bold; margin-bottom: 1rem; display: block;">Seasons Participation</label>
            <div class="selectable-grid" style="background: #f9f9f9; padding: 0.5rem; border-radius: 8px;">
                @foreach (Season season in allSeasons)
                {
                    <CheckboxButton 
                        Id="@($"s-{season.Id}")" 
                        Text="@season.Name" 
                        Checked="@assignedSeasonIds.Contains(season.Id)" 
                        CheckedChanged="@((bool val) => ToggleSeason(season.Id, val))" />
                }
            </div>
        </div>
    </ModelEditor>
}
else
{
    <div class="desktop-only">
        <div class="stat-card view-fade-in" style="animation-delay: 0.1s;">
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Player player in players)
                        {
                            <tr>
                                <td style="text-align: left; font-weight: bold; color: var(--isotopes-accent); cursor: pointer;" @onclick='() => StartEdit("edit", player.Id)'>@player.Name</td>
                                <td style="text-align: right;">
                                    <button class="view-btn" @onclick='() => StartEdit("edit", player.Id)'>Edit</button>
                                    <button class="view-btn" style="color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(player)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mobile-only">
        <div class="mobile-player-grid view-fade-in" style="animation-delay: 0.1s; display: grid;">
            @foreach (Player player in players)
            {
                <div class="mobile-player-card">
                    <div class="mobile-card-header">
                        <div class="mobile-card-name" style="cursor: pointer;" @onclick='() => StartEdit("edit", player.Id)'>@player.Name</div>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="view-btn" style="flex: 1;" @onclick='() => StartEdit("edit", player.Id)'>Edit</button>
                        <button class="view-btn" style="flex: 1; color: var(--isotopes-red); border-color: var(--isotopes-red);" @onclick="() => deleteManager.ConfirmDelete(player)">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Action { get; set; }
    [Parameter] public int? Id { get; set; }

    private List<Player> players = new();
    private List<Season> allSeasons = new();
    private HashSet<int> assignedSeasonIds = new();
    private HashSet<int> originalSeasonIds = new();
    private Player editingPlayer = new();
    private Player originalPlayer = new();
    private bool isAdding = false;
    private bool isEditing = false;
    private DeleteManager<Player> deleteManager = null!;

    protected override async Task OnInitializedAsync()
    {
        allSeasons = await StatsService.GetSeasonsAsync();
        await LoadPlayers();
    }

    protected override async Task OnParametersSetAsync()
    {
        bool wasAdding = isAdding;
        bool wasEditing = isEditing;
        
        isAdding = Action == "add";
        isEditing = Action == "edit";

        if (isAdding || isEditing)
        {
            if (isAdding && !wasAdding)
            {
                await LoadNewPlayer();
            }
            else if (isEditing && (!wasEditing || (Id.HasValue && Id != editingPlayer.Id)))
            {
                await LoadEditingPlayer();
            }
        }
        else
        {
            editingPlayer = new Player();
            originalPlayer = new Player();
            assignedSeasonIds.Clear();
            originalSeasonIds.Clear();
        }
    }

    private async Task LoadNewPlayer()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        editingPlayer = new Player();
        originalPlayer = new Player();
        assignedSeasonIds.Clear();
        originalSeasonIds.Clear();
        await HydrateTempState();
    }

    private async Task LoadEditingPlayer()
    {
        try { await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
        
        if (Action == "edit" && Id.HasValue && Id != 0)
        {
            Player? player = players.FirstOrDefault(p => p.Id == Id);
            if (player == null)
            {
                player = (await StatsService.GetAllPlayersAsync()).FirstOrDefault(p => p.Id == Id);
            }

            if (player != null)
            {
                editingPlayer = player with { };
                originalPlayer = player with { };
                assignedSeasonIds.Clear();
                originalSeasonIds.Clear();

                List<Season> playerSeasons = await StatsService.GetSeasonsForPlayerAsync(player.Id);
                foreach (Season s in playerSeasons)
                {
                    assignedSeasonIds.Add(s.Id);
                    originalSeasonIds.Add(s.Id);
                }
            }
        }
        else
        {
            editingPlayer = new Player();
            originalPlayer = new Player();
            assignedSeasonIds.Clear();
            originalSeasonIds.Clear();
        }

        await HydrateTempState();
    }

    private async Task HydrateTempState()
    {
        try
        {
            ProtectedBrowserStorageResult<Player> result = await ProtectedSessionStore.GetAsync<Player>($"EditState_Player_{Id ?? 0}");
            if (result.Success && result.Value != null)
            {
                editingPlayer = result.Value;
                StateHasChanged();
            }
        }
        catch (Exception) { }
    }

    private async Task LoadPlayers()
    {
        players = await StatsService.GetAllPlayersAsync();
    }

    private void StartEdit(string action, int id)
    {
        if (action == "add") Navigation.NavigateTo("/management/players/add");
        else Navigation.NavigateTo($"/management/players/edit/{id}");
    }

    private void ToggleSeason(int seasonId, bool isChecked)
    {
        if (isChecked) assignedSeasonIds.Add(seasonId);
        else assignedSeasonIds.Remove(seasonId);
    }

    private async Task SavePlayer()
    {
        int playerId;
        if (editingPlayer.Id == 0)
        {
            int firstSeasonId = assignedSeasonIds.FirstOrDefault();
            playerId = await StatsService.AddPlayerAsync(editingPlayer, firstSeasonId);
            foreach (int sid in assignedSeasonIds.Where(id => id != firstSeasonId))
                await StatsService.AddPlayerToSeasonAsync(playerId, sid);
        }
        else
        {
            playerId = editingPlayer.Id;
            await StatsService.UpdatePlayerAsync(editingPlayer);
            foreach (int sid in assignedSeasonIds.Except(originalSeasonIds))
                await StatsService.AddPlayerToSeasonAsync(playerId, sid);
            foreach (int sid in originalSeasonIds.Except(assignedSeasonIds))
                await StatsService.DeletePlayerFromSeasonAsync(playerId, sid);
        }
        await LoadPlayers();
    }

    private async Task DeletePlayer()
    {
        await StatsService.DeletePlayerAsync(editingPlayer.Id);
        await LoadPlayers();
    }
}
